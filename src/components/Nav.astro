---
import { courses } from '../data/content.js';
---

<style>
  #sitenav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    /* Always frosted — readable on both light and dark pages */
    background: rgba(245, 240, 232, 0.82);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid rgba(168, 140, 90, 0.18);
    box-shadow: 0 1px 24px rgba(26, 48, 32, 0.07);
    transition: background 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }
  /* Darker frosted when scrolled deep into page */
  #sitenav.scrolled {
    background: rgba(240, 234, 220, 0.95);
    box-shadow: 0 2px 32px rgba(26, 48, 32, 0.12);
    border-bottom-color: rgba(168, 140, 90, 0.28);
  }

  /* Nav links — dark on frosted light bg */
  .nav-link {
    font-size: 14px; color: #3a4a3e;
    text-decoration: none; padding: 8px 4px;
    transition: color 0.2s; cursor: pointer;
    display: flex; align-items: center; gap: 5px;
    white-space: nowrap; background: none; border: none;
    font-weight: 500; letter-spacing: 0.01em;
  }
  .nav-link:hover, .nav-link.active { color: #a06c30; }
  .nav-link .chevron { transition: transform 0.2s; }
  .nav-item.open .chevron { transform: rotate(180deg); }
  .nav-item.open .nav-link { color: #a06c30; }

  .nav-item { position: relative; }

  .mega-menu {
    position: absolute; top: calc(100% + 10px); left: 50%;
    transform: translateX(-50%) translateY(-6px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 300;
  }
  .mega-menu.open {
    opacity: 1; pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  /* Mobile hamburger */
  #mobile-toggle { display: none; }
  #mobile-menu {
    display: none; position: fixed; inset: 0; top: 0;
    background: rgba(245,240,232,0.99);
    backdrop-filter: blur(24px);
    z-index: 500; padding: 24px; overflow-y: auto;
  }
  #mobile-menu.open { display: flex; flex-direction: column; }

  @media (max-width: 860px) {
    #desktop-nav, #nav-cta { display: none !important; }
    #mobile-toggle { display: flex !important; }
  }
</style>

<nav id="sitenav" style="padding: 0 36px; height: 68px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">

  <!-- REAL LOGO from golfgraeagle.com -->
  <a href="/" style="display:flex;align-items:center;flex-shrink:0;z-index:1;text-decoration:none;" aria-label="Golf Graeagle — Home">
    <img
      src="/logo.png"
      alt="Golf Graeagle"
      style="height:44px;width:auto;display:block;object-fit:contain;"
      onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
    />
    <!-- Fallback text logo if image fails -->
    <span style="display:none;font-family:'Playfair Display',serif;font-size:20px;color:#1a3020;letter-spacing:0.01em;">Golf <span style="color:#a06c30;">Graeagle</span></span>
  </a>

  <!-- Desktop nav -->
  <div id="desktop-nav" style="display: flex; align-items: center; gap: 4px;">

    <!-- COURSES -->
    <div class="nav-item" style="padding: 4px 12px;">
      <button class="nav-link">
        Courses
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mega-menu" style="width:700px; background:rgba(252,249,242,0.98); border:1px solid rgba(168,140,90,0.2); border-radius:20px; padding:28px; backdrop-filter:blur(24px); box-shadow:0 16px 56px rgba(26,48,32,0.14),0 2px 8px rgba(26,48,32,0.06);">
        <p style="font-size:10px;color:#a06c30;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;margin:0 0 14px;">5 Championship Courses · All within 25 minutes</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:18px;">
          {courses.map(c => (
            <a href={`/portfolio/${c.slug === 'nakoma-dragon' ? 'nakoma-dragon-golf-packages' : c.slug + '-golf-packages'}/`}
              style="display:flex;align-items:flex-start;gap:12px;padding:12px 14px;border-radius:12px;text-decoration:none;background:rgba(26,48,32,0.02);border:1px solid rgba(168,140,90,0.1);transition:all 0.18s;"
              onmouseover="this.style.background='rgba(232,168,80,0.08)';this.style.borderColor='rgba(168,140,90,0.3)'"
              onmouseout="this.style.background='rgba(26,48,32,0.02)';this.style.borderColor='rgba(168,140,90,0.1)'">
              <div style="width:34px;height:34px;border-radius:8px;background:rgba(232,168,80,0.12);border:1px solid rgba(168,140,90,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;">⛳</div>
              <div>
                <div style="font-size:13px;font-weight:600;color:#1a3020;margin-bottom:2px;">{c.name}</div>
                <div style="font-size:11px;color:#7a8a7e;line-height:1.4;">{c.tier} · Par {c.par} · {c.yards.toLocaleString()} yds</div>
              </div>
            </a>
          ))}
        </div>
        <div style="border-top:1px solid rgba(168,140,90,0.12);padding-top:13px;display:flex;justify-content:flex-end;">
          <a href="/all-golf-courses/" style="font-size:12px;color:#a06c30;text-decoration:none;font-weight:600;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Compare all 5 courses →</a>
        </div>
      </div>
    </div>

    <!-- LODGING -->
    <div class="nav-item" style="padding: 4px 12px;">
      <button class="nav-link">
        Lodging
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mega-menu" style="width:520px; background:rgba(252,249,242,0.98); border:1px solid rgba(168,140,90,0.2); border-radius:20px; padding:28px; backdrop-filter:blur(24px); box-shadow:0 16px 56px rgba(26,48,32,0.14),0 2px 8px rgba(26,48,32,0.06);">
        <p style="font-size:10px;color:#a06c30;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;margin:0 0 14px;">Where to Stay</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:16px;">
          {[
            {name:'River Pines Resort', tag:'Best for Groups', icon:'🏨', href:'/lodging#river-pines'},
            {name:'Chalet View Lodge', tag:'Best Amenities', icon:'🏔️', href:'/lodging#chalet-view'},
            {name:'The Inn at Nakoma', tag:'Most Unique', icon:'🏛️', href:'/lodging#inn-at-nakoma'},
            {name:'Townhomes at Plumas Pines', tag:'Best for Large Groups', icon:'🏠', href:'/lodging#townhomes'},
          ].map(l => (
            <a href={l.href} style="display:flex;align-items:flex-start;gap:11px;padding:12px 13px;border-radius:10px;text-decoration:none;background:rgba(26,48,32,0.02);border:1px solid rgba(168,140,90,0.1);transition:all 0.18s;"
            onmouseover="this.style.background='rgba(232,168,80,0.08)';this.style.borderColor='rgba(168,140,90,0.3)'"
            onmouseout="this.style.background='rgba(26,48,32,0.02)';this.style.borderColor='rgba(168,140,90,0.1)'">
              <span style="font-size:17px;flex-shrink:0;">{l.icon}</span>
              <div>
                <div style="font-size:13px;font-weight:600;color:#1a3020;margin-bottom:2px;">{l.name}</div>
                <div style="font-size:11px;color:#7a8a7e;">{l.tag}</div>
              </div>
            </a>
          ))}
        </div>
        <div style="border-top:1px solid rgba(168,140,90,0.12);padding-top:13px;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <a href="/lodging#hotels-resorts" style="text-align:center;padding:9px;border-radius:8px;background:rgba(26,48,32,0.03);border:1px solid rgba(168,140,90,0.12);font-size:12px;color:#5a7060;text-decoration:none;transition:all 0.18s;font-weight:500;" onmouseover="this.style.color='#1a3020';this.style.background='rgba(26,48,32,0.06)'" onmouseout="this.style.color='#5a7060';this.style.background='rgba(26,48,32,0.03)'">Hotels &amp; Resorts</a>
          <a href="/lodging#townhomes" style="text-align:center;padding:9px;border-radius:8px;background:rgba(26,48,32,0.03);border:1px solid rgba(168,140,90,0.12);font-size:12px;color:#5a7060;text-decoration:none;transition:all 0.18s;font-weight:500;" onmouseover="this.style.color='#1a3020';this.style.background='rgba(26,48,32,0.06)'" onmouseout="this.style.color='#5a7060';this.style.background='rgba(26,48,32,0.03)'">Townhomes</a>
        </div>
      </div>
    </div>

    <!-- DINING -->
    <div class="nav-item" style="padding: 4px 12px;">
      <button class="nav-link">
        Dining
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mega-menu" style="width:540px; background:rgba(252,249,242,0.98); border:1px solid rgba(168,140,90,0.2); border-radius:20px; padding:28px; backdrop-filter:blur(24px); box-shadow:0 16px 56px rgba(26,48,32,0.14),0 2px 8px rgba(26,48,32,0.06);">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;">
          <div>
            <p style="font-size:10px;color:#a06c30;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;margin:0 0 11px;">Fine Dining</p>
            {[
              {name:'Longboards Bar & Grill', href:'/dining'},
              {name:'Sardine Lake Resort', href:'/dining'},
              {name:'Iron Door Restaurant', href:'/dining'},
            ].map(r=>(
              <a href={r.href} style="display:block;font-size:13px;color:#5a7060;text-decoration:none;margin-bottom:7px;padding:5px 7px;border-radius:6px;transition:all 0.15s;font-weight:500;" onmouseover="this.style.color='#1a3020';this.style.background='rgba(26,48,32,0.05)'" onmouseout="this.style.color='#5a7060';this.style.background='transparent'">{r.name}</a>
            ))}
          </div>
          <div>
            <p style="font-size:10px;color:#a06c30;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;margin:0 0 11px;">Casual</p>
            {[
              {name:'Grizzly Grill', href:'/dining'},
              {name:'Roadhouse at River Pines', href:'/dining'},
              {name:"Cuccia's", href:'/dining'},
              {name:'Sierra SmokeShow', href:'/dining'},
              {name:"Gumba's II Go", href:'/dining'},
            ].map(r=>(
              <a href={r.href} style="display:block;font-size:13px;color:#5a7060;text-decoration:none;margin-bottom:7px;padding:5px 7px;border-radius:6px;transition:all 0.15s;font-weight:500;" onmouseover="this.style.color='#1a3020';this.style.background='rgba(26,48,32,0.05)'" onmouseout="this.style.color='#5a7060';this.style.background='transparent'">{r.name}</a>
            ))}
          </div>
          <div>
            <p style="font-size:10px;color:#a06c30;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;margin:0 0 11px;">Brews &amp; Bars</p>
            {[
              {name:'Eureka Peak Brewing', href:'/dining'},
              {name:'The Brewing Lair', href:'/dining'},
              {name:'Mohawk Tavern', href:'/dining'},
              {name:'Knotty Pine Tavern', href:'/dining'},
            ].map(r=>(
              <a href={r.href} style="display:block;font-size:13px;color:#5a7060;text-decoration:none;margin-bottom:7px;padding:5px 7px;border-radius:6px;transition:all 0.15s;font-weight:500;" onmouseover="this.style.color='#1a3020';this.style.background='rgba(26,48,32,0.05)'" onmouseout="this.style.color='#5a7060';this.style.background='transparent'">{r.name}</a>
            ))}
            <a href="/dining/" style="display:block;font-size:11px;color:#a06c30;text-decoration:none;margin-top:10px;padding:5px 7px;font-weight:600;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">View all dining →</a>
          </div>
        </div>
      </div>
    </div>

    <a href="/about-us/" class="nav-link" style="padding: 8px 12px;">About</a>
    <a href="/blog/" class="nav-link" style="padding: 8px 12px;">Blog</a>
    <a href="/faq/" class="nav-link" style="padding: 8px 12px;">FAQ</a>
  </div>

  <!-- CTA -->
  <a id="nav-cta" href="/request-a-quote/"
    style="background:#1a3020;color:#f5f0e8;font-size:13px;font-weight:700;padding:11px 24px;border-radius:100px;text-decoration:none;transition:all 0.25s;box-shadow:0 3px 14px rgba(26,48,32,0.18);flex-shrink:0;letter-spacing:0.01em;"
    onmouseover="this.style.background='#234d2c';this.style.transform='translateY(-1px)';this.style.boxShadow='0 7px 24px rgba(26,48,32,0.28)'"
    onmouseout="this.style.background='#1a3020';this.style.transform='translateY(0)';this.style.boxShadow='0 3px 14px rgba(26,48,32,0.18)'">
    Plan My Trip →
  </a>

  <!-- Mobile toggle -->
  <button id="mobile-toggle" onclick="document.getElementById('mobile-menu').classList.toggle('open')"
    style="display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:600;">
    <span style="width:24px;height:2px;background:#1a3020;border-radius:2px;display:block;"></span>
    <span style="width:24px;height:2px;background:#1a3020;border-radius:2px;display:block;"></span>
    <span style="width:16px;height:2px;background:#1a3020;border-radius:2px;display:block;"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:36px;">
    <img src="/logo.png" alt="Golf Graeagle" style="height:40px;width:auto;"
      onerror="this.style.display='none';this.nextElementSibling.style.display='block'"/>
    <span style="display:none;font-family:'Playfair Display',serif;font-size:18px;color:#1a3020;">Golf <span style="color:#a06c30;">Graeagle</span></span>
    <button onclick="document.getElementById('mobile-menu').classList.remove('open')" style="background:none;border:none;color:#1a3020;font-size:28px;cursor:pointer;line-height:1;">×</button>
  </div>
  <div style="display:flex;flex-direction:column;gap:4px;">
    {[
      {label:'Home', href:'/'},
      {label:'All Golf Courses', href:'/all-golf-courses/'},
      {label:'Lodging', href:'/lodging/'},
      {label:'Dining', href:'/dining/'},
      {label:'About', href:'/about-us/'},
      {label:'Blog', href:'/blog/'},
      {label:'FAQ', href:'/faq/'},
    ].map(l=>(
      <a href={l.href} style="font-size:20px;color:#3a4a3e;text-decoration:none;padding:13px 0;border-bottom:1px solid rgba(168,140,90,0.12);transition:color 0.2s;font-weight:500;" onmouseover="this.style.color='#a06c30'" onmouseout="this.style.color='#3a4a3e'">{l.label}</a>
    ))}
    <a href="/request-a-quote/" style="margin-top:24px;background:#1a3020;color:#f5f0e8;font-size:16px;font-weight:700;padding:17px;border-radius:14px;text-decoration:none;text-align:center;">Plan My Trip →</a>
  </div>
</div>

<script>
  // Scroll effect
  const nav = document.getElementById('sitenav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // ── Mega menu: JS-controlled with close delay ──────────────────────────
  // Pure CSS :hover is unreliable — the gap between trigger and panel
  // causes mouseleave to fire before the user reaches the menu.
  // Fix: use mouseenter/mouseleave on BOTH the nav-item and the mega-menu,
  // with a short close delay so crossing the gap never closes the menu.

  const CLOSE_DELAY = 120; // ms — enough time to cross the gap

  document.querySelectorAll('.nav-item').forEach(item => {
    const menu = item.querySelector('.mega-menu');
    if (!menu) return;

    let closeTimer = null;

    const open = () => {
      // Close any other open menus first
      document.querySelectorAll('.nav-item.open').forEach(other => {
        if (other !== item) {
          other.classList.remove('open');
          other.querySelector('.mega-menu')?.classList.remove('open');
        }
      });
      clearTimeout(closeTimer);
      item.classList.add('open');
      menu.classList.add('open');
    };

    const scheduleClose = () => {
      closeTimer = setTimeout(() => {
        item.classList.remove('open');
        menu.classList.remove('open');
      }, CLOSE_DELAY);
    };

    const cancelClose = () => clearTimeout(closeTimer);

    // Trigger: hover the nav-item (button + its area)
    item.addEventListener('mouseenter', open);
    item.addEventListener('mouseleave', scheduleClose);

    // Panel: keep open while mouse is inside
    menu.addEventListener('mouseenter', cancelClose);
    menu.addEventListener('mouseleave', scheduleClose);
  });

  // Click outside closes all
  document.addEventListener('click', e => {
    if (!e.target.closest('.nav-item')) {
      document.querySelectorAll('.nav-item.open').forEach(item => {
        item.classList.remove('open');
        item.querySelector('.mega-menu')?.classList.remove('open');
      });
    }
  });
</script>
