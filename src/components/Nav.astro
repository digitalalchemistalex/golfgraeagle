---
import { courses } from '../data/content.js';
---

<style>
  #sitenav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    transition: all 0.4s ease;
  }
  #sitenav.scrolled {
    background: rgba(13,26,14,0.96);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(232,168,80,0.12);
  }

  .nav-item { position: relative; }

  .mega-menu {
    position: absolute; top: calc(100% + 8px); left: 50%;
    transform: translateX(-50%) translateY(-4px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
    z-index: 300;
  }
  .mega-menu.open {
    opacity: 1; pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .nav-link {
    font-size: 14px; color: rgba(240,248,242,0.65);
    text-decoration: none; padding: 8px 4px;
    transition: color 0.2s; cursor: pointer;
    display: flex; align-items: center; gap: 5px;
    white-space: nowrap; background: none; border: none;
  }
  .nav-link:hover, .nav-link.active { color: #e8a850; }
  .nav-link .chevron { transition: transform 0.2s; }
  .nav-item.open .chevron { transform: rotate(180deg); }
  .nav-item.open .nav-link { color: #e8a850; }

  /* Mobile hamburger */
  #mobile-toggle { display: none; }
  #mobile-menu {
    display: none; position: fixed; inset: 0; top: 0;
    background: rgba(13,26,14,0.99); z-index: 500;
    padding: 24px; overflow-y: auto;
  }
  #mobile-menu.open { display: flex; flex-direction: column; }

  @media (max-width: 860px) {
    #desktop-nav, #nav-cta { display: none !important; }
    #mobile-toggle { display: flex !important; }
  }
</style>

<nav id="sitenav" style="padding: 16px 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">

  <!-- Logo -->
  <a href="/" style="font-family:'Playfair Display',serif; font-size: 22px; color: #f0f8f2; text-decoration: none; letter-spacing: 0.01em; flex-shrink:0; z-index:1;">
    Golf <span style="color:#e8a850;">Graeagle</span>
  </a>

  <!-- Desktop nav -->
  <div id="desktop-nav" style="display: flex; align-items: center; gap: 4px;">

    <!-- COURSES -->
    <div class="nav-item" style="padding: 4px 12px;">
      <button class="nav-link">
        Courses
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mega-menu" style="width:680px; background:rgba(10,20,11,0.98); border:1px solid rgba(232,168,80,0.14); border-radius:20px; padding:28px; backdrop-filter:blur(24px); box-shadow:0 24px 64px rgba(0,0,0,0.7);">
        <p style="font-size:10px;color:rgba(232,168,80,0.55);text-transform:uppercase;letter-spacing:0.14em;font-weight:600;margin:0 0 16px;">5 Championship Courses</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:20px;">
          {courses.map(c => (
            <a href={`/portfolio/${c.slug === 'nakoma' ? 'nakoma-dragon-golf-packages' : c.slug + '-golf-packages'}/`}
              style="display:flex;align-items:flex-start;gap:12px;padding:13px 15px;border-radius:12px;text-decoration:none;background:rgba(240,248,242,0.02);border:1px solid transparent;transition:all 0.18s;"
              onmouseover="this.style.background='rgba(232,168,80,0.07)';this.style.borderColor='rgba(232,168,80,0.18)'"
              onmouseout="this.style.background='rgba(240,248,242,0.02)';this.style.borderColor='transparent'">
              <div style="width:34px;height:34px;border-radius:8px;background:rgba(232,168,80,0.1);border:1px solid rgba(232,168,80,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;">⛳</div>
              <div>
                <div style="font-size:13px;font-weight:500;color:#f0f8f2;margin-bottom:2px;">{c.name}</div>
                <div style="font-size:11px;color:rgba(240,248,242,0.35);line-height:1.4;">{c.tier} · Par {c.par} · {c.yards.toLocaleString()} yds</div>
              </div>
            </a>
          ))}
        </div>
        <div style="border-top:1px solid rgba(240,248,242,0.06);padding-top:14px;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:11px;color:rgba(240,248,242,0.28);">All within 25 minutes of each other</span>
          <a href="/all-golf-courses/" style="font-size:12px;color:#e8a850;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">Compare all courses →</a>
        </div>
      </div>
    </div>

    <!-- LODGING -->
    <div class="nav-item" style="padding: 4px 12px;">
      <button class="nav-link">
        Lodging
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mega-menu" style="width:520px; background:rgba(10,20,11,0.98); border:1px solid rgba(232,168,80,0.14); border-radius:20px; padding:28px; backdrop-filter:blur(24px); box-shadow:0 24px 64px rgba(0,0,0,0.7);">
        <p style="font-size:10px;color:rgba(232,168,80,0.55);text-transform:uppercase;letter-spacing:0.14em;font-weight:600;margin:0 0 16px;">Where to Stay</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:18px;">
          {[
            {name:'River Pines Resort', tag:'Best for Groups', icon:'🏨', href:'/portfolio/river-pines-resort-graeagle-ca/'},
            {name:'Chalet View Lodge', tag:'Best Amenities', icon:'🏔️', href:'/portfolio/chalet-view-lodge-graeagle-ca/'},
            {name:'The Inn at Nakoma', tag:'Most Unique', icon:'🏛️', href:'/portfolio/the-inn-at-nakoma-clio-ca/'},
            {name:'Townhomes at Plumas Pines', tag:'Best for Large Groups', icon:'🏠', href:'/portfolio/the-townhomes-at-plumas-pines/'},
          ].map(l => (
            <a href={l.href} style="display:flex;align-items:flex-start;gap:11px;padding:12px 13px;border-radius:10px;text-decoration:none;background:rgba(240,248,242,0.02);border:1px solid transparent;transition:all 0.18s;"
            onmouseover="this.style.background='rgba(232,168,80,0.07)';this.style.borderColor='rgba(232,168,80,0.18)'"
            onmouseout="this.style.background='rgba(240,248,242,0.02)';this.style.borderColor='transparent'">
              <span style="font-size:17px;flex-shrink:0;">{l.icon}</span>
              <div>
                <div style="font-size:13px;font-weight:500;color:#f0f8f2;margin-bottom:2px;">{l.name}</div>
                <div style="font-size:11px;color:rgba(240,248,242,0.32);">{l.tag}</div>
              </div>
            </a>
          ))}
        </div>
        <div style="border-top:1px solid rgba(240,248,242,0.06);padding-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <a href="/hotels/" style="text-align:center;padding:9px;border-radius:8px;background:rgba(240,248,242,0.03);border:1px solid rgba(240,248,242,0.07);font-size:12px;color:rgba(240,248,242,0.5);text-decoration:none;transition:all 0.18s;" onmouseover="this.style.color='#f0f8f2';this.style.background='rgba(240,248,242,0.06)'" onmouseout="this.style.color='rgba(240,248,242,0.5)';this.style.background='rgba(240,248,242,0.03)'">Hotels & Resorts</a>
          <a href="/lodging/" style="text-align:center;padding:9px;border-radius:8px;background:rgba(240,248,242,0.03);border:1px solid rgba(240,248,242,0.07);font-size:12px;color:rgba(240,248,242,0.5);text-decoration:none;transition:all 0.18s;" onmouseover="this.style.color='#f0f8f2';this.style.background='rgba(240,248,242,0.06)'" onmouseout="this.style.color='rgba(240,248,242,0.5)';this.style.background='rgba(240,248,242,0.03)'">Townhomes & Private Homes</a>
        </div>
      </div>
    </div>

    <!-- DINING -->
    <div class="nav-item" style="padding: 4px 12px;">
      <button class="nav-link">
        Dining
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mega-menu" style="width:540px; background:rgba(10,20,11,0.98); border:1px solid rgba(232,168,80,0.14); border-radius:20px; padding:28px; backdrop-filter:blur(24px); box-shadow:0 24px 64px rgba(0,0,0,0.7);">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;">
          <div>
            <p style="font-size:10px;color:rgba(232,168,80,0.55);text-transform:uppercase;letter-spacing:0.12em;font-weight:600;margin:0 0 12px;">Fine Dining</p>
            {[
              {name:'Longboards Bar & Grill', href:'/portfolio/longboards-bar-and-grill/'},
              {name:'Sardine Lake Resort', href:'/portfolio/sardine-lake-resort/'},
              {name:'Iron Door Restaurant', href:'/portfolio/iron-door-restaurant/'},
            ].map(r=>(
              <a href={r.href} style="display:block;font-size:13px;color:rgba(240,248,242,0.5);text-decoration:none;margin-bottom:8px;padding:5px 7px;border-radius:6px;transition:all 0.15s;" onmouseover="this.style.color='#f0f8f2';this.style.background='rgba(240,248,242,0.05)'" onmouseout="this.style.color='rgba(240,248,242,0.5)';this.style.background='transparent'">{r.name}</a>
            ))}
          </div>
          <div>
            <p style="font-size:10px;color:rgba(232,168,80,0.55);text-transform:uppercase;letter-spacing:0.12em;font-weight:600;margin:0 0 12px;">Casual</p>
            {[
              {name:'Grizzly Grill', href:'/portfolio/grizzly-grill/'},
              {name:'Roadhouse at River Pines', href:'/portfolio/roadhouse-at-river-pines/'},
              {name:"Cuccia's", href:'/portfolio/cuccias/'},
              {name:'Sierra SmokeShow', href:'/portfolio/sierra-smokeshow/'},
              {name:"Gumba's II Go", href:'/portfolio/gumbas-ii-go/'},
            ].map(r=>(
              <a href={r.href} style="display:block;font-size:13px;color:rgba(240,248,242,0.5);text-decoration:none;margin-bottom:8px;padding:5px 7px;border-radius:6px;transition:all 0.15s;" onmouseover="this.style.color='#f0f8f2';this.style.background='rgba(240,248,242,0.05)'" onmouseout="this.style.color='rgba(240,248,242,0.5)';this.style.background='transparent'">{r.name}</a>
            ))}
          </div>
          <div>
            <p style="font-size:10px;color:rgba(232,168,80,0.55);text-transform:uppercase;letter-spacing:0.12em;font-weight:600;margin:0 0 12px;">Brews & Bars</p>
            {[
              {name:'Eureka Peak Brewing', href:'/portfolio/eureka-peak-brewing-co/'},
              {name:'The Brewing Lair', href:'/portfolio/the-brewing-lair/'},
              {name:'Mohawk Tavern', href:'/portfolio/mohawk-tavern/'},
              {name:'Knotty Pine Tavern', href:'/portfolio/the-knotty-pine-tavern/'},
            ].map(r=>(
              <a href={r.href} style="display:block;font-size:13px;color:rgba(240,248,242,0.5);text-decoration:none;margin-bottom:8px;padding:5px 7px;border-radius:6px;transition:all 0.15s;" onmouseover="this.style.color='#f0f8f2';this.style.background='rgba(240,248,242,0.05)'" onmouseout="this.style.color='rgba(240,248,242,0.5)';this.style.background='transparent'">{r.name}</a>
            ))}
            <a href="/dining/" style="display:block;font-size:11px;color:#e8a850;text-decoration:none;margin-top:12px;padding:5px 7px;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">View all dining →</a>
          </div>
        </div>
      </div>
    </div>

    <a href="/about-us/" class="nav-link" style="padding: 8px 12px;">About</a>
    <a href="/blog/" class="nav-link" style="padding: 8px 12px;">Blog</a>
  </div>

  <!-- CTA -->
  <a id="nav-cta" href="/request-a-quote/"
    style="background:#e8a850;color:#0d1a0e;font-size:13px;font-weight:700;padding:11px 26px;border-radius:100px;text-decoration:none;transition:all 0.25s;box-shadow:0 4px 16px rgba(232,168,80,0.25);flex-shrink:0;letter-spacing:0.01em;"
    onmouseover="this.style.background='#f2c878';this.style.transform='translateY(-1px)';this.style.boxShadow='0 8px 28px rgba(232,168,80,0.45)'"
    onmouseout="this.style.background='#e8a850';this.style.transform='translateY(0)';this.style.boxShadow='0 4px 16px rgba(232,168,80,0.25)'">
    Plan My Trip →
  </a>

  <!-- Mobile toggle -->
  <button id="mobile-toggle" onclick="document.getElementById('mobile-menu').classList.toggle('open')"
    style="display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:600;">
    <span style="width:24px;height:2px;background:#f0f8f2;border-radius:2px;display:block;"></span>
    <span style="width:24px;height:2px;background:#f0f8f2;border-radius:2px;display:block;"></span>
    <span style="width:16px;height:2px;background:#f0f8f2;border-radius:2px;display:block;"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;">
    <span style="font-family:'Playfair Display',serif;font-size:20px;color:#f0f8f2;">Golf <span style="color:#e8a850;">Graeagle</span></span>
    <button onclick="document.getElementById('mobile-menu').classList.remove('open')" style="background:none;border:none;color:#f0f8f2;font-size:28px;cursor:pointer;line-height:1;">×</button>
  </div>
  <div style="display:flex;flex-direction:column;gap:6px;">
    {[
      {label:'Home', href:'/'},
      {label:'All Golf Courses', href:'/all-golf-courses/'},
      {label:'Lodging', href:'/lodging/'},
      {label:'Dining', href:'/dining/'},
      {label:'About', href:'/about-us/'},
      {label:'Blog', href:'/blog/'},
    ].map(l=>(
      <a href={l.href} style="font-size:22px;color:rgba(240,248,242,0.7);text-decoration:none;padding:14px 0;border-bottom:1px solid rgba(240,248,242,0.06);transition:color 0.2s;" onmouseover="this.style.color='#e8a850'" onmouseout="this.style.color='rgba(240,248,242,0.7)'">{l.label}</a>
    ))}
    <a href="/request-a-quote/" style="margin-top:28px;background:#e8a850;color:#0d1a0e;font-size:17px;font-weight:700;padding:18px;border-radius:14px;text-decoration:none;text-align:center;">Plan My Trip →</a>
  </div>
</div>

<script>
  // Scroll effect
  const nav = document.getElementById('sitenav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // ── Mega menu: JS-controlled with close delay ──────────────────────────
  // Pure CSS :hover is unreliable — the gap between trigger and panel
  // causes mouseleave to fire before the user reaches the menu.
  // Fix: use mouseenter/mouseleave on BOTH the nav-item and the mega-menu,
  // with a short close delay so crossing the gap never closes the menu.

  const CLOSE_DELAY = 120; // ms — enough time to cross the gap

  document.querySelectorAll('.nav-item').forEach(item => {
    const menu = item.querySelector('.mega-menu');
    if (!menu) return;

    let closeTimer = null;

    const open = () => {
      // Close any other open menus first
      document.querySelectorAll('.nav-item.open').forEach(other => {
        if (other !== item) {
          other.classList.remove('open');
          other.querySelector('.mega-menu')?.classList.remove('open');
        }
      });
      clearTimeout(closeTimer);
      item.classList.add('open');
      menu.classList.add('open');
    };

    const scheduleClose = () => {
      closeTimer = setTimeout(() => {
        item.classList.remove('open');
        menu.classList.remove('open');
      }, CLOSE_DELAY);
    };

    const cancelClose = () => clearTimeout(closeTimer);

    // Trigger: hover the nav-item (button + its area)
    item.addEventListener('mouseenter', open);
    item.addEventListener('mouseleave', scheduleClose);

    // Panel: keep open while mouse is inside
    menu.addEventListener('mouseenter', cancelClose);
    menu.addEventListener('mouseleave', scheduleClose);
  });

  // Click outside closes all
  document.addEventListener('click', e => {
    if (!e.target.closest('.nav-item')) {
      document.querySelectorAll('.nav-item.open').forEach(item => {
        item.classList.remove('open');
        item.querySelector('.mega-menu')?.classList.remove('open');
      });
    }
  });
</script>
