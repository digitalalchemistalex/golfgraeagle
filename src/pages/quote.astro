---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { courses, lodging } from '../data/content.js';

const preselected = Astro.url.searchParams.get('course') || '';

const courseCards = [
  { ...courses[0], accolade: 'Golf Digest Top 100',  mustPlay: true  },
  { ...courses[1], accolade: 'The Valley Original', mustPlay: false },
  { ...courses[2], accolade: 'Top 20 CA — 1998',    mustPlay: true  },
  { ...courses[3], accolade: 'Top 5 Best Value',     mustPlay: false },
  { ...courses[4], accolade: 'Golf World Top 75',    mustPlay: true  },
];

const lodgingCards = [
  { ...lodging[0], best:'Groups & Families', icon:'🏕', desc:'Cabins, suites & rooms · Pool & hot tub · Roadhouse dining on-site' },
  { ...lodging[1], best:'Great Amenities',    icon:'🏡', desc:'10 forested acres · Spa · 9-hole exec course · Eureka Peak Brewing' },
  { ...lodging[2], best:'Most Unique',       icon:'🏛', desc:'Frank Lloyd Wright building · Steps from The Dragon · Spa & pool' },
  { ...lodging[3], best:'Large Groups',      icon:'🏘', desc:'2–4 bedroom units · Full kitchens · On the Plumas Pines course' },
];
---
export const prerender = true;

<Base
  title="Request a Graeagle Golf Package Quote | GolfGraeagle"
  description="Plan your Graeagle golf trip. Tell us your dates, group size, courses, and lodging — we'll build a custom stay-and-play package. Free quote, 24-hour response."

  bodyClass="light-page"
>
  <Nav />

  <div style="min-height:100vh;padding-top:88px;background:#0d1a0e;position:relative;">
    <div style="position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse 60% 50% at 70% 0%,rgba(232,168,80,0.05) 0%,transparent 65%);"></div>

    <div class="qw" style="position:relative;z-index:1;">

      <!-- LEFT STICKY PITCH -->
      <aside class="q-pitch">
        <p class="q-eyebrow">Free · No Obligation · 24-hr Response</p>
        <h1 class="q-h1">Build your<br/><em style="color:#e8a850;font-style:italic;">Graeagle</em><br/>golf trip.</h1>
        <p class="q-sub">Five championship courses. Four handpicked properties. One team that's been doing this for 20+ years.</p>

        <!-- live summary -->
        <div id="trip-summary" class="q-summary" style="display:none;">
          <div class="q-summary-title">📋 Your Trip So Far</div>
          <div id="summary-lines"></div>
        </div>

        <div id="static-benefits">
          {[
            { icon:'⛳', t:'Tee time coordination',         s:'All 5 courses booked — no calling around' },
            { icon:'🏔', t:'Lodging matched to your group',  s:'Hotel, resort, or townhomes sized for your crew' },
            { icon:'📋', t:'Full day-by-day itinerary',     s:'Courses, dining recs, and drive times included' },
            { icon:'⚡', t:'24-hour turnaround',            s:'Real people — not a chatbot queue' },
          ].map(b=>(
            <div class="q-benefit">
              <span class="q-benefit-icon">{b.icon}</span>
              <div>
                <div class="q-benefit-title">{b.t}</div>
                <div class="q-benefit-sub">{b.s}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="q-trust-row">
          {[{n:'5',l:'Courses'},{n:'20+',l:'Years'},{n:'24hr',l:'Response'}].map(t=>(
            <div class="q-trust-item">
              <div class="q-trust-n">{t.n}</div>
              <div class="q-trust-l">{t.l}</div>
            </div>
          ))}
        </div>
      </aside>

      <!-- RIGHT: single scrollable form -->
      <main class="q-panel">
        <form id="qf" novalidate>

          <!-- ── CONTACT ── -->
          <div class="q-section">
            <div class="q-section-hd">
              <span class="q-section-num">01</span>
              <div>
                <h2 class="q-section-title">Contact Information</h2>
                <p class="q-section-sub">We'll use this to send your custom package quote.</p>
              </div>
            </div>
            <div class="q-2col">
              <div class="qfld"><label>First Name <span class="req">*</span></label><input type="text" name="firstName" placeholder="Jack" required autocomplete="given-name"/></div>
              <div class="qfld"><label>Last Name <span class="req">*</span></label><input type="text" name="lastName" placeholder="Nicklaus" required autocomplete="family-name"/></div>
              <div class="qfld qfull"><label>Email <span class="req">*</span></label><input type="email" name="email" placeholder="you@example.com" required autocomplete="email"/></div>
              <div class="qfld qfull"><label>Phone <span class="req">*</span></label><input type="tel" name="phone" placeholder="(555) 555-5555" required autocomplete="tel"/></div>
              <div class="qfld qfull">
                <label>How did you hear about us?</label>
                <select name="howHeard">
                  <option value="">Select one…</option>
                  <option value="google">Google Search</option>
                  <option value="referral">Friend / Referral</option>
                  <option value="social">Social Media</option>
                  <option value="golf-course">Golf Course Recommendation</option>
                  <option value="returning">Returning Customer</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
          </div>

          <div class="q-divider"></div>

          <!-- ── TRIP DETAILS ── -->
          <div class="q-section">
            <div class="q-section-hd">
              <span class="q-section-num">02</span>
              <div>
                <h2 class="q-section-title">Trip Details</h2>
                <p class="q-section-sub">Dates, group size, and preferences.</p>
              </div>
            </div>
            <div class="q-2col">
              <div class="qfld"><label>Arrival Date <span class="req">*</span></label><input type="date" name="arrivalDate" id="arrival-date" required/></div>
              <div class="qfld"><label>Departure Date <span class="req">*</span></label><input type="date" name="departureDate" id="departure-date" required/></div>
              <div class="qfld"><label>Group Size <span class="req">*</span></label><input type="number" name="partySize" id="party-size" min="1" max="200" placeholder="4" required/></div>
              <div class="qfld"><label>Number of Nights</label><input type="number" name="numNights" id="num-nights" min="1" placeholder="auto-calculated"/></div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Dates flexible?</div>
              <div class="q-radio-row">
                <label class="q-radio"><input type="radio" name="datesFlexible" value="yes"/> Yes, can shift a few days</label>
                <label class="q-radio"><input type="radio" name="datesFlexible" value="no" checked/> No, these are fixed</label>
              </div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Budget Tier (per golfer, all-in)</div>
              <div class="q-tier-row">
                {[
                  { v:'budget',  l:'$$',   desc:'Value-focused — great golf, smart lodging' },
                  { v:'mid',     l:'$$$',  desc:'Comfort & quality — our most popular tier' },
                  { v:'premium', l:'$$$$', desc:'Resort experience — no compromises' },
                ].map(t=>(
                  <label class="q-tier-card">
                    <input type="radio" name="budgetTier" value={t.v}/>
                    <div class="q-tier-inner">
                      <div class="q-tier-price">{t.l}</div>
                      <div class="q-tier-desc">{t.desc}</div>
                    </div>
                  </label>
                ))}
              </div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Group Skill Level</div>
              <div class="q-radio-row" style="flex-wrap:wrap;">
                {[
                  {v:'beginner',l:'Beginner (30+ HCP)'},{v:'recreational',l:'Recreational (15–29)'},
                  {v:'mid',l:'Mid (8–14)'},{v:'low',l:'Low (0–7)'},{v:'mixed',l:'Mixed group'},
                ].map(s=>(<label class="q-radio"><input type="radio" name="skillLevel" value={s.v}/> {s.l}</label>))}
              </div>
            </div>
          </div>

          <div class="q-divider"></div>

          <!-- ── GOLF PREFERENCES ── -->
          <div class="q-section">
            <div class="q-section-hd">
              <span class="q-section-num">03</span>
              <div>
                <h2 class="q-section-title">Golf Preferences</h2>
                <p class="q-section-sub">Help us build the right round schedule.</p>
              </div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Total Rounds Planned <span class="req">*</span></div>
              <div class="q-radio-row" style="flex-wrap:wrap;">
                {[1,2,3,4,5].map(n=>(
                  <label class="q-num-chip">
                    <input type="radio" name="totalRounds" value={String(n)}/>
                    <span>{n} {n===1?'round':'rounds'}</span>
                  </label>
                ))}
                <label class="q-num-chip">
                  <input type="radio" name="totalRounds" value="other"/>
                  <span>Other</span>
                </label>
              </div>
            </div>

            <div class="qfld" id="rounds-other-wrap" style="display:none;margin-bottom:18px;">
              <label>How many rounds?</label>
              <input type="number" name="totalRoundsCustom" min="1" max="20" placeholder="6" style="max-width:160px;"/>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Preferred Tee Time Window</div>
              <div class="q-radio-row" style="flex-wrap:wrap;">
                {[
                  {v:'early',l:'Early bird (7–9am)'},{v:'mid',l:'Mid-morning (9–11am)'},
                  {v:'midday',l:'Midday (11am–1pm)'},{v:'flex',l:'Flexible'},
                ].map(t=>(<label class="q-radio"><input type="radio" name="idealTeeTimes" value={t.v}/> {t.l}</label>))}
              </div>
            </div>

            <div class="q-2col">
              <div class="q-radio-group" style="margin-bottom:0;">
                <div class="q-radio-label">Play on arrival day?</div>
                <div class="q-radio-row" style="flex-direction:column;gap:6px;">
                  <label class="q-radio"><input type="radio" name="playOnArrival" value="yes"/> Yes</label>
                  <label class="q-radio"><input type="radio" name="playOnArrival" value="no" checked/> No</label>
                </div>
              </div>
              <div class="q-radio-group" style="margin-bottom:0;">
                <div class="q-radio-label">Play on departure day?</div>
                <div class="q-radio-row" style="flex-direction:column;gap:6px;">
                  <label class="q-radio"><input type="radio" name="playOnDeparture" value="yes"/> Yes</label>
                  <label class="q-radio"><input type="radio" name="playOnDeparture" value="no" checked/> No</label>
                </div>
              </div>
            </div>

            <div class="q-radio-group" style="margin-top:18px;">
              <div class="q-radio-label">Walk or ride?</div>
              <div class="q-radio-row">
                <label class="q-radio"><input type="radio" name="cartPref" value="cart"/> Cart preferred</label>
                <label class="q-radio"><input type="radio" name="cartPref" value="walk"/> Walk when available</label>
                <label class="q-radio"><input type="radio" name="cartPref" value="either" checked/> Either works</label>
              </div>
            </div>
          </div>

          <div class="q-divider"></div>

          <!-- ── COURSE SELECTION ── -->
          <div class="q-section">
            <div class="q-section-hd">
              <span class="q-section-num">04</span>
              <div>
                <h2 class="q-section-title">Course Selection</h2>
                <p class="q-section-sub">Which courses are calling you? Select all that interest you. <span style="color:#e8a850;">⭐ = Must-play</span></p>
              </div>
            </div>
            <div class="q-course-grid">
              {courseCards.map(c=>(
                <label class="q-course-card">
                  <input type="checkbox" name="coursesInterested" value={c.slug} checked={preselected===c.slug||undefined}/>
                  <div class="q-course-img-wrap">
                    <img src={c.hero} alt={c.name} loading="lazy" class="q-course-img"/>
                    <div class="q-course-img-fade"></div>
                    {c.mustPlay&&<span class="q-must-badge">⭐ Must-Play</span>}
                    <div class="q-course-check-icon">✓</div>
                  </div>
                  <div class="q-course-info">
                    <div class="q-course-accolade">{c.accolade}</div>
                    <div class="q-course-name">{c.name}</div>
                    <div class="q-course-stats">Par {c.par} · {c.yards.toLocaleString()} yds · Slope {c.slope} · {c.designer}</div>
                  </div>
                </label>
              ))}
            </div>
          </div>

          <div class="q-divider"></div>

          <!-- ── LODGING ── -->
          <div class="q-section">
            <div class="q-section-hd">
              <span class="q-section-num">05</span>
              <div>
                <h2 class="q-section-title">Where to Stay</h2>
                <p class="q-section-sub">Select your preferred property — or let us recommend.</p>
              </div>
            </div>

            <label class="q-lodge-any">
              <input type="checkbox" id="lodge-any" name="lodgingAny" value="yes"/>
              <div class="q-lodge-any-inner">
                <span style="font-size:18px;">🎯</span>
                <div>
                  <div style="font-size:13px;font-weight:600;color:#f0f8f2;">Let us recommend the best fit</div>
                  <div style="font-size:11px;color:rgba(240,248,242,0.35);margin-top:2px;">We'll match lodging to your group size, selected courses, and budget tier.</div>
                </div>
                <div class="q-lodge-any-check">✓</div>
              </div>
            </label>

            <div class="q-lodge-grid" id="lodge-grid">
              {lodgingCards.map(l=>(
                <label class="q-lodge-card">
                  <input type="checkbox" name="lodgingInterested" value={l.slug}/>
                  <div class="q-lodge-img-wrap">
                    <img src={l.hero} alt={l.name} loading="lazy" class="q-lodge-img"/>
                    <div class="q-lodge-img-fade"></div>
                    <div class="q-lodge-check-icon">✓</div>
                  </div>
                  <div class="q-lodge-info">
                    <div class="q-lodge-best">{l.icon} Good for: {l.best}</div>
                    <div class="q-lodge-name">{l.name}</div>
                    <div class="q-lodge-desc">{l.desc}</div>
                  </div>
                </label>
              ))}
            </div>

            <div class="q-radio-group" style="margin-top:24px;">
              <div class="q-radio-label">Room Configuration</div>
              <div class="q-radio-row">
                <label class="q-radio"><input type="radio" name="roomConfig" value="double"/> Double occupancy (shared rooms)</label>
                <label class="q-radio"><input type="radio" name="roomConfig" value="single"/> Single occupancy (own room)</label>
                <label class="q-radio"><input type="radio" name="roomConfig" value="mix"/> Mix of both</label>
              </div>
            </div>
          </div>

          <div class="q-divider"></div>

          <!-- ── EXTRAS ── -->
          <div class="q-section">
            <div class="q-section-hd">
              <span class="q-section-num">06</span>
              <div>
                <h2 class="q-section-title">Final Details</h2>
                <p class="q-section-sub">Any special requirements or add-ons?</p>
              </div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Transportation Needed?</div>
              <div class="q-radio-row">
                <label class="q-radio"><input type="radio" name="transportationNeeded" value="yes"/> Yes — coordinate shuttles or transport</label>
                <label class="q-radio"><input type="radio" name="transportationNeeded" value="no" checked/> No — we have our own</label>
              </div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Include dining recommendations?</div>
              <div class="q-radio-row">
                <label class="q-radio"><input type="radio" name="diningHelp" value="yes"/> Yes please</label>
                <label class="q-radio"><input type="radio" name="diningHelp" value="no" checked/> No — we'll handle it</label>
              </div>
            </div>

            <div class="q-radio-group">
              <div class="q-radio-label">Is this a special occasion?</div>
              <div class="q-radio-row" style="flex-wrap:wrap;">
                {[
                  {v:'none',l:'Just golf'},{v:'birthday',l:'Birthday'},{v:'bachelor',l:'Bachelor party'},
                  {v:'corporate',l:'Corporate outing'},{v:'anniversary',l:'Anniversary'},{v:'other',l:'Other event'},
                ].map(e=>(<label class="q-radio"><input type="radio" name="eventType" value={e.v}/> {e.l}</label>))}
              </div>
            </div>

            <div class="qfld" id="event-detail-wrap" style="display:none;margin-bottom:18px;">
              <label>Tell us about the event</label>
              <input type="text" name="fbEventWhen" placeholder="e.g. 50th birthday dinner Saturday night for 12"/>
            </div>

            <div class="qfld">
              <label>Special Requests or Notes</label>
              <textarea name="specialRequests" rows="4" placeholder="Dietary needs, mobility requirements, pace-of-play preferences, skill mix, specific requests…"></textarea>
            </div>
          </div>

          <!-- ── SUBMIT ── -->
          <div class="q-submit-row">
            <div class="q-submit-left">
              <div style="font-size:13px;font-weight:600;color:rgba(240,248,242,0.7);">Ready? We'll respond within 24 hours.</div>
              <div style="font-size:12px;color:rgba(240,248,242,0.3);margin-top:4px;">No commitment required. Free quote.</div>
            </div>
            <button type="submit" id="q-submit" class="q-btn-submit">Send My Quote Request →</button>
          </div>
          <div id="q-error" class="q-error" style="display:none;"></div>

        </form>

        <!-- SUCCESS -->
        <div id="q-success" style="display:none;padding:72px 40px;text-align:center;">
          <div style="width:80px;height:80px;border-radius:50%;background:rgba(82,168,98,0.12);border:2px solid rgba(82,168,98,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 28px;font-size:32px;">✓</div>
          <h2 style="font-family:'Playfair Display',serif;font-size:30px;font-weight:500;color:#f0f8f2;margin:0 0 12px;">You're all set, <span id="s-name"></span>!</h2>
          <p style="font-size:15px;color:rgba(240,248,242,0.5);margin:0 0 8px;">Your quote request has been received.</p>
          <p style="font-size:13px;color:rgba(240,248,242,0.3);margin:0 0 8px;">One of our Graeagle trip specialists will reach out within 24 hours.</p>
          <p style="font-size:13px;color:rgba(240,248,242,0.3);margin:0 0 36px;">Confirmation heading to <strong id="s-email" style="color:rgba(240,248,242,0.5);"></strong></p>
          <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
            <button id="q-reset" class="q-btn-back">Submit Another Request</button>
            <a href="/" style="background:#e8a850;color:#0d1a0e;font-size:13px;font-weight:700;padding:12px 26px;border-radius:100px;text-decoration:none;">← Back to Home</a>
          </div>
        </div>
      </main>
    </div>
  </div>
  <Footer />
</Base>

<style is:global>
.qw{max-width:1280px;margin:0 auto;padding:48px clamp(16px,4vw,48px) 100px;display:grid;grid-template-columns:300px 1fr;gap:60px;align-items:start;}
@media(max-width:900px){.qw{grid-template-columns:1fr;gap:36px;}}
.q-pitch{position:sticky;top:100px;}
@media(max-width:900px){.q-pitch{position:static;}}
.q-eyebrow{font-size:10px;color:#e8a850;letter-spacing:.18em;text-transform:uppercase;font-weight:600;margin:0 0 18px;}
.q-h1{font-family:'Playfair Display',serif;font-size:clamp(32px,3.5vw,46px);font-weight:500;color:#f0f8f2;margin:0 0 14px;line-height:1.1;}
.q-sub{font-size:13px;color:rgba(240,248,242,0.4);line-height:1.75;margin:0 0 24px;max-width:280px;}
.q-summary{border:1px solid rgba(232,168,80,0.15);border-radius:14px;padding:16px;background:rgba(232,168,80,0.03);margin-bottom:20px;}
.q-summary-title{font-size:10px;color:#e8a850;letter-spacing:.1em;text-transform:uppercase;font-weight:600;margin-bottom:10px;}
#summary-lines{display:flex;flex-direction:column;gap:6px;}
.q-sum-line{font-size:11px;color:rgba(240,248,242,0.5);display:flex;gap:7px;}
#static-benefits{display:flex;flex-direction:column;gap:9px;margin-bottom:24px;}
.q-benefit{display:flex;align-items:flex-start;gap:12px;padding:11px 13px;border-radius:10px;background:rgba(240,248,242,0.02);border:1px solid rgba(240,248,242,0.04);}
.q-benefit-icon{font-size:15px;flex-shrink:0;margin-top:1px;}
.q-benefit-title{font-size:11px;font-weight:600;color:rgba(240,248,242,0.7);margin-bottom:1px;}
.q-benefit-sub{font-size:10px;color:rgba(240,248,242,0.25);line-height:1.5;}
.q-trust-row{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;}
.q-trust-item{text-align:center;padding:10px 6px;border-radius:9px;background:rgba(232,168,80,0.04);border:1px solid rgba(232,168,80,0.1);}
.q-trust-n{font-family:'Playfair Display',serif;font-size:18px;color:#e8a850;font-weight:500;}
.q-trust-l{font-size:9px;color:rgba(240,248,242,0.25);margin-top:2px;letter-spacing:.05em;text-transform:uppercase;}
/* panel */
.q-panel{background:rgba(240,248,242,0.025);border:1px solid rgba(240,248,242,0.06);border-radius:24px;overflow:hidden;}
/* sections */
.q-section{padding:32px;}
@media(max-width:540px){.q-section{padding:22px 18px;}}
.q-section-hd{display:flex;align-items:flex-start;gap:16px;margin-bottom:24px;}
.q-section-num{font-family:'Playfair Display',serif;font-size:28px;color:rgba(232,168,80,0.25);font-weight:500;line-height:1;flex-shrink:0;margin-top:2px;}
.q-section-title{font-family:'Playfair Display',serif;font-size:19px;font-weight:500;color:#f0f8f2;margin:0 0 4px;}
.q-section-sub{font-size:12px;color:rgba(240,248,242,0.32);margin:0;line-height:1.5;}
.q-divider{height:1px;background:rgba(240,248,242,0.05);margin:0 32px;}
@media(max-width:540px){.q-divider{margin:0 18px;}}
/* fields */
.q-2col{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
.qfull{grid-column:1/-1;}
@media(max-width:540px){.q-2col{grid-template-columns:1fr;}}
.qfld{display:flex;flex-direction:column;}
.qfld label{font-size:10px;color:rgba(240,248,242,0.38);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;font-weight:500;}
.req{color:rgba(232,168,80,0.7);}
.qfld input,.qfld select,.qfld textarea{background:rgba(240,248,242,0.03);border:1px solid rgba(240,248,242,0.08);border-radius:12px;color:#f0f8f2;padding:12px 14px;font-size:14px;font-family:'Inter',sans-serif;outline:none;transition:border-color .2s,background .2s;-webkit-appearance:none;}
.qfld input:focus,.qfld select:focus,.qfld textarea:focus{border-color:rgba(232,168,80,0.35);background:rgba(240,248,242,0.05);}
.qfld select option{background:#0d1a0e;}
.qfld textarea{resize:vertical;min-height:100px;}
.qfld input[type="date"]{color-scheme:dark;}
.qfld input.invalid,.qfld select.invalid{border-color:rgba(248,113,113,0.45)!important;}
/* radio */
.q-radio-group{margin-bottom:16px;}
.q-radio-label{font-size:10px;color:rgba(240,248,242,0.38);text-transform:uppercase;letter-spacing:.08em;font-weight:500;margin-bottom:9px;}
.q-radio-row{display:flex;gap:7px;flex-wrap:wrap;}
.q-radio{display:flex;align-items:center;gap:7px;font-size:12px;color:rgba(240,248,242,0.5);cursor:pointer;padding:8px 13px;border-radius:10px;border:1px solid rgba(240,248,242,0.07);background:rgba(240,248,242,0.02);transition:all .2s;white-space:nowrap;}
.q-radio:has(input:checked){color:#e8a850;border-color:rgba(232,168,80,0.22);background:rgba(232,168,80,0.06);}
.q-radio input[type="radio"]{accent-color:#e8a850;flex-shrink:0;}
/* tier */
.q-tier-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:2px;}
@media(max-width:480px){.q-tier-row{grid-template-columns:1fr;}}
.q-tier-card{cursor:pointer;display:block;}
.q-tier-card input{display:none;}
.q-tier-inner{padding:14px;border-radius:12px;border:1px solid rgba(240,248,242,0.08);background:rgba(240,248,242,0.02);text-align:center;transition:all .2s;}
.q-tier-card:has(input:checked) .q-tier-inner{border-color:rgba(232,168,80,0.3);background:rgba(232,168,80,0.07);}
.q-tier-price{font-family:'Playfair Display',serif;font-size:22px;color:#e8a850;font-weight:500;margin-bottom:5px;}
.q-tier-desc{font-size:10px;color:rgba(240,248,242,0.32);line-height:1.5;}
/* round chips */
.q-num-chip{cursor:pointer;}
.q-num-chip input{display:none;}
.q-num-chip span{display:block;padding:8px 16px;border-radius:100px;border:1px solid rgba(240,248,242,0.1);background:rgba(240,248,242,0.02);font-size:12px;color:rgba(240,248,242,0.5);transition:all .2s;}
.q-num-chip:has(input:checked) span{background:rgba(232,168,80,0.1);border-color:rgba(232,168,80,0.3);color:#e8a850;}
/* course cards */
.q-course-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:480px){.q-course-grid{grid-template-columns:1fr;}}
.q-course-card{cursor:pointer;display:block;}
.q-course-card input{display:none;}
.q-course-img-wrap{position:relative;height:120px;overflow:hidden;border-radius:12px 12px 0 0;}
.q-course-img{width:100%;height:100%;object-fit:cover;transition:transform 6s ease;}
.q-course-card:hover .q-course-img{transform:scale(1.05);}
.q-course-img-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,26,14,0.85) 0%,transparent 60%);}
.q-must-badge{position:absolute;top:8px;left:8px;font-size:9px;background:rgba(232,168,80,0.92);color:#0d1a0e;padding:3px 8px;border-radius:100px;font-weight:700;letter-spacing:.04em;}
.q-course-check-icon{position:absolute;top:8px;right:8px;width:22px;height:22px;border-radius:50%;background:#e8a850;color:#0d1a0e;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;opacity:0;transition:opacity .2s;}
.q-course-card:has(input:checked) .q-course-check-icon{opacity:1;}
.q-course-card:has(input:checked) .q-course-img-wrap{box-shadow:0 0 0 2px #e8a850;}
.q-course-info{padding:10px 12px 12px;background:rgba(240,248,242,0.03);border:1px solid rgba(240,248,242,0.07);border-top:none;border-radius:0 0 12px 12px;transition:all .2s;}
.q-course-card:has(input:checked) .q-course-info{background:rgba(232,168,80,0.06);border-color:rgba(232,168,80,0.2);}
.q-course-accolade{font-size:9px;color:#e8a850;text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px;font-weight:600;}
.q-course-name{font-family:'Playfair Display',serif;font-size:13px;color:#f0f8f2;margin-bottom:3px;}
.q-course-stats{font-size:10px;color:rgba(240,248,242,0.28);line-height:1.5;}
/* lodge any */
.q-lodge-any{display:block;cursor:pointer;margin-bottom:10px;}
.q-lodge-any input{display:none;}
.q-lodge-any-inner{display:flex;align-items:center;gap:14px;padding:13px 16px;border-radius:12px;border:1px solid rgba(240,248,242,0.08);background:rgba(240,248,242,0.02);transition:all .2s;}
.q-lodge-any:has(input:checked) .q-lodge-any-inner{border-color:rgba(232,168,80,0.25);background:rgba(232,168,80,0.06);}
.q-lodge-any-check{margin-left:auto;width:22px;height:22px;border-radius:50%;background:#e8a850;color:#0d1a0e;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;opacity:0;transition:opacity .2s;}
.q-lodge-any:has(input:checked) .q-lodge-any-check{opacity:1;}
/* lodge cards */
.q-lodge-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;transition:opacity .2s;}
@media(max-width:480px){.q-lodge-grid{grid-template-columns:1fr;}}
.q-lodge-card{cursor:pointer;display:block;}
.q-lodge-card input{display:none;}
.q-lodge-img-wrap{position:relative;height:100px;overflow:hidden;border-radius:12px 12px 0 0;}
.q-lodge-img{width:100%;height:100%;object-fit:cover;transition:transform 6s ease;}
.q-lodge-card:hover .q-lodge-img{transform:scale(1.05);}
.q-lodge-img-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,26,14,0.8) 0%,transparent 60%);}
.q-lodge-check-icon{position:absolute;top:8px;right:8px;width:22px;height:22px;border-radius:50%;background:#e8a850;color:#0d1a0e;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;opacity:0;transition:opacity .2s;}
.q-lodge-card:has(input:checked) .q-lodge-check-icon{opacity:1;}
.q-lodge-card:has(input:checked) .q-lodge-img-wrap{box-shadow:0 0 0 2px #e8a850;}
.q-lodge-info{padding:10px 12px 12px;background:rgba(240,248,242,0.03);border:1px solid rgba(240,248,242,0.07);border-top:none;border-radius:0 0 12px 12px;transition:all .2s;}
.q-lodge-card:has(input:checked) .q-lodge-info{background:rgba(232,168,80,0.06);border-color:rgba(232,168,80,0.2);}
.q-lodge-best{font-size:9px;color:#e8a850;text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px;font-weight:600;}
.q-lodge-name{font-family:'Playfair Display',serif;font-size:13px;color:#f0f8f2;margin-bottom:3px;}
.q-lodge-desc{font-size:10px;color:rgba(240,248,242,0.28);line-height:1.5;}
/* submit */
.q-submit-row{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:28px 32px;border-top:1px solid rgba(240,248,242,0.06);flex-wrap:wrap;}
.q-submit-left{flex:1;min-width:160px;}
.q-btn-submit{background:#e8a850;color:#0d1a0e;font-size:15px;font-weight:700;padding:15px 36px;border-radius:100px;cursor:pointer;border:none;transition:all .25s;box-shadow:0 4px 20px rgba(232,168,80,0.25);font-family:'Inter',sans-serif;white-space:nowrap;}
.q-btn-submit:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(232,168,80,0.4);}
.q-btn-submit:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.q-btn-back{background:rgba(240,248,242,0.05);border:1px solid rgba(240,248,242,0.1);color:rgba(240,248,242,0.5);font-size:13px;padding:11px 22px;border-radius:100px;cursor:pointer;transition:all .2s;font-family:'Inter',sans-serif;}
.q-btn-back:hover{background:rgba(240,248,242,0.09);}
.q-error{margin:0 32px 16px;padding:12px 16px;border-radius:10px;background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2);color:#f87171;font-size:13px;}
</style>

<script define:vars={{ preselected }}>
const form = document.getElementById('qf');
const $id  = id => document.getElementById(id);

// auto-calc nights
function calcNights() {
  const a = $id('arrival-date')?.value, d = $id('departure-date')?.value;
  if (a && d && d > a) {
    const n = Math.round((new Date(d) - new Date(a)) / 86400000);
    const nn = $id('num-nights');
    if (nn) nn.value = n;
  }
  updateSummary();
}
$id('arrival-date')?.addEventListener('change', calcNights);
$id('departure-date')?.addEventListener('change', calcNights);

// other rounds
document.querySelectorAll('[name="totalRounds"]').forEach(r => {
  r.addEventListener('change', () => {
    $id('rounds-other-wrap').style.display = r.value === 'other' ? 'flex' : 'none';
    updateSummary();
  });
});

// event type conditional
document.querySelectorAll('[name="eventType"]').forEach(r => {
  r.addEventListener('change', () => {
    $id('event-detail-wrap').style.display =
      ['birthday','bachelor','corporate','anniversary','other'].includes(r.value) ? 'flex' : 'none';
  });
});

// lodge-any dims grid
$id('lodge-any')?.addEventListener('change', function() {
  const grid = $id('lodge-grid');
  grid.style.opacity = this.checked ? '0.35' : '1';
  grid.style.pointerEvents = this.checked ? 'none' : 'auto';
  updateSummary();
});

// live summary
function fv(name) {
  const el = form.querySelector(`[name="${name}"]:checked`);
  return el ? el.value : (form.querySelector(`[name="${name}"]`)?.value || null);
}

function updateSummary() {
  const lines = [];
  const arrive = $id('arrival-date')?.value;
  const depart  = $id('departure-date')?.value;
  const party   = $id('party-size')?.value;
  const rounds  = fv('totalRounds');
  const budget  = fv('budgetTier');
  const skill   = fv('skillLevel');
  const tee     = fv('idealTeeTimes');
  const courses = [...form.querySelectorAll('[name="coursesInterested"]:checked')].map(c => c.value);
  const lodge   = [...form.querySelectorAll('[name="lodgingInterested"]:checked')].map(l => l.value);

  const fmt = d => { if (!d) return ''; const [y,m,day] = d.split('-'); return `${m}/${day}/${y.slice(2)}`; };

  if (arrive && depart && depart > arrive) lines.push({ icon:'📅', text:`${fmt(arrive)} → ${fmt(depart)}` });
  if (party && party > 0)   lines.push({ icon:'👥', text:`${party} golfer${party > 1 ? 's' : ''}` });
  if (rounds && rounds !== 'other') lines.push({ icon:'⛳', text:`${rounds} round${rounds > 1 ? 's' : ''}` });
  if (budget) lines.push({ icon:'💰', text:`${'$'.repeat(budget==='budget'?2:budget==='mid'?3:4)} tier` });
  if (skill)  lines.push({ icon:'🎯', text:`${skill}` });
  if (tee)    lines.push({ icon:'⏰', text:`Tee: ${tee}` });
  if (courses.length) lines.push({ icon:'🏌', text:`${courses.length} course${courses.length > 1 ? 's' : ''} selected` });
  if (lodge.length)   lines.push({ icon:'🏨', text:`${lodge.length} lodging option${lodge.length > 1 ? 's' : ''} selected` });

  const summary = $id('trip-summary');
  const summaryLines = $id('summary-lines');
  const staticBenefits = $id('static-benefits');

  if (lines.length > 0) {
    summaryLines.innerHTML = lines.map(l =>
      `<div class="q-sum-line"><span>${l.icon}</span><span>${l.text}</span></div>`
    ).join('');
    summary.style.display = 'block';
    staticBenefits.style.display = lines.length > 3 ? 'none' : '';
  } else {
    summary.style.display = 'none';
    staticBenefits.style.display = '';
  }
}

form.addEventListener('change', updateSummary);
form.addEventListener('input', updateSummary);

// validate required fields
function validate() {
  let ok = true;
  form.querySelectorAll('[required]').forEach(el => {
    el.classList.remove('invalid');
    if (!el.value.trim()) { el.classList.add('invalid'); ok = false; }
  });
  const a = $id('arrival-date')?.value, d = $id('departure-date')?.value;
  if (a && d && d <= a) {
    $id('departure-date').classList.add('invalid');
    ok = false;
  }
  return ok;
}

// submit
form.addEventListener('submit', async e => {
  e.preventDefault();
  if (!validate()) {
    const err = $id('q-error');
    err.textContent = 'Please fill in all required fields (First Name, Last Name, Email, Phone, Arrival Date, Departure Date, Group Size).';
    err.style.display = 'block';
    // scroll to first invalid
    const first = form.querySelector('.invalid');
    if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
    return;
  }

  const btn = $id('q-submit');
  btn.textContent = 'Sending…';
  btn.disabled = true;
  $id('q-error').style.display = 'none';

  const data = Object.fromEntries(new FormData(form));
  data.coursesInterested = [...form.querySelectorAll('[name="coursesInterested"]:checked')].map(c => c.value);
  data.lodgingInterested = [...form.querySelectorAll('[name="lodgingInterested"]:checked')].map(l => l.value);
  data.destination  = 'graeagle';
  data.source       = 'golfgraeagle.com';
  data.submittedAt  = new Date().toISOString();
  if (data.totalRounds === 'other' && data.totalRoundsCustom) data.totalRounds = data.totalRoundsCustom;

  try {
    const res = await fetch('/api/leads', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
    });
    if (!res.ok) throw new Error(await res.text());
    form.style.display = 'none';
    $id('q-success').style.display = 'block';
    $id('s-name').textContent  = data.firstName || 'there';
    $id('s-email').textContent = data.email || '';
  } catch {
    const err = $id('q-error');
    err.textContent = 'Something went wrong. Please try again or email mike.eskuchen@golfthehighsierra.com.';
    err.style.display = 'block';
    btn.textContent = 'Send My Quote Request →';
    btn.disabled = false;
  }
});

// reset
$id('q-reset').addEventListener('click', () => {
  form.reset();
  $id('q-success').style.display = 'none';
  form.style.display = 'block';
  $id('q-error').style.display = 'none';
  updateSummary();
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

// pre-check URL param
if (preselected) {
  const cb = form.querySelector(`input[value="${preselected}"]`);
  if (cb) cb.checked = true;
}

updateSummary();
</script>
