    <button id="lb-next" onclick="lbNav(1)" style="position:fixed;right:16px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:white;font-size:28px;cursor:pointer;z-index:10001;width:52px;height:52px;border-radius:50%;">&#8250;</button>
    <div id="lb-counter" style="position:fixed;bottom:20px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.5);font-size:13px;letter-spacing:0.1em;"></div>
  </div>

  <style>
    #lb.open { display:flex !important; }
    .gallery-btn:hover img { transform:scale(1.05); }
    .gallery-btn:hover .gal-ov { background:rgba(0,0,0,0.35) !important; }
    .gallery-btn:hover .gal-ov svg { opacity:1 !important; }
    #lb-prev:hover, #lb-next:hover { background:rgba(255,255,255,0.2) !important; }
  </style>

  <script>
    let lbSrcs = [], lbIdx = 0;
    let touchStartX = 0, touchStartY = 0;

    function lbOpen(srcs, idx) {
      lbSrcs = srcs; lbIdx = idx;
      document.getElementById('lb').classList.add('open');
      document.body.style.overflow = 'hidden';
      lbShow();
    }
    function lbClose() {
      document.getElementById('lb').classList.remove('open');
      document.body.style.overflow = '';
    }
    function lbNav(dir) {
      lbIdx = (lbIdx + dir + lbSrcs.length) % lbSrcs.length;
      lbShow();
    }
    function lbShow() {
      const img = document.getElementById('lb-img');
      img.style.opacity = '0';
      setTimeout(() => { img.src = lbSrcs[lbIdx]; img.style.opacity = '1'; }, 150);
      document.getElementById('lb-counter').textContent = (lbIdx + 1) + ' / ' + lbSrcs.length;
      document.getElementById('lb-prev').style.display = lbSrcs.length > 1 ? '' : 'none';
      document.getElementById('lb-next').style.display = lbSrcs.length > 1 ? '' : 'none';
    }

    document.addEventListener('DOMContentLoaded', () => {
      const btns = Array.from(document.querySelectorAll('.gallery-btn'));
      if (!btns.length) return;
      const allSrcs = btns.map(b => b.dataset.src);
      btns.forEach((btn, i) => btn.addEventListener('click', () => lbOpen(allSrcs, i)));

      // Keyboard nav
      document.addEventListener('keydown', e => {
        if (!document.getElementById('lb').classList.contains('open')) return;
        if (e.key === 'Escape') lbClose();
        if (e.key === 'ArrowRight') lbNav(1);
        if (e.key === 'ArrowLeft') lbNav(-1);
      });

      // Click backdrop to close
      document.getElementById('lb').addEventListener('click', e => {
        if (e.target.id === 'lb') lbClose();
      });

      // Touch/swipe support for mobile
      const lb = document.getElementById('lb');
      lb.addEventListener('touchstart', e => {
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
      }, { passive: true });

      lb.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].screenX - touchStartX;
        const dy = e.changedTouches[0].screenY - touchStartY;
        // Only trigger if horizontal swipe > 50px and more horizontal than vertical
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
          lbNav(dx < 0 ? 1 : -1);
        } else if (Math.abs(dy) > 80 && dy > 0) {
          // Swipe down to close
          lbClose();
        }
      }, { passive: true });
    });
  </script>
</Base>
