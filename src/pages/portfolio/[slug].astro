  <div id="lb" style="position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.93);align-items:center;justify-content:center;display:none;">
    <button onclick="lbClose()" style="position:fixed;top:20px;right:24px;background:none;border:none;color:white;font-size:36px;cursor:pointer;z-index:10001;line-height:1;opacity:0.7;">&times;</button>
