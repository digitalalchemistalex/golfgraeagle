---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RelatedTrips from '../../components/RelatedTrips.tsx';
import Testimonials from '../../components/Testimonials.tsx';
import { courses, lodging, dining, siteConfig, courseToLodging, lodgingToCourses, imageAlts } from '../../data/content.js';

// Helper: get descriptive SEO alt text for any image URL
function getImgAlt(src, fallback) {
  const filename = src.split('/').pop().split('?')[0];
  return imageAlts[filename] || fallback;
}

// ── Fetch TripsCaddie data at build time for dynamic schema + reviews ──────
let allTrips = [];
try {
  const tripsRes = await fetch('https://golfthehighsierra.com/trips-caddie/api/api-recaps.php');
  allTrips = await tripsRes.json();
} catch (e) {
  // Fallback to empty — static reviews below will still work
  allTrips = [];
}

// Filter Graeagle trips with real content
const graeagleTrips = allTrips.filter((t: any) =>
  (t.region || '').toLowerCase() === 'graeagle' &&
  (t.synopsis || t.highlights?.length)
);

// Build course review map from live API data
const COURSE_NAME_MAP: Record<string, string[]> = {
  'graeagle-meadows':  ['Graeagle Meadows', 'Graeagle Meadows Golf Course'],
  'whitehawk-ranch':   ['Whitehawk Ranch', 'Whitehawk Ranch Golf Course', 'Whitehawk Ranch Golf Club'],
  'plumas-pines':      ['Plumas Pines', 'Plumas Pines Golf Resort'],
  'grizzly-ranch':     ['Grizzly Ranch', 'Grizzly Ranch Golf Club'],
  'nakoma-dragon':     ['Nakoma', 'Dragon', 'Nakoma Dragon', 'The Dragon'],
};
const LODGING_NAME_MAP: Record<string, string[]> = {
  'river-pines-resort':        ['River Pines Resort', 'River Pines'],
  'chalet-view-lodge':         ['Chalet View Lodge', 'Chalet View'],
  'inn-at-nakoma':             ['The Inn at Nakoma', 'Inn at Nakoma', 'Nakoma Resort'],
  'townhomes-at-plumas-pines': ['Townhomes at Plumas Pines', 'Plumas Pines Townhomes'],
};

// Vibe → star rating (same logic as Testimonials.tsx)
function deriveStarsFromTrip(trip: any): number {
  const vibe = (trip.vibe || '').toLowerCase();
  if (vibe === 'premium' || vibe === 'bucket list') return 5;
  return 4;
}

// Get best quote from trip
const OPERATOR_PATTERNS = [
  /^great graeagle trip/i, /^you just have to experience/i,
  /^this group was a la carte/i, /^the package offered/i,
  /^groups coming in from northern california/i, /^if you're looking for an inexpensive/i,
];
function getBestQuote(trip: any): string {
  const candidates = [trip.synopsis, ...(trip.highlights || []), trip.whyItWorked].filter(Boolean);
  const clean = candidates.find((s: string) => !OPERATOR_PATTERNS.some(p => p.test(s.trim())));
  if (!clean) return '';
  return clean.length > 200 ? clean.slice(0, 197) + '…' : clean;
}

// Build live review lists per slug
function getLiveReviews(slug: string, nameMap: Record<string, string[]>): any[] {
  const names = nameMap[slug] || [];
  if (!names.length) return [];
  return graeagleTrips
    .filter((t: any) => {
      const allText = [...(t.courses || []), t.lodging || ''].join(' ').toLowerCase();
      return names.some((n: string) => allText.includes(n.toLowerCase()));
    })
    .sort((a: any, b: any) => {
      // Premium first, then by group size
      const aScore = (a.vibe?.toLowerCase() === 'premium' ? 1000 : 0) + (a.groupSize || 0);
      const bScore = (b.vibe?.toLowerCase() === 'premium' ? 1000 : 0) + (b.groupSize || 0);
      return bScore - aScore;
    })
    .slice(0, 5)
    .map((t: any) => ({
      author: t.groupName || 'Golf Group',
      pax: t.groupSize,
      stars: deriveStarsFromTrip(t),
      body: getBestQuote(t),
      when: [t.month, t.year].filter(Boolean).join(' ') || '2025',
    }))
    .filter((r: any) => r.body); // Only include reviews with actual content
}


// Map WP portfolio slugs → our data
const wpSlugMap = {
  // Courses
  'graeagle-meadows-golf-packages': { type: 'course', data: courses.find(c => c.slug === 'graeagle-meadows') },
  'whitehawk-ranch-golf-packages':  { type: 'course', data: courses.find(c => c.slug === 'whitehawk-ranch') },
  'plumas-pines-golf-packages':     { type: 'course', data: courses.find(c => c.slug === 'plumas-pines') },
  'grizzly-ranch-golf-packages':    { type: 'course', data: courses.find(c => c.slug === 'grizzly-ranch') },
  'nakoma-dragon-golf-packages':    { type: 'course', data: courses.find(c => c.slug === 'nakoma-dragon') },
  // Also handle the /portfolio/plumas-pines-golf-resort/ style from search results
  'plumas-pines-golf-resort':       { type: 'course', data: courses.find(c => c.slug === 'plumas-pines') },
  'graeagle-meadows-golf-course':   { type: 'course', data: courses.find(c => c.slug === 'graeagle-meadows') },
  'whitehawk-ranch-golf-course':    { type: 'course', data: courses.find(c => c.slug === 'whitehawk-ranch') },
  'grizzly-ranch-golf-club':        { type: 'course', data: courses.find(c => c.slug === 'grizzly-ranch') },
  // Lodging
  'river-pines-resort-graeagle-ca': { type: 'lodging', data: lodging.find(l => l.slug === 'river-pines-resort') },
  'chalet-view-lodge-graeagle-ca':  { type: 'lodging', data: lodging.find(l => l.slug === 'chalet-view-lodge') },
  'the-inn-at-nakoma-clio-ca':      { type: 'lodging', data: lodging.find(l => l.slug === 'inn-at-nakoma') },
  'the-townhomes-at-plumas-pines':  { type: 'lodging', data: lodging.find(l => l.slug === 'townhomes-at-plumas-pines') },
  // Dining
  'longboards-bar-and-grill':       { type: 'dining', data: dining.find(d => d.slug === 'longboards') },
  'sardine-lake-resort':            { type: 'dining', data: dining.find(d => d.slug === 'sardine-lake') },
  'iron-door-restaurant':           { type: 'dining', data: dining.find(d => d.slug === 'iron-door') },
  'grizzly-grill':                  { type: 'dining', data: dining.find(d => d.slug === 'grizzly-grill') },
  'roadhouse-at-river-pines':       { type: 'dining', data: dining.find(d => d.slug === 'roadhouse') },
  'graeagle-meadows-golf-course-restaurant': { type: 'dining', data: dining.find(d => d.slug === 'meadows-restaurant') },
  'cuccias':                        { type: 'dining', data: dining.find(d => d.slug === 'cuccias') },
  'sierra-smokeshow':               { type: 'dining', data: dining.find(d => d.slug === 'sierra-smokeshow') },
  'gumbas-ii-go':                   { type: 'dining', data: dining.find(d => d.slug === 'gumbas') },
  'eureka-peak-brewing-co':         { type: 'dining', data: dining.find(d => d.slug === 'eureka-peak-brewing') },
  'the-brewing-lair':               { type: 'dining', data: dining.find(d => d.slug === 'brewing-lair') },
  'mohawk-tavern':                  { type: 'dining', data: dining.find(d => d.slug === 'mohawk-tavern') },
  'the-knotty-pine-tavern':         { type: 'dining', data: dining.find(d => d.slug === 'knotty-pine') },
  'little-bite-deli':               { type: 'dining', data: dining.find(d => d.slug === 'little-bite-deli') },
  'graeagle-mountain-frostee':      { type: 'dining', data: dining.find(d => d.slug === 'mountain-frostee') },
  'graeagle-restaurant':            { type: 'dining', data: dining.find(d => d.slug === 'graeagle-restaurant') },
};

export function getStaticPaths() {
  return Object.keys({
  'graeagle-meadows-golf-packages': 1,'whitehawk-ranch-golf-packages':1,'plumas-pines-golf-packages':1,
  'grizzly-ranch-golf-packages':1,'nakoma-dragon-golf-packages':1,'plumas-pines-golf-resort':1,
  'graeagle-meadows-golf-course':1,'whitehawk-ranch-golf-course':1,'grizzly-ranch-golf-club':1,
  'river-pines-resort-graeagle-ca':1,'chalet-view-lodge-graeagle-ca':1,'the-inn-at-nakoma-clio-ca':1,
  'the-townhomes-at-plumas-pines':1,'longboards-bar-and-grill':1,'sardine-lake-resort':1,
  'iron-door-restaurant':1,'grizzly-grill':1,'roadhouse-at-river-pines':1,
  'graeagle-meadows-golf-course-restaurant':1,'cuccias':1,'sierra-smokeshow':1,'gumbas-ii-go':1,
  'eureka-peak-brewing-co':1,'the-brewing-lair':1,'mohawk-tavern':1,'the-knotty-pine-tavern':1,
  'little-bite-deli':1,'graeagle-mountain-frostee':1,'graeagle-restaurant':1,
  }).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const entry = wpSlugMap[slug];
const item = entry?.data;
const type = entry?.type;
const c = item; // alias for rich course template compatibility
const pageUrl = `${siteConfig.url}/portfolio/${slug}`;

// ── Titles — upgraded with accolades, location, and intent keywords ────────────
const wpTitles: Record<string, string> = {
  // Course pages — accolade + location + intent
  'graeagle-meadows-golf-packages':   'Graeagle Meadows Golf Course — Tee Times & Stay and Play Packages | Graeagle, CA',
  'whitehawk-ranch-golf-packages':    'Whitehawk Ranch Golf Course — Top 20 California | Tee Times & Packages | Graeagle, CA',
  'plumas-pines-golf-packages':       'Plumas Pines Golf Resort — Best Value Sierra Nevada | Tee Times & Stay and Play | Graeagle, CA',
  'grizzly-ranch-golf-packages':      'Grizzly Ranch Golf Club — Golf Digest Top 100 | Tee Times & Stay and Play | Graeagle, CA',
  'nakoma-dragon-golf-packages':      'Nakoma Dragon Golf Course — Frank Lloyd Wright Clubhouse | Golf World Top 75 | Graeagle, CA',
  // Lodging pages
  'river-pines-resort-graeagle-ca':   'River Pines Resort Graeagle — Golf Lodging & Stay and Play Packages',
  'chalet-view-lodge-graeagle-ca':    'Chalet View Lodge Graeagle — Golf Lodging & Stay and Play Packages',
  'the-inn-at-nakoma-clio-ca':        'Inn at Nakoma — Frank Lloyd Wright Resort | Golf Stay and Play | Clio, CA',
  'the-townhomes-at-plumas-pines':    'Townhomes at Plumas Pines — On-Course Golf Lodging | Graeagle, CA',
  // Dining pages
  'grizzly-grill':                    'Grizzly Grill — Gourmet Dining in Plumas National Forest | Graeagle, CA',
  'iron-door-restaurant':             'Iron Door Restaurant — Historic Steakhouse Since 1961 | Graeagle, CA',
  'roadhouse-at-river-pines':         'Roadhouse at River Pines — Steaks & Whisky | Après-Golf Dining | Graeagle, CA',
  'the-brewing-lair':                 'The Brewing Lair — Craft Brewery & Après-Golf Bar | Graeagle, CA',
  'eureka-peak-brewing-co':           'Eureka Peak Brewing Co. — Craft Beer at Chalet View Lodge | Graeagle, CA',
  'gumbas-ii-go':                     "Gumba's II Go — Pizza & Italian To-Go | Graeagle Golf Groups",
  'sierra-smokeshow':                 'Sierra SmokeShow — BBQ Ribs & Brisket Near Graeagle Golf Courses',
  'little-bite-deli':                 'Little Bite Deli — Fresh Sandwiches & Salads on Hwy 89 | Blairsden, CA',
  'graeagle-restaurant':              'Graeagle Restaurant — Family-Owned Café Since 1958 | Graeagle, CA',
  'graeagle-meadows-golf-course-restaurant': 'Graeagle Meadows Golf Course Restaurant — Clubhouse Dining | Graeagle, CA',
};
const pageTitle = wpTitles[slug] || (item ? `${item.name} | GolfGraeagle.com` : `${slug} | GolfGraeagle.com`);

// ── Meta descriptions — upgraded with accolades, differentiators, price/intent ─
const wpDescs: Record<string, string> = {
  // Course pages — accolade first, then intent, then CTA
  'graeagle-meadows-golf-packages':   'Graeagle Meadows Golf Course — par 72, slope 120, designed by Ellis Van Gorder (1968). The most accessible championship course in the valley with mountain views and the famous "English Gold" signature hole. Stay-and-play packages from $299/golfer.',
  'whitehawk-ranch-golf-packages':    'Whitehawk Ranch Golf Course — Top 20 Golf Courses in California (1998). Par 71, slope 132. 550 acres of Mohawk Valley meadows and forested hillsides. The crowd favourite in Graeagle. Stay-and-play packages with guaranteed tee times.',
  'plumas-pines-golf-packages':       'Plumas Pines Golf Resort — Top 5 Best Values in the Sierra Nevada (California Golf + Travel). Par 72, slope 132, designed by Homer Flint. Tight pines, small greens, on-course townhome lodging. Stay-and-play packages from $299/golfer.',
  'grizzly-ranch-golf-packages':      'Grizzly Ranch Golf Club — Golf Digest Top 100 Greatest Public Courses in the US (2021). Par 72, 7,411 yards, slope 140 at 4,800–5,400 ft elevation. Designed by Bob Cupp. Guaranteed tee times via GolfGraeagle stay-and-play packages.',
  'nakoma-dragon-golf-packages':      'Nakoma Dragon Golf Course — Golf World Top 75 at debut. Par 72, slope 147. The only golf clubhouse in the world designed by Frank Lloyd Wright. Designed by Robin Nelson. Stay-and-play packages with Inn at Nakoma lodging.',
  // Lodging pages
  'river-pines-resort-graeagle-ca':   'River Pines Resort — family-owned 40+ years, Graeagle CA. Cabins, suites, and rooms in one property. Pool, hot tub, The Roadhouse on-site. Best base for golf groups of 8–60. Stay-and-play packages from $299/golfer.',
  'chalet-view-lodge-graeagle-ca':    'Chalet View Lodge — 10 forested acres in Graeagle. Lodge rooms, terrace suites, and private cabins. Spa, 9-hole executive course, Eureka Peak Brewing on-site. Stay-and-play golf packages with tee times at all 5 courses.',
  'the-inn-at-nakoma-clio-ca':        'Inn at Nakoma — 42 rooms in the Frank Lloyd Wright-designed FLW Lodge. Steps from The Dragon golf course. Frette linens, heated pool, Fifty44 Restaurant & Bar on-site. Golf stay-and-play packages from $299/golfer.',
  'the-townhomes-at-plumas-pines':    'Townhomes at Plumas Pines — 2–4 bedroom units directly adjacent to Plumas Pines Golf Resort. Full kitchens, private decks with fairway views, pools and tennis on-site. Best on-course lodging in Graeagle for groups.',
  // Dining pages
  'grizzly-grill':                    'Grizzly Grill — gourmet dining at 4,800 ft in the Plumas National Forest. Stone hearth, exposed beams, local Sierra game and produce. Full bar. Off Hwy 70, 5 minutes from Graeagle. The dinner choice for a serious group trip.',
  'roadhouse-at-river-pines':         'Roadhouse at River Pines — steaks, ribs, and whisky flights just off Hwy 70. Connected to River Pines Resort. The easiest group dinner in Graeagle — on-site if you\'re staying at River Pines.',
  'the-brewing-lair':                 'The Brewing Lair — 15-acre craft brewery in the Sierra forest off Hwy 70. Après-golf drinks, lawn games, outdoor seating. The first-night Graeagle tradition for golf groups.',
  'eureka-peak-brewing-co':           'Eureka Peak Brewing Co. — IPAs, stouts, and saisons inside Chalet View Lodge. Locally sourced seasonal dishes, timber-framed setting. The more intimate après-golf alternative to The Brewing Lair.',
  'gumbas-ii-go':                     "Gumba's II Go — hand-tossed pizza, oven-baked subs, pasta, and salads in Graeagle. Fast, group-friendly, easy pick-up after a long day on the course.",
  'sierra-smokeshow':                 'Sierra SmokeShow — baby back ribs, brisket, and pork shoulder smoked over hickory and applewood. Blairsden-Graeagle gateway. The casual group dinner between tee times.',
  'little-bite-deli':                 'Little Bite Deli — fresh sandwiches and salads on Highway 89. The local lunch spot between rounds. Fast, affordable, and exactly what you need between Whitehawk and Grizzly Ranch.',
  'graeagle-restaurant':              'Graeagle Restaurant — family-owned since 1958 in the historic Box Factory Mill. Breakfast, lunch, and homemade pies. Three generations, one of the most beloved spots in the valley.',
  'graeagle-meadows-golf-course-restaurant': 'Graeagle Meadows Golf Course Restaurant — clubhouse dining with fairway and mountain views. Seasonal menus, warm hospitality. The natural first or last meal of your Graeagle golf trip.',
};
const pageDesc = wpDescs[slug] || item?.description || item?.tagline || `Graeagle golf packages for ${item?.name || slug}.`;

// ── Schema per page type ──────────────────────────────────────────────────────
const buildSchema = () => {
  if (!item) return null;

  const breadcrumb = {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: type === 'course' ? 'Golf Courses' : type === 'lodging' ? 'Lodging' : 'Dining', item: `${siteConfig.url}/${type === 'course' ? 'all-golf-courses' : type}` },
      { '@type': 'ListItem', position: 3, name: item.name, item: pageUrl },
    ],
  };

  if (type === 'course') {
    // Static reviews baked from known TripsCaddie data — crawlable by Google/AI without JS
    const courseReviews: Record<string, any[]> = {
      'graeagle-meadows': [
        { author: 'Graeagle River Pines Golf Group', pax: 24, stars: 4, body: 'Graeagle Meadows was a great opener for our group — beautiful mountain views and manageable for all skill levels. We paired it with Whitehawk and Plumas Pines over 2 nights.', when: 'September 2025' },
        { author: 'Graeagle Quick Hitter Group', pax: 8, stars: 4, body: 'Three courses in two nights — Meadows was the perfect fast-playing addition. Signature hole views are genuinely stunning.', when: 'June 2025' },
      ],
      'whitehawk-ranch': [
        { author: 'Graeagle-Buckets Golf Trip', pax: 24, stars: 5, body: 'Whitehawk Ranch was the highlight of a 4-course trip. The meadow-to-forest layout is unlike anything else in the valley. We played it twice.', when: 'July 2025' },
        { author: 'River Pines Golf Package', pax: 52, stars: 5, body: 'Whitehawk Ranch handled our 52-person group flawlessly. Staggered tee times, great pace of play. The entire group wants to return.', when: 'June 2025' },
        { author: 'Plumas Pines Golf Group', pax: 36, stars: 5, body: '36 holes at Whitehawk in one day — demanding but worth every step. Top 20 California for good reason.', when: 'July 2024' },
      ],
      'plumas-pines': [
        { author: 'Graeagle Golf Trip', pax: 12, stars: 4, body: 'Best value course in Graeagle. Tight pines, small greens — you can\'t muscle your way through it. Stayed in the townhomes right on the course.', when: 'July 2025' },
        { author: 'River Pines Golf Package', pax: 52, stars: 4, body: 'Plumas Pines was smooth to coordinate for a large group. Fast-playing, great staff, excellent value.', when: 'June 2025' },
      ],
      'grizzly-ranch': [
        { author: 'Graeagle-Buckets Golf Trip', pax: 24, stars: 5, body: 'Golf Digest Top 100 is no exaggeration. Grizzly Ranch is the most demanding and most rewarding round in Graeagle. The ridgeline holes are unforgettable.', when: 'July 2025' },
        { author: 'Plumas Pines Golf Group', pax: 36, stars: 5, body: 'Grizzly Ranch set the tone for the whole trip. 36 players, early morning tee times, everyone was talking about it at dinner.', when: 'July 2024' },
        { author: 'Graeagle Golf Trip', pax: 30, stars: 5, body: 'Three nights, three courses — Grizzly Ranch was the unanimous group favorite. Slope 140 at elevation is a real test.', when: 'June 2026' },
      ],
      'nakoma-dragon': [
        { author: 'Graeagle-Buckets Golf Trip', pax: 24, stars: 5, body: 'The Dragon was the bucket list round. The Frank Lloyd Wright clubhouse alone is worth the trip — then you play a slope 147 course with that as your starting point.', when: 'July 2025' },
        { author: 'Graeagle Golf Trip', pax: 16, stars: 5, body: 'Nakoma Dragon exceeded every expectation. We spent 20 minutes in the clubhouse before teeing off. Hardest course we\'ve played. Best experience we\'ve had.', when: 'June 2026' },
      ],
    };
    const reviews = courseReviews[item.slug] || [];
    return [
      {
        '@type': 'GolfCourse',
        '@id': `${pageUrl}#golfcourse`,
        name: `${item.name} Golf Course`,
        description: item.description,
        url: pageUrl,
        numberOfHoles: 18,
        address: { '@type': 'PostalAddress', streetAddress: item.address, addressRegion: 'CA', addressCountry: 'US' },
        geo: item.coordinates ? { '@type': 'GeoCoordinates', latitude: item.coordinates?.lat, longitude: item.coordinates?.lng } : undefined,
        designer: { '@type': 'Person', name: item.designer },
        dateCreated: `${item.year}`,
        image: item.hero,
        amenityFeature: item.highlights?.map((h: string) => ({ '@type': 'LocationFeatureSpecification', name: h, value: true })),
        potentialAction: { '@type': 'ReserveAction', target: { '@type': 'EntryPoint', urlTemplate: `${siteConfig.url}/request-a-quote` } },
        ...(reviews.length > 0 && {
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: (reviews.reduce((s: number, r: any) => s + r.stars, 0) / reviews.length).toFixed(1),
            reviewCount: reviews.length,
            bestRating: 5,
            worstRating: 4,
            description: 'Group trip ratings from verified GolfGraeagle.com bookings',
          },
          review: reviews.map((r: any) => ({
            '@type': 'Review',
            author: { '@type': 'Organization', name: r.author },
            reviewRating: { '@type': 'Rating', ratingValue: r.stars, bestRating: 5 },
            reviewBody: r.body,
            datePublished: r.when,
          })),
        }),
      },
      breadcrumb,
      {
        '@type': 'FAQPage',
        mainEntity: (item.faqs && item.faqs.length > 0)
          ? item.faqs.map((f: any) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
          : [
            { '@type': 'Question', name: `How do I book a tee time at ${item.name}?`, acceptedAnswer: { '@type': 'Answer', text: `GolfGraeagle.com handles all ${item.name} tee time bookings as part of stay-and-play packages. Request a free quote at golfgraeagle.com/request-a-quote and we'll coordinate everything.` } },
            { '@type': 'Question', name: `What is the slope rating at ${item.name}?`, acceptedAnswer: { '@type': 'Answer', text: `${item.name} has a slope rating of ${item.slope} and a course rating of ${item.rating}, playing ${item.yards?.toLocaleString()} yards from the back tees at par ${item.par}.` } },
            { '@type': 'Question', name: `Who designed ${item.name}?`, acceptedAnswer: { '@type': 'Answer', text: `${item.name} was designed by ${item.designer} and opened in ${item.year}.` } },
          ],
      },
    ];
  }

  if (type === 'lodging') {
    const lodgingReviews: Record<string, any[]> = {
      'river-pines-resort': [
        { author: 'Graeagle River Pines Golf Group', pax: 24, stars: 4, body: 'River Pines Resort was the perfect base for our group of 24. One check-in, on-site dining at the Roadhouse, easy access to all 5 courses. Exactly what a golf group needs.', when: 'September 2025' },
        { author: 'River Pines Golf Package', pax: 52, stars: 5, body: 'We ran a 52-person golf event through River Pines. The staff handled the group block without a single hiccup. Banquet dinner was excellent. We\'ll be back next year.', when: 'June 2025' },
        { author: 'Graeagle Quick Hitter Group', pax: 8, stars: 4, body: 'Two nights, three rounds — River Pines made it seamless. Hot tub after 36 holes on day 2 was essential.', when: 'June 2025' },
      ],
      'chalet-view-lodge': [
        { author: 'Graeagle Golf Group', pax: 16, stars: 5, body: 'Chalet View Lodge is the hidden gem of Graeagle lodging. Eureka Peak Brewing on-site, spa services, 10 forested acres. Our group didn\'t want to leave.', when: 'August 2025' },
      ],
      'inn-at-nakoma': [
        { author: 'Graeagle-Buckets Golf Trip', pax: 24, stars: 5, body: 'Staying at the Inn at Nakoma and playing The Dragon is the definitive Graeagle bucket list experience. The FLW lodge, Fifty44 restaurant, heated pool — premium in every way.', when: 'July 2025' },
        { author: 'Graeagle Golf Trip', pax: 16, stars: 5, body: 'Frette linens, fireplace lobby, forest views — the Inn at Nakoma matched the quality of the golf perfectly. Dog-friendly too, which mattered to half our group.', when: 'June 2026' },
      ],
      'townhomes-at-plumas-pines': [
        { author: 'Graeagle Golf Trip', pax: 30, stars: 5, body: 'Private 3-bedroom townhomes — everyone got their own bedroom, full kitchen, golf course out the window. The right way to do a premium Graeagle group trip.', when: 'June 2026' },
        { author: 'Plumas Pines Golf Group', pax: 36, stars: 5, body: 'Townhomes at Plumas Pines made the whole trip cohesive. The group had a central gathering space, easy walking distance to the first tee, and no hotel lobby congestion.', when: 'July 2024' },
      ],
    };
    const reviews = lodgingReviews[item.slug] || [];
    return [
      {
        '@type': 'LodgingBusiness',
        '@id': `${pageUrl}#lodging`,
        name: item.name,
        description: item.description,
        url: pageUrl,
        image: item.hero,
        address: { '@type': 'PostalAddress', addressRegion: 'CA', addressCountry: 'US', addressLocality: 'Graeagle' },
        geo: item.coordinates ? { '@type': 'GeoCoordinates', latitude: item.coordinates.lat, longitude: item.coordinates.lng } : undefined,
        amenityFeature: item.highlights?.map((h: string) => ({ '@type': 'LocationFeatureSpecification', name: h, value: true })),
        priceRange: 'Contact for pricing',
        telephone: item.phone,
        potentialAction: { '@type': 'ReserveAction', target: { '@type': 'EntryPoint', urlTemplate: `${siteConfig.url}/request-a-quote` } },
        ...(reviews.length > 0 && {
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: (reviews.reduce((s: number, r: any) => s + r.stars, 0) / reviews.length).toFixed(1),
            reviewCount: reviews.length,
            bestRating: 5,
            worstRating: 4,
            description: 'Group trip ratings from verified GolfGraeagle.com bookings',
          },
          review: reviews.map((r: any) => ({
            '@type': 'Review',
            author: { '@type': 'Organization', name: r.author },
            reviewRating: { '@type': 'Rating', ratingValue: r.stars, bestRating: 5 },
            reviewBody: r.body,
            datePublished: r.when,
          })),
        }),
      },
      breadcrumb,
      {
        '@type': 'FAQPage',
        mainEntity: [
          { '@type': 'Question', name: `Is ${item.name} good for golf groups?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${item.name} is ${item.distanceFromGraeagle} and is paired with tee times at all 5 Graeagle championship courses by GolfGraeagle.com. Contact GolfGraeagle.com for current package pricing.` } },
          { '@type': 'Question', name: `How far is ${item.name} from the golf courses?`, acceptedAnswer: { '@type': 'Answer', text: `${item.name} is ${item.distanceFromGraeagle}. All 5 Graeagle courses — Graeagle Meadows, Whitehawk Ranch, Plumas Pines, Grizzly Ranch, and Nakoma (The Dragon) — are within 25 minutes.` } },
          { '@type': 'Question', name: `Does ${item.name} offer stay and play golf packages?`, acceptedAnswer: { '@type': 'Answer', text: `GolfGraeagle.com offers stay-and-play packages at ${item.name} available for groups of all sizes. Packages include lodging, tee times, and full trip coordination. Request a free quote at golfgraeagle.com/request-a-quote.` } },
        ],
      },
    ];
  }

  if (type === 'dining') {
    return [
      {
        '@type': 'Restaurant',
        '@id': `${pageUrl}#restaurant`,
        name: item.name,
        description: item.description,
        url: pageUrl,
        image: item.hero,
        servesCuisine: item.cuisine,
        address: { '@type': 'PostalAddress', streetAddress: item.location, addressRegion: 'CA', addressCountry: 'US', addressLocality: 'Graeagle' },
        geo: item.coordinates ? { '@type': 'GeoCoordinates', latitude: item.coordinates.lat, longitude: item.coordinates.lng } : undefined,
        telephone: item.phone,
        priceRange: item.category === 'fine-dining' ? '$$$' : '$$',
      },
      breadcrumb,
      {
        '@type': 'FAQPage',
        mainEntity: [
          { '@type': 'Question', name: `Is ${item.name} good for golf groups?`, acceptedAnswer: { '@type': 'Answer', text: `Yes. ${item.name} is popular with Graeagle golf groups. ${item.description?.split('.')[0]}.` } },
          { '@type': 'Question', name: `Where is ${item.name} located?`, acceptedAnswer: { '@type': 'Answer', text: `${item.name} is located at ${item.location || 'near Graeagle, California'}, approximately 5 minutes from the main Graeagle golf courses.` } },
        ],
      },
    ];
  }

  return [breadcrumb];
};

const pageSchema = buildSchema();

const wpCourseSlugMap: Record<string, string> = {
  'graeagle-meadows': 'graeagle-meadows-golf-packages',
