---
<Base title={pageTitle} description={pageDesc} schema={pageSchema} canonical={pageUrl} ogImage={item?.hero || undefined} preloadImage={item?.hero || undefined} bodyClass="light-page">
  <Nav />

  {item && type === 'course' && (
    <>
<!-- ═══ HERO ═══ -->
<section class="ch-hero">

  <!-- LCP image -->
  <img
    src={item.hero}
    alt={getImgAlt(item.hero, `${item.name} Golf Course — Graeagle, California`)}
    class="ch-bg"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    width="1600"
    height="900"
  />
  <div class="ch-overlay"></div>

  <!-- Film strip -->
  <div class="ch-strip">
    {courses.map((course) => {
      const isActive = course.slug === item.slug;
      return (
        <a href={`/portfolio/${course.slug === 'nakoma-dragon' ? 'nakoma-dragon-golf-packages' : course.slug + '-golf-packages'}/`} class={`ch-strip-item${isActive ? ' is-active' : ''}`} aria-label={`View ${course.name}`}>
          <img src={course.hero} alt={course.name} class="ch-strip-thumb" loading={isActive ? 'eager' : 'lazy'} />
          <div class="ch-strip-dim"></div>
          <span class="ch-strip-label">{course.name.replace(' — The Dragon','').replace('Graeagle ','')}</span>
        </a>
      );
    })}
  </div>

  <!-- Main content -->
  <div class="ch-content">

    <!-- Left -->
    <div class="ch-left">
      <nav aria-label="Breadcrumb" class="ch-breadcrumb">
        <a href="/courses" class="ch-breadcrumb-link">← All Courses</a>
      </nav>

      {(item.awards?.length > 0 || item.tier) && (
        <div class="ch-badges">
          {item.awards?.map(a => <span class="ch-badge ch-badge-gold">{a}</span>)}
          <span class="ch-badge ch-badge-dim">{item.tier} Green Fees</span>
        </div>
      )}

      <h1 class="ch-h1 speakable">{item.name} <span style="display:block;font-size:0.55em;font-weight:400;color:rgba(255,255,255,0.5);font-style:italic;margin-top:4px;">Golf Packages &amp; Tee Times — Graeagle, CA</span></h1>
      <p class="ch-tagline page-intro">{item.tagline}</p>

      <div class="ch-ctas">
        <a href={`/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=${item.slug}-hero`} class="btn-green-glow ch-btn-primary">Book a Package →</a>
        {item.website && (
          <a href={item.website} class="ch-btn-ghost" target="_blank" rel="noopener">Course Website ↗</a>
        )}
      </div>
    </div>

    <!-- Right: removed (stats shown in body section below) -->
    <div class="ch-right" style="display:none;"></div>

  </div>

  <!-- Info bar -->
  <div class="ch-infobar">
    <div class="ch-infobar-items">
      {[
        ['Altitude', item.altitude],
        ['Open', 'May – November'],
        ['Location', item.address?.split(',')[1]?.trim() || 'Graeagle, CA'],
      ].map(([k, v]) => (
        <div class="ch-infobar-item">
          <span class="ch-infobar-label">{k}</span>
          <span class="ch-infobar-val">{v}</span>
        </div>
      ))}
    </div>
    <div class="ch-infobar-aside">5 courses · All within 25 min of Graeagle</div>
  </div>

</section>

<style>
  /* ─── COURSE HERO ─── */
  .ch-hero {
    position: relative;
    background: #090f09;
    display: flex;
    flex-direction: column;
  }

  .ch-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: calc(100% - 48px); /* stop above infobar */
    object-fit: cover;
    object-position: center 40%;
  }

  .ch-overlay {
    position: absolute;
    inset: 0;
    bottom: 48px;
    background: linear-gradient(
      180deg,
      rgba(9,15,9,0.52) 0%,
      transparent 30%,
      transparent 42%,
      rgba(9,15,9,0.9) 75%,
      rgba(9,15,9,1) 100%
    );
    z-index: 1;
  }

  /* Film strip */
  .ch-strip {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 3px;
    padding: 3px clamp(20px,4vw,52px);
    padding-top: calc(68px + 3px);
  }

  .ch-strip-item {
    flex: 1;
    height: 72px;
    overflow: hidden;
    border-radius: 6px;
    position: relative;
    text-decoration: none;
    display: block;
    transition: flex 0.5s cubic-bezier(0.4,0,0.2,1), box-shadow 0.4s ease, outline 0.4s ease;
    outline: 2px solid transparent;
    outline-offset: 0px;
    animation: stripEnter 0.6s ease both;
  }

  /* Staggered entrance */
  .ch-strip-item:nth-child(1) { animation-delay: 0.05s; }
  .ch-strip-item:nth-child(2) { animation-delay: 0.12s; }
  .ch-strip-item:nth-child(3) { animation-delay: 0.19s; }
  .ch-strip-item:nth-child(4) { animation-delay: 0.26s; }
  .ch-strip-item:nth-child(5) { animation-delay: 0.33s; }

  @keyframes stripEnter {
    from { opacity: 0; transform: translateY(-8px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Active — expanded with pulsing green glow */
  .ch-strip-item.is-active {
    flex: 2.8;
    outline: 2px solid rgba(120,255,160,0.9);
    box-shadow: 0 0 0 1px rgba(120,255,160,0.4), 0 0 14px 4px rgba(80,255,120,0.55), 0 0 32px 8px rgba(60,220,100,0.28);
    animation: stripEnter 0.6s ease both, glowPulse 2.8s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%,100% { box-shadow: 0 0 0 1px rgba(120,255,160,0.4), 0 0 14px 4px rgba(80,255,120,0.55), 0 0 32px 8px rgba(60,220,100,0.28); }
    50%      { box-shadow: 0 0 0 1px rgba(120,255,160,0.6), 0 0 22px 8px rgba(80,255,120,0.75), 0 0 48px 14px rgba(60,220,100,0.4); }
  }

  .ch-strip-item:not(.is-active):hover {
    flex: 1.6;
    outline: 2px solid rgba(120,255,160,0.6);
    box-shadow: 0 0 0 1px rgba(120,255,160,0.2), 0 0 10px 2px rgba(80,255,120,0.35), 0 0 20px 4px rgba(60,220,100,0.15);
  }

  /* Thumb — Ken Burns on active, zoom on hover */
  .ch-strip-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .ch-strip-item.is-active .ch-strip-thumb {
    animation: kenBurns 12s ease-in-out infinite alternate;
  }
  @keyframes kenBurns {
    from { transform: scale(1.0) translateX(0); }
    to   { transform: scale(1.1) translateX(-3%); }
  }
  .ch-strip-item:not(.is-active):hover .ch-strip-thumb { transform: scale(1.08); }

  /* Shimmer sweep on hover */
  .ch-strip-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 30%, rgba(232,168,80,0.18) 50%, transparent 70%);
    background-size: 200% 100%;
    background-position: -200% 0;
    transition: background-position 0s;
    pointer-events: none;
    z-index: 3;
    border-radius: inherit;
  }
  .ch-strip-item:hover::after {
    background-position: 200% 0;
    transition: background-position 0.55s ease;
  }

  .ch-strip-dim {
    position: absolute;
    inset: 0;
    transition: background 0.35s;
  }

  .ch-strip-item:not(.is-active) .ch-strip-dim { background: rgba(0,0,0,0.5); }
  .ch-strip-item.is-active .ch-strip-dim { background: rgba(0,0,0,0.06); }
  .ch-strip-item:not(.is-active):hover .ch-strip-dim { background: rgba(0,0,0,0.22); }

  .ch-strip-label {
    position: absolute;
    bottom: 8px;
    left: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 90%;
    text-shadow: 0 1px 6px rgba(0,0,0,0.8), 0 0 12px rgba(0,0,0,0.6);
    transition: color 0.3s;
  }

  .ch-strip-item.is-active .ch-strip-label { color: #ffffff; }
  .ch-strip-item:not(.is-active) .ch-strip-label { color: rgba(255,255,255,0.75); }
  .ch-strip-item:not(.is-active):hover .ch-strip-label { color: #ffffff; }

  /* Main content grid */
  .ch-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px,3vw,40px);
    align-items: end;
    padding: clamp(24px,5vw,56px) clamp(20px,4vw,52px);
    min-height: clamp(380px,48vh,560px);
  }

  /* Left */
  .ch-breadcrumb { margin-bottom: 16px; }
  .ch-breadcrumb-link {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .ch-breadcrumb-link:hover { color: rgba(255,255,255,0.8); }

  .ch-badges {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .ch-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 100px;
    letter-spacing: 0.06em;
    backdrop-filter: blur(12px);
  }
  .ch-badge-gold {
    background: rgba(26,48,20,0.75);
    border: 1px solid rgba(232,168,80,0.45);
    color: #e8a850;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .ch-badge-dim {
    background: rgba(26,48,20,0.75);
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.92);
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  .ch-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(34px,5.5vw,72px);
    font-weight: 500;
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
    line-height: 1.0;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
  }

  .ch-tagline {
    font-size: clamp(13px,1.5vw,16px);
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin: 0 0 24px;
    max-width: 680px;
  }

  .ch-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .ch-btn-primary {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 700;
    padding: 13px 24px;
    letter-spacing: 0.01em;
  }
  .ch-btn-primary:hover { }

  .ch-btn-ghost {
    display: inline-flex;
    align-items: center;
    background: rgba(28,18,8,0.06);
    border: 1px solid var(--border);
    color: rgba(28,18,8,0.55);
    font-size: 12px;
    font-weight: 500;
    padding: 13px 22px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .ch-btn-ghost:hover { background: var(--border); color:var(--text-primary); }

  /* Stat card */
  .ch-right { align-self: end; }

  .ch-stat-card {
    background: rgba(9,15,9,0.72);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    overflow: hidden;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .ch-stat-heading {
    font-size: 9px;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 14px 18px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ch-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    gap: 10px;
  }

  .ch-stat-label {
    font-size: 10px;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

  .ch-stat-val {
    font-size: 15px;
    font-weight: 600;
    color: #ffffff;
  }

  .ch-stat-designer {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 18px 14px;
  }

  .ch-stat-designer-name {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.75);
    text-align: right;
  }

  .ch-stat-year {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    text-align: right;
  }

  /* Info bar */
  .ch-infobar {
    position: relative;
    z-index: 2;
    padding: 13px clamp(20px,4vw,52px);
    background: rgba(9,15,9,0.97);
    border-bottom: 1px solid rgba(232,168,80,0.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ch-infobar-items {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .ch-infobar-item { display: flex; gap: 8px; align-items: center; }

  .ch-infobar-label {
    font-size: 9px;
    color: rgba(28,18,8,0.2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ch-infobar-val {
    font-size: 12px;
    color: rgba(28,18,8,0.5);
    font-weight: 500;
  }

  .ch-infobar-aside {
    font-size: 11px;
    color: var(--border-strong);
  }

  /* ─── BODY LAYOUT ─── */
  .course-body { background:var(--page-bg); padding: clamp(40px, 8vw, 80px) clamp(20px, 10%, 10%); }
  .course-layout { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 380px; gap: 64px; }
  .photo-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }

  /* ─── MOBILE ─── */
  @media (max-width: 860px) {
    .ch-content {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .ch-right { display: none; }
    .ch-strip-item { height: 58px; }
  }

  @media (max-width: 640px) {
    /* Hide the 5-course strip — wastes vertical space on mobile */
    .ch-strip { display: none; }
    .ch-infobar-aside { display: none; }
    .gallery-swipe-hint { display: block !important; }
    .gallery-count-desktop { display: none !important; }
    /* Tighten section spacing on mobile */
    .course-body { padding: 32px clamp(16px,5%,32px) 48px; }
    .reveal { margin-bottom: 36px !important; }
  }

  @media (max-width: 900px) {
    .course-layout { grid-template-columns: 1fr; }
    .course-sidebar { order: -1; }
    .course-sidebar-inner { position: static !important; }
  }

  /* ─── LODGING / DINING BODY GRIDS ─── */
  .lod-body-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 5%;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
    align-items: start;
  }
  .lod-amenities-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .din-body-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 5%;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 56px;
    align-items: start;
  }

  @media (max-width: 860px) {
    .lod-body-grid,
    .din-body-grid {
      grid-template-columns: 1fr;
      padding: 40px 6%;
      gap: 40px;
    }
    .lod-amenities-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Lodging hero content */
  .lod-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 10% 64px;
    max-width: 1400px;
    width: 100%;
  }
  .din-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 10% 56px;
    max-width: 1400px;
    width: 100%;
  }
  @media (max-width: 860px) {
    .lod-hero-content {
      padding: 0 5% 40px;
    }
    .din-hero-content {
      padding: 0 5% 36px;
    }
  }
</style>

<div class="course-body">
  <div class="course-layout">

    <!-- LEFT: Content -->
    <div>
      <!-- Description — speakable intro -->
      <div class="reveal" style="margin-bottom:56px;">
        <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:var(--text-primary);margin:0 0 20px;">About {item.name}</h2>
        <p class="speakable" style="font-size:16px;color:rgba(28,18,8,0.55);line-height:1.85;">{item.description}</p>
      </div>

      <!-- Course Highlights -->
      <div class="reveal" style="margin-bottom:56px;">
