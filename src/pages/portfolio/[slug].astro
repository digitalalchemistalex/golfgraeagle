---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { courses, lodging, dining, siteConfig, courseToLodging, lodgingToCourses } from '../../data/content.js';

// Map WP portfolio slugs → our data
const wpSlugMap = {
  // Courses
  'graeagle-meadows-golf-packages': { type: 'course', data: courses.find(c => c.slug === 'graeagle-meadows') },
  'whitehawk-ranch-golf-packages':  { type: 'course', data: courses.find(c => c.slug === 'whitehawk-ranch') },
  'plumas-pines-golf-packages':     { type: 'course', data: courses.find(c => c.slug === 'plumas-pines') },
  'grizzly-ranch-golf-packages':    { type: 'course', data: courses.find(c => c.slug === 'grizzly-ranch') },
  'nakoma-dragon-golf-packages':    { type: 'course', data: courses.find(c => c.slug === 'nakoma-dragon') },
  // Also handle the /portfolio/plumas-pines-golf-resort/ style from search results
  'plumas-pines-golf-resort':       { type: 'course', data: courses.find(c => c.slug === 'plumas-pines') },
  'graeagle-meadows-golf-course':   { type: 'course', data: courses.find(c => c.slug === 'graeagle-meadows') },
  'whitehawk-ranch-golf-course':    { type: 'course', data: courses.find(c => c.slug === 'whitehawk-ranch') },
  'grizzly-ranch-golf-club':        { type: 'course', data: courses.find(c => c.slug === 'grizzly-ranch') },
  // Lodging
  'river-pines-resort-graeagle-ca': { type: 'lodging', data: lodging.find(l => l.slug === 'river-pines-resort') },
  'chalet-view-lodge-graeagle-ca':  { type: 'lodging', data: lodging.find(l => l.slug === 'chalet-view-lodge') },
  'the-inn-at-nakoma-clio-ca':      { type: 'lodging', data: lodging.find(l => l.slug === 'inn-at-nakoma') },
  'the-townhomes-at-plumas-pines':  { type: 'lodging', data: lodging.find(l => l.slug === 'townhomes-at-plumas-pines') },
  // Dining
  'longboards-bar-and-grill':       { type: 'dining', data: dining.find(d => d.slug === 'longboards') },
  'sardine-lake-resort':            { type: 'dining', data: dining.find(d => d.slug === 'sardine-lake') },
  'iron-door-restaurant':           { type: 'dining', data: dining.find(d => d.slug === 'iron-door') },
  'grizzly-grill':                  { type: 'dining', data: dining.find(d => d.slug === 'grizzly-grill') },
  'roadhouse-at-river-pines':       { type: 'dining', data: dining.find(d => d.slug === 'roadhouse') },
  'graeagle-meadows-golf-course-restaurant': { type: 'dining', data: dining.find(d => d.slug === 'meadows-restaurant') },
  'cuccias':                        { type: 'dining', data: dining.find(d => d.slug === 'cuccias') },
  'sierra-smokeshow':               { type: 'dining', data: dining.find(d => d.slug === 'sierra-smokeshow') },
  'gumbas-ii-go':                   { type: 'dining', data: dining.find(d => d.slug === 'gumbas') },
  'eureka-peak-brewing-co':         { type: 'dining', data: dining.find(d => d.slug === 'eureka-peak-brewing') },
  'the-brewing-lair':               { type: 'dining', data: dining.find(d => d.slug === 'brewing-lair') },
  'mohawk-tavern':                  { type: 'dining', data: dining.find(d => d.slug === 'mohawk-tavern') },
  'the-knotty-pine-tavern':         { type: 'dining', data: dining.find(d => d.slug === 'knotty-pine') },
  'little-bite-deli':               { type: 'dining', data: dining.find(d => d.slug === 'little-bite-deli') },
  'graeagle-mountain-frostee':      { type: 'dining', data: dining.find(d => d.slug === 'mountain-frostee') },
  'graeagle-restaurant':            { type: 'dining', data: dining.find(d => d.slug === 'graeagle-restaurant') },
};

export function getStaticPaths() {
  return Object.keys({
  'graeagle-meadows-golf-packages': 1,'whitehawk-ranch-golf-packages':1,'plumas-pines-golf-packages':1,
  'grizzly-ranch-golf-packages':1,'nakoma-dragon-golf-packages':1,'plumas-pines-golf-resort':1,
  'graeagle-meadows-golf-course':1,'whitehawk-ranch-golf-course':1,'grizzly-ranch-golf-club':1,
  'river-pines-resort-graeagle-ca':1,'chalet-view-lodge-graeagle-ca':1,'the-inn-at-nakoma-clio-ca':1,
  'the-townhomes-at-plumas-pines':1,'longboards-bar-and-grill':1,'sardine-lake-resort':1,
  'iron-door-restaurant':1,'grizzly-grill':1,'roadhouse-at-river-pines':1,
  'graeagle-meadows-golf-course-restaurant':1,'cuccias':1,'sierra-smokeshow':1,'gumbas-ii-go':1,
  'eureka-peak-brewing-co':1,'the-brewing-lair':1,'mohawk-tavern':1,'the-knotty-pine-tavern':1,
  'little-bite-deli':1,'graeagle-mountain-frostee':1,'graeagle-restaurant':1,
  }).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const entry = wpSlugMap[slug];
const item = entry?.data;
const type = entry?.type;
const c = item; // alias for rich course template compatibility
const pageUrl = `${siteConfig.url}/portfolio/${slug}`;

// ── Titles matching WP indexed titles (from site audit) ───────────────────────
const wpTitles: Record<string, string> = {
  'graeagle-meadows-golf-packages':   'Graeagle Meadows Golf Group Packages | Stay and Play Deals',
  'whitehawk-ranch-golf-packages':    'Whitehawk Ranch Golf Packages | Stay and Play in Graeagle, CA',
  'plumas-pines-golf-packages':       'Plumas Pines Golf Group Packages | Stay and Play Deals',
  'grizzly-ranch-golf-packages':      'Grizzly Ranch Golf Group Packages | Stay and Play Deals',
  'nakoma-dragon-golf-packages':      'Nakoma Dragon Golf Packages | Graeagle Golf Stay & Play Packages',
  'river-pines-resort-graeagle-ca':   'River Pines Resort | Graeagle Golf Group Packages & Stay and Play Deals',
  'chalet-view-lodge-graeagle-ca':    'Chalet View Lodge | Graeagle Golf Group Packages & Stay and Play Deals',
  'the-inn-at-nakoma-clio-ca':        'Inn at Nakoma | Graeagle Golf Group Packages & Stay and Play Deals',
  'the-townhomes-at-plumas-pines':    'The Townhomes at Plumas Pines | Graeagle Golf Stay & Play',
  'grizzly-grill':                    'Grizzly Grill | Gourmet Dining in Graeagle\'s Plumas National Forest',
  'iron-door-restaurant':             'Iron Door Restaurant | Graeagle Golf Stay & Play Packages',
  'roadhouse-at-river-pines':         'River Pines Resort | Graeagle Golf, Casino, Lodging & Dining',
  'the-brewing-lair':                 'The Brewing Lair | Après-Golf Drinks for Graeagle Groups',
  'eureka-peak-brewing-co':           'Eureka Peak Brewing Co. | Après-Golf Drinks for Graeagle Groups',
  'gumbas-ii-go':                     "Gumba's II Go | Pizza & To-Go for Graeagle Golf Groups",
  'sierra-smokeshow':                 'Sierra SmokeShow | BBQ Dining for Graeagle Golf Groups',
  'little-bite-deli':                 'Little Bite Deli — Fresh Sandwiches & Salads in Blairsden | Graeagle',
  'graeagle-restaurant':              'Graeagle Restaurant — Classic Café & Homestyle Dining Since 1958',
  'graeagle-meadows-golf-course-restaurant': 'Graeagle Meadows Golf Course Restaurant | Dining for Golf Groups',
};
const pageTitle = wpTitles[slug] || (item ? `${item.name} | GolfGraeagle.com` : `${slug} | GolfGraeagle.com`);

// ── Meta descriptions matching WP indexed descriptions ────────────────────────
const wpDescs: Record<string, string> = {
  'graeagle-meadows-golf-packages': 'Graeagle Meadows golf group packages with stay and play deals. Includes tee times, lodging, and trip planning for Graeagle groups.',
  'whitehawk-ranch-golf-packages':  'Custom Whitehawk Ranch golf trips with lodging + guaranteed tee times. Best stay-and-play packages. Request a quote.',
  'plumas-pines-golf-packages':     'Plumas Pines golf group packages with stay and play deals. Custom tee times, lodging, and trip planning for Graeagle groups.',
  'grizzly-ranch-golf-packages':    'Grizzly Ranch golf group packages with stay and play deals. Custom tee times, lodging, and trip planning for Graeagle groups.',
  'river-pines-resort-graeagle-ca': 'River Pines Resort cabins in Graeagle with golf group packages and stay and play deals from $299–$499 per golfer. Lodging, tee times, and trip planning included.',
  'chalet-view-lodge-graeagle-ca':  'Stay at Chalet View Lodge in Graeagle with golf group packages and stay and play deals from $299–$499 per golfer. Lodging, tee times, and trip planning included.',
  'the-inn-at-nakoma-clio-ca':      'Stay at the Inn at Nakoma with Graeagle golf group packages and stay and play deals from $299–$499 per golfer. Includes lodging, tee times, and trip planning.',
  'grizzly-grill':                  'Discover Grizzly Grill in Plumas National Forest: gourmet menu, full bar, seasonal wild-game dishes, and forest views. Reserve your table today!',
  'roadhouse-at-river-pines':       'Experience River Pines Resort near Graeagle: golf, casino, cozy lodging, spa services, four restaurants, event venues, and lakeside recreation. Book now!',
  'the-brewing-lair':               'Craft beers and lawn-game vibe for Graeagle golf groups. Easy après-golf meet-up; group-friendly setup.',
  'eureka-peak-brewing-co':         "Craft beers and casual vibe near Graeagle courses—great après-golf meet-up for groups. We can align stop times with your tee sheet.",
  'gumbas-ii-go':                   "Gumba's II Go serves pizza and Italian favorites in Graeagle—easy pick-up for golf groups before or after tee times. Group-friendly, central location.",
  'sierra-smokeshow':               'Sierra SmokeShow serves barbecue plates and sandwiches near Graeagle courses—easy for golf groups before or after tee times. Group-friendly setup.',
  'little-bite-deli':               'Hidden gem on Highway 89—Little Bite Deli serves big sandwiches, crisp salads & friendly service. Perfect for lunch near Graeagle golf.',
  'graeagle-restaurant':            'Family-owned café in the historic Box Factory Mill—serving breakfast, lunch & homemade pies in Graeagle since 1958. A local favorite.',
  'graeagle-meadows-golf-course-restaurant': 'Graeagle Meadows Golf Course Restaurant serves golfers with clubhouse dining—perfect for group lunches or après-golf meals in Graeagle.',
};
const pageDesc = wpDescs[slug] || item?.description || item?.tagline || `Graeagle golf packages for ${item?.name || slug}.`;

// ── Schema per page type ──────────────────────────────────────────────────────
const buildSchema = () => {
  if (!item) return null;

  const breadcrumb = {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: type === 'course' ? 'Golf Courses' : type === 'lodging' ? 'Lodging' : 'Dining', item: `${siteConfig.url}/${type === 'course' ? 'all-golf-courses' : type}` },
      { '@type': 'ListItem', position: 3, name: item.name, item: pageUrl },
    ],
  };

  if (type === 'course') {
    return [
      {
        '@type': 'GolfCourse',
        '@id': `${pageUrl}#golfcourse`,
        name: `${item.name} Golf Course`,
        description: item.description,
        url: pageUrl,
        numberOfHoles: 18,
        address: { '@type': 'PostalAddress', streetAddress: item.address, addressRegion: 'CA', addressCountry: 'US' },
        geo: item.coordinates ? { '@type': 'GeoCoordinates', latitude: item.coordinates?.lat, longitude: item.coordinates?.lng } : undefined,
        designer: { '@type': 'Person', name: item.designer },
        dateCreated: `${item.year}`,
        image: item.hero,
        amenityFeature: item.highlights?.map((h: string) => ({ '@type': 'LocationFeatureSpecification', name: h, value: true })),
        potentialAction: { '@type': 'ReserveAction', target: { '@type': 'EntryPoint', urlTemplate: `${siteConfig.url}/request-a-quote` } },
      },
      breadcrumb,
      {
        '@type': 'FAQPage',
        mainEntity: [
          { '@type': 'Question', name: `How do I book a tee time at ${item.name}?`, acceptedAnswer: { '@type': 'Answer', text: `GolfGraeagle.com handles all ${item.name} tee time bookings as part of stay-and-play packages. Request a free quote at golfgraeagle.com/request-a-quote and we'll coordinate everything.` } },
          { '@type': 'Question', name: `What is the slope rating at ${item.name}?`, acceptedAnswer: { '@type': 'Answer', text: `${item.name} has a slope rating of ${item.slope} and a course rating of ${item.rating}, playing ${item.yards?.toLocaleString()} yards from the back tees at par ${item.par}.` } },
          { '@type': 'Question', name: `Who designed ${item.name}?`, acceptedAnswer: { '@type': 'Answer', text: `${item.name} was designed by ${item.designer} and opened in ${item.year}.` } },
        ],
      },
    ];
  }

  if (type === 'lodging') {
    return [
      {
        '@type': 'LodgingBusiness',
        '@id': `${pageUrl}#lodging`,
        name: item.name,
        description: item.description,
        url: pageUrl,
        image: item.hero,
        address: { '@type': 'PostalAddress', addressRegion: 'CA', addressCountry: 'US', addressLocality: 'Graeagle' },
        geo: item.coordinates ? { '@type': 'GeoCoordinates', latitude: item.coordinates.lat, longitude: item.coordinates.lng } : undefined,
        amenityFeature: item.highlights?.map((h: string) => ({ '@type': 'LocationFeatureSpecification', name: h, value: true })),
        priceRange: '$299–$499 per golfer',
        telephone: item.phone,
        potentialAction: { '@type': 'ReserveAction', target: { '@type': 'EntryPoint', urlTemplate: `${siteConfig.url}/request-a-quote` } },
      },
      breadcrumb,
    ];
  }

  if (type === 'dining') {
    return [
      {
        '@type': 'Restaurant',
        '@id': `${pageUrl}#restaurant`,
        name: item.name,
        description: item.description,
        url: pageUrl,
        image: item.hero,
        servesCuisine: item.cuisine,
        address: { '@type': 'PostalAddress', streetAddress: item.location, addressRegion: 'CA', addressCountry: 'US', addressLocality: 'Graeagle' },
        geo: item.coordinates ? { '@type': 'GeoCoordinates', latitude: item.coordinates.lat, longitude: item.coordinates.lng } : undefined,
        telephone: item.phone,
        priceRange: item.category === 'fine-dining' ? '$$$' : item.category === 'brewery' || item.category === 'bar' ? '$$' : '$$',
      },
      breadcrumb,
    ];
  }

  return [breadcrumb];
};

const pageSchema = buildSchema();
---
<Base title={pageTitle} description={pageDesc} schema={pageSchema} canonical={pageUrl}>
  <Nav />

  {item && type === 'course' && (
    <>
<!-- ═══ HERO ═══ -->
<section class="ch-hero">

  <!-- LCP image -->
  <img
    src={item.hero}
    alt={`${item.name} Golf Course — Graeagle, California`}
    class="ch-bg"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    width="1600"
    height="900"
  />
  <div class="ch-overlay"></div>

  <!-- Film strip -->
  <div class="ch-strip">
    {courses.map((course) => {
      const isActive = course.slug === item.slug;
      return (
        <a href={`/courses/${course.slug}`} class={`ch-strip-item${isActive ? ' is-active' : ''}`} aria-label={`View ${course.name}`}>
          <img src={course.hero} alt={course.name} class="ch-strip-thumb" loading={isActive ? 'eager' : 'lazy'} />
          <div class="ch-strip-dim"></div>
          <span class="ch-strip-label">{course.name.replace(' — The Dragon','').replace('Graeagle ','')}</span>
        </a>
      );
    })}
  </div>

  <!-- Main content -->
  <div class="ch-content">

    <!-- Left -->
    <div class="ch-left">
      <nav aria-label="Breadcrumb" class="ch-breadcrumb">
        <a href="/courses" class="ch-breadcrumb-link">← All Courses</a>
      </nav>

      {(item.awards?.length > 0 || item.tier) && (
        <div class="ch-badges">
          {item.awards?.map(a => <span class="ch-badge ch-badge-gold">{a}</span>)}
          <span class="ch-badge ch-badge-dim">{item.tier} Green Fees</span>
        </div>
      )}

      <h1 class="ch-h1 speakable">{item.name}</h1>
      <p class="ch-tagline page-intro">{item.tagline}</p>

      <div class="ch-ctas">
        <a href="/request-a-quote" class="ch-btn-primary">Book a Package →</a>
        {item.website && (
          <a href={item.website} class="ch-btn-ghost" target="_blank" rel="noopener">Course Website ↗</a>
        )}
      </div>
    </div>

    <!-- Right: stat card -->
    <div class="ch-right">
      <div class="ch-stat-card">
        <div class="ch-stat-heading">Quick Stats</div>
        {[
          ['Par', `${item.par}`],
          ['Yards', item.yards.toLocaleString()],
          ['Slope', `${item.slope}`],
          ['Rating', `${item.rating}`],
        ].map(([k, v]) => (
          <div class="ch-stat-row">
            <span class="ch-stat-label">{k}</span>
            <span class="ch-stat-val">{v}</span>
          </div>
        ))}
        <div class="ch-stat-designer">
          <span class="ch-stat-label">Designer</span>
          <div>
            <div class="ch-stat-designer-name">{item.designer}</div>
            <div class="ch-stat-year">Est. {item.year}</div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Info bar -->
  <div class="ch-infobar">
    <div class="ch-infobar-items">
      {[
        ['Altitude', item.altitude],
        ['Open', 'May – November'],
        ['Location', item.address?.split(',')[1]?.trim() || 'Graeagle, CA'],
      ].map(([k, v]) => (
        <div class="ch-infobar-item">
          <span class="ch-infobar-label">{k}</span>
          <span class="ch-infobar-val">{v}</span>
        </div>
      ))}
    </div>
    <div class="ch-infobar-aside">5 courses · All within 25 min of Graeagle</div>
  </div>

</section>

<style>
  /* ─── COURSE HERO ─── */
  .ch-hero {
    position: relative;
    background: #090f09;
    display: flex;
    flex-direction: column;
  }

  .ch-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: calc(100% - 48px); /* stop above infobar */
    object-fit: cover;
    object-position: center 40%;
  }

  .ch-overlay {
    position: absolute;
    inset: 0;
    bottom: 48px;
    background: linear-gradient(
      180deg,
      rgba(9,15,9,0.52) 0%,
      transparent 30%,
      transparent 42%,
      rgba(9,15,9,0.9) 75%,
      rgba(9,15,9,1) 100%
    );
    z-index: 1;
  }

  /* Film strip */
  .ch-strip {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 3px;
    padding: 3px clamp(20px,4vw,52px);
    padding-top: calc(68px + 3px);
  }

  .ch-strip-item {
    flex: 1;
    height: 72px;
    overflow: hidden;
    border-radius: 6px;
    position: relative;
    text-decoration: none;
    display: block;
    transition: flex 0.4s cubic-bezier(0.4,0,0.2,1);
  }

  .ch-strip-item.is-active { flex: 2.8; }
  .ch-strip-item:not(.is-active):hover { flex: 1.6; }

  .ch-strip-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 6s ease;
  }

  .ch-strip-item:hover .ch-strip-thumb { transform: scale(1.06); }

  .ch-strip-dim {
    position: absolute;
    inset: 0;
    transition: background 0.3s;
  }

  .ch-strip-item:not(.is-active) .ch-strip-dim { background: rgba(0,0,0,0.5); }
  .ch-strip-item.is-active .ch-strip-dim { background: rgba(0,0,0,0.06); }
  .ch-strip-item:not(.is-active):hover .ch-strip-dim { background: rgba(0,0,0,0.22); }

  .ch-strip-label {
    position: absolute;
    bottom: 7px;
    left: 9px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.05em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 90%;
    transition: color 0.3s;
  }

  .ch-strip-item.is-active .ch-strip-label { color: rgba(255,255,255,0.9); }
  .ch-strip-item:not(.is-active) .ch-strip-label { color: rgba(255,255,255,0.4); }
  .ch-strip-item:not(.is-active):hover .ch-strip-label { color: rgba(255,255,255,0.75); }

  /* Main content grid */
  .ch-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: clamp(20px,3vw,40px);
    align-items: end;
    padding: clamp(24px,5vw,56px) clamp(20px,4vw,52px);
    min-height: clamp(380px,48vh,560px);
  }

  /* Left */
  .ch-breadcrumb { margin-bottom: 16px; }
  .ch-breadcrumb-link {
    font-size: 11px;
    color: rgba(240,248,242,0.32);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .ch-breadcrumb-link:hover { color: rgba(240,248,242,0.65); }

  .ch-badges {
    display: flex;
    gap: 7px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .ch-badge {
    font-size: 9px;
    padding: 4px 12px;
    border-radius: 100px;
    letter-spacing: 0.08em;
  }
  .ch-badge-gold {
    background: rgba(232,168,80,0.14);
    border: 1px solid rgba(232,168,80,0.28);
    color: #e8a850;
  }
  .ch-badge-dim {
    background: rgba(240,248,242,0.07);
    border: 1px solid rgba(240,248,242,0.12);
    color: rgba(240,248,242,0.5);
  }

  .ch-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(34px,5.5vw,72px);
    font-weight: 500;
    color: #f0f8f2;
    line-height: 1.0;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
  }

  .ch-tagline {
    font-size: clamp(13px,1.5vw,16px);
    color: rgba(240,248,242,0.45);
    line-height: 1.6;
    margin: 0 0 24px;
    max-width: 520px;
  }

  .ch-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .ch-btn-primary {
    display: inline-flex;
    align-items: center;
    background: #f0f8f2;
    color: #090f09;
    font-size: 12px;
    font-weight: 700;
    padding: 13px 24px;
    border-radius: 100px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.2s;
  }
  .ch-btn-primary:hover { background: #fff; transform: translateY(-1px); }

  .ch-btn-ghost {
    display: inline-flex;
    align-items: center;
    background: rgba(240,248,242,0.07);
    border: 1px solid rgba(240,248,242,0.14);
    color: rgba(240,248,242,0.6);
    font-size: 12px;
    font-weight: 500;
    padding: 13px 22px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s;
  }
