---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';
import { fetchTripStats } from '../lib/tripStats';
const { minPrice, maxPrice, tripCount } = await fetchTripStats();

const title = "Book Tee Times in Graeagle, CA | All 5 Courses";
const description = `Book guaranteed tee times at all 5 Graeagle courses — including semi-private Grizzly Ranch and Nakoma Dragon. Expert group booking, 6–8 weeks ahead in summer. GolfGraeagle secures access others can't.`;


const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I book tee times in Graeagle, California?", "acceptedAnswer": { "@type": "Answer", "text": "Request a quote at GolfGraeagle.com with your dates, group size, and courses. GolfGraeagle books guaranteed tee times at all 5 Graeagle courses and returns a full package within 24 hours." } },
    { "@type": "Question", "name": "Can I book tee times at Grizzly Ranch Golf Club?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Grizzly Ranch is semi-private but accessible through GolfGraeagle packages. Grizzly Ranch is Golf Digest Top 100 Greatest Public Courses in the US (2021). GolfGraeagle secures guaranteed tee times as part of every stay-and-play package." } },
    { "@type": "Question", "name": "How far in advance do I need to book Graeagle tee times?", "acceptedAnswer": { "@type": "Answer", "text": "For summer weekends (June-August), book 4-6 weeks ahead. Spring and fall can typically be arranged 2-3 weeks out. Large groups (12+) requiring consecutive tee time blocks need 6-8 weeks for peak summer." } },
    { "@type": "Question", "name": "Can GolfGraeagle book tee times for large groups?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. GolfGraeagle books consecutive tee time blocks for groups of 4 to 200+ golfers. We coordinate directly with the pro shop at all 5 courses. Shotgun starts and tournament formats can be arranged for groups of 20+." } },
    { "@type": "Question", "name": "Are Graeagle golf courses open to the public?", "acceptedAnswer": { "@type": "Answer", "text": "All five Graeagle courses accept public play. Grizzly Ranch and Nakoma Dragon are semi-private — accessible through GolfGraeagle packages. The other three are fully public." } }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Golf Packages", "item": "https://golfgraeagle.com/golf-packages/" },
    { "@type": "ListItem", "position": 3, "name": "Tee Times Graeagle", "item": "https://golfgraeagle.com/tee-times-graeagle/" }
  ]
};
const orgSchema = {
  "@context": "https://schema.org", "@graph": [
    { "@type": ["TravelAgency","Organization"], "@id": "https://golfgraeagle.com/#organization", "name": "GolfGraeagle.com", "url": "https://golfgraeagle.com",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
    { "@type": "WebPage", "url": "https://golfgraeagle.com/tee-times-graeagle/", "name": title }
  ]
};
const howToSchema = {
  "@context": "https://schema.org", "@type": "HowTo",
  "name": "How to Book Tee Times at Graeagle Golf Courses",
  "description": "Book guaranteed tee times at all 5 Graeagle courses — including semi-private Grizzly Ranch and Nakoma Dragon — through GolfGraeagle.",
  "totalTime": "PT24H",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Request tee times with your dates and courses", "text": "Submit your dates, group size, and which courses via golfgraeagle.com/request-a-quote. Peak season (July–August): submit 6–8 weeks ahead. Spring and fall: 2–4 weeks." },
    { "@type": "HowToStep", "position": 2, "name": "GolfGraeagle books directly with each pro shop", "text": "GolfGraeagle contacts each course pro shop directly. Semi-private courses (Grizzly Ranch, Nakoma Dragon) require an operator relationship — which GolfGraeagle has. Confirmation returned within 24 hours." },
    { "@type": "HowToStep", "position": 3, "name": "Receive your confirmed tee sheet", "text": "Tee times confirmed with exact times per course per day. For groups of 9+, consecutive tee time blocks are arranged. All tee times are paired with lodging options in one bundled proposal." },
    { "@type": "HowToStep", "position": 4, "name": "Show up and check in", "text": "Your tee sheet is confirmed and in your inbox before you leave home. Check in at each pro shop with your name. GolfGraeagle handles any day-of changes." }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Graeagle Tee Time Booking",
  "description": "Guaranteed tee times at all 5 Graeagle golf courses bundled with lodging in one package.",
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Golf Tee Time Booking",
  "offers": { "@type": "AggregateOffer", "lowPrice": `${minPrice}`, "highPrice": `${maxPrice}`, "priceCurrency": "USD" }
};

const courses = [
  { name: 'Graeagle Meadows', slug: 'graeagle-meadows-golf-packages', par: 72, yards: '6,759', slope: 120, rating: '70.7', access: 'Public', designer: 'Ellis Van Gorder', year: 1968, badge: 'Since 1968', badgeColor: '#2563eb', hero: '/wp-images/graeagle-meadows-hero.webp', note: 'Most accessible. Best opening round for mixed groups.' },
  { name: 'Whitehawk Ranch',  slug: 'whitehawk-ranch-golf-packages',  par: 71, yards: '6,983', slope: 132, rating: '72.3', access: 'Public', designer: 'Dick Bailey', year: 1996, badge: 'Top 20 CA', badgeColor: '#1a7a40', hero: '/wp-images/whitehawk-hero.webp', note: 'Top 20 California. Meadow and forest mix.' },
  { name: 'Plumas Pines',     slug: 'plumas-pines-golf-packages',     par: 72, yards: '6,504', slope: 132, rating: '71.3', access: 'Public', designer: 'Homer Flint', year: 1980, badge: 'Best Value', badgeColor: '#b45309', hero: '/wp-images/plumas-pines-hero.webp', note: 'Top 5 Best Value Sierra Nevada. Feather River layout.' },
  { name: 'Grizzly Ranch',    slug: 'grizzly-ranch-golf-packages',    par: 72, yards: '7,411', slope: 140, rating: '74.9', access: 'Semi-private', designer: 'Bob Cupp', year: 2005, badge: 'Top 100', badgeColor: '#7c3aed', hero: '/wp-images/grizzly-ranch-hero.webp', note: 'Golf Digest Top 100. 7,411 yds at 4,800 ft. Access via package.' },
  { name: 'Nakoma — The Dragon', slug: 'nakoma-dragon-golf-packages', par: 72, yards: '7,015', slope: 147, rating: '73.4', access: 'Semi-private', designer: 'Robin Nelson', year: 1998, badge: 'FLW Club', badgeColor: '#be123c', hero: '/wp-images/nakoma-dragon-feather-river.webp', note: 'Only FLW golf clubhouse in the world. Golf World Top 75.' },
];

const windows = [
  { month: 'May–June', lead: '4–6 weeks ahead', note: 'Season opening. Good conditions. Smaller crowds than peak summer. Best value window for groups.', hot: false },
  { month: 'July–August', lead: '6–8 weeks ahead', note: 'Peak season. Grizzly Ranch and Nakoma Dragon fill fastest. Book as early as possible for weekends.', hot: true },
  { month: 'September–October', lead: '2–4 weeks ahead', note: 'Best conditions of the year. Firm fairways, fall color, fewer crowds. The locals choose this window.', hot: false },
];

const whyPoints = [
  ['🔒','Guaranteed access — including semi-private courses','Grizzly Ranch (Top 100) and Nakoma Dragon are semi-private. GolfGraeagle secures tee times at both. You get on the courses others cannot book directly.'],
  ['👥','Groups of 4 to 200+ golfers','Consecutive tee time blocks across one or multiple courses. Shotgun starts for outings of 20+. We coordinate directly with every pro shop.'],
  ['📋','Tee times + lodging in one package','We bundle your tee times with lodging so nothing conflicts. One invoice, one contact, every detail handled.'],
  ['⚡','Confirmation in 24 hours','Every quote request receives a full tee time and lodging proposal within 24 hours. Urgent bookings? Call (888) 586-1157.'],
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, serviceSchema, howToSchema]}
  canonical="https://golfgraeagle.com/tee-times-graeagle/"
  ogImage="https://golfgraeagle.com/wp-images/grizzly-ranch--1024x682.webp"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="tt-hero">
    <div class="tt-hero-img" style="background-image:url(/wp-images/grizzly-ranch--1024x682.webp)"></div>
    <div class="tt-hero-overlay"></div>
    <div class="tt-hero-inner">
      <p class="tt-eyebrow reveal-up">Book Tee Times · Graeagle, California · All 5 Courses</p>
      <h1 class="tt-h1 reveal-up delay-1">Graeagle<br/><em>Tee Times</em></h1>
      <p class="tt-subhead speakable reveal-up delay-2">Book tee times at all 5 Graeagle golf courses — including Grizzly Ranch (Golf Digest Top 100) and Nakoma Dragon (Golf World Top 75). Guaranteed access bundled with lodging from ${minPrice}/golfer.</p>
      <div class="tt-pills reveal-up delay-3">
        <span class="tt-pill">All 5 courses</span>
        <span class="tt-pill">Groups 4–200+</span>
        <span class="tt-pill">⭐ 4.8 · 672 reviews</span>
        <span class="tt-pill">24h confirmation</span>
      </div>
      <div class="tt-hero-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow tt-cta-main">Book Tee Times →</a>
        <a href="/all-golf-courses/" class="tt-cta-ghost underline-draw">Compare all 5 courses ↗</a>
      </div>
    </div>
    <!-- Floating stat cards — desktop right -->
    <div class="tt-floats reveal-fade delay-5">
      <div class="tt-float"><div class="tt-float-val" data-count="5">0</div><div class="tt-float-lbl">Courses</div></div>
      <div class="tt-float"><div class="tt-float-val">4.8★</div><div class="tt-float-lbl">Avg Rating</div></div>
      <div class="tt-float"><div class="tt-float-val" data-count="24">0</div><div class="tt-float-lbl">Hr Confirm</div></div>
    </div>
  </section>

  <!-- ═══ COURSE CARDS ═══ -->
  <section class="tt-section">
    <div class="tt-container">
      <div class="tt-header reveal-up">
        <span class="sec-label">Book tee times at all 5 Graeagle courses — GolfGraeagle guarantees access</span>
        <h2 class="tt-h2">Graeagle golf courses<br/><em>open for booking</em></h2>
      </div>
      <div class="tt-courses-grid">
        {courses.map((c, i) => (
          <a href={`/portfolio/${c.slug}/`} class={`tt-course-card glow-card reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="tt-course-img" style={`background-image:url(${c.hero})`}>
              <div class="tt-course-fade"></div>
              <span class="tt-course-badge" style={`background:${c.badgeColor}`}>{c.badge}</span>
              <span class={`tt-access-tag ${c.access==='Public'?'public':'semi'}`}>{c.access}</span>
            </div>
            <div class="tt-course-body">
              <h3 class="tt-course-name">{c.name}</h3>
              <div class="tt-course-specs">
                <span>Par {c.par}</span><span class="tt-dot">·</span>
                <span>{c.yards} yds</span><span class="tt-dot">·</span>
                <span>Slope {c.slope}</span><span class="tt-dot">·</span>
                <span>{c.designer}, {c.year}</span>
              </div>
              <p class="tt-course-note">{c.note}</p>
              <span class="tt-course-link underline-draw">View packages →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="tt-access-note reveal-up">Grizzly Ranch and Nakoma Dragon are semi-private. <a href="/request-a-quote/" style="color:var(--tt-green);font-weight:700;">GolfGraeagle guarantees access via packages →</a></p>
    </div>
  </section>

  <!-- ═══ WHY GOLFGRAEAGLE — dark split ═══ -->
  <section class="tt-section tt-dark tt-why">
    <div class="tt-container tt-why-inner">
      <div class="tt-why-text">
        <span class="sec-label">Why book through GolfGraeagle</span>
        <h2 class="tt-h2 reveal-up" style="color:#f5f0e8;margin-top:10px">Tee times + lodging<br/><em>guaranteed together</em></h2>
        <div class="tt-points">
          {whyPoints.map(([icon, title, body], i) => (
            <div class={`tt-point reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
              <span class="tt-pt-icon">{icon}</span>
              <div>
                <div class="tt-pt-title">{title}</div>
                <div class="tt-pt-body">{body}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="tt-why-img reveal-scale delay-2">
        <img src="/wp-images/nakoma-dragon-feather-river.webp" alt="Nakoma Dragon golf course — Frank Lloyd Wright clubhouse — Graeagle CA" loading="lazy"/>
        <div class="tt-why-badge">
          <div style="font-family:'Playfair Display',serif;font-size:22px;color:#e8a850;font-weight:400;line-height:1">Golf World</div>
          <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.55);margin-top:5px">Top 75 Course</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BOOKING WINDOWS ═══ -->
  <section class="tt-section">
    <div class="tt-container">
      <div class="tt-header reveal-up">
        <span class="sec-label">Plan ahead — especially for summer</span>
        <h2 class="tt-h2">When to book<br/><em>Graeagle tee times</em></h2>
      </div>
      <div class="tt-windows">
        {windows.map((w, i) => (
          <div class={`tt-window glow-card reveal-scale delay-${i+1}${w.hot?' tt-window-hot':''}`}>
            {w.hot && <div class="tt-window-tag">Peak Season</div>}
            <div class="tt-window-month">{w.month}</div>
            <div class="tt-window-lead">{w.lead}</div>
            <p class="tt-window-note">{w.note}</p>
            <a href="/request-a-quote/" class="tt-window-cta underline-draw">Book this window →</a>
          </div>
        ))}
      </div>
      <p class="tt-access-note reveal-up" style="margin-top:28px">
        Not sure which courses to play or in what order? See our <a href="/graeagle-golf-itinerary/" style="color:var(--tt-green);font-weight:700">recommended day-by-day Graeagle golf itineraries</a> — sequenced easiest to hardest so your group peaks on the right round.
      </p>
    </div>
  </section>

  <!-- ═══ TRUST STATS — dark ═══ -->
  <section class="tt-trust tt-dark">
    <div class="tt-container tt-trust-row">
      {[
        ['5','Courses bookable'],
        ['2','Semi-private accessible'],
        ['4.8','672 verified reviews'],
        ['24','Hour confirmation'],
        ['6',  'Weeks ahead peak season'],
      ].map(([val, label], i) => (
        <div class={`tt-stat reveal-scale delay-${i+1}`}>
          <div class="tt-stat-val">
            {val === '4.8' ? <><span data-count="4.8">0</span>★</> :
             val === '24'  ? <><span data-count="24">0</span>h</>  :
             <span data-count={val}>0</span>}
          </div>
          <div class="tt-stat-label">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="tt-section">
    <div class="tt-container" style="max-width:780px">
      <div class="tt-header reveal-up">
        <span class="sec-label">Common questions</span>
        <h2 class="tt-h2">Tee Times FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`tt-faq reveal-up delay-${(i % 4) + 1}`}>
          <summary class="tt-faq-q">{item.name}<span class="tt-faq-icon">+</span></summary>
          <p class="tt-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ INLINE BOOKING FORM — turns page from description to transaction ═══ -->
  <section class="tt-book tt-dark">
    <div class="tt-cta-glow"></div>
    <div class="tt-container" style="max-width:700px;position:relative;z-index:1">
      <div class="tt-header reveal-up" style="margin-bottom:36px">
        <span class="sec-label" style="color:#e8a850">Book your tee times now</span>
        <h2 class="tt-cta-h2 reveal-up">Grizzly Ranch. Nakoma Dragon.<br/><em>We get you on both.</em></h2>
        <p class="tt-cta-sub reveal-up delay-1">Tell us your dates, group size, and which courses. We confirm guaranteed tee times — including semi-private access — within 24 hours.</p>
      </div>
      <form class="tt-mini-form reveal-up delay-2" id="ttBookForm">
        <div class="tt-form-row">
          <div class="tt-form-group">
            <label class="tt-form-label">Your name</label>
            <input type="text" name="name" class="tt-form-input" placeholder="First name" required/>
          </div>
          <div class="tt-form-group">
            <label class="tt-form-label">Email</label>
            <input type="email" name="email" class="tt-form-input" placeholder="you@email.com" required/>
          </div>
        </div>
        <div class="tt-form-row">
          <div class="tt-form-group">
            <label class="tt-form-label">Preferred dates</label>
            <input type="text" name="dates" class="tt-form-input" placeholder="e.g. July 18–20, 2026"/>
          </div>
          <div class="tt-form-group">
            <label class="tt-form-label">Group size</label>
            <select name="group_size" class="tt-form-input">
              <option value="">Select...</option>
              <option>Solo / 2</option>
              <option>3–4 golfers</option>
              <option>5–8 golfers</option>
              <option>9–16 golfers</option>
              <option>17–30 golfers</option>
              <option>31+ golfers</option>
            </select>
          </div>
        </div>
        <div class="tt-form-group" style="margin-bottom:20px">
          <label class="tt-form-label">Courses you want (check all that apply)</label>
          <div class="tt-course-checks">
            {courses.map((c) => (
              <label class="tt-check-label">
                <input type="checkbox" name="courses" value={c.name}/> {c.name}
              </label>
            ))}
          </div>
        </div>
        <button type="submit" class="btn-green-glow tt-form-submit" id="ttSubmitBtn">
          Book My Tee Times →
        </button>
        <p class="tt-cta-trust" style="margin-top:14px">All 5 courses guaranteed · 4.8★ · Groups 4 to 200+ · Response in 24h</p>
        <div id="ttFormSuccess" style="display:none;margin-top:20px;padding:20px;background:rgba(26,122,64,.15);border:1px solid rgba(26,122,64,.3);border-radius:12px;text-align:center">
          <p style="color:#a8e6c0;font-size:15px;font-weight:600;margin:0">✅ Request received. We'll confirm your tee times within 24 hours.</p>
        </div>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('ttBookForm') as HTMLFormElement;
    const btn = document.getElementById('ttSubmitBtn') as HTMLButtonElement;
    const success = document.getElementById('ttFormSuccess') as HTMLElement;
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.textContent = 'Sending...';
        const fd = new FormData(form);
        const courses_selected = form.querySelectorAll('input[name="courses"]:checked');
        const courseList = Array.from(courses_selected).map((c: any) => c.value).join(', ');
        const payload = {
          name: fd.get('name'),
          email: fd.get('email'),
          message: `TEE TIMES REQUEST\nDates: ${fd.get('dates') || 'TBD'}\nGroup size: ${fd.get('group_size') || 'TBD'}\nCourses: ${courseList || 'TBD'}\nSource: /tee-times-graeagle/`,
          source: 'tee-times-graeagle',
          status: 'new',
        };
        try {
          await fetch('https://egplpluvbfsjrqzecnjf.supabase.co/rest/v1/gg_leads', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVncGxwbHV2YmZzanJxemVjbmpmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkzODQ2ODUsImV4cCI6MjA4NDk2MDY4NX0.siY1RnlsOBa7yiXFx8LmVhA08z33SfuGOx91_DlINBU',
              'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVncGxwbHV2YmZzanJxemVjbmpmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkzODQ2ODUsImV4cCI6MjA4NDk2MDY4NX0.siY1RnlsOBa7yiXFx8LmVhA08z33SfuGOx91_DlINBU',
              'Prefer': 'return=minimal',
            },
            body: JSON.stringify(payload),
          });
          form.style.display = 'none';
          success.style.display = 'block';
        } catch {
          btn.disabled = false;
          btn.textContent = 'Book My Tee Times →';
          alert('Something went wrong — please try again or call (888) 586-1157.');
        }
      });
    }
  </script>

  <RelatedTrips client:load slug="tee-times-graeagle" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
:root{--tt-gold:#e8a850;--tt-green:#1a7a40;--tt-dark:#0d1a0e;--tt-text:#1c1208;--tt-muted:rgba(28,18,8,0.52);--tt-border:rgba(28,18,8,0.08);--tt-r:20px}
.tt-container{max-width:1140px;margin:0 auto;padding:0 clamp(20px,6%,80px)}
.tt-section{padding:clamp(72px,9vw,120px) 0;background:var(--page-bg,#f8f5f0)}
.tt-dark{background:var(--tt-dark)!important}
.tt-header{text-align:center;margin-bottom:clamp(40px,5vw,68px)}
.tt-h2{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,52px);font-weight:500;color:var(--tt-text);line-height:1.1;margin:8px 0 0}
.tt-h2 em{font-style:italic;color:var(--tt-green)}

/* HERO */
.tt-hero{position:relative;min-height:90vh;display:flex;align-items:flex-end;overflow:hidden}
.tt-hero-img{position:absolute;inset:0;background-size:cover;background-position:center 35%;transform:scale(1.06);animation:ttZoom 10s ease forwards}
@keyframes ttZoom{to{transform:scale(1)}}
.tt-hero-overlay{position:absolute;inset:0;background:linear-gradient(158deg,rgba(13,26,14,.18) 0%,rgba(13,26,14,.62) 50%,rgba(13,26,14,.97) 100%)}
.tt-hero-inner{position:relative;z-index:2;padding:0 clamp(24px,8%,120px) clamp(60px,8vw,100px);max-width:820px}
.tt-eyebrow{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,168,80,.85);margin:0 0 18px}
.tt-h1{font-family:'Playfair Display',serif;font-size:clamp(46px,7.5vw,92px);font-weight:500;color:#f5f0e8;line-height:.98;margin:0 0 20px}
.tt-h1 em{font-style:italic;color:var(--tt-gold)}
.tt-subhead{font-size:clamp(16px,2vw,21px);color:rgba(245,240,232,.65);line-height:1.6;margin:0 0 28px}
.tt-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
