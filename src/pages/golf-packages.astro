---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';
import { fetchTripStats } from '../lib/tripStats';
const { minPrice, maxPrice, tripCount } = await fetchTripStats();


const title = "Graeagle Golf Packages — Tee Times, Lodging & Itineraries | GolfGraeagle.com";
const description = `Graeagle golf packages from $${minPrice}/golfer. Real pricing from 76 completed trips. Custom stay-and-play packages at 5 championship courses. Free quote in 24 hours.`;

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is included in a Graeagle golf package?", "acceptedAnswer": { "@type": "Answer", "text": "A GolfGraeagle package includes guaranteed tee times at your chosen courses, lodging coordination, and a day-by-day itinerary. Dining reservations available on request. Packages from ${minPrice} per golfer." } },
    { "@type": "Question", "name": "How much do Graeagle golf packages cost?", "acceptedAnswer": { "@type": "Answer", "text": "Real completed Graeagle golf packages range from $620 to $1,705 per person. A typical 2-night, 3-course package for a group of 12–24 runs $620–$875 per golfer. All pricing from real booked trips." } },
    { "@type": "Question", "name": "How many courses can I play in a Graeagle golf package?", "acceptedAnswer": { "@type": "Answer", "text": "Any combination of the 5 Graeagle courses. A 2-night package typically covers 2–3 courses. A 3-night covers 3–4. Most groups play 3 courses across 2–3 days." } },
    { "@type": "Question", "name": "Can I see real pricing from past Graeagle golf packages?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Browse 76 real completed packages at golfgraeagle.com/trips/ — course combinations, nights, group sizes, and price per person. Prices range from $620 to $1,705 per person." } },
    { "@type": "Question", "name": "How do I book a Graeagle golf package?", "acceptedAnswer": { "@type": "Answer", "text": "Submit a quote request with your dates, group size, and courses you want to play. GolfGraeagle responds within 24 hours with a custom proposal." } }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Golf Packages", "item": "https://golfgraeagle.com/golf-packages/" }
  ]
};
const orgSchema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": ["TravelAgency","Organization"], "@id": "https://golfgraeagle.com/#organization", "name": "GolfGraeagle.com", "url": "https://golfgraeagle.com",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
    { "@type": "WebPage", "@id": "https://golfgraeagle.com/golf-packages/#webpage", "url": "https://golfgraeagle.com/golf-packages/", "name": title }
  ]
};
const howToSchema = {
  "@context": "https://schema.org", "@type": "HowTo",
  "name": "How to Plan a Graeagle Golf Trip",
  "description": "Book a custom Graeagle golf package with tee times, lodging, and itinerary in three steps.",
  "totalTime": "PT24H",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Tell us what you want", "text": "Share your dates, group size, how many rounds, and which courses interest you. Takes 2 minutes." },
    { "@type": "HowToStep", "position": 2, "name": "Get your Graeagle golf itinerary in 24 hours", "text": "Tee times locked, lodging matched to your group, day-by-day schedule, all-in price." },
    { "@type": "HowToStep", "position": 3, "name": "Show up and play", "text": "We handle every detail of your Graeagle golf vacation. You handle the birdies." }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Graeagle Golf Packages",
  "description": "Custom stay and play golf packages at 5 championship courses in Graeagle, California. Tee times, lodging, and itinerary in one package.",
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Golf Trip Planning",
  "offers": { "@type": "AggregateOffer", "lowPrice": `${minPrice}`, "highPrice": `${maxPrice}`, "priceCurrency": "USD" }
};

// Real TripsCaddie data — verified from live API
const realTrips = [
  { vibe: 'Value',   price: 620,  nights: 2, rounds: 3, pax: 24, courses: 'Whitehawk + Graeagle Meadows + Plumas Pines', badge: '💰 Best Value',  hot: false,
    includes: ['Tee times at 3 courses', '2 nights lodging', 'Day-by-day itinerary', 'Group of 8–24'] },
  { vibe: 'Value',   price: 645,  nights: 2, rounds: 2, pax: 12, courses: 'Grizzly Ranch + Whitehawk Ranch',              badge: '⭐ Most Booked', hot: true,
    includes: ['Tee times at 2 top-rated courses', '2 nights lodging', 'Day-by-day itinerary', 'Group of 8–12'] },
  { vibe: 'Value',   price: 675,  nights: 2, rounds: 3, pax: 16, courses: 'Whitehawk + Graeagle Meadows + Grizzly Ranch', badge: '👥 Groups',      hot: false,
    includes: ['Tee times at 3 courses inc. Grizzly', '2 nights lodging', 'Itinerary + dining tips', 'Group of 12–24'] },
  { vibe: 'Premium', price: 876,  nights: 3, rounds: 3, pax: 16, courses: 'Plumas Pines + Whitehawk + Grizzly Ranch',     badge: '🏆 3-Night',     hot: false,
    includes: ['Tee times at 3 courses', '3 nights lodging', 'Full itinerary + dining res.', 'Group of 8–16'] },
  { vibe: 'Premium', price: 1120, nights: 3, rounds: 4, pax: 24, courses: 'Plumas + Grizzly Ranch + Nakoma Dragon',       badge: '🐉 Dragon',      hot: false,
    includes: ['Tee times at 4 courses inc. Nakoma', '3 nights at Inn at Nakoma', 'Fifty44 dining res.', 'Group of 16–24'] },
];

const courses = [
  { name: 'Graeagle Meadows', slug: 'graeagle-meadows-golf-packages', par: 72, yards: 6759, slope: 120, priceFrom: 620, badge: 'Since 1968',     badgeColor: '#2563eb', hero: '/wp-images/graeagle-meadows-hero.webp',  best: 'First-timers · Mixed groups' },
  { name: 'Whitehawk Ranch',  slug: 'whitehawk-ranch-golf-packages',  par: 71, yards: 6983, slope: 132, priceFrom: 620, badge: 'Top 20 CA',       badgeColor: '#1a7a40', hero: '/wp-images/whitehawk-hero.webp',           best: 'Competitive · All skill levels' },
  { name: 'Plumas Pines',     slug: 'plumas-pines-golf-packages',     par: 72, yards: 6504, slope: 132, priceFrom: 620, badge: 'Top 5 Value',     badgeColor: '#b45309', hero: '/wp-images/plumas-pines-hero.webp',        best: 'Shot-makers · Value seekers' },
  { name: 'Grizzly Ranch',    slug: 'grizzly-ranch-golf-packages',    par: 72, yards: 7411, slope: 140, priceFrom: 645, badge: '🏆 Top 100',      badgeColor: '#7c3aed', hero: '/wp-images/grizzly-ranch-hero.webp',      best: 'Low-handicap · Challenge' },
  { name: 'Nakoma — The Dragon', slug: 'nakoma-dragon-golf-packages', par: 72, yards: 7015, slope: 147, priceFrom: 876, badge: 'FLW Clubhouse',   badgeColor: '#be123c', hero: '/wp-images/nakoma-dragon-feather-river.webp', best: 'Bucket-list · Architecture lovers' },
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, howToSchema, serviceSchema]}
  canonical="https://golfgraeagle.com/golf-packages/"
  ogImage="https://golfgraeagle.com/wp-images/DJI_0965-Edit.webp"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="gp-hero">
    <div class="gp-hero-img" style="background-image:url(/wp-images/DJI_0965-Edit.webp)"></div>
    <div class="gp-hero-overlay"></div>
    <div class="gp-hero-inner">
      <p class="gp-eyebrow reveal-up">Graeagle Golf Trip Planning · 5 Courses · Sierra Nevada · Since 2004</p>
      <h1 class="gp-h1 reveal-up delay-1">Graeagle Golf<br/><em>Packages</em></h1>
      <p class="gp-subhead speakable reveal-up delay-2">Graeagle golf trip packages from $${minPrice}/golfer — stay and play golf packages with tee times, lodging, and a day-by-day golf itinerary. Real pricing. No surprises.</p>
      <div class="gp-pills reveal-up delay-3">
        <span class="gp-pill">From <strong>${minPrice}</strong>/golfer</span>
        <span class="gp-pill">⭐ 4.8 · 672 reviews</span>
        <span class="gp-pill">24hr quote</span>
        <span class="gp-pill">76 real trips</span>
      </div>
      <div class="gp-hero-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow gp-cta-main">Get a Free Quote →</a>
        <a href="/trips/" class="gp-cta-text underline-draw">Browse real pricing ↗</a>
      </div>
    </div>
    <div class="gp-scroll-hint reveal-fade delay-6">scroll</div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="gp-section">
    <div class="gp-container">
      <div class="gp-header reveal-up">
        <span class="sec-label">The process</span>
        <h2 class="gp-h2">How to Plan a<br/><em>Graeagle Golf Trip</em></h2>
      </div>
      <div class="gp-steps">
        <div class="gp-step glow-card reveal-left">
          <div class="gp-step-n">01</div>
          <div class="gp-step-icon">📋</div>
          <h3 class="gp-step-title">Pick your courses</h3>
          <p class="gp-step-body">5 courses, any combination. Tell us which ones you want and how many rounds. We'll recommend the right order based on skill level — or see our <a href="/graeagle-golf-itinerary/" style="color:var(--gp-green);font-weight:700;text-decoration:underline">day-by-day Graeagle golf itineraries</a> for 2, 3, 4 and 5-day trip plans.</p>
        </div>
        <div class="gp-step glow-card reveal-up delay-2">
          <div class="gp-step-n">02</div>
          <div class="gp-step-icon">💰</div>
          <h3 class="gp-step-title">Get a real price in 24h</h3>
          <p class="gp-step-body">Not an estimate. A real all-in number — tee times, lodging, dates locked — from actual booked trips like yours.</p>
        </div>
        <div class="gp-step glow-card reveal-right">
          <div class="gp-step-n">03</div>
          <div class="gp-step-icon">⛳</div>
          <h3 class="gp-step-title">Approve and we book everything</h3>
          <p class="gp-step-body">One invoice. We lock every tee time, confirm your rooms, and handle any dining reservations. You just show up.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ REAL PRICING — dark ═══ -->
  <section class="gp-section gp-dark">
    <div class="gp-container">
      <div class="gp-header reveal-up">
        <span class="sec-label">From the TripsCaddie archive</span>
        <h2 class="gp-h2 gp-h2-light">Real trips.<br/>Real prices.</h2>
        <p class="gp-pricing-intro">These are actual completed packages — not estimates. Group size, courses, and nights affect the final number.</p>
      </div>
      <div class="gp-trips-grid">
        {realTrips.map((t, i) => (
          <div class={`gp-trip-card reveal-scale delay-${i+1}${t.hot ? ' gp-trip-hot' : ''}`}>
            {t.hot && <div class="gp-hot-pill">Most Booked</div>}
            <div class="gp-trip-badge">{t.badge}</div>
            <div class="gp-trip-price">
              <span class="gp-trip-dollar">$</span>
              <span data-count={t.price} class="gp-trip-num">0</span>
              <span class="gp-trip-pp">/pp</span>
            </div>
            <div class="gp-trip-meta">
              <span>🌙 {t.nights}n</span>
              <span>⛳ {t.rounds}r</span>
              <span>👥 {t.pax} golfers</span>
            </div>
            <ul class="gp-trip-includes">
              {t.includes.map((item: string) => <li>✓ {item}</li>)}
            </ul>
            <p class="gp-trip-courses">e.g. {t.courses}</p>
            <div class={`gp-trip-vibe ${t.vibe.toLowerCase()}`}>{t.vibe}</div>
          </div>
        ))}
      </div>
      <p class="gp-archive-link reveal-up">
        <a href="/trips/" class="underline-draw" style="color:#e8a850;font-weight:700;">Browse all 76 real packages →</a>
      </p>
    </div>
  </section>

  <!-- ═══ THE 5 COURSES ═══ -->
  <section class="gp-section">
    <div class="gp-container">
      <div class="gp-header reveal-up">
        <span class="sec-label">Book tee times at all 5 Graeagle courses — mix and match any combination</span>
        <h2 class="gp-h2">The 5 courses</h2>
      </div>
      <div class="gp-courses-grid">
        {courses.map((c, i) => (
          <a href={`/portfolio/${c.slug}/`} class={`gp-course-card reveal-${i % 2 === 0 ? 'left' : 'right'} delay-${(i % 3) + 1}`}>
            <div class="gp-course-img" style={`background-image:url(${c.hero})`}>
              <div class="gp-course-fade"></div>
              <span class="gp-course-badge" style={`background:${c.badgeColor}`}>{c.badge}</span>
              <div class="gp-course-from">From <strong>${c.priceFrom}/pp</strong></div>
            </div>
            <div class="gp-course-body">
              <h3 class="gp-course-name">{c.name}</h3>
              <div class="gp-course-specs">
                <span>Par {c.par}</span><span class="gp-dot">·</span>
                <span>{c.yards.toLocaleString()} yds</span><span class="gp-dot">·</span>
                <span>Slope {c.slope}</span>
              </div>
              <p class="gp-course-best">{c.best}</p>
              <span class="gp-course-link underline-draw">View course →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STATS — dark ═══ -->
  <section class="gp-trust gp-dark">
    <div class="gp-container gp-trust-row">
      {[
        ['76', 'Real packages in archive'],
        ['620', 'Lowest price per person'],
        ['4.8', '672 verified reviews'],
        ['24', 'Hour quote turnaround'],
        ['2004', 'Year we started'],
      ].map(([val, label], i) => (
        <div class={`gp-stat reveal-scale delay-${i+1}`}>
          <div class="gp-stat-val">
            {val === '4.8' ? <><span data-count="4.8">0</span>★</> :
             val === '24'  ? <><span data-count="24">0</span>h</>  :
             <span data-count={val}>0</span>}
          </div>
          <div class="gp-stat-label">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="gp-section">
    <div class="gp-container" style="max-width:780px">
      <div class="gp-header reveal-up">
        <span class="sec-label">Common questions</span>
        <h2 class="gp-h2">Golf Package FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`gp-faq reveal-up delay-${(i % 4) + 1}`}>
          <summary class="gp-faq-q">{item.name}<span class="gp-faq-icon">+</span></summary>
          <p class="gp-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ FINAL CTA — dark ═══ -->
  <section class="gp-cta-section gp-dark">
    <div class="gp-cta-ring"></div>
    <div class="gp-container" style="text-align:center;max-width:660px;position:relative;z-index:1">
      <h2 class="gp-cta-h2 reveal-up">76 real trips. One<br/><em>free quote for yours.</em></h2>
      <p class="gp-cta-sub reveal-up delay-1">Every quote is built from actual booked packages — real courses, real lodging, real prices. Tell us your dates and group size. All-in number back in 24 hours.</p>
      <div class="reveal-scale delay-2">
        <a href="/request-a-quote/" class="btn-green-glow gp-cta-main">Get My Package Quote →</a>
        <p class="gp-cta-trust">From ${minPrice}/golfer · 72-hr cancellation · 4.8★ · 672 verified reviews</p>
      </div>
    </div>
  </section>

  <RelatedTrips client:load slug="golf-packages" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
/* ── Variables ── */
:root {
  --gp-gold: #e8a850; --gp-green: #1a7a40; --gp-dark: #0d1a0e;
  --gp-text: #1c1208; --gp-muted: rgba(28,18,8,0.52);
  --gp-border: rgba(28,18,8,0.08); --gp-r: 20px;
}

/* ── Layout ── */
.gp-container { max-width: 1140px; margin: 0 auto; padding: 0 clamp(20px,6%,80px); }
.gp-section { padding: clamp(72px,9vw,120px) 0; background: var(--page-bg,#f8f5f0); }
.gp-dark { background: var(--gp-dark) !important; }
.gp-header { text-align: center; margin-bottom: clamp(40px,5vw,68px); }
.gp-h2 { font-family:'Playfair Display',serif; font-size:clamp(30px,4vw,52px); font-weight:500; color:var(--gp-text); line-height:1.1; margin:8px 0 0; }
.gp-h2 em { font-style:italic; color:var(--gp-green); }
.gp-h2-light { color: #f0ece3; }
.gp-h2-light em { color: var(--gp-gold); }
.gp-pricing-intro { font-size:15px; color:rgba(245,240,232,0.72); max-width:480px; margin:16px auto 0; line-height:1.7; }

/* ── HERO ── */
.gp-hero { position:relative; min-height:90vh; display:flex; align-items:flex-end; overflow:hidden; }
.gp-hero-img { position:absolute; inset:0; background-size:cover; background-position:center 38%; transform:scale(1.06); animation:gpZoom 10s ease forwards; }
@keyframes gpZoom { to { transform:scale(1); } }
.gp-hero-overlay { position:absolute; inset:0; background:linear-gradient(158deg,rgba(13,26,14,0.18) 0%,rgba(13,26,14,0.62) 50%,rgba(13,26,14,0.97) 100%); }
.gp-hero-inner { position:relative; z-index:2; padding:0 clamp(24px,8%,120px) clamp(60px,8vw,100px); max-width:820px; }
.gp-eyebrow { font-size:11px; font-weight:700; letter-spacing:.22em; text-transform:uppercase; color:rgba(232,168,80,0.85); margin:0 0 18px; }
.gp-h1 { font-family:'Playfair Display',serif; font-size:clamp(46px,7.5vw,92px); font-weight:500; color:#f5f0e8; line-height:0.98; margin:0 0 20px; }
.gp-h1 em { font-style:italic; color:var(--gp-gold); }
.gp-subhead { font-size:clamp(16px,2vw,21px); color:rgba(245,240,232,0.65); line-height:1.6; margin:0 0 28px; }
.gp-pills { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:36px; }
.gp-pill { font-size:12px; font-weight:600; color:rgba(245,240,232,0.85); padding:7px 16px; background:rgba(255,255,255,0.1); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.18); border-radius:100px; }
.gp-pill strong { color:var(--gp-gold); }
.gp-hero-ctas { display:flex; gap:20px; align-items:center; flex-wrap:wrap; }
.gp-cta-main { display:inline-block; padding:15px 36px; border-radius:100px; font-size:15px; font-weight:700; text-decoration:none; }
.gp-cta-text { font-size:14px; font-weight:600; color:rgba(232,168,80,0.9); text-decoration:none; }
.gp-scroll-hint { position:absolute; bottom:28px; left:50%; transform:translateX(-50%); font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:rgba(245,240,232,0.28); z-index:2; }

/* ── HOW IT WORKS ── */
.gp-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; }
.gp-step { padding:40px 34px; border:1px solid var(--gp-border); background:#fff; transition:all .35s; position:relative; overflow:hidden; }
.gp-step:hover { transform:translateY(-5px); box-shadow:0 20px 48px rgba(0,0,0,0.09); border-color:rgba(232,168,80,0.35); }
.gp-step-n { font-family:'Playfair Display',serif; font-size:80px; font-weight:400; color:rgba(232,168,80,0.1); line-height:1; margin:-8px 0 -16px -4px; }
.gp-step-icon { font-size:34px; margin-bottom:16px; }
.gp-step-title { font-size:17px; font-weight:700; color:var(--gp-text); margin:0 0 10px; }
.gp-step-body { font-size:14px; color:var(--gp-muted); line-height:1.75; margin:0; }

/* ── PRICING CARDS ── */
.gp-trips-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; margin-bottom:28px; }
.gp-trip-card { background:rgba(255,255,255,0.09); border:1px solid rgba(245,240,232,0.18); border-radius:var(--gp-r); padding:26px 22px; transition:all .35s; position:relative; overflow:hidden; }
.gp-trip-card::after { content:''; position:absolute; inset:0; border-radius:var(--gp-r); background:linear-gradient(135deg,rgba(232,168,80,0.08),transparent); opacity:0; transition:opacity .3s; pointer-events:none; }
.gp-trip-card:hover { transform:translateY(-6px); border-color:rgba(232,168,80,0.3); box-shadow:0 24px 56px rgba(0,0,0,0.3); }
.gp-trip-card:hover::after { opacity:1; }
.gp-trip-hot { border-color:rgba(232,168,80,0.3) !important; background:rgba(232,168,80,0.05) !important; }
.gp-hot-pill { position:absolute; top:-1px; right:16px; background:var(--gp-gold); color:#1c1208; font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:.1em; padding:4px 12px; border-radius:0 0 10px 10px; }
.gp-trip-badge { font-size:10px; font-weight:800; color:var(--gp-gold); text-transform:uppercase; letter-spacing:.1em; margin-bottom:14px; }
.gp-trip-price { display:flex; align-items:baseline; gap:1px; margin-bottom:14px; }
.gp-trip-dollar { font-size:22px; color:var(--gp-gold); font-weight:700; }
.gp-trip-num { font-family:'Playfair Display',serif; font-size:42px; font-weight:500; color:#f5f0e8; line-height:1; }
.gp-trip-pp { font-size:13px; color:rgba(245,240,232,0.6); margin-left:3px; }
.gp-trip-meta { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:10px; }
.gp-trip-meta span { font-size:11px; color:rgba(245,240,232,0.78); }
.gp-trip-includes { list-style:none; margin:0 0 12px; padding:0; display:flex; flex-direction:column; gap:5px; }
.gp-trip-includes li { font-size:11px; color:rgba(245,240,232,0.85); display:flex; align-items:flex-start; gap:6px; line-height:1.4; }
.gp-trip-includes li::before { content: ''; }
.gp-trip-courses { font-size:11px; font-style:italic; color:rgba(245,240,232,0.48); line-height:1.55; margin:0 0 14px; }
.gp-trip-vibe { display:inline-block; font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:.12em; padding:3px 10px; border-radius:100px; }
.gp-trip-vibe.value { background:rgba(26,122,64,0.25); color:#52c27d; }
.gp-trip-vibe.premium { background:rgba(232,168,80,0.18); color:var(--gp-gold); }
