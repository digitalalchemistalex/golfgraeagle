---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TripsHub from '../components/TripsHub.tsx';
import { siteConfig } from '../data/content.js';

const pageTitle = "Graeagle Golf Trip Packages — Real Itineraries & Pricing | GolfGraeagle";
const pageDesc = "Browse real Graeagle golf trip packages with actual pricing from $620/person. See full itineraries, courses played, lodging used, and group size — then request the same trip for your group.";
const pageUrl = `${siteConfig.url}/trips/`;

// ItemList schema — will be hydrated client-side with real data
// Static fallback schema for crawlers
const schema = {
  "@type": "ItemList",
  "@id": `${pageUrl}#triplist`,
  "name": "Graeagle Golf Trip Packages — Real Itineraries",
  "description": "Real golf trip packages from GolfGraeagle.com featuring verified itineraries, actual pricing, courses played, and lodging used by real groups in the Graeagle region.",
  "url": pageUrl,
  "numberOfItems": 15,
};
---

<Base
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  schema={schema}
  ogImage="https://golfgraeagle.com/wp-images/DJI_0006-Edit.jpg"
  bodyClass="light-page"
>
  <Nav />

  <!-- Hero -->
  <section style="background:#0d1a0e;padding:120px clamp(20px,8%,120px) 72px;text-align:center;">
    <div style="max-width:720px;margin:0 auto;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#e8a850;margin-bottom:16px;">
        Real Trips · Real Pricing · Graeagle, CA
      </div>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,56px);font-weight:500;color:#ffffff;margin:0 0 20px;line-height:1.15;">
        Graeagle Golf Trip Packages
      </h1>
      <p style="font-size:clamp(15px,2vw,18px);color:rgba(255,255,255,0.55);margin:0 0 32px;line-height:1.7;max-width:580px;margin-left:auto;margin-right:auto;">
        Every package below is a real trip we've run — actual itinerary, actual price, actual group size.
        Pick one and we'll match it for your group, or customize it from scratch.
      </p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/request-a-quote/?ref=trips-page" class="btn-green-glow" style="font-size:14px;font-weight:700;padding:14px 32px;">
          Build My Custom Package →
        </a>
        <a href="#trips" style="display:inline-flex;align-items:center;gap:6px;font-size:14px;color:rgba(255,255,255,0.45);text-decoration:none;padding:14px 20px;border:1px solid rgba(255,255,255,0.12);border-radius:100px;transition:color 0.2s,border-color 0.2s;"
          onmouseover="this.style.color='rgba(255,255,255,0.8)';this.style.borderColor='rgba(255,255,255,0.3)'"
          onmouseout="this.style.color='rgba(255,255,255,0.45)';this.style.borderColor='rgba(255,255,255,0.12)'">
          Browse Trips ↓
        </a>
      </div>
    </div>
  </section>

  <!-- AEO stat bar -->
  <div style="background:#0a130a;border-top:1px solid rgba(232,168,80,0.1);border-bottom:1px solid rgba(232,168,80,0.1);padding:18px clamp(20px,8%,120px);">
    <div style="max-width:900px;margin:0 auto;display:flex;gap:32px;flex-wrap:wrap;justify-content:center;">
      {[
        ["$620", "Lowest price/person"],
        ["5 courses", "All within 25 min"],
        ["15 trips", "In this region"],
        ["24 hrs", "Quote turnaround"],
      ].map(([val, label]) => (
        <div style="text-align:center;">
          <div style="font-size:20px;font-weight:700;color:#e8a850;font-family:'Playfair Display',serif;">{val}</div>
          <div style="font-size:11px;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em;margin-top:2px;">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Main trips hub — React island -->
  <div id="trips">
    <TripsHub client:load />
  </div>

  <!-- AEO FAQ section -->
  <section style="background:#f7f3ec;padding:80px clamp(20px,8%,120px);">
    <div style="max-width:720px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:#1c1208;margin:0 0 40px;font-weight:400;">Common Questions About Graeagle Golf Packages</h2>
      {[
        ["How much does a Graeagle golf trip cost?",
         "Based on real trips we've run, Graeagle golf packages start at approximately $620 per person for a 2-night, 2-round trip. A 3-night, 3-round package with premium lodging typically runs $865–$1,120 per person. All pricing includes lodging and guaranteed tee times."],
        ["What's included in a Graeagle stay-and-play package?",
         "Every package includes confirmed tee times at your chosen courses, lodging (hotel, townhomes, or resort), and full trip coordination. Transportation and dining can be added. We handle everything — you just show up and play."],
        ["How many golfers do you need to book a group package?",
         "We build packages for groups of 4 to 200. The sweet spot is 8–20 golfers. Larger groups get better per-person rates and we can coordinate split lodging across multiple properties."],
        ["Can I customize an existing trip itinerary?",
         "Yes. Every trip shown here is a starting point. You can swap courses, change lodging, adjust nights, or add rounds. Request a quote and we'll send a custom itinerary within 24 hours."],
        ["What is the best time of year to golf in Graeagle?",
         "Graeagle courses are open May through November. Peak season is July through September — warmest weather, best course conditions. June and October offer excellent conditions with fewer crowds and better rates."],
        ["How far in advance should I book a Graeagle golf trip?",
         "For summer weekends (July–August), book 6–8 weeks out. Shoulder season (May–June, September–October) can often be arranged in 2–3 weeks. We maintain relationships with all 5 courses and can sometimes secure last-minute tee times."],
      ].map(([q, a]) => (
        <details style="border-bottom:1px solid rgba(28,18,8,0.08);padding:0;">
          <summary style="font-size:16px;color:#1c1208;font-weight:500;padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            {q}<span style="color:#e8a850;font-size:20px;flex-shrink:0;margin-left:16px;">+</span>
          </summary>
          <p style="font-size:14px;color:rgba(28,18,8,0.55);line-height:1.8;padding:0 0 20px;margin:0;">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="background:#0d1a0e;padding:80px clamp(20px,8%,120px);text-align:center;">
    <div style="max-width:560px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,38px);color:#ffffff;margin:0 0 16px;font-weight:400;">Ready to Build Your Trip?</h2>
      <p style="font-size:16px;color:rgba(255,255,255,0.45);margin:0 0 32px;line-height:1.65;">Tell us your group size, dates, and budget. We'll send a custom itinerary with confirmed tee times and lodging options within 24 hours — free, no obligation.</p>
      <a href="/request-a-quote/?ref=trips-bottom" class="btn-green-glow" style="font-size:15px;font-weight:700;padding:16px 40px;">
        Request a Free Quote →
      </a>
      <div style="margin-top:20px;font-size:12px;color:rgba(255,255,255,0.25);">+1-888-586-1157 · 24-hour response · 72-hour cancellation policy</div>
    </div>
  </section>

  <Footer />
</Base>
