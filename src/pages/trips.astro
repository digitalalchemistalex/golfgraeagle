---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TripsHub from '../components/TripsHub.tsx';
import { siteConfig, courses } from '../data/content.js';

// ── LIVE DATA AT BUILD TIME ────────────────────────────────────────────────
// Fetched from TripsCaddie API during astro build — never hardcoded
let graeagleTrips: any[] = [];
let minPrice = 620;
let totalGolfers = 0;
let tripCount = 0;

try {
  const res = await fetch('https://golfthehighsierra.com/trips-caddie/api/api-recaps.php');
  const all: any[] = await res.json();
  graeagleTrips = all.filter((t: any) => (t.region || '').toLowerCase() === 'graeagle');
  const prices = graeagleTrips
    .map((t: any) => t.pricePerPerson || t.pricePerPersonEstimate || 0)
    .filter(Boolean);
  minPrice = prices.length ? Math.min(...prices) : 620;
  totalGolfers = graeagleTrips.reduce((s: number, t: any) => s + (t.groupSize || 0), 0);
  tripCount = graeagleTrips.length;
} catch (e) {
  // fallback to known minimums
  minPrice = 620; tripCount = 15; totalGolfers = 358;
}

// Best 6 trips for static cards — premium first, then by group size
const staticTrips = [...graeagleTrips]
  .filter((t: any) => t.lodging && t.lodging !== 'TBD' && (t.nights || 0) > 0)
  .sort((a: any, b: any) => {
    const ap = (a.vibe || '').toLowerCase() === 'premium' ? 1 : 0;
    const bp = (b.vibe || '').toLowerCase() === 'premium' ? 1 : 0;
    if (bp !== ap) return bp - ap;
    return (b.groupSize || 0) - (a.groupSize || 0);
  })
  .slice(0, 6);

// Clean course names for display
function cleanCourse(name: string) {
  return name.replace(/ Golf Club$/, '').replace(/ Golf Course$/, '').replace(/ Golf Resort$/, '').replace(/ GC$/, '').trim();
}

// Clean lodging name
function cleanLodging(name: string) {
  return name.replace(/^Seven \(\d+\) /, '').replace(/Golf Resort \(Townhomes\)$/, 'Townhomes').trim();
}

const pageUrl = `${siteConfig.url}/trips/`;
const pageTitle = "Graeagle Golf Trip Packages — Real Itineraries & Pricing | GolfGraeagle";
const pageDesc = `Browse ${tripCount} real Graeagle golf trip packages from $${minPrice}/person. Actual itineraries, actual pricing, actual group sizes. Pick a trip and we'll match it for your group.`;

// ── SCHEMA ─────────────────────────────────────────────────────────────────
const tripListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${pageUrl}#triplist`,
  "name": "Graeagle Golf Trip Packages — Real Itineraries & Pricing",
  "description": `Real golf trip packages from GolfGraeagle.com. ${tripCount} verified itineraries with actual pricing, courses played, and lodging used by real groups in Graeagle, California.`,
  "url": pageUrl,
  "numberOfItems": tripCount,
  "itemListElement": staticTrips.map((t: any, i: number) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": `${t.groupName} — ${t.groupSize} Golfers, ${t.rounds} Rounds, $${(t.pricePerPerson || t.pricePerPersonEstimate).toLocaleString()}/person`,
    "description": `${t.nights}-night, ${t.rounds}-round golf package for ${t.groupSize} golfers. ${(t.courses || []).map(cleanCourse).join(', ')}. Lodging: ${cleanLodging(t.lodging || '')}. $${(t.pricePerPerson || t.pricePerPersonEstimate).toLocaleString()} per person all-inclusive.`,
    "url": `${pageUrl}?ref=schema`,
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "Golf Trip Packages", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does a Graeagle golf trip package cost?", "acceptedAnswer": { "@type": "Answer", "text": `Graeagle golf trip packages start from $${minPrice} per person based on real booked groups. Value packages (2 nights, 3 rounds) run $620–$875 per person. Premium packages (3 nights, 4 rounds, private townhomes) reach $1,067–$1,150. All prices include lodging, green fees, and taxes.` } },
    { "@type": "Question", "name": "Are these real Graeagle golf packages or estimated prices?", "acceptedAnswer": { "@type": "Answer", "text": `These are ${tripCount} real packages from actual booked groups arranged by GolfGraeagle.com. Every price, itinerary, group size, and course combination is verified — not an estimate or rack rate.` } },
    { "@type": "Question", "name": "Can I request the same trip shown in a package?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Any trip shown can be replicated for your group with the same courses, lodging, and structure — adjusted for your dates and headcount. Request a quote and reference the trip name." } },
    { "@type": "Question", "name": "What golf courses are in Graeagle golf packages?", "acceptedAnswer": { "@type": "Answer", "text": "Graeagle packages feature the 5 championship courses: Graeagle Meadows (par 72, slope 120), Whitehawk Ranch (par 71, slope 132, Top 20 CA 1998), Plumas Pines (par 72, slope 132), Grizzly Ranch (par 72, slope 140, Golf Digest Top 100 US 2021), and Nakoma Dragon (par 72, slope 147, FLW clubhouse). Most 2–3 night packages include 2–3 courses." } },
    { "@type": "Question", "name": "How many golfers can join a Graeagle golf group package?", "acceptedAnswer": { "@type": "Answer", "text": "GolfGraeagle.com builds packages for 4 to 200 golfers. The sweet spot is 8–36. Larger groups are split across multiple courses simultaneously for better pace of play and per-person pricing." } },
  ]
};

const schema = [tripListSchema, breadcrumbSchema, faqSchema];
---

<Base
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  schema={schema}
  ogImage="https://golfgraeagle.com/wp-images/DJI_0006-Edit.jpg"
  bodyClass="light-page"
>
  <Nav />

  <!-- Hero -->
  <section style="background:#0d1a0e;padding:120px clamp(20px,8%,120px) 72px;text-align:center;">
    <div style="max-width:760px;margin:0 auto;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#e8a850;margin-bottom:16px;">
        {tripCount} Real Trips · Verified Pricing · Graeagle, CA
      </div>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,56px);font-weight:500;color:#ffffff;margin:0 0 20px;line-height:1.1;">
        Real Graeagle Golf Trips.<br/><em style="color:rgba(255,255,255,0.45);font-style:italic;">Real prices. Real groups.</em>
      </h1>
      <p style="font-size:clamp(15px,2vw,18px);color:rgba(255,255,255,0.5);margin:0 0 32px;line-height:1.75;max-width:580px;margin-left:auto;margin-right:auto;">
        Every package here is a trip we've run — actual itinerary, actual cost, actual group size.
        Pick one, tell us your dates, and we'll match it for your group.
      </p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/request-a-quote/?ref=trips-page" class="btn-green-glow" style="font-size:14px;font-weight:700;padding:14px 32px;">
          Build My Custom Package →
        </a>
        <a href="#trips" style="display:inline-flex;align-items:center;gap:6px;font-size:14px;color:rgba(255,255,255,0.4);text-decoration:none;padding:14px 20px;border:1px solid rgba(255,255,255,0.1);border-radius:100px;transition:color 0.2s,border-color 0.2s;"
          onmouseover="this.style.color='rgba(255,255,255,0.75)';this.style.borderColor='rgba(255,255,255,0.25)'"
          onmouseout="this.style.color='rgba(255,255,255,0.4)';this.style.borderColor='rgba(255,255,255,0.1)'">
          Browse trips ↓
        </a>
      </div>
    </div>
  </section>

  <!-- Stat bar — all dynamic from API -->
  <div style="background:#0a130a;border-top:1px solid rgba(232,168,80,0.08);border-bottom:1px solid rgba(232,168,80,0.08);padding:20px clamp(20px,8%,120px);">
    <div style="max-width:900px;margin:0 auto;display:flex;gap:40px;flex-wrap:wrap;justify-content:center;">
      {[
        [`From $${minPrice}`, "per person, all-in"],
        [`${tripCount} packages`, "in this region"],
        [`${totalGolfers}+`, "golfers booked"],
        ["5 courses", "within 25 min"],
        ["24 hrs", "quote turnaround"],
      ].map(([val, label]) => (
        <div style="text-align:center;">
          <div style="font-size:20px;font-weight:700;color:#e8a850;font-family:'Playfair Display',serif;line-height:1;">{val}</div>
          <div style="font-size:10px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin-top:4px;">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Static trip cards — crawlable by Google, generated from live API data at build time -->
  <section style="background:#fff;padding:72px clamp(20px,8%,120px) 0;">
    <div style="max-width:1100px;margin:0 auto;">

      <!-- Section H2 — targets "graeagle golf trip packages" SERP intent, speaks to buyer psychology -->
      <div style="margin-bottom:40px;">
        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#e8a850;margin-bottom:10px;">Verified Trip Archive</div>
        <h2 style="font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,38px);font-weight:400;color:#1c1208;margin:0 0 12px;line-height:1.2;">
          Show up. Play golf. Go home happy.
        </h2>
        <p style="font-size:15px;color:rgba(28,18,8,0.5);max-width:560px;line-height:1.7;margin:0;">
          Every trip below is a Graeagle golf package we've built and delivered. Courses played, where they stayed, what they paid.
          Nothing estimated. Use any as your starting point — we'll customise from there.
        </p>
      </div>

      <!-- Cards — dynamic from API at build time -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(320px,100%),1fr));gap:20px;padding-bottom:32px;">
        {staticTrips.map((t: any) => {
          const price = t.pricePerPerson || t.pricePerPersonEstimate;
          const isPremium = (t.vibe || '').toLowerCase() === 'premium';
          const cleanCourses = (t.courses || []).map(cleanCourse);
          const lodgingClean = cleanLodging(t.lodging || '');
          return (
            <div style="background:#f8fbf8;border:1px solid #e0ece0;border-radius:16px;padding:22px;display:flex;flex-direction:column;gap:12px;">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <span style={`font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:3px 10px;border-radius:100px;${isPremium ? 'background:rgba(232,168,80,0.15);color:#92400e;' : 'background:rgba(16,185,129,0.1);color:#065f46;'}`}>
                  {t.vibe || 'Value'}
                </span>
                <span style="font-size:18px;font-weight:800;color:#1a7a40;">
                  ${price?.toLocaleString()}<span style="font-size:11px;font-weight:500;color:rgba(28,18,8,0.4);">/person</span>
                </span>
              </div>
              <div style="font-size:15px;font-weight:700;color:#1c1208;">{t.groupName}</div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
                {[["👥", `${t.groupSize} pax`], ["🌙", `${t.nights} nights`], ["⛳", `${t.rounds} rounds`]].map(([icon, val]) => (
                  <div style="text-align:center;background:#fff;border:1px solid rgba(28,18,8,0.07);border-radius:8px;padding:7px 4px;">
                    <div style="font-size:13px;margin-bottom:2px;">{icon}</div>
                    <div style="font-size:11px;font-weight:600;color:#1c1208;">{val}</div>
                  </div>
                ))}
              </div>
              <div>
                <div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(28,18,8,0.3);margin-bottom:5px;">Courses Played</div>
                <div style="display:flex;flex-wrap:wrap;gap:4px;">
                  {cleanCourses.map((c: string) => (
                    <span style="font-size:11px;color:#3a4a3e;background:#fff;border:1px solid rgba(28,18,8,0.1);border-radius:6px;padding:3px 8px;">{c}</span>
                  ))}
                </div>
              </div>
              <div style="font-size:11px;color:rgba(28,18,8,0.45);">🏨 {lodgingClean}</div>
              <a href={`/request-a-quote/?ref=trips-page&trip=${encodeURIComponent(t.groupName)}&partySize=${t.groupSize}&nights=${t.nights}&rounds=${t.rounds}&lodging=${encodeURIComponent(t.lodging||'')}&courses=${encodeURIComponent((t.courses||[]).join(','))}&vibe=${encodeURIComponent(t.vibe||'')}`}
                style="display:block;background:#2d7a3a;color:#fff;font-size:12px;font-weight:700;padding:11px;border-radius:100px;text-decoration:none;text-align:center;text-transform:uppercase;letter-spacing:0.05em;transition:background 0.2s;"
                onmouseover="this.style.background='#245f2d'" onmouseout="this.style.background='#2d7a3a'">
                Get This Trip →
              </a>
            </div>
          );
        })}
      </div>

      <div style="text-align:center;padding:0 0 16px;">
        <p style="font-size:13px;color:rgba(28,18,8,0.4);margin:0;">
          Showing {staticTrips.length} of {tripCount} Graeagle packages — filter and browse all below.
        </p>
      </div>
    </div>
  </section>

  <!-- Full interactive hub (React island — visible to users, not crawlers) -->
  <div id="trips">
    <TripsHub client:load />
  </div>

  <!-- AEO content — Why Graeagle section -->
  <section style="background:#0d1a0e;padding:80px clamp(20px,8%,120px);">
    <div style="max-width:1000px;margin:0 auto;">
      <!-- H2 targets "why golf graeagle" / "graeagle vs tahoe golf" comparison intent -->
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,38px);font-weight:400;color:#fff;margin:0 0 12px;line-height:1.2;">
        Five courses. Zero compromises.
      </h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.45);max-width:600px;line-height:1.75;margin:0 0 48px;">
        Every course within 25 minutes. Golf Digest Top 100. Frank Lloyd Wright clubhouse. Top 20 California.
        Graeagle puts five championship rounds in a single long weekend — without the Tahoe price tag or the Palm Springs summer heat.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(260px,100%),1fr));gap:16px;">
        {courses.map((c: any) => (
          <a href={`/portfolio/${c.slug}-golf-packages/`} style="display:block;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:20px;text-decoration:none;transition:background 0.2s,border-color 0.2s;"
            onmouseover="this.style.background='rgba(232,168,80,0.06)';this.style.borderColor='rgba(232,168,80,0.2)'"
            onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.borderColor='rgba(255,255,255,0.07)'">
            <div style="font-size:15px;font-weight:700;color:#fff;margin-bottom:4px;">{c.name}</div>
            <div style="font-size:11px;color:rgba(255,255,255,0.35);margin-bottom:8px;">Par {c.par} · Slope {c.slope} · {c.yards?.toLocaleString()} yds</div>
            {c.accolades?.[0] && <div style="font-size:10px;color:#e8a850;font-weight:600;">{c.accolades[0]}</div>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AEO content — Lodging section -->
  <section style="background:#f7f3ec;padding:80px clamp(20px,8%,120px);">
    <div style="max-width:900px;margin:0 auto;">
      <!-- H2 targets "graeagle golf lodging" / "stay and play graeagle" intent -->
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,38px);font-weight:400;color:#1c1208;margin:0 0 12px;line-height:1.2;">
        Stay on the courses. Wake up ready to play.
      </h2>
      <p style="font-size:15px;color:rgba(28,18,8,0.5);max-width:560px;line-height:1.75;margin:0 0 32px;">
        River Pines Resort handles groups of 8 to 52 in one block. Plumas Pines townhomes put you steps from the first tee.
        The Inn at Nakoma means dinner at a Frank Lloyd Wright building and a 60-second walk to your morning round.
        We match you to the right property for your group size, budget, and courses.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:12px;">
        {[
          { name:'River Pines Resort', tag:'Best for Groups', href:'/portfolio/river-pines-resort-graeagle-ca/' },
          { name:'Townhomes at Plumas Pines', tag:'Steps from the First Tee', href:'/portfolio/the-townhomes-at-plumas-pines/' },
          { name:'Inn at Nakoma', tag:'Frank Lloyd Wright', href:'/portfolio/the-inn-at-nakoma-clio-ca/' },
          { name:'Chalet View Lodge', tag:'Best Amenities', href:'/portfolio/chalet-view-lodge-graeagle-ca/' },
        ].map(l => (
          <a href={l.href} style="display:inline-flex;flex-direction:column;gap:2px;padding:14px 18px;background:#fff;border:1px solid rgba(28,18,8,0.1);border-radius:12px;text-decoration:none;transition:all 0.2s;"
            onmouseover="this.style.borderColor='#e8a850';this.style.background='rgba(232,168,80,0.04)'"
            onmouseout="this.style.borderColor='rgba(28,18,8,0.1)';this.style.background='#fff'">
            <span style="font-size:13px;font-weight:700;color:#1c1208;">{l.name}</span>
            <span style="font-size:11px;color:#a06c30;">{l.tag}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AEO content — Dining section -->
  <section style="background:#fff;padding:80px clamp(20px,8%,120px);">
    <div style="max-width:900px;margin:0 auto;">
      <!-- H2 targets "graeagle restaurants golf" / "where to eat graeagle" intent -->
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,38px);font-weight:400;color:#1c1208;margin:0 0 12px;line-height:1.2;">
        13 restaurants. Something for every night.
      </h2>
      <p style="font-size:15px;color:rgba(28,18,8,0.5);max-width:580px;line-height:1.75;margin:0 0 32px;">
        The Iron Door has been open since 1961 in a 1906 general store — book ahead for prime rib night.
        The Brewing Lair is 15 acres of Sierra forest and craft beer, perfect after a long day on Grizzly Ranch.
        Sardine Lake Resort books four weeks out. We'll build your dining plan alongside your tee sheet.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px;">
        {[
          ['Iron Door Restaurant', '/portfolio/iron-door-restaurant/'],
          ['Grizzly Grill', '/portfolio/grizzly-grill/'],
          ['Sardine Lake Resort', '/portfolio/sardine-lake-resort/'],
          ['The Brewing Lair', '/portfolio/the-brewing-lair/'],
          ['Longboards Bar & Grill', '/portfolio/longboards-bar-and-grill/'],
          ['Eureka Peak Brewing', '/portfolio/eureka-peak-brewing-co/'],
          ['Roadhouse at River Pines', '/portfolio/roadhouse-at-river-pines/'],
        ].map(([name, href]) => (
          <a href={href} style="font-size:12px;font-weight:600;color:#3a4a3e;padding:7px 14px;background:#f7f3ec;border:1px solid rgba(28,18,8,0.08);border-radius:100px;text-decoration:none;transition:all 0.15s;"
            onmouseover="this.style.background='rgba(232,168,80,0.1)';this.style.borderColor='rgba(168,140,90,0.3)'"
            onmouseout="this.style.background='#f7f3ec';this.style.borderColor='rgba(28,18,8,0.08)'">
            {name}
          </a>
        ))}
      </div>
      <a href="/dining/" style="font-size:13px;color:#a06c30;font-weight:600;text-decoration:none;">See all 13 Graeagle restaurants →</a>
    </div>
  </section>

  <!-- FAQ section — AEO optimised, speakable -->
  <section style="background:#f7f3ec;padding:80px clamp(20px,8%,120px);">
    <div style="max-width:720px;margin:0 auto;">
      <!-- H2 targets "graeagle golf trip questions" / FAQ intent -->
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,32px);font-weight:400;color:#1c1208;margin:0 0 8px;">
        Before you book — questions that actually matter.
      </h2>
      <p style="font-size:14px;color:rgba(28,18,8,0.45);margin:0 0 36px;">Straight answers. No upsell.</p>
      {[
        ["How much does a Graeagle golf trip cost?",
         `Based on real trips we've run, packages start from $${minPrice} per person for a 2-night, 2-round trip. A 3-night, 3-round package with private townhome lodging typically runs $865–$1,120 per person all-inclusive.`],
        ["What's included in a Graeagle stay-and-play package?",
         "Every package includes confirmed tee times at your chosen courses, lodging, and full trip coordination — one quote, one contact, one invoice. Transportation and banquet dinners are available as add-ons."],
        ["How many golfers can join a Graeagle group package?",
         "We build packages for groups of 4 to 200. The sweet spot is 8–36 golfers. Larger groups are split across multiple courses simultaneously for better pace of play and per-person pricing."],
        ["Can I customise an existing trip itinerary?",
         "Yes. Every trip shown is a starting point. Swap courses, change lodging, add nights, adjust rounds. Request a quote and we'll send a custom itinerary within 24 hours — no obligation."],
        ["What is the best time of year to golf in Graeagle?",
         "Courses open May through November. June, September, and October are the insider picks — excellent conditions, fewer crowds, and better rates than peak July–August."],
        ["How far in advance should I book Graeagle tee times?",
         "For summer weekends, 6–8 weeks ahead. Shoulder season can often be arranged in 2–3 weeks. We maintain relationships with all 5 courses and handle tee time coordination across the full trip."],
      ].map(([q, a]) => (
        <details style="border-bottom:1px solid rgba(28,18,8,0.08);padding:0;">
          <summary style="font-size:15px;color:#1c1208;font-weight:500;padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;" data-speakable>
            {q}<span style="color:#e8a850;font-size:20px;flex-shrink:0;margin-left:16px;">+</span>
          </summary>
          <p style="font-size:14px;color:rgba(28,18,8,0.55);line-height:1.8;padding:0 0 20px;margin:0;" data-speakable>{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="background:#0d1a0e;padding:80px clamp(20px,8%,120px);text-align:center;">
    <div style="max-width:560px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,40px);color:#ffffff;margin:0 0 16px;font-weight:400;line-height:1.15;">
        Your group. Your courses.<br/><em style="color:#e8a850;font-style:italic;">Done in 24 hours.</em>
      </h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.4);margin:0 0 32px;line-height:1.7;">Tell us your group size, dates, and budget. We'll send a custom itinerary with tee times and lodging locked — free, no obligation. Same-trip replications or built from scratch.</p>
      <a href="/request-a-quote/?ref=trips-bottom" class="btn-green-glow" style="font-size:15px;font-weight:700;padding:16px 40px;">
