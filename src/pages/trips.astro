---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TripsHub from '../components/TripsHub.tsx';
import { siteConfig } from '../data/content.js';

const pageTitle = "Graeagle Golf Trip Packages — Real Itineraries & Pricing | GolfGraeagle";
const pageDesc = "Browse real Graeagle golf trip packages with actual pricing from $620/person. See full itineraries, courses played, lodging used, and group size — then request the same trip for your group.";
const pageUrl = `${siteConfig.url}/trips/`;

// Static schema for Googlebot — real trip data baked in at build time
// TripsHub widget hydrates dynamically but crawlers get this
const tripListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `${pageUrl}#triplist`,
  "name": "Graeagle Golf Trip Packages — Real Itineraries & Pricing",
  "description": "Real golf trip packages from GolfGraeagle.com with verified itineraries, actual pricing, courses played, and lodging used by real groups in Graeagle, California.",
  "url": pageUrl,
  "numberOfItems": 15,
  "itemListElement": [
    {
      "@type": "ListItem", "position": 1,
      "name": "Graeagle River Pines Golf Group — 24 Golfers, 3 Rounds, $620/person",
      "description": "3-day, 2-night golf package for 24 golfers at River Pines Resort. Rounds at Whitehawk Ranch, Graeagle Meadows, and Plumas Pines. $620 per person all-inclusive.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 2,
      "name": "Graeagle Quick Hitter — 8 Golfers, 3 Rounds, $675/person",
      "description": "2-night, 3-round golf trip for 8 golfers at River Pines Resort. Whitehawk Ranch, Graeagle Meadows, and Grizzly Ranch. $675 per person.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 3,
      "name": "River Pines Golf Package — 52 Golfers, 3 Rounds + Banquet, $865/person",
      "description": "2-night, 3-round golf package for 52 golfers at River Pines Resort with banquet dinner and open bar. Plumas Pines, Whitehawk Ranch, Grizzly Ranch. $865 per person.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 4,
      "name": "Graeagle-Buckets Premium Trip — 24 Golfers, 4 Courses, 36-Hole Days, $1,120/person",
      "description": "3-night, 4-round bucket list trip for 24 golfers in townhomes at Plumas Pines. Plumas Pines, Grizzly Ranch, The Dragon at Nakoma, Whitehawk Ranch. 36-hole days Friday and Saturday. $1,120 per person.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 5,
      "name": "Plumas Pines Golf Group — 36 Golfers, 4 Rounds + Banquet, $1,150/person",
      "description": "3-night, 4-round corporate-style package for 36 golfers in townhomes at Plumas Pines. Grizzly Ranch, Whitehawk Ranch (36 holes), Plumas Pines. Awards banquet at Longboards. $1,150 per person.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 6,
      "name": "Graeagle Golf Trip — 30 Golfers, 3 Rounds, Private Homes, $1,067/person",
      "description": "3-night, 3-round golf trip for 30 golfers in private 3-bedroom townhomes at Plumas Pines. Each golfer assured own bedroom. Plumas Pines, Whitehawk Ranch, Grizzly Ranch. $1,067 per person.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 7,
      "name": "Graeagle Golf Trip — 16 Golfers, 3 Rounds, Private Townhomes, $876/person",
      "description": "3-night, 3-round premium trip for 16 golfers in private homes and townhomes at Plumas Pines Golf Resort. Plumas Pines, Whitehawk Ranch, Grizzly Ranch. $876 per person.",
      "url": `${pageUrl}?ref=schema`
    },
    {
      "@type": "ListItem", "position": 8,
      "name": "Graeagle Golf Trip — 12 Golfers, 2 Rounds, Townhomes, $645/person",
      "description": "2-night, 2-round value trip for 12 golfers in Plumas Pines townhomes. Grizzly Ranch and Whitehawk Ranch. $645 per person — best value entry point for Graeagle.",
      "url": `${pageUrl}?ref=schema`
    },
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "Golf Trip Packages", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a Graeagle golf trip package cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "Graeagle golf trip packages range from $620 to $1,150 per person depending on group size, number of nights, rounds played, and lodging type. Value packages (2 nights, 3 rounds, River Pines Resort) start at $620 per person for groups of 24. Premium packages (3 nights, 4 rounds, private townhomes) reach $1,120–$1,150 per person. All prices include lodging, green fees, and taxes." }
    },
    {
      "@type": "Question",
      "name": "Are these real golf trip packages or estimates?",
      "acceptedAnswer": { "@type": "Answer", "text": "These are real packages from actual booked groups. Every itinerary, price, group size, and course combination shown was a real trip arranged by GolfGraeagle.com. Prices reflect what groups actually paid, not estimates or rack rates." }
    },
    {
      "@type": "Question",
      "name": "Can I request the same trip shown in a package?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Any trip shown can be replicated for your group with the same courses, lodging, and structure — adjusted for your dates and headcount. Request a quote and reference the trip name." }
    },
    {
      "@type": "Question",
      "name": "What golf courses are in Graeagle golf packages?",
      "acceptedAnswer": { "@type": "Answer", "text": "Graeagle golf packages typically feature combinations of the 5 championship courses: Graeagle Meadows (par 72, slope 120), Whitehawk Ranch (par 71, slope 132, Top 20 CA), Plumas Pines (par 72, slope 132), Grizzly Ranch (par 72, slope 140, Golf Digest Top 100 US), and Nakoma Dragon (par 72, slope 147, FLW clubhouse). Most 2–3 night packages include 2–3 courses." }
    }
  ]
};

const schema = [tripListSchema, breadcrumbSchema, faqSchema];
---

<Base
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  schema={schema}
  ogImage="https://golfgraeagle.com/wp-images/DJI_0006-Edit.jpg"
  bodyClass="light-page"
>
  <Nav />

  <!-- Hero -->
  <section style="background:#0d1a0e;padding:120px clamp(20px,8%,120px) 72px;text-align:center;">
    <div style="max-width:720px;margin:0 auto;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#e8a850;margin-bottom:16px;">
        Real Trips · Real Pricing · Graeagle, CA
      </div>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,56px);font-weight:500;color:#ffffff;margin:0 0 20px;line-height:1.15;">
        Graeagle Golf Trip Packages
      </h1>
      <p style="font-size:clamp(15px,2vw,18px);color:rgba(255,255,255,0.55);margin:0 0 32px;line-height:1.7;max-width:580px;margin-left:auto;margin-right:auto;">
        Every package below is a real trip we've run — actual itinerary, actual price, actual group size.
        Pick one and we'll match it for your group, or customize it from scratch.
      </p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/request-a-quote/?ref=trips-page" class="btn-green-glow" style="font-size:14px;font-weight:700;padding:14px 32px;">
          Build My Custom Package →
        </a>
        <a href="#trips" style="display:inline-flex;align-items:center;gap:6px;font-size:14px;color:rgba(255,255,255,0.45);text-decoration:none;padding:14px 20px;border:1px solid rgba(255,255,255,0.12);border-radius:100px;transition:color 0.2s,border-color 0.2s;"
          onmouseover="this.style.color='rgba(255,255,255,0.8)';this.style.borderColor='rgba(255,255,255,0.3)'"
          onmouseout="this.style.color='rgba(255,255,255,0.45)';this.style.borderColor='rgba(255,255,255,0.12)'">
          Browse Trips ↓
        </a>
      </div>
    </div>
  </section>

  <!-- AEO stat bar -->
  <div style="background:#0a130a;border-top:1px solid rgba(232,168,80,0.1);border-bottom:1px solid rgba(232,168,80,0.1);padding:18px clamp(20px,8%,120px);">
    <div style="max-width:900px;margin:0 auto;display:flex;gap:32px;flex-wrap:wrap;justify-content:center;">
      {[
        ["$620", "Lowest price/person"],
        ["5 courses", "All within 25 min"],
        ["15 trips", "In this region"],
        ["24 hrs", "Quote turnaround"],
      ].map(([val, label]) => (
        <div style="text-align:center;">
          <div style="font-size:20px;font-weight:700;color:#e8a850;font-family:'Playfair Display',serif;">{val}</div>
          <div style="font-size:11px;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em;margin-top:2px;">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Main trips hub — React island -->
  <!-- Static trip summaries for Google — crawlable, baked at build time -->
  <section style="background:#fff;padding:64px clamp(20px,8%,120px) 0;">
    <div style="max-width:1100px;margin:0 auto;">
      <div style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:36px;">
        <div>
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:#e8a850;margin-bottom:8px;">Real Trips · Verified Pricing</div>
          <h2 style="font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,32px);font-weight:400;color:#1c1208;margin:0;">Graeagle Golf Packages — Real Itineraries</h2>
        </div>
        <p style="font-size:13px;color:rgba(28,18,8,0.45);max-width:380px;line-height:1.6;margin:0;">Every package below is a real trip. Actual group size, actual courses played, actual price paid.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(320px,100%),1fr));gap:20px;padding-bottom:32px;">
        {[
          { name:"Graeagle Quick Hitter", pax:8, nights:2, rounds:3, price:675, vibe:"Value", lodging:"River Pines Resort", courses:["Whitehawk Ranch","Graeagle Meadows","Grizzly Ranch"], note:"Best entry-level Graeagle trip — 3 top courses, 2 nights, River Pines on-site bar." },
          { name:"Graeagle River Pines Group", pax:24, nights:2, rounds:3, price:620, vibe:"Value", lodging:"River Pines Resort", courses:["Whitehawk Ranch","Graeagle Meadows","Plumas Pines"], note:"Best per-person value at scale. 24 golfers, $620/person all-in." },
          { name:"River Pines Golf Package", pax:52, nights:2, rounds:3, price:865, vibe:"Value", lodging:"River Pines Resort", courses:["Plumas Pines","Whitehawk Ranch","Grizzly Ranch"], note:"52-person group with banquet dinner and open bar. One invoice." },
          { name:"Graeagle Golf Trip", pax:16, nights:3, rounds:3, price:876, vibe:"Premium", lodging:"Private Homes at Plumas Pines", courses:["Plumas Pines","Whitehawk Ranch","Grizzly Ranch"], note:"Private home accommodations — every golfer gets their own bedroom." },
          { name:"Graeagle-Buckets Golf Trip", pax:24, nights:3, rounds:4, price:1120, vibe:"Premium", lodging:"Townhomes at Plumas Pines", courses:["Plumas Pines","Grizzly Ranch","The Dragon","Whitehawk Ranch"], note:"36-hole days Friday and Saturday. The Dragon + Golf Digest Top 100 in one trip." },
          { name:"Plumas Pines Golf Group", pax:36, nights:3, rounds:4, price:1150, vibe:"Premium", lodging:"Townhomes at Plumas Pines", courses:["Grizzly Ranch","Whitehawk Ranch","Plumas Pines"], note:"36-person corporate trip with awards banquet at Longboards." },
        ].map(t => (
          <div style="background:#f8fbf8;border:1px solid #e0ece0;border-radius:16px;padding:22px;display:flex;flex-direction:column;gap:12px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <span style={`font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:3px 10px;border-radius:100px;${t.vibe==='Premium'?'background:rgba(232,168,80,0.15);color:#92400e;':'background:rgba(16,185,129,0.1);color:#065f46;'}`}>{t.vibe}</span>
              <span style="font-size:18px;font-weight:800;color:#1a7a40;">${t.price.toLocaleString()}<span style="font-size:11px;font-weight:500;color:rgba(28,18,8,0.4);">/person</span></span>
            </div>
            <div style="font-size:16px;font-weight:700;color:#1c1208;">{t.name}</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
              {[["👥",t.pax+" pax"],["🌙",t.nights+" nights"],["⛳",t.rounds+" rounds"]].map(([icon,val]) => (
                <div style="text-align:center;background:#fff;border:1px solid rgba(28,18,8,0.07);border-radius:8px;padding:7px 4px;">
                  <div style="font-size:13px;margin-bottom:2px;">{icon}</div>
                  <div style="font-size:11px;font-weight:600;color:#1c1208;">{val}</div>
                </div>
              ))}
            </div>
            <p style="font-size:12px;color:rgba(28,18,8,0.5);line-height:1.5;font-style:italic;margin:0;">"{t.note}"</p>
            <div>
              <div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:rgba(28,18,8,0.3);margin-bottom:5px;">Courses Played</div>
              <div style="display:flex;flex-wrap:wrap;gap:4px;">
                {t.courses.map(c => (<span style="font-size:11px;color:#3a4a3e;background:#fff;border:1px solid rgba(28,18,8,0.1);border-radius:6px;padding:3px 8px;">{c}</span>))}
              </div>
            </div>
            <div style="font-size:11px;color:rgba(28,18,8,0.45);">🏨 {t.lodging}</div>
            <a href={`/request-a-quote/?ref=trips-page&trip=${encodeURIComponent(t.name)}&partySize=${t.pax}&nights=${t.nights}&rounds=${t.rounds}`}
              style="display:block;background:#2d7a3a;color:#fff;font-size:12px;font-weight:700;padding:11px;border-radius:100px;text-decoration:none;text-align:center;text-transform:uppercase;letter-spacing:0.05em;transition:background 0.2s;"
              onmouseover="this.style.background='#245f2d'" onmouseout="this.style.background='#2d7a3a'">
              Get This Trip →
            </a>
          </div>
        ))}
      </div>
      <div style="text-align:center;padding:0 0 16px;">
        <p style="font-size:13px;color:rgba(28,18,8,0.4);margin:0 0 8px;">Showing 6 of 15 Graeagle trips — filter and browse all packages below.</p>
      </div>
    </div>
  </section>

  <div id="trips">
    <TripsHub client:load />
  </div>

  <!-- AEO FAQ section -->
  <section style="background:#f7f3ec;padding:80px clamp(20px,8%,120px);">
    <div style="max-width:720px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:#1c1208;margin:0 0 40px;font-weight:400;">Common Questions About Graeagle Golf Packages</h2>
      {[
        ["How much does a Graeagle golf trip cost?",
         "Based on real trips we've run, Graeagle golf packages start at approximately $620 per person for a 2-night, 2-round trip. A 3-night, 3-round package with premium lodging typically runs $865–$1,120 per person. All pricing includes lodging and guaranteed tee times."],
        ["What's included in a Graeagle stay-and-play package?",
         "Every package includes confirmed tee times at your chosen courses, lodging (hotel, townhomes, or resort), and full trip coordination. Transportation and dining can be added. We handle everything — you just show up and play."],
        ["How many golfers do you need to book a group package?",
         "We build packages for groups of 4 to 200. The sweet spot is 8–20 golfers. Larger groups get better per-person rates and we can coordinate split lodging across multiple properties."],
        ["Can I customize an existing trip itinerary?",
         "Yes. Every trip shown here is a starting point. You can swap courses, change lodging, adjust nights, or add rounds. Request a quote and we'll send a custom itinerary within 24 hours."],
        ["What is the best time of year to golf in Graeagle?",
         "Graeagle courses are open May through November. Peak season is July through September — warmest weather, best course conditions. June and October offer excellent conditions with fewer crowds and better rates."],
        ["How far in advance should I book a Graeagle golf trip?",
         "For summer weekends (July–August), book 6–8 weeks out. Shoulder season (May–June, September–October) can often be arranged in 2–3 weeks. We maintain relationships with all 5 courses and can sometimes secure last-minute tee times."],
      ].map(([q, a]) => (
        <details style="border-bottom:1px solid rgba(28,18,8,0.08);padding:0;">
          <summary style="font-size:16px;color:#1c1208;font-weight:500;padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            {q}<span style="color:#e8a850;font-size:20px;flex-shrink:0;margin-left:16px;">+</span>
          </summary>
          <p style="font-size:14px;color:rgba(28,18,8,0.55);line-height:1.8;padding:0 0 20px;margin:0;">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="background:#0d1a0e;padding:80px clamp(20px,8%,120px);text-align:center;">
    <div style="max-width:560px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,38px);color:#ffffff;margin:0 0 16px;font-weight:400;">Ready to Build Your Trip?</h2>
      <p style="font-size:16px;color:rgba(255,255,255,0.45);margin:0 0 32px;line-height:1.65;">Tell us your group size, dates, and budget. We'll send a custom itinerary with confirmed tee times and lodging options within 24 hours — free, no obligation.</p>
      <a href="/request-a-quote/?ref=trips-bottom" class="btn-green-glow" style="font-size:15px;font-weight:700;padding:16px 40px;">
        Request a Free Quote →
      </a>
      <div style="margin-top:20px;font-size:12px;color:rgba(255,255,255,0.25);">+1-888-586-1157 · 24-hour response · 72-hour cancellation policy</div>
    </div>
  </section>

  <Footer />
</Base>
