---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';

const title = "Graeagle Stay and Play Golf Packages | GolfGraeagle.com";
const description = "Graeagle stay and play packages from $620/golfer. Tee times at all 5 courses + lodging in one package. 5 championship courses within 25 minutes. Free quote 24h.";

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is included in a Graeagle stay and play golf package?", "acceptedAnswer": { "@type": "Answer", "text": "A GolfGraeagle stay-and-play package includes guaranteed tee times, lodging coordination, and a full day-by-day itinerary. Dining reservations can be added. Packages from $620 per golfer." } },
    { "@type": "Question", "name": "How much does a Graeagle stay and play package cost?", "acceptedAnswer": { "@type": "Answer", "text": "Real completed stay-and-play packages range from $620 to $1,705 per person. A typical 2-night, 3-course package for 12–24 golfers runs $620–$875 per person including lodging and tee times." } },
    { "@type": "Question", "name": "How many courses can I play?", "acceptedAnswer": { "@type": "Answer", "text": "Any combination of the 5 Graeagle courses. Most 2-night packages cover 2–3 courses; 3-night covers 3–4. All 5 courses in one valley means no wasted driving time." } },
    { "@type": "Question", "name": "Which lodging is best for a stay and play golf trip?", "acceptedAnswer": { "@type": "Answer", "text": "River Pines Resort is most popular for golf groups — flexible rooms, pool, The Roadhouse on-site. Townhomes at Plumas Pines offer multi-bedroom units steps from the first tee. Inn at Nakoma puts you inside the Frank Lloyd Wright resort with The Dragon at your door." } },
    { "@type": "Question", "name": "Can GolfGraeagle book large group stay and play packages?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — groups of 4 to 200+ golfers served. Large groups use consecutive tee time blocks. GolfGraeagle coordinates all courses and lodging." } }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Stay and Play", "item": "https://golfgraeagle.com/stay-and-play/" }
  ]
};
const orgSchema = { "@context":"https://schema.org","@graph":[
  { "@type":["TravelAgency","Organization"],"@id":"https://golfgraeagle.com/#organization","name":"GolfGraeagle.com","url":"https://golfgraeagle.com",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
  { "@type":"WebPage","url":"https://golfgraeagle.com/stay-and-play/","name":title }
]};
const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Graeagle Stay and Play Golf Packages",
  "description": "Stay and play golf packages at 5 championship courses in Graeagle, California. Tee times and lodging bundled in one package from $620 per golfer.",
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Stay and Play Golf Package",
  "offers": { "@type": "AggregateOffer", "lowPrice": "620", "highPrice": "1705", "priceCurrency": "USD" }
};

const packages = [
  { name:'Weekend Starter',    priceRange:'$620–$645/pp', nights:'2', rounds:'2–3', pax:'8–24', hot:false,
    desc:'The valley intro. Whitehawk + Graeagle Meadows + Plumas Pines.',
    includes:['Tee times at 3 courses','2 nights lodging at River Pines or Townhomes','Day-by-day itinerary','Dining suggestions included'] },
  { name:'3-Night Sweet Spot', priceRange:'$645–$875/pp', nights:'3', rounds:'3–4', pax:'4–24', hot:true,
    desc:'Most popular format. Grizzly Ranch as the anchor round.',
    includes:['Tee times at 3–4 courses','3 nights lodging (River Pines or Chalet View)','Full itinerary + dining reservations','Quote in 24 hours'] },
  { name:'Dragon Run',         priceRange:'$876–$1,120/pp',nights:'3',rounds:'3–4',pax:'16–24',hot:false,
    desc:'Includes Nakoma Dragon — the Frank Lloyd Wright course.',
    includes:['Tee times at 4 courses incl. Nakoma','3 nights lodging (Chalet View or Nakoma Inn)','Fifty44 dining reservation','All logistics handled'] },
  { name:'Grand Tour',         priceRange:'$1,120–$1,705/pp',nights:'4–5',rounds:'5',pax:'4–24',hot:false,
    desc:'All 5 courses in one trip. The bucket-list Graeagle experience.',
    includes:['Tee times at all 5 courses','4–5 nights at Inn at Nakoma','All dining reservations','Single itinerary, one invoice'] },
];

const lodging = [
  { name:'River Pines Resort',   slug:'river-pines-resort-graeagle-ca',   tag:'Most Popular',    hero:'/wp-images/DJI_0949-Edit.webp',            desc:'Cabins, suites, pool, hot tub. The Roadhouse on-site. Best base for most golf groups.' },
  { name:'Chalet View Lodge',    slug:'chalet-view-lodge-graeagle-ca',    tag:'Best Amenities',   hero:'/wp-images/ChaletView-02.webp',             desc:'10 forested acres, spa, Eureka Peak Brewing on-site. 10 min from Graeagle village.' },
  { name:'The Inn at Nakoma',    slug:'the-inn-at-nakoma-clio-ca',         tag:'Bucket List Stay', hero:'/wp-images/nakoma-flw-lodge-exterior.webp', desc:'Steps from The Dragon first tee. Frank Lloyd Wright resort. Fifty44 Restaurant on-site.' },
  { name:'Townhomes at Plumas',  slug:'the-townhomes-at-plumas-pines',    tag:'Best for Groups',  hero:'/wp-images/2024-07-20.webp',               desc:'2–4BR units, full kitchens, pool — steps from Plumas Pines first tee.' },
];

const includes = [
  { icon:'⛳', title:'Guaranteed Tee Times',      body:'At any combination of the 5 courses — including Grizzly Ranch semi-private access.' },
  { icon:'🏨', title:'Lodging Matched to Group',   body:'On-course stays or village properties — matched to group size, nights, and budget.' },
  { icon:'📋', title:'Day-by-Day Itinerary',       body:'Tee times, driving directions, dining suggestions — everything in one document.' },
  { icon:'📞', title:'24-Hour Response',            body:'Every quote returned within 24 hours. Changes handled directly, no hold music.' },
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, serviceSchema]}
  canonical="https://golfgraeagle.com/stay-and-play/"
  ogImage="https://golfgraeagle.com/wp-images/grizzly-ranch-hero.webp"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="sap-hero">
    <div class="sap-bg" style="background-image:url(/wp-images/grizzly-ranch-hero.webp)"></div>
    <div class="sap-overlay"></div>
    <div class="sap-hero-inner">
      <p class="sap-eyebrow reveal-up">Graeagle Golf Vacation — California · Sierra Nevada</p>
      <h1 class="sap-h1 reveal-up delay-1">Stay and Play<br/><em>Golf Packages</em></h1>
      <p class="sap-sub speakable reveal-up delay-2">Graeagle stay and play golf packages — five championship courses, golf and lodging in one package, from $620/golfer. Everything handled.</p>
      <div class="sap-pills reveal-up delay-3">
        <span>From <strong>$620</strong>/golfer</span>
        <span>5 courses · 25 min apart</span>
        <span>4–200+ golfers</span>
        <span>Free quote · 24h</span>
      </div>
      <div class="sap-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow sap-btn">Get a Free Quote →</a>
        <a href="/trips/" class="sap-ghost underline-draw">See real pricing ↗</a>
      </div>
    </div>
    <!-- Floating stat cards — right side desktop -->
    <div class="sap-floats reveal-fade delay-5">
      <div class="sap-float"><div class="sap-float-val" data-count="76">0</div><div class="sap-float-lbl">Real Packages</div></div>
      <div class="sap-float"><div class="sap-float-val">4.8★</div><div class="sap-float-lbl">Avg Rating</div></div>
      <div class="sap-float"><div class="sap-float-val" data-count="2004">0</div><div class="sap-float-lbl">Est.</div></div>
    </div>
  </section>

  <!-- ═══ WHAT'S INCLUDED ═══ -->
  <section class="sap-section">
    <div class="sap-container">
      <div class="sap-header reveal-up">
        <span class="sec-label">What's included in a Graeagle stay and play package</span>
        <h2 class="sap-h2">You play.<br/><em>We handle everything else.</em></h2>
      </div>
      <div class="sap-includes">
        {includes.map((item, i) => (
          <div class={`sap-inc glow-card reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="sap-inc-icon">{item.icon}</div>
            <h3 class="sap-inc-title">{item.title}</h3>
            <p class="sap-inc-body">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PACKAGES — dark ═══ -->
  <section class="sap-section sap-dark">
    <div class="sap-container">
      <div class="sap-header reveal-up">
        <span class="sec-label" style="color:#e8a850">Real pricing from the archive</span>
        <h2 class="sap-h2 sap-h2-light">Package options</h2>
      </div>
      <div class="sap-pkgs">
        {packages.map((p, i) => (
          <div class={`sap-pkg reveal-scale delay-${i+1}${p.hot?' sap-pkg-hot':''}`}>
            {p.hot && <div class="sap-hot-tag">Most Popular</div>}
            <div class="sap-pkg-label">{p.name}</div>
            <div class="sap-pkg-price">{p.priceRange}</div>
            <div class="sap-pkg-meta">
              <span>🌙 {p.nights}n</span><span>⛳ {p.rounds}r</span><span>👥 {p.pax}</span>
            </div>
            <p class="sap-pkg-desc">{p.desc}</p>
            <ul class="sap-pkg-includes">
              {p.includes.map((item: string) => <li>✓ {item}</li>)}
            </ul>
            <a href="/request-a-quote/" class="sap-pkg-cta underline-draw">Get this package →</a>
          </div>
        ))}
      </div>
      <p class="sap-note reveal-up">Based on real completed trips · <a href="/trips/" class="underline-draw" style="color:#e8a850;font-weight:700;">Browse full archive →</a></p>
    </div>
  </section>

  <!-- ═══ LODGING ═══ -->
  <section class="sap-section">
    <div class="sap-container">
      <div class="sap-header reveal-up">
        <span class="sec-label">Golf and lodging packages — all coordinated through GolfGraeagle</span>
        <h2 class="sap-h2">Where you'll stay</h2>
      </div>
      <div class="sap-lodging">
        {lodging.map((l, i) => (
          <a href={`/portfolio/${l.slug}/`} class={`sap-lodge reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="sap-lodge-img" style={`background-image:url(${l.hero})`}>
              <div class="sap-lodge-fade"></div>
              <span class="sap-lodge-tag">{l.tag}</span>
            </div>
            <div class="sap-lodge-body">
              <h3 class="sap-lodge-name">{l.name}</h3>
              <p class="sap-lodge-desc">{l.desc}</p>
              <span class="sap-lodge-link underline-draw">View lodging →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="sap-section">
    <div class="sap-container" style="max-width:760px">
      <div class="sap-header reveal-up">
        <span class="sec-label">Quick answers</span>
        <h2 class="sap-h2">Stay and Play FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`sap-faq reveal-up delay-${(i%4)+1}`}>
          <summary class="sap-faq-q">{item.name}<span class="sap-faq-icon">+</span></summary>
          <p class="sap-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ CTA — dark ═══ -->
  <section class="sap-cta sap-dark">
    <div class="sap-cta-glow"></div>
    <div class="sap-container" style="text-align:center;max-width:640px;position:relative;z-index:1">
      <h2 class="sap-cta-h2 reveal-up">Build your Graeagle<br/><em>stay and play package</em></h2>
      <p class="sap-cta-sub reveal-up delay-1">Dates, group size, courses you want. Quote back in 24 hours, no obligation.</p>
      <div class="reveal-scale delay-2">
        <a href="/request-a-quote/" class="btn-green-glow sap-btn">Request a Free Quote →</a>
        <p style="font-size:12px;color:rgba(245,240,232,0.28);margin-top:14px;">No obligation · 72-hr cancellation · 4.8★ rated</p>
      </div>
    </div>
  </section>

  <RelatedTrips client:load slug="stay-and-play" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
:root{--sap-gold:#e8a850;--sap-green:#1a7a40;--sap-dark:#0d1a0e;--sap-text:#1c1208;--sap-muted:rgba(28,18,8,0.52);--sap-border:rgba(28,18,8,0.08);--sap-r:20px}
.sap-container{max-width:1140px;margin:0 auto;padding:0 clamp(20px,6%,80px)}
.sap-section{padding:clamp(72px,9vw,120px) 0;background:var(--page-bg,#f8f5f0)}
.sap-dark{background:var(--sap-dark)!important}
.sap-header{text-align:center;margin-bottom:clamp(40px,5vw,68px)}
.sap-h2{font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,50px);font-weight:500;color:var(--sap-text);line-height:1.1;margin:8px 0 0}
.sap-h2 em{font-style:italic;color:var(--sap-green)}
.sap-h2-light{color:#f5f0e8!important}
.sap-h2-light em{color:var(--sap-gold)!important}

/* HERO */
.sap-hero{position:relative;min-height:90vh;display:grid;grid-template-columns:1fr}
.sap-bg{position:absolute;inset:0;background-size:cover;background-position:center 28%;transform:scale(1.07);animation:sapZoom 10s ease forwards}
@keyframes sapZoom{to{transform:scale(1)}}
.sap-overlay{position:absolute;inset:0;background:linear-gradient(155deg,rgba(13,26,14,.2) 0%,rgba(13,26,14,.65) 52%,rgba(13,26,14,.97) 100%)}
.sap-hero-inner{position:relative;z-index:2;padding:clamp(100px,16vh,160px) clamp(24px,8%,120px) clamp(56px,8vw,90px);align-self:end}
.sap-eyebrow{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,168,80,.82);margin:0 0 18px}
.sap-h1{font-family:'Playfair Display',serif;font-size:clamp(44px,7vw,88px);font-weight:500;color:#f5f0e8;line-height:.98;margin:0 0 18px}
.sap-h1 em{font-style:italic;color:var(--sap-gold)}
.sap-sub{font-size:clamp(16px,2vw,21px);color:rgba(245,240,232,.6);line-height:1.55;margin:0 0 26px}
.sap-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px}
.sap-pills span{font-size:12px;font-weight:600;color:rgba(245,240,232,.8);padding:6px 15px;background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.18);border-radius:100px}
.sap-pills strong{color:var(--sap-gold)}
.sap-ctas{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.sap-btn{display:inline-block;padding:15px 36px;border-radius:100px;font-size:15px;font-weight:700;text-decoration:none}
.sap-ghost{font-size:14px;font-weight:600;color:rgba(232,168,80,.9);text-decoration:none}
/* Float cards */
.sap-floats{position:absolute;right:clamp(24px,5%,72px);bottom:clamp(56px,8vw,90px);display:flex;flex-direction:column;gap:10px;z-index:3}
.sap-float{background:rgba(255,255,255,.1);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:14px 22px;text-align:center;min-width:116px}
.sap-float-val{font-family:'Playfair Display',serif;font-size:26px;color:var(--sap-gold);font-weight:400;line-height:1}
.sap-float-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.45);margin-top:5px}

/* INCLUDES */
.sap-includes{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px}
.sap-inc{padding:36px 32px;border:1px solid var(--sap-border);background:#fff;transition:all .35s;position:relative;overflow:hidden}
.sap-inc:hover{transform:translateY(-5px);box-shadow:0 20px 48px rgba(0,0,0,.08);border-color:rgba(232,168,80,.3)}
.sap-inc-icon{font-size:34px;margin-bottom:16px}
.sap-inc-title{font-size:17px;font-weight:700;color:var(--sap-text);margin:0 0 10px}
.sap-inc-body{font-size:14px;color:var(--sap-muted);line-height:1.75;margin:0}

/* PACKAGES */
.sap-pkgs{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;margin-bottom:24px}
.sap-pkg{border:1px solid rgba(245,240,232,.2);border-radius:var(--sap-r);padding:30px 26px;background:rgba(255,255,255,.1);transition:all .35s;position:relative}
.sap-pkg:hover{transform:translateY(-5px);border-color:rgba(232,168,80,.32);box-shadow:0 22px 52px rgba(0,0,0,.25)}
.sap-pkg-hot{border-color:rgba(232,168,80,.3)!important;background:rgba(232,168,80,.05)!important}
.sap-hot-tag{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--sap-gold);color:#1c1208;font-size:9px;font-weight:800;padding:4px 14px;border-radius:0 0 10px 10px;text-transform:uppercase;letter-spacing:.1em;white-space:nowrap}
.sap-pkg-label{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,240,232,.7);margin-bottom:10px}
.sap-pkg-price{font-family:'Playfair Display',serif;font-size:22px;color:var(--sap-gold);font-weight:400;margin-bottom:14px}
.sap-pkg-meta{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px}
.sap-pkg-meta span{font-size:11px;color:rgba(245,240,232,.8)}
.sap-pkg-includes{list-style:none;margin:0 0 16px;padding:0;display:flex;flex-direction:column;gap:6px}
.sap-pkg-includes li{font-size:11px;color:rgba(245,240,232,.88);display:flex;align-items:flex-start;gap:6px;line-height:1.45}
.sap-pkg-desc{font-size:13px;color:rgba(245,240,232,.72);line-height:1.68;margin:0 0 18px}
.sap-pkg-cta{font-size:12px;font-weight:700;color:var(--sap-gold);text-decoration:none}
.sap-note{text-align:center;font-size:14px;color:rgba(245,240,232,.65);margin:0}

/* LODGING */
.sap-lodging{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:22px}
.sap-lodge{border-radius:var(--sap-r);overflow:hidden;text-decoration:none;background:#fff;border:1px solid var(--sap-border);box-shadow:0 2px 14px rgba(0,0,0,.05);transition:all .38s;display:flex;flex-direction:column}
.sap-lodge:hover{transform:translateY(-7px);box-shadow:0 28px 64px rgba(0,0,0,.13);border-color:rgba(232,168,80,.45)}
.sap-lodge-img{height:200px;background-size:cover;background-position:center;position:relative}
.sap-lodge-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(9,15,9,.7) 0%,transparent 52%)}
.sap-lodge-tag{position:absolute;top:12px;right:12px;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#fff;background:rgba(0,0,0,.48);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.18);padding:4px 10px;border-radius:100px}
.sap-lodge-body{padding:20px 22px 22px;flex:1;display:flex;flex-direction:column}
.sap-lodge-name{font-size:16px;font-weight:700;color:var(--sap-text);margin:0 0 8px}
.sap-lodge-desc{font-size:13px;color:var(--sap-muted);line-height:1.62;flex:1;margin:0 0 14px}
.sap-lodge-link{font-size:12px;font-weight:700;color:var(--sap-green);text-decoration:none}
.sap-lodge:hover .sap-lodge-link{color:var(--sap-gold)}

/* FAQ */
.sap-faq{border-bottom:1px solid var(--sap-border)}
.sap-faq[open]{background:rgba(232,168,80,.03);border-radius:12px;border-color:rgba(232,168,80,.22)}
.sap-faq-q{font-size:15px;font-weight:600;color:var(--sap-text);padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px}
.sap-faq-q::-webkit-details-marker{display:none}
.sap-faq[open] .sap-faq-q{color:var(--sap-green)}
.sap-faq-icon{font-size:24px;color:var(--sap-gold);flex-shrink:0;transition:transform .3s}
.sap-faq[open] .sap-faq-icon{transform:rotate(45deg)}
.sap-faq-a{font-size:14px;color:var(--sap-muted);line-height:1.82;padding:0 0 20px;margin:0}

/* CTA */
.sap-cta{padding:clamp(80px,10vw,132px) 0;position:relative;overflow:hidden}
.sap-cta-glow{position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(26,122,64,.18) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.sap-cta-h2{font-family:'Playfair Display',serif;font-size:clamp(30px,5.5vw,56px);color:#f5f0e8;font-weight:500;line-height:1.15;margin:0 0 18px}
.sap-cta-h2 em{color:var(--sap-gold);font-style:italic}
.sap-cta-sub{font-size:16px;color:rgba(245,240,232,.76);line-height:1.75;margin:0 0 36px}

@media(max-width:900px){
  .sap-hero{min-height:100svh}
  .sap-floats{display:none}
  .sap-pkgs{grid-template-columns:1fr 1fr}
  .sap-lodging{grid-template-columns:1fr}
}
@media(max-width:540px){.sap-pkgs{grid-template-columns:1fr}}
</style>
