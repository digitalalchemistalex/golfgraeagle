---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';
import { fetchTripStats } from '../lib/tripStats';
const { minPrice, tripCount } = await fetchTripStats();

const title = "Graeagle Golf Resort — 4 Properties, 5 Courses, One Valley | GolfGraeagle.com";
const description = `Graeagle golf resort packages — 4 lodging properties and 5 championship courses within 25 minutes. Golf Digest Top 100, Frank Lloyd Wright clubhouse. Packages from $${minPrice}/golfer.`;

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is there a golf resort in Graeagle California?", "acceptedAnswer": { "@type": "Answer", "text": "Graeagle has four resort and lodge properties within 15 minutes of each other: River Pines Resort, Chalet View Lodge, The Inn at Nakoma (inside the Frank Lloyd Wright clubhouse), and the Townhomes at Plumas Pines. All are bookable as part of stay-and-play golf packages through GolfGraeagle.com." } },
    { "@type": "Question", "name": "What is the best golf resort in Graeagle?", "acceptedAnswer": { "@type": "Answer", "text": "The best Graeagle golf resort depends on group size and preference. The Inn at Nakoma is the most unique — 42 rooms inside the only Frank Lloyd Wright-designed golf clubhouse, with The Dragon course on-site. River Pines Resort is best for groups of 8–60 wanting everything in one property. Townhomes at Plumas Pines is best for groups wanting on-course lodging with full kitchens." } },
    { "@type": "Question", "name": "How many golf courses are near Graeagle resorts?", "acceptedAnswer": { "@type": "Answer", "text": "Five championship courses are within 25 minutes of all Graeagle resort properties: Graeagle Meadows (par 72, slope 120), Whitehawk Ranch (par 71, slope 132, Top 20 California), Plumas Pines (par 72, slope 132), Grizzly Ranch (par 72, slope 140, Golf Digest Top 100), and Nakoma Dragon (par 72, slope 147, Golf World Top 75, Frank Lloyd Wright clubhouse)." } },
    { "@type": "Question", "name": "How much does a Graeagle golf resort package cost?", "acceptedAnswer": { "@type": "Answer", "text": `Graeagle golf resort packages start from $${minPrice} per golfer for a 2-night, 2–3 round stay-and-play. Premium packages with The Inn at Nakoma and 4 courses reach $1,705 per person. All packages include guaranteed tee times, lodging, and a day-by-day itinerary.` } },
    { "@type": "Question", "name": "Is Graeagle golf cheaper than Lake Tahoe resorts?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Graeagle resort packages run 40–60% less than comparable Truckee or North Tahoe resort packages, while offering equal or better course quality — including Golf Digest Top 100 (Grizzly Ranch) and Golf World Top 75 (Nakoma Dragon)." } },
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Lodging", "item": "https://golfgraeagle.com/lodging/" },
    { "@type": "ListItem", "position": 3, "name": "Graeagle Golf Resort", "item": "https://golfgraeagle.com/graeagle-golf-resort/" }
  ]
};
const orgSchema = {
  "@context": "https://schema.org", "@graph": [
    { "@type": ["TravelAgency","Organization"], "@id": "https://golfgraeagle.com/#organization",
      "name": "GolfGraeagle.com", "url": "https://golfgraeagle.com",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
    { "@type": "WebPage", "url": "https://golfgraeagle.com/graeagle-golf-resort/", "name": title }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Graeagle Golf Resort Packages",
  "description": `Stay-and-play golf resort packages in Graeagle — 4 properties, 5 championship courses from $${minPrice}/golfer.`,
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Golf Resort Package",
  "offers": { "@type": "AggregateOffer", "lowPrice": `${minPrice}`, "highPrice": "1705", "priceCurrency": "USD" }
};

const properties = [
  {
    name: 'River Pines Resort',
    slug: 'river-pines-resort-graeagle-ca',
    badge: 'Best for Groups',
    badgeColor: '#1a7a40',
    tagline: 'Family-owned 40+ years. Pool, hot tub, casino, The Roadhouse on-site.',
    bestFor: 'Groups of 8–60 wanting everything in one property',
    distance: '5 min via Hwy 89',
    rooms: 'Cabins, suites, and lodge rooms',
    courses: 3,
    hero: '/wp-images/River-Pines-Resort.jpg',
    highlights: ['Pool + hot tub + casino on-site', 'The Roadhouse bar and grill', 'Group rates for 8–60 golfers', 'Direct Plumas Pines golf access'],
  },
  {
    name: 'The Inn at Nakoma',
    slug: 'the-inn-at-nakoma-clio-ca',
    badge: 'Most Unique',
    badgeColor: '#7c3aed',
    tagline: '42 rooms inside the Frank Lloyd Wright clubhouse. The Dragon on-site.',
    bestFor: 'Bucket-list trips, premium groups, FLW architecture enthusiasts',
    distance: '15 min via Hwy 89',
    rooms: '42 rooms and suites',
    courses: 2,
    hero: '/wp-images/nakoma-inn-lobby-fireplace.jpg',
    highlights: ['Only Frank Lloyd Wright-designed golf clubhouse', 'Golf World Top 75 Dragon course on-site', 'Heated pool, spa, hot tubs', 'Fifty44 Restaurant & Bar on-site'],
  },
  {
    name: 'Chalet View Lodge',
    slug: 'chalet-view-lodge-graeagle-ca',
    badge: 'Most Scenic',
    badgeColor: '#b45309',
    tagline: '10 forested acres. Spa, executive course, Eureka Peak Brewing on-site.',
    bestFor: 'Couples, smaller groups, those wanting a spa and brewery',
    distance: '10 min via Hwy 89',
    rooms: 'Lodge rooms, terrace suites, cabins',
    courses: 4,
    hero: '/wp-images/chalet-view-lodge-exterior.jpg',
    highlights: ['10 forested acres in the Sierra Nevada', 'Spa + 9-hole executive course on-site', 'Eureka Peak Brewing Co. on property', '4 championship courses within 12 min'],
  },
  {
    name: 'Townhomes at Plumas Pines',
    slug: 'the-townhomes-at-plumas-pines',
    badge: 'On-Course',
    badgeColor: '#0369a1',
    tagline: 'Steps from the 1st tee. Full kitchens, private decks, golf course views.',
    bestFor: 'Groups of 8–20 wanting on-course lodging with kitchen + deck',
    distance: 'Adjacent to Plumas Pines',
    rooms: '2–4 bedroom townhomes',
    courses: 5,
    hero: '/wp-images/plumas-pines-townhomes-exterior.webp',
    highlights: ['Steps from Plumas Pines 1st tee', 'Full kitchens — cook your own meals', 'Private decks with golf course views', 'Pool, tennis, game lounge on-site'],
  },
];

const courses = [
  { name: 'Graeagle Meadows', slug: 'graeagle-meadows-golf-packages', par: 72, slope: 120, badge: 'Opener', color: '#2563eb' },
  { name: 'Whitehawk Ranch', slug: 'whitehawk-ranch-golf-packages', par: 71, slope: 132, badge: 'Top 20 CA', color: '#1a7a40' },
  { name: 'Plumas Pines', slug: 'plumas-pines-golf-packages', par: 72, slope: 132, badge: 'Best Value', color: '#b45309' },
  { name: 'Grizzly Ranch', slug: 'grizzly-ranch-golf-packages', par: 72, slope: 140, badge: 'Top 100', color: '#7c3aed' },
  { name: 'Nakoma — Dragon', slug: 'nakoma-dragon-golf-packages', par: 72, slope: 147, badge: 'FLW Club', color: '#be123c' },
];

const compareRows = [
  { label: 'Best for', rp: 'Groups 8–60', cv: 'Couples + small groups', inn: 'Premium / bucket-list', tp: 'Groups 8–20 + families' },
  { label: 'On-site dining', rp: 'The Roadhouse', cv: 'Eureka Peak Brewing', inn: 'Fifty44 Restaurant', tp: 'None — full kitchens' },
  { label: 'Pool / hot tub', rp: '✅ Both', cv: '✅ Pool + spa', inn: '✅ Heated pool + 2 hot tubs', tp: '✅ Pool + tennis' },
  { label: 'Closest course', rp: 'Plumas Pines (5 min)', cv: 'Whitehawk Ranch (8 min)', inn: 'Nakoma Dragon (on-site)', tp: 'Plumas Pines (steps)' },
  { label: 'Group pricing', rp: 'Best for 12–60', cv: 'Best for 4–16', inn: 'Best for 8–24', tp: 'Best for 8–20' },
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, serviceSchema]}
  canonical="https://golfgraeagle.com/graeagle-golf-resort/"
  ogImage="https://golfgraeagle.com/wp-images/DJI_0965-Edit.webp"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="gr-hero">
    <div class="gr-hero-img" style="background-image:url(/wp-images/DJI_0965-Edit.webp)"></div>
    <div class="gr-hero-overlay"></div>
    <div class="gr-hero-inner">
      <p class="gr-eyebrow reveal-up">Graeagle Golf Resort · Sierra Nevada · Graeagle, CA</p>
      <h1 class="gr-h1 reveal-up delay-1">Graeagle Golf Resort.<br/><em>4 Properties. 5 Courses.</em></h1>
      <p class="gr-subhead speakable reveal-up delay-2">Golf Digest Top 100 and a Frank Lloyd Wright clubhouse in one Sierra Nevada valley. Four resort properties — from on-course townhomes to the only FLW golf lodge in the world. Packages from $${minPrice}/golfer.</p>
      <div class="gr-pills reveal-up delay-3">
        <span class="gr-pill">4 resort properties</span>
        <span class="gr-pill">5 championship courses</span>
        <span class="gr-pill">⭐ 4.8 · 672 reviews</span>
        <span class="gr-pill">40% below Tahoe</span>
      </div>
      <div class="gr-hero-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow gr-cta-main">Plan My Resort Package →</a>
        <a href="/lodging/" class="gr-cta-ghost underline-draw">Browse all lodging ↗</a>
      </div>
    </div>
    <div class="gr-floats reveal-fade delay-5">
      <div class="gr-float"><div class="gr-float-val">4</div><div class="gr-float-lbl">Resort properties</div></div>
      <div class="gr-float"><div class="gr-float-val">5</div><div class="gr-float-lbl">Championship courses</div></div>
      <div class="gr-float"><div class="gr-float-val">4.8★</div><div class="gr-float-lbl">672 reviews</div></div>
    </div>
  </section>

  <!-- ═══ 4 PROPERTIES — light ═══ -->
  <section class="gr-section">
    <div class="gr-container">
      <div class="gr-header reveal-up">
        <span class="sec-label">Choose your base — all bookable as golf packages</span>
        <h2 class="gr-h2">The 4 Graeagle<br/><em>resort properties</em></h2>
      </div>
      <div class="gr-props-grid">
        {properties.map((p, i) => (
          <a href={`/portfolio/${p.slug}/`} class={`gr-prop-card glow-card reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="gr-prop-img" style={`background-image:url(${p.hero})`}>
              <div class="gr-prop-fade"></div>
              <span class="gr-prop-badge" style={`background:${p.badgeColor}`}>{p.badge}</span>
            </div>
            <div class="gr-prop-body">
              <h3 class="gr-prop-name">{p.name}</h3>
              <p class="gr-prop-tagline">{p.tagline}</p>
              <div class="gr-prop-meta">
                <span>📍 {p.distance}</span>
                <span>🛏 {p.rooms}</span>
                <span>⛳ {p.courses} courses nearby</span>
              </div>
              <div class="gr-prop-best">Best for: {p.bestFor}</div>
              <span class="gr-prop-link underline-draw">View packages →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ COMPARISON TABLE — dark ═══ -->
  <section class="gr-section gr-dark">
    <div class="gr-container">
      <div class="gr-header reveal-up">
        <span class="sec-label" style="color:#e8a850">Side by side — pick the right property for your group</span>
        <h2 class="gr-h2" style="color:#f5f0e8">How the 4 properties<br/><em>compare</em></h2>
      </div>
      <div class="gr-table-wrap reveal-up delay-1">
        <table class="gr-table">
          <thead>
            <tr>
              <th class="gr-th gr-th-left"></th>
              <th class="gr-th">River Pines</th>
              <th class="gr-th">Chalet View</th>
              <th class="gr-th">Inn at Nakoma</th>
              <th class="gr-th">Townhomes</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map((r, i) => (
              <tr class="gr-tr">
                <td class="gr-td gr-td-label">{r.label}</td>
                <td class="gr-td">{r.rp}</td>
                <td class="gr-td">{r.cv}</td>
                <td class="gr-td">{r.inn}</td>
                <td class="gr-td">{r.tp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ 5 COURSES — light ═══ -->
  <section class="gr-section">
    <div class="gr-container">
      <div class="gr-header reveal-up">
        <span class="sec-label">All within 25 minutes of every resort property</span>
        <h2 class="gr-h2">5 courses at your<br/><em>Graeagle resort base</em></h2>
      </div>
      <div class="gr-courses-row">
        {courses.map((c, i) => (
          <a href={`/portfolio/${c.slug}/`} class={`gr-course-pill glow-card reveal-scale delay-${i+1}`}>
            <span class="gr-course-badge" style={`background:${c.color}`}>{c.badge}</span>
            <div class="gr-course-name">{c.name}</div>
            <div class="gr-course-specs">Par {c.par} · Slope {c.slope}</div>
          </a>
        ))}
      </div>
      <p class="gr-footer-note reveal-up">
        Not sure which courses to play or in what order? See our <a href="/graeagle-golf-itinerary/" style="color:var(--gr-green);font-weight:700">day-by-day Graeagle golf itineraries</a> — 2, 3, 4 and 5-day plans sequenced by difficulty.
      </p>
    </div>
  </section>

  <!-- ═══ WHY GRAEAGLE OVER TAHOE — dark ═══ -->
  <section class="gr-section gr-dark">
    <div class="gr-container" style="max-width:800px;text-align:center">
      <div class="gr-header reveal-up">
        <span class="sec-label" style="color:#e8a850">Same mountains. Better golf value.</span>
        <h2 class="gr-h2 reveal-up" style="color:#f5f0e8;margin-top:10px">Graeagle vs Lake Tahoe<br/><em>golf resorts</em></h2>
      </div>
      <div class="gr-why-grid">
        {[
          ['🏆', 'Golf Digest Top 100 + Golf World Top 75', 'Grizzly Ranch and Nakoma Dragon — both nationally ranked — in the same valley. No Tahoe resort area has both.'],
          ['💰', `40–60% cheaper than Tahoe`, `Comparable course quality and lodging. Graeagle packages from $${minPrice}/golfer vs $1,200–$1,800 at Truckee/Tahoe resorts.`],
          ['🚗', 'No resort traffic or I-80 congestion', 'Highway 70 through the Feather River Canyon. No Truckee bottlenecks. No Kings Beach traffic. 2.5 hours from Sacramento.'],
          ['⛳', '5 courses in 25 minutes', 'All 5 Graeagle courses within one valley. Play a different course every day without long drives between properties.'],
        ].map(([icon, title, body], i) => (
          <div class={`gr-why-card glow-card reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="gr-why-icon">{icon}</div>
            <div class="gr-why-title">{title}</div>
            <p class="gr-why-body">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STATS ═══ -->
  <section class="gr-trust gr-dark">
    <div class="gr-container gr-trust-row">
      {[
        [`$${minPrice}`, 'Starting per golfer'],
        ['4', 'Resort properties'],
        ['5', 'Championship courses'],
        ['4.8★', '672 verified reviews'],
        ['40%', 'Below Tahoe pricing'],
      ].map(([val, label], i) => (
        <div class={`gr-stat reveal-scale delay-${i+1}`}>
          <div class="gr-stat-val">{val}</div>
          <div class="gr-stat-label">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="gr-section">
    <div class="gr-container" style="max-width:780px">
      <div class="gr-header reveal-up">
        <span class="sec-label">Common questions about Graeagle golf resorts</span>
        <h2 class="gr-h2">Graeagle Golf Resort FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`gr-faq reveal-up delay-${(i%4)+1}`}>
          <summary class="gr-faq-q">{item.name}<span class="gr-faq-icon">+</span></summary>
          <p class="gr-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="gr-cta-section gr-dark">
    <div class="gr-cta-glow"></div>
    <div class="gr-container" style="text-align:center;max-width:660px;position:relative;z-index:1">
      <h2 class="gr-cta-h2 reveal-up">Pick your property.<br/><em>We handle everything else.</em></h2>
      <p class="gr-cta-sub reveal-up delay-1">Tell us your dates, group size, and which property interests you. We send a full resort package — tee times at your chosen courses, lodging confirmed, day-by-day itinerary included — within 24 hours.</p>
      <div class="reveal-scale delay-2">
        <a href="/request-a-quote/" class="btn-green-glow gr-cta-main">Plan My Graeagle Resort Trip →</a>
        <p class="gr-cta-trust">From $${minPrice}/golfer · 4 properties · 5 courses · 4.8★ · 24h response</p>
      </div>
    </div>
  </section>

  <RelatedTrips client:load slug="graeagle-golf-resort" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
:root{--gr-gold:#e8a850;--gr-green:#1a7a40;--gr-dark:#0d1a0e;--gr-text:#1c1208;--gr-muted:rgba(28,18,8,0.52);--gr-border:rgba(28,18,8,0.08)}
.gr-container{max-width:1140px;margin:0 auto;padding:0 clamp(20px,6%,80px)}
.gr-section{padding:clamp(72px,9vw,120px) 0;background:var(--page-bg,#f8f5f0)}
.gr-dark{background:var(--gr-dark)!important}
.gr-header{text-align:center;margin-bottom:clamp(40px,5vw,68px)}
.gr-h2{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,52px);font-weight:500;color:var(--gr-text);line-height:1.1;margin:8px 0 0}
.gr-h2 em{font-style:italic;color:var(--gr-green)}
.gr-footer-note{text-align:center;font-size:14px;color:var(--gr-muted);max-width:600px;margin:28px auto 0;line-height:1.7}

/* HERO */
.gr-hero{position:relative;min-height:90vh;display:flex;align-items:flex-end;overflow:hidden}
.gr-hero-img{position:absolute;inset:0;background-size:cover;background-position:center 40%;transform:scale(1.06);animation:grZoom 10s ease forwards}
@keyframes grZoom{to{transform:scale(1)}}
.gr-hero-overlay{position:absolute;inset:0;background:linear-gradient(158deg,rgba(13,26,14,.18) 0%,rgba(13,26,14,.62) 50%,rgba(13,26,14,.97) 100%)}
.gr-hero-inner{position:relative;z-index:2;padding:0 clamp(24px,8%,120px) clamp(60px,8vw,100px);max-width:820px}
.gr-eyebrow{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,168,80,.85);margin:0 0 18px}
.gr-h1{font-family:'Playfair Display',serif;font-size:clamp(42px,7vw,88px);font-weight:500;color:#f5f0e8;line-height:.98;margin:0 0 20px}
.gr-h1 em{font-style:italic;color:var(--gr-gold)}
.gr-subhead{font-size:clamp(16px,2vw,20px);color:rgba(245,240,232,.65);line-height:1.6;margin:0 0 28px}
.gr-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
.gr-pill{font-size:12px;font-weight:600;color:rgba(245,240,232,.85);padding:7px 16px;background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.18);border-radius:100px}
.gr-hero-ctas{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.gr-cta-main{display:inline-block;padding:15px 36px;border-radius:100px;font-size:15px;font-weight:700;text-decoration:none}
.gr-cta-ghost{font-size:14px;font-weight:600;color:rgba(232,168,80,.9);text-decoration:none}
.gr-floats{position:absolute;right:clamp(24px,5%,72px);bottom:clamp(56px,8vw,90px);display:flex;flex-direction:column;gap:10px;z-index:3}
.gr-float{background:rgba(255,255,255,.1);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:14px 22px;text-align:center;min-width:116px}
.gr-float-val{font-family:'Playfair Display',serif;font-size:26px;color:var(--gr-gold);font-weight:400;line-height:1}
.gr-float-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.45);margin-top:5px}

/* PROPERTY CARDS */
.gr-props-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px}
.gr-prop-card{border-radius:20px;overflow:hidden;text-decoration:none;background:#fff;border:1px solid var(--gr-border);transition:all .35s;display:flex;flex-direction:column}
.gr-prop-card:hover{transform:translateY(-6px);box-shadow:0 24px 56px rgba(0,0,0,.12);border-color:rgba(232,168,80,.4)}
.gr-prop-img{height:200px;background-size:cover;background-position:center;position:relative;flex-shrink:0}
.gr-prop-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(9,15,9,.7) 0%,transparent 50%)}
.gr-prop-badge{position:absolute;top:12px;left:12px;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#fff;padding:4px 10px;border-radius:100px}
.gr-prop-body{padding:20px;flex:1;display:flex;flex-direction:column;gap:8px}
.gr-prop-name{font-family:'Playfair Display',serif;font-size:18px;color:var(--gr-text);font-weight:500;margin:0}
.gr-prop-tagline{font-size:13px;color:var(--gr-muted);line-height:1.5;margin:0;flex:1}
.gr-prop-meta{display:flex;flex-direction:column;gap:3px;font-size:11px;color:rgba(28,18,8,.4)}
.gr-prop-best{font-size:11px;font-weight:700;color:var(--gr-green);background:rgba(26,122,64,.06);padding:6px 10px;border-radius:8px}
.gr-prop-link{font-size:12px;font-weight:700;color:var(--gr-gold)}

/* COMPARISON TABLE */
.gr-table-wrap{overflow-x:auto;border-radius:14px;border:1px solid rgba(245,240,232,.1)}
.gr-table{width:100%;border-collapse:collapse;font-size:12px;min-width:600px}
.gr-th{padding:12px 10px;text-align:center;background:rgba(245,240,232,.06);border-bottom:1px solid rgba(245,240,232,.1);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:rgba(245,240,232,.5)}
.gr-th-left{text-align:left}
.gr-tr{border-bottom:1px solid rgba(245,240,232,.06)}
.gr-tr:hover{background:rgba(245,240,232,.03)}
.gr-td{padding:12px 10px;text-align:center;color:rgba(245,240,232,.65);font-size:12px;vertical-align:top}
.gr-td-label{text-align:left;font-weight:700;color:rgba(245,240,232,.9);font-size:12px;white-space:nowrap}

/* COURSES ROW */
.gr-courses-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px}
.gr-course-pill{border-radius:16px;padding:16px 12px;text-decoration:none;background:#fff;border:1px solid var(--gr-border);transition:all .3s;text-align:center;display:flex;flex-direction:column;gap:6px;align-items:center}
.gr-course-pill:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.1);border-color:rgba(232,168,80,.4)}
.gr-course-badge{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#fff;padding:3px 10px;border-radius:100px}
.gr-course-name{font-size:12px;font-weight:700;color:var(--gr-text);line-height:1.3}
.gr-course-specs{font-size:10px;color:var(--gr-muted)}

/* WHY GRID */
.gr-why-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;text-align:left;margin-top:32px}
.gr-why-card{border-radius:18px;padding:24px;background:rgba(255,255,255,.05);border:1px solid rgba(245,240,232,.1);display:flex;flex-direction:column;gap:8px}
.gr-why-icon{font-size:26px}
.gr-why-title{font-size:14px;font-weight:700;color:#f5f0e8}
.gr-why-body{font-size:12px;color:rgba(245,240,232,.65);line-height:1.6;margin:0}

/* TRUST */
.gr-trust{padding:clamp(48px,6vw,80px) 0}
.gr-trust-row{display:grid;grid-template-columns:repeat(5,1fr);gap:24px;text-align:center}
.gr-stat-val{font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,40px);color:var(--gr-gold);font-weight:400;line-height:1;margin-bottom:8px}
.gr-stat-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.55)}

/* FAQ */
.gr-faq{border-bottom:1px solid var(--gr-border)}
.gr-faq[open]{background:rgba(232,168,80,.03);border-radius:12px;border-color:rgba(232,168,80,.22)}
.gr-faq-q{font-size:15px;font-weight:600;color:var(--gr-text);padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px}
.gr-faq-q::-webkit-details-marker{display:none}
.gr-faq[open] .gr-faq-q{color:var(--gr-green)}
.gr-faq-icon{font-size:24px;color:var(--gr-gold);flex-shrink:0;transition:transform .3s}
.gr-faq[open] .gr-faq-icon{transform:rotate(45deg)}
.gr-faq-a{font-size:14px;color:var(--gr-muted);line-height:1.82;padding:0 0 20px;margin:0}

/* CTA */
.gr-cta-section{padding:clamp(80px,10vw,132px) 0;position:relative;overflow:hidden}
.gr-cta-glow{position:absolute;width:720px;height:720px;border-radius:50%;background:radial-gradient(circle,rgba(26,122,64,.18) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.gr-cta-h2{font-family:'Playfair Display',serif;font-size:clamp(28px,5vw,52px);color:#f5f0e8;font-weight:500;line-height:1.15;margin:0 0 20px}
.gr-cta-h2 em{color:var(--gr-gold);font-style:italic}
.gr-cta-sub{font-size:16px;color:rgba(245,240,232,.75);line-height:1.75;margin:0 0 36px}
.gr-cta-trust{font-size:12px;color:rgba(245,240,232,.3);margin-top:14px}

/* Mobile */
@media(max-width:900px){.gr-floats{display:none}.gr-courses-row{grid-template-columns:repeat(3,1fr)}.gr-trust-row{grid-template-columns:repeat(3,1fr)}.gr-why-grid{grid-template-columns:1fr}}
@media(max-width:540px){.gr-props-grid{grid-template-columns:1fr}.gr-courses-row{grid-template-columns:1fr 1fr}.gr-trust-row{grid-template-columns:1fr 1fr}}
</style>
