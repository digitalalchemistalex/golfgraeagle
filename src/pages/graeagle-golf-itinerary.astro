---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';

const title = "Graeagle Golf Itinerary — 2, 3, 4 & 5-Day Plans | GolfGraeagle.com";
const description = "Real Graeagle golf itineraries for every trip length. 2-day, 3-day, and 4-day sample schedules with course order, lodging, and dining. Custom itineraries from $620/golfer.";

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the best 3-day Graeagle golf itinerary?", "acceptedAnswer": { "@type": "Answer", "text": "Day 1: Graeagle Meadows (slope 120 — warm up, mixed-handicap friendly). Day 2: Whitehawk Ranch (slope 132 — meadow and forest layout). Day 3: Grizzly Ranch (Golf Digest Top 100, slope 140 — the challenge round). Lodging at River Pines Resort. Dinner at Sardine Lake Resort on night 2 — book 4 weeks ahead." } },
    { "@type": "Question", "name": "How many courses can you play in a Graeagle golf itinerary?", "acceptedAnswer": { "@type": "Answer", "text": "A 2-day itinerary covers 2 courses. A 3-day covers 3–4 courses. A 4–5-day itinerary can include all 5 Graeagle courses. All five are within 25 minutes of each other, so no day is wasted on driving." } },
    { "@type": "Question", "name": "What order should you play the Graeagle golf courses?", "acceptedAnswer": { "@type": "Answer", "text": "Most groups start with Graeagle Meadows (slope 120) or Plumas Pines (slope 132) to warm up, then build toward Grizzly Ranch (slope 140) and Nakoma Dragon (slope 147) for the challenge rounds. Save Nakoma for a rest day before or after — the FLW clubhouse and Inn at Nakoma are the trip highlight." } },
    { "@type": "Question", "name": "Can GolfGraeagle build a custom golf itinerary for my group?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every GolfGraeagle package includes a full day-by-day itinerary — tee times in sequence, lodging matched to your group, dining recommendations, and driving directions between courses. Request a free quote and receive your custom Graeagle golf itinerary within 24 hours." } },
    { "@type": "Question", "name": "What is the best time of year for a Graeagle golf trip?", "acceptedAnswer": { "@type": "Answer", "text": "September and October are the best months — courses are in peak condition, crowds thin out after Labor Day, and fall foliage adds to the scenery. June through August is peak season: book tee times 4–6 weeks ahead. May is ideal for smaller groups who want uncrowded courses." } }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Golf Packages", "item": "https://golfgraeagle.com/golf-packages/" },
    { "@type": "ListItem", "position": 3, "name": "Graeagle Golf Itinerary", "item": "https://golfgraeagle.com/graeagle-golf-itinerary/" }
  ]
};
const orgSchema = {
  "@context": "https://schema.org", "@graph": [
    { "@type": ["TravelAgency","Organization"], "@id": "https://golfgraeagle.com/#organization", "name": "GolfGraeagle.com", "url": "https://golfgraeagle.com",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
    { "@type": "WebPage", "url": "https://golfgraeagle.com/graeagle-golf-itinerary/", "name": title }
  ]
};
const howToSchema = {
  "@context": "https://schema.org", "@type": "HowTo",
  "name": "How to Build a Graeagle Golf Itinerary",
  "description": "Step-by-step guide to building a Graeagle golf trip itinerary — course order, lodging, and dining.",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Choose your trip length", "text": "2 nights = 2–3 courses. 3 nights = 3–4 courses. 4–5 nights = all 5 courses. Most groups choose 3 nights." },
    { "@type": "HowToStep", "position": 2, "name": "Sequence courses by difficulty", "text": "Start with Graeagle Meadows or Plumas Pines (slope 120–132). Build to Whitehawk Ranch and Grizzly Ranch. Save Nakoma Dragon (slope 147) for the signature round." },
    { "@type": "HowToStep", "position": 3, "name": "Match lodging to your itinerary", "text": "River Pines Resort suits most groups. Inn at Nakoma puts you on-course at The Dragon. Townhomes at Plumas Pines work for groups of 8–24 needing multi-bedroom units." },
    { "@type": "HowToStep", "position": 4, "name": "Book dining in advance", "text": "Sardine Lake Resort requires 4-week advance reservation. Grizzly Grill and Iron Door are popular for group dinners — ask GolfGraeagle to include reservations in your itinerary." }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Custom Graeagle Golf Itinerary Planning",
  "description": "Day-by-day Graeagle golf itineraries with tee times, lodging, and dining — custom-built for your group size and trip length.",
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Golf Itinerary Planning",
  "offers": { "@type": "AggregateOffer", "lowPrice": "620", "highPrice": "1705", "priceCurrency": "USD" }
};

// Itinerary data — verified facts only
const itineraries = [
  {
    label: '2-Day Itinerary',
    nights: 2, rounds: 2, priceRange: '$620–$645/pp',
    badge: 'Weekend Trip',
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72, slope 120. Arrive, settle in, afternoon round. Dinner at Grizzly Grill or Mohawk Tavern.' },
      { day: 'Day 2', course: 'Whitehawk Ranch', note: 'Par 71, slope 132. Top 20 California. Morning round, depart after lunch.' },
    ],
    lodging: 'River Pines Resort',
  },
  {
    label: '3-Day Itinerary',
    nights: 3, rounds: 3, priceRange: '$645–$875/pp',
    badge: 'Most Popular',
    hot: true,
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72, slope 120. Warm-up round. Easy fairways, Mohawk Valley views.' },
      { day: 'Day 2', course: 'Whitehawk Ranch', note: 'Par 71, slope 132. Meadow and forest mix. Sulphur Creek in play.' },
      { day: 'Day 3', course: 'Grizzly Ranch', note: 'Golf Digest Top 100. Par 72, slope 140, 7,411 yds. The challenge round.' },
    ],
    lodging: 'River Pines Resort or Chalet View Lodge',
  },
  {
    label: '4-Day Itinerary',
    nights: 4, rounds: 4, priceRange: '$876–$1,120/pp',
    badge: 'Dragon Run',
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72, slope 120. Settle in, afternoon round.' },
      { day: 'Day 2', course: 'Plumas Pines', note: 'Par 72, slope 132. Top 5 Best Value Sierra Nevada. On-course condos option.' },
      { day: 'Day 3', course: 'Grizzly Ranch', note: 'Golf Digest Top 100. Par 72, slope 140. Elevation 4,800–5,400 ft.' },
      { day: 'Day 4', course: 'Nakoma — The Dragon', note: 'Par 72, slope 147. Golf World Top 75. Only FLW golf clubhouse in the world.' },
    ],
    lodging: 'Inn at Nakoma (nights 3–4) + River Pines (nights 1–2)',
  },
  {
    label: '5-Day Grand Tour',
    nights: 5, rounds: 5, priceRange: '$1,120–$1,705/pp',
    badge: 'All 5 Courses',
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72, slope 120.' },
      { day: 'Day 2', course: 'Plumas Pines', note: 'Par 72, slope 132.' },
      { day: 'Day 3', course: 'Whitehawk Ranch', note: 'Par 71, slope 132. Top 20 California.' },
      { day: 'Day 4', course: 'Grizzly Ranch', note: 'Golf Digest Top 100. Par 72, slope 140.' },
      { day: 'Day 5', course: 'Nakoma — The Dragon', note: 'Par 72, slope 147. FLW clubhouse. Fifty44 dinner on-site.' },
    ],
    lodging: 'Inn at Nakoma (full stay)',
  },
];

const courses = [
  { name: 'Graeagle Meadows', slug: 'graeagle-meadows-golf-packages', par: 72, yards: '6,759', slope: 120, difficulty: 'Easiest', badge: 'Start here', badgeColor: '#2563eb' },
  { name: 'Plumas Pines',     slug: 'plumas-pines-golf-packages',     par: 72, yards: '6,504', slope: 132, difficulty: 'Moderate', badge: 'Best Value', badgeColor: '#b45309' },
  { name: 'Whitehawk Ranch',  slug: 'whitehawk-ranch-golf-packages',  par: 71, yards: '6,983', slope: 132, difficulty: 'Moderate', badge: 'Top 20 CA', badgeColor: '#1a7a40' },
  { name: 'Grizzly Ranch',    slug: 'grizzly-ranch-golf-packages',    par: 72, yards: '7,411', slope: 140, difficulty: 'Hard', badge: 'Top 100', badgeColor: '#7c3aed' },
  { name: 'Nakoma — Dragon',  slug: 'nakoma-dragon-golf-packages',    par: 72, yards: '7,015', slope: 147, difficulty: 'Hardest', badge: 'FLW Club', badgeColor: '#be123c' },
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, howToSchema, serviceSchema]}
  canonical="https://golfgraeagle.com/graeagle-golf-itinerary/"
  ogImage="https://golfgraeagle.com/wp-images/grizzly-ranch-hero.webp"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="gi-hero">
    <div class="gi-hero-img" style="background-image:url(/wp-images/graeagle-meadows-aerial.jpg)"></div>
    <div class="gi-hero-overlay"></div>
    <div class="gi-hero-inner">
      <p class="gi-eyebrow reveal-up">Graeagle Golf Itinerary Planning · Sierra Nevada · Since 2004</p>
      <h1 class="gi-h1 reveal-up delay-1">Graeagle Golf<br/><em>Itineraries</em></h1>
      <p class="gi-subhead speakable reveal-up delay-2">Sample Graeagle golf itineraries for 2, 3, 4, and 5-day trips — course order, lodging, and dining built around your group. Custom day-by-day plans from $620/golfer, delivered in 24 hours.</p>
      <div class="gi-pills reveal-up delay-3">
        <span class="gi-pill">2 to 5 days</span>
        <span class="gi-pill">All 5 courses</span>
        <span class="gi-pill">⭐ 4.8 · 672 reviews</span>
        <span class="gi-pill">24h quote</span>
      </div>
      <div class="gi-hero-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow gi-cta-main">Get My Custom Itinerary →</a>
        <a href="/trips/" class="gi-cta-text underline-draw">Browse 76 real trips ↗</a>
      </div>
    </div>
  </section>

  <!-- ═══ COURSE ORDER — difficulty ramp ═══ -->
  <section class="gi-section">
    <div class="gi-container">
      <div class="gi-header reveal-up">
        <span class="sec-label">Build difficulty into your schedule</span>
        <h2 class="gi-h2">Recommended course<br/><em>order for any itinerary</em></h2>
      </div>
      <div class="gi-ramp">
        {courses.map((c, i) => (
          <a href={`/portfolio/${c.slug}/`} class={`gi-ramp-card reveal-up delay-${i+1}`}>
            <div class="gi-ramp-num">{i + 1}</div>
            <span class="gi-ramp-badge" style={`background:${c.badgeColor}`}>{c.badge}</span>
            <h3 class="gi-ramp-name">{c.name}</h3>
            <div class="gi-ramp-specs">
              <span>Par {c.par}</span><span class="gi-dot">·</span>
              <span>{c.yards} yds</span><span class="gi-dot">·</span>
              <span>Slope {c.slope}</span>
            </div>
            <div class="gi-ramp-diff" style={`color:${c.badgeColor}`}>{c.difficulty}</div>
          </a>
        ))}
      </div>
      <p class="gi-ramp-note reveal-up">Courses sequenced from easiest to hardest. Most golfers play 2–3 courses per trip. GolfGraeagle routes your itinerary to match your group's skill level.</p>
    </div>
  </section>

  <!-- ═══ SAMPLE ITINERARIES — dark ═══ -->
  <section class="gi-section gi-dark">
    <div class="gi-container">
      <div class="gi-header reveal-up">
        <span class="sec-label">Based on real completed trips</span>
        <h2 class="gi-h2 gi-h2-light">Sample itineraries<br/><em>by trip length</em></h2>
      </div>
      <div class="gi-itin-grid">
        {itineraries.map((it, idx) => (
          <div class={`gi-itin-card reveal-scale delay-${idx+1}${it.hot ? ' gi-itin-hot' : ''}`}>
            {it.hot && <div class="gi-hot-pill">Most Popular</div>}
            <div class="gi-itin-header">
              <span class="gi-itin-label">{it.label}</span>
              <span class="gi-itin-price">{it.priceRange}</span>
            </div>
            <div class="gi-itin-meta">
              <span>🌙 {it.nights}n</span>
              <span>⛳ {it.rounds} rounds</span>
            </div>
            <div class="gi-itin-days">
              {it.days.map((d) => (
                <div class="gi-itin-day">
                  <span class="gi-day-label">{d.day}</span>
                  <div>
                    <div class="gi-day-course">{d.course}</div>
                    <div class="gi-day-note">{d.note}</div>
                  </div>
                </div>
              ))}
            </div>
            <div class="gi-itin-lodging">🏨 {it.lodging}</div>
            <a href="/request-a-quote/" class="gi-itin-cta underline-draw">Build this itinerary →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="gi-section">
    <div class="gi-container" style="max-width:860px">
      <div class="gi-header reveal-up">
        <span class="sec-label">The process</span>
        <h2 class="gi-h2">How to build your<br/><em>Graeagle golf itinerary</em></h2>
      </div>
      <div class="gi-steps">
        {[
          ['01','Choose your trip length','2 nights = 2-3 courses. 3 nights = 3-4 courses. 4-5 nights = all 5. Most groups choose 3 nights — the sweet spot.'],
          ['02','Sequence by difficulty','Start accessible (Graeagle Meadows, slope 120). Build up. Save Grizzly Ranch and Nakoma Dragon for the challenge rounds. Your group will not burn out on day 1.'],
          ['03','Match lodging to your route','River Pines Resort for most groups. Inn at Nakoma if playing The Dragon — the on-site stay is worth it. Townhomes at Plumas Pines for groups of 8–24.'],
          ['04','Lock dining before you arrive','Sardine Lake Resort books 4 weeks out. Iron Door and Grizzly Grill for group dinners. GolfGraeagle includes reservations in every itinerary on request.'],
        ].map(([n, title, body], i) => (
          <div class={`gi-step glow-card reveal-${i % 2 === 0 ? 'left' : 'right'} delay-${(i % 3) + 1}`}>
            <div class="gi-step-n">{n}</div>
            <h3 class="gi-step-title">{title}</h3>
            <p class="gi-step-body">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="gi-section gi-faq-section">
    <div class="gi-container" style="max-width:780px">
      <div class="gi-header reveal-up">
        <span class="sec-label">Common questions</span>
        <h2 class="gi-h2">Graeagle Golf Itinerary FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`gi-faq reveal-up delay-${(i % 4) + 1}`}>
          <summary class="gi-faq-q">{item.name}<span class="gi-faq-icon">+</span></summary>
          <p class="gi-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ CTA — dark ═══ -->
  <section class="gi-cta-section gi-dark">
    <div class="gi-cta-ring"></div>
    <div class="gi-container" style="text-align:center;max-width:660px;position:relative;z-index:1">
      <h2 class="gi-cta-h2 reveal-up">Get your custom Graeagle<br/><em>golf itinerary in 24 hours.</em></h2>
      <p class="gi-cta-sub reveal-up delay-1">Tell us your dates, group size, and which courses you want. We build the full day-by-day schedule — tee times, lodging, dining — and send it back within 24 hours.</p>
      <div class="reveal-scale delay-2">
        <a href="/request-a-quote/" class="btn-green-glow gi-cta-main">Request a Free Quote →</a>
        <p class="gi-cta-trust">No obligation · 72-hr cancellation · 4.8★ · 672 reviews</p>
      </div>
    </div>
  </section>

  <RelatedTrips client:load slug="graeagle-golf-itinerary" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
:root{--gi-gold:#e8a850;--gi-green:#1a7a40;--gi-dark:#0d1a0e;--gi-text:#1c1208;--gi-muted:rgba(28,18,8,0.52);--gi-border:rgba(28,18,8,0.08);--gi-r:20px}
.gi-container{max-width:1140px;margin:0 auto;padding:0 clamp(20px,6%,80px)}
.gi-section{padding:clamp(72px,9vw,120px) 0;background:var(--page-bg,#f8f5f0)}
.gi-dark{background:var(--gi-dark)!important}
.gi-header{text-align:center;margin-bottom:clamp(40px,5vw,68px)}
.gi-h2{font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,50px);font-weight:500;color:var(--gi-text);line-height:1.1;margin:8px 0 0}
.gi-h2 em{font-style:italic;color:var(--gi-green)}
.gi-h2-light{color:#f0ece3!important}
.gi-h2-light em{color:var(--gi-gold)!important}

/* HERO */
.gi-hero{position:relative;min-height:90vh;display:flex;align-items:flex-end;overflow:hidden}
.gi-hero-img{position:absolute;inset:0;background-size:cover;background-position:center 30%;transform:scale(1.06);animation:giZoom 10s ease forwards}
@keyframes giZoom{to{transform:scale(1)}}
.gi-hero-overlay{position:absolute;inset:0;background:linear-gradient(158deg,rgba(13,26,14,.18) 0%,rgba(13,26,14,.62) 50%,rgba(13,26,14,.97) 100%)}
.gi-hero-inner{position:relative;z-index:2;padding:0 clamp(24px,8%,120px) clamp(60px,8vw,100px);max-width:820px}
.gi-eyebrow{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,168,80,.85);margin:0 0 18px}
.gi-h1{font-family:'Playfair Display',serif;font-size:clamp(46px,7.5vw,92px);font-weight:500;color:#f5f0e8;line-height:.98;margin:0 0 20px}
.gi-h1 em{font-style:italic;color:var(--gi-gold)}
.gi-subhead{font-size:clamp(16px,2vw,21px);color:rgba(245,240,232,.65);line-height:1.6;margin:0 0 28px}
.gi-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
.gi-pill{font-size:12px;font-weight:600;color:rgba(245,240,232,.85);padding:7px 16px;background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.18);border-radius:100px}
.gi-hero-ctas{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.gi-cta-main{display:inline-block;padding:15px 36px;border-radius:100px;font-size:15px;font-weight:700;text-decoration:none}
.gi-cta-text{font-size:14px;font-weight:600;color:rgba(232,168,80,.9);text-decoration:none}

/* COURSE RAMP */
.gi-ramp{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:24px}
.gi-ramp-card{border-radius:var(--gi-r);padding:24px 18px;border:1px solid var(--gi-border);background:#fff;text-decoration:none;transition:all .35s;position:relative;overflow:hidden;display:flex;flex-direction:column;gap:8px}
.gi-ramp-card:hover{transform:translateY(-5px);box-shadow:0 20px 48px rgba(0,0,0,.1);border-color:rgba(232,168,80,.4)}
.gi-ramp-num{font-family:'Playfair Display',serif;font-size:48px;color:rgba(232,168,80,.12);font-weight:400;line-height:1;margin:-4px 0 -8px -2px}
.gi-ramp-badge{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#fff;padding:3px 9px;border-radius:100px;align-self:flex-start}
.gi-ramp-name{font-size:14px;font-weight:700;color:var(--gi-text);line-height:1.3;margin:0}
.gi-ramp-specs{display:flex;flex-wrap:wrap;gap:4px;font-size:11px;color:var(--gi-muted)}
.gi-dot{color:rgba(28,18,8,.2)}
.gi-ramp-diff{font-size:11px;font-weight:700;margin-top:2px}
.gi-ramp-note{text-align:center;font-size:14px;color:var(--gi-muted);max-width:660px;margin:0 auto;line-height:1.7}

/* ITINERARIES */
.gi-itin-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px}
.gi-itin-card{border:1px solid rgba(245,240,232,.18);border-radius:var(--gi-r);padding:28px 24px;background:rgba(255,255,255,.09);transition:all .35s;position:relative}
.gi-itin-card:hover{transform:translateY(-5px);border-color:rgba(232,168,80,.3);box-shadow:0 22px 52px rgba(0,0,0,.25)}
.gi-itin-hot{border-color:rgba(232,168,80,.3)!important;background:rgba(232,168,80,.05)!important}
.gi-hot-pill{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--gi-gold);color:#1c1208;font-size:9px;font-weight:800;padding:4px 14px;border-radius:0 0 10px 10px;text-transform:uppercase;letter-spacing:.1em;white-space:nowrap}
.gi-itin-header{display:flex;justify-content:space-between;align-items:baseline;gap:8px;margin-bottom:10px}
.gi-itin-label{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,240,232,.7)}
.gi-itin-price{font-family:'Playfair Display',serif;font-size:16px;color:var(--gi-gold);font-weight:400}
.gi-itin-meta{display:flex;gap:12px;margin-bottom:16px}
.gi-itin-meta span{font-size:11px;color:rgba(245,240,232,.78)}
.gi-itin-days{display:flex;flex-direction:column;gap:10px;margin-bottom:14px}
.gi-itin-day{display:grid;grid-template-columns:46px 1fr;gap:8px;align-items:start}
.gi-day-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--gi-gold);padding-top:2px}
.gi-day-course{font-size:13px;font-weight:700;color:#f5f0e8;margin-bottom:2px}
.gi-day-note{font-size:11px;color:rgba(245,240,232,.55);line-height:1.5}
.gi-itin-lodging{font-size:11px;color:rgba(245,240,232,.6);margin-bottom:14px;border-top:1px solid rgba(245,240,232,.08);padding-top:12px}
.gi-itin-cta{font-size:12px;font-weight:700;color:var(--gi-gold);text-decoration:none}

/* HOW IT WORKS */
.gi-steps{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.gi-step{padding:36px 32px;border:1px solid var(--gi-border);background:#fff;transition:all .35s}
.gi-step:hover{transform:translateY(-5px);box-shadow:0 20px 48px rgba(0,0,0,.09);border-color:rgba(232,168,80,.35)}
.gi-step-n{font-family:'Playfair Display',serif;font-size:72px;font-weight:400;color:rgba(232,168,80,.1);line-height:1;margin:-4px 0 -12px -2px}
.gi-step-title{font-size:16px;font-weight:700;color:var(--gi-text);margin:16px 0 10px}
.gi-step-body{font-size:14px;color:var(--gi-muted);line-height:1.75;margin:0}

/* FAQ */
.gi-faq{border-bottom:1px solid var(--gi-border)}
.gi-faq[open]{background:rgba(232,168,80,.03);border-radius:12px;border-color:rgba(232,168,80,.22)}
.gi-faq-q{font-size:15px;font-weight:600;color:var(--gi-text);padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;transition:color .2s}
.gi-faq-q::-webkit-details-marker{display:none}
.gi-faq[open] .gi-faq-q{color:var(--gi-green)}
.gi-faq-icon{font-size:24px;color:var(--gi-gold);flex-shrink:0;transition:transform .3s}
.gi-faq[open] .gi-faq-icon{transform:rotate(45deg)}
.gi-faq-a{font-size:14px;color:var(--gi-muted);line-height:1.82;padding:0 0 20px;margin:0}
.gi-faq-section{background:var(--page-bg,#f8f5f0)!important}

/* CTA */
.gi-cta-section{padding:clamp(80px,10vw,132px) 0;position:relative;overflow:hidden}
.gi-cta-ring{position:absolute;width:720px;height:720px;border-radius:50%;border:1px solid rgba(232,168,80,.07);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.gi-cta-ring::before{content:'';position:absolute;inset:80px;border-radius:50%;border:1px solid rgba(232,168,80,.04)}
.gi-cta-h2{font-family:'Playfair Display',serif;font-size:clamp(28px,5vw,54px);color:#f5f0e8;font-weight:500;line-height:1.15;margin:0 0 20px}
.gi-cta-h2 em{color:var(--gi-gold);font-style:italic}
.gi-cta-sub{font-size:16px;color:rgba(245,240,232,.75);line-height:1.75;margin:0 0 36px}
.gi-cta-trust{font-size:12px;color:rgba(245,240,232,.3);margin-top:14px}

/* Mobile */
@media(max-width:900px){
  .gi-hero{min-height:100svh}
  .gi-ramp{grid-template-columns:1fr 1fr;gap:10px}
  .gi-itin-grid{grid-template-columns:1fr}
  .gi-steps{grid-template-columns:1fr}
}
@media(max-width:540px){
  .gi-ramp{grid-template-columns:1fr}
}
</style>
