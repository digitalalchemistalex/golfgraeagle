---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';

const title = "Graeagle Golf Itinerary — 2, 3, 4 & 5-Day Plans | GolfGraeagle.com";
const description = "Real Graeagle golf itineraries for every trip length. 2-day, 3-day, and 4-day sample schedules with course order, lodging, and dining. Custom itineraries from $620/golfer.";

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the best 3-day Graeagle golf itinerary?", "acceptedAnswer": { "@type": "Answer", "text": "Day 1: Graeagle Meadows (slope 120 — warm up). Day 2: Whitehawk Ranch (slope 132 — meadow and forest). Day 3: Grizzly Ranch (Golf Digest Top 100, slope 140 — the challenge round). Lodging at River Pines Resort. Dinner at Sardine Lake Resort on night 2 — book 4 weeks ahead." } },
    { "@type": "Question", "name": "How many courses can you play in a Graeagle golf itinerary?", "acceptedAnswer": { "@type": "Answer", "text": "A 2-day itinerary covers 2 courses. A 3-day covers 3-4 courses. A 4-5-day itinerary can include all 5 Graeagle courses. All five are within 25 minutes of each other." } },
    { "@type": "Question", "name": "What order should you play the Graeagle golf courses?", "acceptedAnswer": { "@type": "Answer", "text": "Start with Graeagle Meadows (slope 120) or Plumas Pines (slope 132) to warm up, then build toward Grizzly Ranch (slope 140) and Nakoma Dragon (slope 147) for the challenge rounds." } },
    { "@type": "Question", "name": "Can GolfGraeagle build a custom golf itinerary for my group?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every GolfGraeagle package includes a full day-by-day itinerary — tee times in sequence, lodging matched to your group, dining recommendations. Request a free quote and receive your custom Graeagle golf itinerary within 24 hours." } },
    { "@type": "Question", "name": "What is the best time of year for a Graeagle golf trip?", "acceptedAnswer": { "@type": "Answer", "text": "September and October are the best months — peak condition, fewer crowds after Labor Day, fall foliage. June through August is peak season: book 4-6 weeks ahead. May is ideal for smaller groups who want uncrowded courses." } }
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Golf Packages", "item": "https://golfgraeagle.com/golf-packages/" },
    { "@type": "ListItem", "position": 3, "name": "Graeagle Golf Itinerary", "item": "https://golfgraeagle.com/graeagle-golf-itinerary/" }
  ]
};
const orgSchema = {
  "@context": "https://schema.org", "@graph": [
    { "@type": ["TravelAgency","Organization"], "@id": "https://golfgraeagle.com/#organization", "name": "GolfGraeagle.com", "url": "https://golfgraeagle.com",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
    { "@type": "WebPage", "url": "https://golfgraeagle.com/graeagle-golf-itinerary/", "name": title }
  ]
};
const howToSchema = {
  "@context": "https://schema.org", "@type": "HowTo",
  "name": "How to Build a Graeagle Golf Itinerary",
  "description": "Step-by-step guide to building a Graeagle golf trip itinerary — course order, lodging, and dining.",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Choose your trip length", "text": "2 nights = 2-3 courses. 3 nights = 3-4 courses. 4-5 nights = all 5 courses." },
    { "@type": "HowToStep", "position": 2, "name": "Sequence courses by difficulty", "text": "Start with Graeagle Meadows or Plumas Pines. Build to Whitehawk Ranch and Grizzly Ranch. Save Nakoma Dragon for the signature round." },
    { "@type": "HowToStep", "position": 3, "name": "Match lodging to your itinerary", "text": "River Pines Resort suits most groups. Inn at Nakoma for The Dragon. Townhomes at Plumas Pines for groups of 8-24." },
    { "@type": "HowToStep", "position": 4, "name": "Book dining in advance", "text": "Sardine Lake Resort requires 4-week advance reservation. Grizzly Grill and Iron Door are popular for group dinners." }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Custom Graeagle Golf Itinerary Planning",
  "description": "Day-by-day Graeagle golf itineraries with tee times, lodging, and dining — custom-built for your group size and trip length.",
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Golf Itinerary Planning",
  "offers": { "@type": "AggregateOffer", "lowPrice": "620", "highPrice": "1705", "priceCurrency": "USD" }
};

const itineraries = [
  { label: '2-Day', nights: 2, rounds: 2, priceRange: '$620–$645/pp', badge: 'Weekend', hot: false,
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72 · Slope 120 · Arrive, warm up round. Dinner at Grizzly Grill.' },
      { day: 'Day 2', course: 'Whitehawk Ranch', note: 'Par 71 · Slope 132 · Top 20 CA. Morning round, depart after lunch.' },
    ],
    includes: ['Tee times at 2 courses', '2 nights at River Pines', 'Day-by-day itinerary', 'Groups of 4-24'],
    lodging: 'River Pines Resort' },
  { label: '3-Day', nights: 3, rounds: 3, priceRange: '$645–$875/pp', badge: 'Most Popular', hot: true,
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72 · Slope 120 · Warm-up round. Easy fairways.' },
      { day: 'Day 2', course: 'Whitehawk Ranch', note: 'Par 71 · Slope 132 · Meadow and forest. Sulphur Creek in play.' },
      { day: 'Day 3', course: 'Grizzly Ranch', note: 'Golf Digest Top 100 · Par 72 · Slope 140 · The challenge round.' },
    ],
    includes: ['Tee times at 3 courses', '3 nights lodging', 'Full itinerary + dining tips', 'Groups of 4-24'],
    lodging: 'River Pines or Chalet View' },
  { label: '4-Day', nights: 4, rounds: 4, priceRange: '$876–$1,120/pp', badge: 'Dragon Run', hot: false,
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72 · Slope 120 · Settle in, afternoon round.' },
      { day: 'Day 2', course: 'Plumas Pines', note: 'Par 72 · Slope 132 · Top 5 Best Value Sierra Nevada.' },
      { day: 'Day 3', course: 'Grizzly Ranch', note: 'Golf Digest Top 100 · 7,411 yds at 4,800 ft.' },
      { day: 'Day 4', course: 'Nakoma — The Dragon', note: 'Par 72 · Slope 147 · Golf World Top 75 · FLW clubhouse.' },
    ],
    includes: ['Tee times at 4 courses inc. Nakoma', '4 nights (Nakoma Inn + River Pines)', 'Fifty44 dining res.', 'All logistics handled'],
    lodging: 'Inn at Nakoma + River Pines' },
  { label: '5-Day', nights: 5, rounds: 5, priceRange: '$1,120–$1,705/pp', badge: 'Grand Tour', hot: false,
    days: [
      { day: 'Day 1', course: 'Graeagle Meadows', note: 'Par 72 · Slope 120' },
      { day: 'Day 2', course: 'Plumas Pines', note: 'Par 72 · Slope 132' },
      { day: 'Day 3', course: 'Whitehawk Ranch', note: 'Par 71 · Slope 132 · Top 20 California' },
      { day: 'Day 4', course: 'Grizzly Ranch', note: 'Golf Digest Top 100 · Slope 140' },
      { day: 'Day 5', course: 'Nakoma — The Dragon', note: 'Par 72 · Slope 147 · FLW clubhouse · Fifty44 dinner' },
    ],
    includes: ['Tee times at all 5 courses', '5 nights at Inn at Nakoma', 'All dining reservations', 'Single invoice'],
    lodging: 'Inn at Nakoma' },
];

const courses = [
  { name: 'Graeagle Meadows', slug: 'graeagle-meadows-golf-packages', par: 72, yards: '6,759', slope: 120, difficulty: 'Easiest',  badge: 'Start here', badgeColor: '#2563eb', hero: '/wp-images/graeagle-meadows-hero.webp',           note: 'Most accessible. Best opening round for any group.' },
  { name: 'Plumas Pines',     slug: 'plumas-pines-golf-packages',     par: 72, yards: '6,504', slope: 132, difficulty: 'Moderate', badge: 'Best Value', badgeColor: '#b45309', hero: '/wp-images/plumas-pines-hero.webp',               note: 'Top 5 Best Value Sierra Nevada. Precision layout.' },
  { name: 'Whitehawk Ranch',  slug: 'whitehawk-ranch-golf-packages',  par: 71, yards: '6,983', slope: 132, difficulty: 'Moderate', badge: 'Top 20 CA',  badgeColor: '#1a7a40', hero: '/wp-images/whitehawk-hero.webp',                  note: 'Meadow and forest. Sulphur Creek in play.' },
  { name: 'Grizzly Ranch',    slug: 'grizzly-ranch-golf-packages',    par: 72, yards: '7,411', slope: 140, difficulty: 'Hard',     badge: 'Top 100',    badgeColor: '#7c3aed', hero: '/wp-images/grizzly-ranch-hero.webp',             note: 'Golf Digest Top 100. 7,411 yds at 4,800 ft.' },
  { name: 'Nakoma — Dragon',  slug: 'nakoma-dragon-golf-packages',    par: 72, yards: '7,015', slope: 147, difficulty: 'Hardest',  badge: 'FLW Club',   badgeColor: '#be123c', hero: '/wp-images/nakoma-dragon-feather-river.webp',    note: 'Golf World Top 75. Save this for last.' },
];

const whyPoints = [
  ['⛳','Play 2-5 courses in one trip','All 5 courses within 25 minutes. No travel days wasted. Most groups play 3-4 courses on a weekend.'],
  ['📋','Custom itinerary in 24 hours','Tell us your dates and group size. We send a full day-by-day schedule — tee times, lodging, dining — within 24 hours.'],
  ['🏆','Access to Top 100 + Golf World Top 75','Grizzly Ranch (Golf Digest Top 100) and Nakoma Dragon (Golf World Top 75) on the same itinerary. We secure the access.'],
  ['💰','40% cheaper than Lake Tahoe','Same championship golf. Comparable lodging. Graeagle packages run $620-$875/pp vs $1,200-$1,800/pp at Tahoe.'],
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, howToSchema, serviceSchema]}
  canonical="https://golfgraeagle.com/graeagle-golf-itinerary/"
  ogImage="https://golfgraeagle.com/wp-images/graeagle-meadows-aerial.jpg"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="gi-hero">
    <div class="gi-hero-img" style="background-image:url(/wp-images/graeagle-meadows-aerial.jpg)"></div>
    <div class="gi-hero-overlay"></div>
    <div class="gi-hero-inner">
      <p class="gi-eyebrow reveal-up">Graeagle Golf Itinerary Planning · 5 Courses · Sierra Nevada · Since 2004</p>
      <h1 class="gi-h1 reveal-up delay-1">Graeagle Golf<br/><em>Itineraries</em></h1>
      <p class="gi-subhead speakable reveal-up delay-2">2, 3, 4, and 5-day Graeagle golf itineraries — course order, lodging, and dining built around your group. Custom day-by-day plans from $620/golfer, back in 24 hours.</p>
      <div class="gi-pills reveal-up delay-3">
        <span class="gi-pill">2 to 5 days</span>
        <span class="gi-pill">All 5 courses</span>
        <span class="gi-pill">⭐ 4.8 · 672 reviews</span>
        <span class="gi-pill">24h quote</span>
      </div>
      <div class="gi-hero-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow gi-cta-main">Get My Custom Itinerary →</a>
        <a href="/trips/" class="gi-cta-ghost underline-draw">Browse 76 real trips ↗</a>
      </div>
    </div>
    <!-- Floating stat cards — desktop right -->
    <div class="gi-floats reveal-fade delay-5">
      <div class="gi-float"><div class="gi-float-val" data-count="76">0</div><div class="gi-float-lbl">Real Packages</div></div>
      <div class="gi-float"><div class="gi-float-val">4.8★</div><div class="gi-float-lbl">Avg Rating</div></div>
      <div class="gi-float"><div class="gi-float-val" data-count="5">0</div><div class="gi-float-lbl">Courses</div></div>
    </div>
  </section>

  <!-- ═══ COURSE ORDER — difficulty ramp ═══ -->
  <section class="gi-section">
    <div class="gi-container">
      <div class="gi-header reveal-up">
        <span class="sec-label">Build difficulty into every itinerary</span>
        <h2 class="gi-h2">Recommended course<br/><em>order for any trip length</em></h2>
      </div>
      <div class="gi-ramp">
        {courses.map((c, i) => (
          <a href={`/portfolio/${c.slug}/`} class={`gi-ramp-card glow-card reveal-${i % 2 === 0 ? 'left' : 'right'} delay-${(i % 3) + 1}`}>
            <div class="gi-ramp-img" style={`background-image:url(${c.hero})`}>
              <div class="gi-ramp-fade"></div>
              <span class="gi-ramp-badge" style={`background:${c.badgeColor}`}>{c.badge}</span>
              <div class="gi-ramp-num-overlay">{i + 1}</div>
              <div class="gi-ramp-slope">Slope {c.slope}</div>
            </div>
            <div class="gi-ramp-body">
              <h3 class="gi-ramp-name">{c.name}</h3>
              <div class="gi-ramp-specs">
                <span>Par {c.par}</span><span class="gi-dot">·</span>
                <span>{c.yards} yds</span>
              </div>
              <p class="gi-ramp-note">{c.note}</p>
              <div class="gi-ramp-footer-row">
                <span class="gi-ramp-diff" style={`color:${c.badgeColor}`}>{c.difficulty}</span>
                <span class="gi-ramp-link underline-draw">View →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
      <p class="gi-ramp-footer reveal-up">Courses sequenced easiest to hardest. GolfGraeagle routes your itinerary by skill level — your group plays best on day 1, not burned out.</p>
    </div>
  </section>

  <!-- ═══ SAMPLE ITINERARIES — dark ═══ -->
  <section class="gi-section gi-dark">
    <div class="gi-container">
      <div class="gi-header reveal-up">
        <span class="sec-label" style="color:#e8a850">Based on real completed trips</span>
        <h2 class="gi-h2 gi-h2-light">Sample itineraries<br/><em>by trip length</em></h2>
        <p class="gi-section-sub">Real pricing. Real courses. Real day-by-day schedules — not estimates.</p>
      </div>
      <div class="gi-itin-grid">
        {itineraries.map((it, idx) => (
          <div class={`gi-itin-card glow-card reveal-scale delay-${idx+1}${it.hot ? ' gi-itin-hot' : ''}`}>
            {it.hot && <div class="gi-hot-pill">Most Popular</div>}
            <div class="gi-itin-top">
              <span class="gi-itin-badge">{it.badge}</span>
              <div class="gi-itin-price">{it.priceRange}</div>
            </div>
            <div class="gi-itin-meta">
              <span>🌙 {it.nights} nights</span><span>⛳ {it.rounds} rounds</span>
            </div>
            <div class="gi-itin-days">
              {it.days.map((d) => (
                <div class="gi-itin-day">
                  <span class="gi-day-label">{d.day}</span>
                  <div>
                    <div class="gi-day-course">{d.course}</div>
                    <div class="gi-day-note">{d.note}</div>
                  </div>
                </div>
              ))}
            </div>
            <ul class="gi-itin-includes">
              {it.includes.map((item: string) => <li>✓ {item}</li>)}
            </ul>
            <p class="gi-itin-lodging">🏨 {it.lodging}</p>
            <a href="/request-a-quote/" class="gi-itin-cta underline-draw">Build this itinerary →</a>
          </div>
        ))}
      </div>
      <p class="gi-archive-link reveal-up">
        <a href="/trips/" class="underline-draw" style="color:#e8a850;font-weight:700;">Browse all 76 real packages with pricing →</a>
      </p>
    </div>
  </section>

  <!-- ═══ WHY GRAEAGLE — dark split ═══ -->
  <section class="gi-section gi-dark gi-why">
    <div class="gi-container gi-why-inner">
      <div class="gi-why-text">
        <span class="sec-label">Why Graeagle beats Tahoe for golf itineraries</span>
        <h2 class="gi-h2 reveal-up" style="color:#f5f0e8;margin-top:10px">Why groups<br/><em>choose Graeagle</em></h2>
        <div class="gi-points">
          {whyPoints.map(([icon, title, body], i) => (
            <div class={`gi-point reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
              <span class="gi-pt-icon">{icon}</span>
              <div>
                <div class="gi-pt-title">{title}</div>
                <div class="gi-pt-body">{body}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="gi-why-img reveal-scale delay-2">
        <img src="/wp-images/grizzly-ranch-hero.webp" alt="Grizzly Ranch Golf Club — Golf Digest Top 100 — Graeagle California" loading="lazy"/>
        <div class="gi-why-badge">
          <div style="font-family:'Playfair Display',serif;font-size:26px;color:#e8a850;font-weight:400;line-height:1">Golf Digest</div>
          <div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.55);margin-top:5px">Top 100 Course</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <section class="gi-section">
    <div class="gi-container">
      <div class="gi-header reveal-up">
        <span class="sec-label">The process</span>
        <h2 class="gi-h2">How to build your<br/><em>Graeagle golf itinerary</em></h2>
      </div>
      <div class="gi-steps">
        {[
          ['01','📋','Tell us your trip length','Dates, group size, how many rounds, budget range. Takes 2 minutes via the quote form or call (888) 586-1157.'],
          ['02','⚡','Get your day-by-day itinerary in 24h','Courses sequenced by difficulty, tee times locked, lodging matched, dining suggested. All-in price included.'],
          ['03','✅','Confirm and we book everything','Approve the itinerary. We lock tee times, reserve lodging, and make any dining reservations. One invoice.'],
          ['04','⛳','Show up and play','You arrive. Everything is pre-arranged. We handle every detail of your Graeagle golf vacation.'],
        ].map(([n, icon, t, b], i) => (
          <div class={`gi-step glow-card reveal-${i<2?'left':'right'} delay-${(i%3)+1}`}>
            <div class="gi-step-n">{n}</div>
            <div class="gi-step-icon">{icon}</div>
            <h3 class="gi-step-title">{t}</h3>
            <p class="gi-step-body">{b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STATS — dark ═══ -->
  <section class="gi-trust gi-dark">
    <div class="gi-container gi-trust-row">
      {[
        ['76','Real itineraries archived'],
        ['5','Championship courses'],
        ['4.8','672 verified reviews'],
        ['24','Hour quote turnaround'],
        ['2004','Year we started'],
      ].map(([val, label], i) => (
        <div class={`gi-stat reveal-scale delay-${i+1}`}>
          <div class="gi-stat-val">
            {val === '4.8' ? <><span data-count="4.8">0</span>★</> :
             val === '24'  ? <><span data-count="24">0</span>h</>  :
             <span data-count={val}>0</span>}
          </div>
          <div class="gi-stat-label">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="gi-section">
    <div class="gi-container" style="max-width:780px">
      <div class="gi-header reveal-up">
        <span class="sec-label">Common questions</span>
        <h2 class="gi-h2">Graeagle Golf Itinerary FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`gi-faq reveal-up delay-${(i % 4) + 1}`}>
          <summary class="gi-faq-q">{item.name}<span class="gi-faq-icon">+</span></summary>
          <p class="gi-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ FINAL CTA — dark ═══ -->
  <section class="gi-cta-section gi-dark">
    <div class="gi-cta-glow"></div>
    <div class="gi-container" style="text-align:center;max-width:660px;position:relative;z-index:1">
      <h2 class="gi-cta-h2 reveal-up">Your custom Graeagle<br/><em>golf itinerary in 24 hours.</em></h2>
      <p class="gi-cta-sub reveal-up delay-1">Tell us your dates, group size, and which courses you want. We build the full day-by-day schedule — tee times, lodging, dining — and send it back within 24 hours.</p>
      <div class="reveal-scale delay-2">
        <a href="/request-a-quote/" class="btn-green-glow gi-cta-main">Request a Free Quote →</a>
        <p class="gi-cta-trust">No obligation · 72-hr cancellation · 4.8★ · 672 reviews</p>
      </div>
    </div>
  </section>

  <RelatedTrips client:load slug="graeagle-golf-itinerary" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
:root{--gi-gold:#e8a850;--gi-green:#1a7a40;--gi-dark:#0d1a0e;--gi-text:#1c1208;--gi-muted:rgba(28,18,8,0.52);--gi-border:rgba(28,18,8,0.08);--gi-r:20px}
.gi-container{max-width:1140px;margin:0 auto;padding:0 clamp(20px,6%,80px)}
.gi-section{padding:clamp(72px,9vw,120px) 0;background:var(--page-bg,#f8f5f0)}
.gi-dark{background:var(--gi-dark)!important}
.gi-header{text-align:center;margin-bottom:clamp(40px,5vw,68px)}
.gi-h2{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,52px);font-weight:500;color:var(--gi-text);line-height:1.1;margin:8px 0 0}
.gi-h2 em{font-style:italic;color:var(--gi-green)}
.gi-h2-light{color:#f0ece3!important}
.gi-h2-light em{color:var(--gi-gold)!important}
.gi-section-sub{font-size:15px;color:rgba(245,240,232,.72);max-width:480px;margin:16px auto 0;line-height:1.7}

/* HERO */
.gi-hero{position:relative;min-height:90vh;display:flex;align-items:flex-end;overflow:hidden}
.gi-hero-img{position:absolute;inset:0;background-size:cover;background-position:center 30%;transform:scale(1.06);animation:giZoom 10s ease forwards}
@keyframes giZoom{to{transform:scale(1)}}
.gi-hero-overlay{position:absolute;inset:0;background:linear-gradient(158deg,rgba(13,26,14,.18) 0%,rgba(13,26,14,.62) 50%,rgba(13,26,14,.97) 100%)}
.gi-hero-inner{position:relative;z-index:2;padding:0 clamp(24px,8%,120px) clamp(60px,8vw,100px);max-width:820px}
.gi-eyebrow{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,168,80,.85);margin:0 0 18px}
.gi-h1{font-family:'Playfair Display',serif;font-size:clamp(46px,7.5vw,92px);font-weight:500;color:#f5f0e8;line-height:.98;margin:0 0 20px}
.gi-h1 em{font-style:italic;color:var(--gi-gold)}
.gi-subhead{font-size:clamp(16px,2vw,21px);color:rgba(245,240,232,.65);line-height:1.6;margin:0 0 28px}
.gi-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
.gi-pill{font-size:12px;font-weight:600;color:rgba(245,240,232,.85);padding:7px 16px;background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.18);border-radius:100px}
