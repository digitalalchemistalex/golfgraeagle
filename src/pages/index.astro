---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { courses } from '../data/content.js';

const title = "Golf Graeagle | 5 Championship Courses · Sierra Nevada, California";
const description = "Plan your Graeagle golf trip. Five championship courses — Graeagle Meadows, Whitehawk Ranch, Plumas Pines, Grizzly Ranch, and Nakoma The Dragon — all within 25 minutes. Golf Digest Top 100. Frank Lloyd Wright clubhouse.";

const courseImages = {
  'graeagle-meadows': 'https://images.unsplash.com/photo-1587174486073-ae5e5cff23aa?w=800&q=80&auto=format',
  'whitehawk-ranch':  'https://images.unsplash.com/photo-1535131749006-b7f58c99034b?w=800&q=80&auto=format',
  'plumas-pines':     'https://images.unsplash.com/photo-1601978810700-bc1c7e0b0292?w=800&q=80&auto=format',
  'grizzly-ranch':    'https://images.unsplash.com/photo-1592919505780-303950717480?w=800&q=80&auto=format',
  'nakoma-dragon':    'https://images.unsplash.com/photo-1547347298-4074fc3086f0?w=800&q=80&auto=format',
};
const courseBadges = {
  'graeagle-meadows': { label: 'Golf Digest Best Places to Play', icon: '⭐' },
  'whitehawk-ranch':  { label: 'Golf Digest Undiscovered Gem', icon: '💎' },
  'plumas-pines':     { label: 'Same Slope as Augusta National', icon: '🏆' },
  'grizzly-ranch':    { label: 'Golf Digest Top 100 Nationally', icon: '🥇' },
  'nakoma-dragon':    { label: 'Frank Lloyd Wright Clubhouse', icon: '🏛️' },
};
const priceTier = {
  'graeagle-meadows': '$$',
  'whitehawk-ranch':  '$$$',
  'plumas-pines':     '$$$',
  'grizzly-ranch':    '$$$$',
  'nakoma-dragon':    '$$$',
};
const diffPill = (d) => {
  if (d.includes('Beginner')) return 'background:rgba(82,168,98,0.15);color:#78c488;border-color:rgba(82,168,98,0.3)';
  if (d.includes('Intermediate')) return 'background:rgba(200,136,64,0.15);color:#e8a850;border-color:rgba(200,136,64,0.3)';
  if (d.includes('Expert')) return 'background:rgba(160,40,40,0.2);color:#f07060;border-color:rgba(160,40,40,0.4)';
  return 'background:rgba(220,80,60,0.15);color:#f08070;border-color:rgba(220,80,60,0.3)';
};
---
<Base title={title} description={description}>

<Nav />


<!-- ══════════════════════════ HERO ══════════════════════════ -->
<section style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;">

  <!-- BG image with parallax -->
  <div id="hero-bg" style="position:absolute;inset:-20%;background-image:url('https://images.unsplash.com/photo-1593111774240-d529f12cf4bb?w=1920&q=85&auto=format');background-size:cover;background-position:center 35%;will-change:transform;"></div>

  <!-- Atmospheric overlays — Sierra greens and dawn gold, NOT pure black -->
  <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(13,26,14,0.6) 0%,rgba(22,40,22,0.25) 40%,rgba(13,26,14,0.82) 80%,rgba(13,26,14,1) 100%);"></div>
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 100% 60% at 55% 25%,rgba(35,77,44,0.4) 0%,transparent 65%);"></div>
  <div style="position:absolute;bottom:0;left:0;right:0;height:35%;background:linear-gradient(to top,rgba(42,28,14,0.55),transparent);"></div>

  <!-- Grain -->
  <div style="position:absolute;inset:0;opacity:0.03;background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');pointer-events:none;"></div>

  <div style="position:relative;z-index:10;max-width:1200px;margin:0 auto;padding:120px 48px 80px;">

    <!-- Eyebrow -->
    <div class="reveal" style="display:inline-flex;align-items:center;gap:10px;background:rgba(232,168,80,0.1);border:1px solid rgba(232,168,80,0.22);border-radius:100px;padding:8px 18px;margin-bottom:36px;font-size:11px;color:rgba(232,168,80,0.85);letter-spacing:0.12em;text-transform:uppercase;">
      <span style="width:6px;height:6px;border-radius:50%;background:#e8a850;animation:navpulse 2s infinite;"></span>
      Sierra Nevada · Graeagle, California · 3,500–5,000 ft
    </div>

    <!-- Main headline -->
    <h1 class="reveal" style="font-family:'Playfair Display',serif;font-size:clamp(60px,8.5vw,116px);font-weight:500;line-height:1.0;color:#f0f8f2;margin:0 0 28px;letter-spacing:-0.025em;transition-delay:0.1s;">
      Five Courses.<br>
      <em id="hero-shimmer" style="font-style:italic;">One Valley.</em>
    </h1>

    <p class="reveal" style="font-size:clamp(17px,2vw,21px);color:rgba(240,248,242,0.6);max-width:560px;line-height:1.65;margin:0 0 44px;font-weight:300;transition-delay:0.2s;">
      Northern California's most concentrated mountain golf destination. Championship courses, Sierra altitude, none of the Tahoe crowds or prices.
    </p>

    <div class="reveal" style="display:flex;gap:16px;align-items:center;flex-wrap:wrap;margin-bottom:80px;transition-delay:0.3s;">
      <a href="/quote" style="background:#e8a850;color:#0d1a0e;font-weight:600;font-size:16px;padding:17px 40px;border-radius:100px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:all 0.3s;box-shadow:0 8px 32px rgba(232,168,80,0.25);"
      onmouseover="this.style.background='#f2c878';this.style.transform='translateY(-2px)';this.style.boxShadow='0 14px 44px rgba(232,168,80,0.45)'"
      onmouseout="this.style.background='#e8a850';this.style.transform='translateY(0)';this.style.boxShadow='0 8px 32px rgba(232,168,80,0.25)'">
        Plan My Golf Trip
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/courses" style="border:1px solid rgba(240,248,242,0.22);color:rgba(240,248,242,0.75);font-size:15px;padding:17px 34px;border-radius:100px;text-decoration:none;backdrop-filter:blur(8px);background:rgba(240,248,242,0.04);transition:all 0.3s;"
      onmouseover="this.style.borderColor='rgba(240,248,242,0.45)';this.style.color='#f0f8f2';this.style.background='rgba(240,248,242,0.08)'"
      onmouseout="this.style.borderColor='rgba(240,248,242,0.22)';this.style.color='rgba(240,248,242,0.75)';this.style.background='rgba(240,248,242,0.04)'">
        Explore 5 Courses
      </a>
    </div>

    <!-- Stats bar -->
    <div class="reveal" style="display:grid;grid-template-columns:repeat(4,auto);gap:1px;background:rgba(232,168,80,0.1);border:1px solid rgba(232,168,80,0.14);border-radius:18px;overflow:hidden;width:fit-content;transition-delay:0.4s;">
      {[
        {num:'5',     suf:'',    label:'Championship Courses'},
        {num:'25',    suf:' min',label:'Max Between Courses'},
        {num:'4500',  suf:'ft',  label:'Avg Elevation'},
        {num:'10',    suf:'%',   label:'Extra Carry Distance'},
      ].map(s=>(
        <div style="background:rgba(13,26,14,0.55);padding:22px 30px;text-align:center;backdrop-filter:blur(12px);">
          <div style="font-family:'Playfair Display',serif;font-size:30px;font-weight:500;color:#e8a850;line-height:1;">
            <span data-count={s.num}>{s.num}</span>{s.suf}
          </div>
          <div style="font-size:10px;color:rgba(240,248,242,0.32);margin-top:6px;letter-spacing:0.07em;text-transform:uppercase;white-space:nowrap;">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll cue -->
  <div style="position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(240,248,242,0.22);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;z-index:10;">
    <span>Scroll</span>
    <div style="width:1px;height:52px;background:linear-gradient(to bottom,rgba(232,168,80,0.45),transparent);animation:navpulse 2s infinite;"></div>
  </div>
</section>

<style>
  @keyframes navpulse{0%,100%{opacity:0.6}50%{opacity:1}}
  @keyframes shimmer{0%{background-position:0% center}100%{background-position:200% center}}
  #hero-shimmer{
    background:linear-gradient(90deg,#e8a850,#f2c878,#c88840,#e8a850);
    background-size:200% auto;
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    animation:shimmer 4s linear infinite;
  }
</style>
<script>
  const bg=document.getElementById('hero-bg');
  if(bg) window.addEventListener('scroll',()=>{bg.style.transform=`translateY(${window.scrollY*0.28}px)`;},{passive:true});
</script>


<!-- ══════════════ SOCIAL PROOF MARQUEE ══════════════ -->
<div style="border-top:1px solid rgba(232,168,80,0.1);border-bottom:1px solid rgba(232,168,80,0.1);padding:14px 0;overflow:hidden;background:rgba(42,28,14,0.25);">
  <div style="display:flex;gap:56px;white-space:nowrap;width:max-content;animation:marqueeScroll 35s linear infinite;">
    {[
      '⭐ Golf Digest Best Places to Play','🥇 Golf Digest Top 100 — Grizzly Ranch',
      '💎 Golf Digest Undiscovered Gem — Whitehawk Ranch','🏛️ Frank Lloyd Wright Clubhouse — Nakoma',
      '⛳ 5 Championship Courses · 25 Minutes Apart','🏔️ Sierra Nevada · Cool Summers · No Crowds',
      '🌿 Better value than Tahoe. Better golf than Sacramento.',
      '⭐ Golf Digest Best Places to Play','🥇 Golf Digest Top 100 — Grizzly Ranch',
      '💎 Golf Digest Undiscovered Gem — Whitehawk Ranch','🏛️ Frank Lloyd Wright Clubhouse — Nakoma',
      '⛳ 5 Championship Courses · 25 Minutes Apart','🏔️ Sierra Nevada · Cool Summers · No Crowds',
      '🌿 Better value than Tahoe. Better golf than Sacramento.',
    ].map(item=>(
      <span style="font-size:11px;color:rgba(232,168,80,0.65);letter-spacing:0.09em;text-transform:uppercase;">{item}</span>
    ))}
  </div>
</div>
<style>
  @keyframes marqueeScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
</style>


<!-- ══════════════════════ COURSES SECTION ══════════════════════ -->
<section style="padding:100px 48px;max-width:1480px;margin:0 auto;">

  <div class="reveal" style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:60px;flex-wrap:wrap;gap:24px;">
    <div>
      <p style="font-size:11px;color:#e8a850;letter-spacing:0.15em;text-transform:uppercase;margin:0 0 14px;">The Courses</p>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(40px,5.5vw,68px);font-weight:500;color:#f0f8f2;margin:0;line-height:1.05;">
        Every course,<br><em style="font-style:italic;color:rgba(240,248,242,0.5);">a different world.</em>
      </h2>
    </div>
    <a href="/courses" style="color:rgba(232,168,80,0.75);text-decoration:none;font-size:14px;border-bottom:1px solid rgba(232,168,80,0.25);padding-bottom:4px;transition:all 0.2s;white-space:nowrap;"
    onmouseover="this.style.color='#e8a850';this.style.borderColor='rgba(232,168,80,0.7)'"
    onmouseout="this.style.color='rgba(232,168,80,0.75)';this.style.borderColor='rgba(232,168,80,0.25)'">
      Full comparison table →
    </a>
  </div>

  <!-- 5-course layout: 2 top large, 3 bottom medium -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
    {courses.slice(0,2).map((course,i)=>{
      const img=courseImages[course.slug];
      const badge=courseBadges[course.slug];
      const tier=priceTier[course.slug];
      const dp=diffPill(course.difficulty);
      return(
      <a href={`/courses/${course.slug}`} class={`reveal ${i===1?'reveal-right':''}`} style={`display:block;text-decoration:none;position:relative;border-radius:22px;overflow:hidden;height:500px;transition:transform 0.4s ease,box-shadow 0.4s ease;box-shadow:0 4px 24px rgba(0,0,0,0.5);transition-delay:${i*0.1}s;`}
      onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 24px 64px rgba(0,0,0,0.65)'"
      onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 24px rgba(0,0,0,0.5)'">
        <img src={img} alt={`${course.name} golf course Graeagle California`} loading="lazy"
          style="position:absolute;inset:0;width:100%;height:115%;object-fit:cover;object-position:center 40%;transition:transform 7s ease;"
          onmouseover="this.style.transform='scale(1.07)'" onmouseout="this.style.transform='scale(1)'" />
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(13,26,14,0.04) 0%,rgba(13,26,14,0.12) 30%,rgba(13,26,14,0.6) 60%,rgba(13,26,14,0.97) 100%);"></div>
        <div style="position:absolute;top:20px;left:20px;right:20px;display:flex;justify-content:space-between;z-index:5;">
          <span style={`font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 13px;border-radius:100px;border:1px solid;${dp}`}>{course.difficulty}</span>
          <div style="display:flex;gap:8px;">
            <span style="background:rgba(13,26,14,0.65);border:1px solid rgba(240,248,242,0.08);color:rgba(240,248,242,0.45);font-size:11px;padding:4px 10px;border-radius:100px;backdrop-filter:blur(8px);">{course.type}</span>
            <span style="background:rgba(232,168,80,0.12);border:1px solid rgba(232,168,80,0.22);color:#e8a850;font-size:13px;font-weight:700;padding:4px 13px;border-radius:100px;">{tier}</span>
          </div>
        </div>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:28px;z-index:5;">
          <div style="display:inline-flex;align-items:center;gap:7px;background:rgba(13,26,14,0.6);border:1px solid rgba(232,168,80,0.18);border-radius:100px;padding:5px 13px;margin-bottom:14px;backdrop-filter:blur(8px);">
            <span style="font-size:13px;">{badge.icon}</span>
            <span style="font-size:10px;color:rgba(232,168,80,0.88);letter-spacing:0.05em;">{badge.label}</span>
          </div>
          <h3 style="font-family:'Playfair Display',serif;font-size:clamp(24px,2.8vw,34px);font-weight:500;color:#f0f8f2;margin:0 0 6px;line-height:1.15;">{course.name}</h3>
          <p style="font-size:13px;color:rgba(240,248,242,0.5);margin:0 0 18px;font-style:italic;">{course.tagline}</p>
          <div style="display:flex;gap:20px;align-items:center;">
            {[{l:'Par',v:course.par},{l:'Yards',v:course.yards.toLocaleString()},{l:'Slope',v:course.slope},{l:'Rating',v:course.rating}].map(s=>(
              <div style="text-align:center;">
                <div style="font-family:'Playfair Display',serif;font-size:20px;color:#f0f8f2;font-weight:500;line-height:1;">{s.v}</div>
                <div style="font-size:9px;color:rgba(240,248,242,0.3);text-transform:uppercase;letter-spacing:0.08em;margin-top:2px;">{s.l}</div>
              </div>
            ))}
            <span style="margin-left:auto;font-size:11px;color:rgba(232,168,80,0.65);">View →</span>
          </div>
        </div>
      </a>
      );
    })}
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;">
    {courses.slice(2).map((course,i)=>{
      const img=courseImages[course.slug];
      const badge=courseBadges[course.slug];
      const tier=priceTier[course.slug];
      const dp=diffPill(course.difficulty);
      return(
      <a href={`/courses/${course.slug}`} class={`reveal delay-${i*100}`} style="display:block;text-decoration:none;position:relative;border-radius:20px;overflow:hidden;height:420px;transition:transform 0.4s ease,box-shadow 0.4s ease;box-shadow:0 4px 20px rgba(0,0,0,0.45);"
      onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 22px 56px rgba(0,0,0,0.65)'"
      onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.45)'">
        <img src={img} alt={`${course.name} golf course`} loading="lazy"
          style="position:absolute;inset:0;width:100%;height:115%;object-fit:cover;object-position:center 40%;transition:transform 7s ease;"
          onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'" />
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(13,26,14,0.04) 0%,rgba(13,26,14,0.55) 55%,rgba(13,26,14,0.97) 100%);"></div>
        <div style="position:absolute;top:18px;left:18px;right:18px;display:flex;justify-content:space-between;z-index:5;">
          <span style={`font-size:10px;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;padding:4px 11px;border-radius:100px;border:1px solid;${dp}`}>{course.difficulty}</span>
          <span style="background:rgba(232,168,80,0.12);border:1px solid rgba(232,168,80,0.22);color:#e8a850;font-size:12px;font-weight:700;padding:4px 12px;border-radius:100px;">{tier}</span>
        </div>
        {/* Featured badge for Grizzly (i=1 in slice(2)) */}
        {i===1&&(
          <div style="position:absolute;top:50%;right:20px;transform:translateY(-50%);background:rgba(232,168,80,0.12);border:1px solid rgba(232,168,80,0.28);border-radius:14px;padding:14px 18px;z-index:5;backdrop-filter:blur(12px);text-align:center;animation:floatBadge 5s ease-in-out infinite;">
            <div style="font-size:20px;margin-bottom:5px;">🥇</div>
            <div style="font-size:9px;color:#e8a850;letter-spacing:0.1em;text-transform:uppercase;font-weight:600;max-width:72px;line-height:1.4;">Golf Digest Top 100</div>
          </div>
        )}
        <div style="position:absolute;bottom:0;left:0;right:0;padding:22px;z-index:5;">
          <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(13,26,14,0.6);border:1px solid rgba(232,168,80,0.16);border-radius:100px;padding:4px 12px;margin-bottom:10px;backdrop-filter:blur(8px);">
            <span style="font-size:12px;">{badge.icon}</span>
            <span style="font-size:9px;color:rgba(232,168,80,0.85);letter-spacing:0.05em;">{badge.label}</span>
          </div>
          <h3 style="font-family:'Playfair Display',serif;font-size:clamp(18px,2vw,24px);font-weight:500;color:#f0f8f2;margin:0 0 5px;">{course.name}</h3>
          <p style="font-size:12px;color:rgba(240,248,242,0.48);margin:0 0 14px;font-style:italic;">{course.tagline}</p>
          <div style="display:flex;gap:14px;align-items:center;">
            {[{l:'Par',v:course.par},{l:'Slope',v:course.slope},{l:'Rating',v:course.rating}].map(s=>(
              <div style="text-align:center;">
                <div style="font-family:'Playfair Display',serif;font-size:17px;color:#f0f8f2;font-weight:500;line-height:1;">{s.v}</div>
                <div style="font-size:9px;color:rgba(240,248,242,0.28);text-transform:uppercase;letter-spacing:0.07em;margin-top:2px;">{s.l}</div>
              </div>
            ))}
            <span style="margin-left:auto;font-size:11px;color:rgba(232,168,80,0.6);">View →</span>
          </div>
        </div>
      </a>
      );
    })}
  </div>
</section>
<style>
  @keyframes floatBadge{0%,100%{transform:translateY(-50%) translateY(0)}50%{transform:translateY(-50%) translateY(-8px)}}
</style>


<!-- ══════════════════════ ALTITUDE ══════════════════════ -->
<section style="position:relative;overflow:hidden;margin:0 48px 80px;border-radius:28px;min-height:480px;">
  <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=80&auto=format"
    alt="Sierra Nevada mountains" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 60%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(13,26,14,0.94) 0%,rgba(13,26,14,0.75) 50%,rgba(42,28,14,0.88) 100%);"></div>

  <div style="position:relative;z-index:5;padding:72px 64px;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;">
    <div class="reveal-left">
      <p style="font-size:11px;color:#e8a850;letter-spacing:0.15em;text-transform:uppercase;margin:0 0 16px;">The Altitude Advantage</p>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(34px,4vw,54px);font-weight:500;color:#f0f8f2;margin:0 0 20px;line-height:1.15;">Hit it further.<br>Every single round.</h2>
      <p style="font-size:15px;color:rgba(240,248,242,0.55);line-height:1.75;margin:0 0 28px;">Thinner Sierra air means 8–10% more carry distance on every shot. That 150-yard approach plays like 163 here. Real distance, every time.</p>
      <div style="display:flex;flex-direction:column;gap:14px;">
        {[{c:'7-iron',s:150,g:163},{c:'Driver',s:250,g:272},{c:'5-iron',s:180,g:196}].map(r=>(
          <div style="display:grid;grid-template-columns:68px 1fr 72px;align-items:center;gap:16px;">
            <span style="font-size:12px;color:rgba(240,248,242,0.4);text-transform:uppercase;letter-spacing:0.07em;">{r.c}</span>
            <div style="position:relative;height:3px;background:rgba(240,248,242,0.07);border-radius:2px;">
              <div style={`width:${(r.s/300)*100}%;height:100%;border-radius:2px;background:rgba(232,168,80,0.35);position:absolute;left:0;top:0;`}></div>
              <div style={`width:${(r.g/300)*100}%;height:100%;border-radius:2px;background:#e8a850;position:absolute;left:0;top:0;opacity:0.8;`}></div>
            </div>
