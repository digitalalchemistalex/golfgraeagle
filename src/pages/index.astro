---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { courses, lodging, siteConfig, imageAlts } from '../data/content.js';
const getImgAlt = (src, fallback) => { const f = (src || '').split('/').pop().split('?')[0]; return (imageAlts || {})[f] || fallback; };

const HERO_IMG = '/wp-images/DJI_0006-Edit.jpg';

const courseListSchema = {
  "@type": "ItemList",
  "name": "Golf Courses in Graeagle, California",
  "description": "Five championship golf courses in the Graeagle, California region of the Sierra Nevada mountains.",
  "numberOfItems": courses.length,
  "itemListElement": courses.map((c, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": `${c.name} Golf Course`,
    "url": `${siteConfig.url}/courses/${c.slug}`,
    "item": {
      "@type": "GolfCourse",
      "name": `${c.name} Golf Course`,
      "url": `${siteConfig.url}/courses/${c.slug}`,
      "numberOfHoles": 18,
      "address": { "@type": "PostalAddress", "streetAddress": c.address, "addressRegion": "CA", "addressCountry": "US" }
    }
  }))
};

const homeFaqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many golf courses are in Graeagle California?",
      "acceptedAnswer": { "@type": "Answer", "text": "Graeagle, California has 5 championship golf courses within 25 minutes of each other: Graeagle Meadows Golf Course, Whitehawk Ranch Golf Course, Plumas Pines Golf Resort, Grizzly Ranch Golf Club, and Nakoma (The Dragon) Golf Course." }
    },
    {
      "@type": "Question",
      "name": "What is the best golf course in Graeagle?",
      "acceptedAnswer": { "@type": "Answer", "text": "The best course depends on skill level. Nakoma Dragon (slope 147) is the most challenging and the only golf clubhouse designed by Frank Lloyd Wright. Grizzly Ranch (Golf Digest Top 100) is the longest at 7,411 yards. Graeagle Meadows is the most accessible for mixed-handicap groups." }
    },
    {
      "@type": "Question",
      "name": "Is Graeagle near Lake Tahoe?",
      "acceptedAnswer": { "@type": "Answer", "text": "Graeagle is approximately 1.5 hours north of North Lake Tahoe via Highway 89. It is located in Plumas County in the Sierra Nevada mountains of Northern California." }
    },
    {
      "@type": "Question",
      "name": "When does golf season start in Graeagle?",
      "acceptedAnswer": { "@type": "Answer", "text": "Golf season in Graeagle typically runs from May through October or November, depending on weather and elevation. Most courses open in late April or early May after snowmelt." }
    },
    {
      "@type": "Question",
      "name": "How far is Graeagle from Sacramento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Graeagle is approximately 2.5 hours northeast of Sacramento via Highway 70 or Highway 89 through the Sierra Nevada mountains." }
    },
    {
      "@type": "Question",
      "name": "What is the hardest golf course in Graeagle?",
      "acceptedAnswer": { "@type": "Answer", "text": "Nakoma Dragon is the hardest golf course in Graeagle with a slope rating of 147 and a course rating of 73.4. Grizzly Ranch is second with a slope of 140 at 7,411 yards." }
    }
  ]
};
---
<Base
  title="Graeagle Golf Packages & Tee Times | GolfGraeagle.com"
  description="Plan your Graeagle golf trip — 5 championship courses in the Sierra Nevada within 25 minutes of each other. Custom stay-and-play packages, tee times, and lodging. Free quote in 24 hours."
  preloadImage={HERO_IMG}
  schema={[courseListSchema, homeFaqSchema]}
  bodyClass="light-page"
>
<Nav />

<!-- ══════ HERO ══════ -->
<section class="hero-section">

  <!-- LCP image — full bleed, eager load -->
  <img
    src={HERO_IMG}
    alt="Graeagle California — aerial view of Feather River, golf courses and Sierra Nevada mountains"
    class="hero-img"
    loading="eager"
    fetchpriority="high"
    decoding="sync"
    width="1920"
    height="1080"
  />

  <!-- Gradient overlay: dark top (behind nav), transparent mid, heavy dark bottom -->
  <div class="hero-overlay"></div>

  <!-- Film strip: 5 courses, sits just below nav -->
  <div class="hero-strip">
    {courses.map((c) => (
      <a href={`/portfolio/${c.slug === "nakoma-dragon" ? "nakoma-dragon-golf-packages" : c.slug + "-golf-packages"}`} class="strip-item" aria-label={`View ${c.name}`}>
        <img src={c.hero} alt={getImgAlt(c.hero, `${c.name} Golf Course — Graeagle CA`)} class="strip-thumb" loading="lazy" />
        <div class="strip-dim"></div>
        <span class="strip-label">{c.name.replace(' — The Dragon','').replace('Graeagle ','')}</span>
      </a>
    ))}
  </div>

  <!-- Main content: left headline + right stat card -->
  <div class="hero-content">

    <!-- LEFT -->
    <div class="hero-left">
      <div class="hero-eyebrow reveal">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">Sierra Nevada · Plumas County · California</span>
      </div>

      <h1 class="hero-h1 reveal delay-100 speakable">
        Five courses.<br/>
        One <em>unforgettable</em><br/>
        valley.
      </h1>

      <p class="hero-sub reveal delay-200 page-intro">
        Championship golf within 25 minutes of each other — from the only Frank Lloyd Wright golf clubhouse to a Golf Digest Top 100 course. We handle everything.
      </p>

      <div class="hero-ctas reveal delay-300">
        <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=homepage-hero" class="btn-green-glow btn-gold">Plan My Trip →</a>
        <a href="/courses" class="btn-ghost-hero">See all 5 courses ↓</a>
      </div>
    </div>

    <!-- RIGHT: stat card -->
    <div class="hero-right reveal delay-200">
      <div class="stat-card">
        {[
          ['Packages from', '$299 per golfer'],
          ['Courses', '5 within 25 min'],
          ['Altitude', '4,300 – 5,400 ft'],
          ['Season', 'May – November'],
          ['Reviews', '4.8 / 5 · 672 verified'],
        ].map(([label, val]) => (
          <div class="stat-row">
            <span class="stat-label">{label}</span>
            <span class="stat-val">{val}</span>
          </div>
        ))}
        <div class="stat-cta">
          <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=homepage-stat-card" class="btn-green-glow btn-gold-sm">Request a Free Quote</a>
          <p class="stat-cta-meta">No obligation · Response within 24 hrs</p>
        </div>
      </div>
    </div>

  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>

</section>

<!-- ══════ COURSES GRID ══════ -->
<section style="background:var(--page-bg);padding:clamp(60px,10vw,100px) 0;">
  <div class="container">
    <div class="reveal section-header">
      <div>
        <p style="font-size:11px;color:var(--gold);letter-spacing:0.16em;text-transform:uppercase;margin:0 0 12px;">The Courses</p>
        <h2 style="font-family:'Playfair Display',serif;font-size:clamp(32px,4.5vw,56px);font-weight:500;color:var(--text-primary);margin:0;line-height:1.1;">Five courses.<br/>Zero compromises.</h2>
      </div>
      <a href="/courses" class="link-gold-sm" style="white-space:nowrap;">Compare all →</a>
    </div>

    <div class="courses-five-grid">
      {[courses[0], courses[1], courses[2], courses[3], courses[4]].map((c,i)=>(
        <a href={`/portfolio/${c.slug === "nakoma-dragon" ? "nakoma-dragon-golf-packages" : c.slug + "-golf-packages"}`} class={`reveal delay-${i*75} course-card-equal`} style="text-decoration:none;display:block;">
          <img src={c.hero} alt={getImgAlt(c.hero, `${c.name} Golf Course — Graeagle, California`)} loading="lazy" class="course-card-img"/>
          <div class="card-gradient"></div>
          <div class="course-card-body">
            <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;">
              <span class="card-pill">Par {c.par}</span>
              <span class="card-pill">{c.yards.toLocaleString()} yds</span>
              <span class="card-pill">{c.designer}</span>
            </div>
            <h3 style="font-family:'Playfair Display',serif;font-size:clamp(16px,1.4vw,20px);color:#ffffff;text-shadow:0 1px 8px rgba(0,0,0,0.5);margin:0 0 12px;line-height:1.2;">{c.name}</h3>
            <span class="link-gold-sm">View course →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════ WHY GRAEAGLE ══════ -->
<section class="dark-section" style="background:#1e1a12;padding:clamp(60px,10vw,100px) 0;overflow:hidden;">
  <div class="container">
    <div class="two-col-section">
      <div>
        <p class="reveal" style="font-size:11px;color:var(--gold);letter-spacing:0.16em;text-transform:uppercase;margin:0 0 16px;">Why Graeagle</p>
        <h2 class="reveal delay-100" style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,52px);color:#f0f8f2;margin:0 0 32px;line-height:1.15;">Every other California golf region forces a compromise.</h2>
        <div class="reveal delay-200" style="display:flex;flex-direction:column;gap:0;">
          {[
            ['Monterey','Elite — but extremely expensive'],
            ['Palm Springs','Summer heat eliminates half the day'],
            ['Truckee / North Tahoe','Premium-priced, scattered courses'],
            ['San Diego / LA','Traffic, long waits, heat'],
          ].map(([place,issue])=>(
            <div style="display:flex;align-items:flex-start;gap:16px;padding:16px 0;border-bottom:1px solid rgba(255,255,255,0.07);">
              <span style="color:rgba(220,80,80,0.7);font-size:18px;flex-shrink:0;margin-top:1px;">✗</span>
              <div>
                <span style="font-size:14px;font-weight:500;color:rgba(255,255,255,0.55);">{place}: </span>
                <span style="font-size:14px;color:rgba(255,255,255,0.35);">{issue}</span>
              </div>
            </div>
          ))}
          <div style="display:flex;align-items:flex-start;gap:16px;padding:20px 0;background:rgba(232,168,80,0.06);margin:8px -16px 0;padding-left:16px;border-radius:12px;border:1px solid rgba(232,168,80,0.15);">
            <span style="color:var(--gold);font-size:20px;flex-shrink:0;">✓</span>
            <div>
              <span style="font-size:15px;font-weight:600;color:var(--gold);">Graeagle: </span>
              <span style="font-size:15px;color:rgba(255,255,255,0.75);">5 elite courses · predictable drives · no city congestion · lower green fees than Tahoe · altitude advantage</span>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal-right why-image-wrap">
        <div style="border-radius:24px;overflow:hidden;aspect-ratio:4/5;">
          <img src="https://golf-pass.brightspotcdn.com/fb/c0/25fb1031420d23ab00595c5024f0/84464.jpg"
            alt="Whitehawk Ranch Golf Course — Mohawk Valley"
            loading="lazy" style="width:100%;height:100%;object-fit:cover;"/>
        </div>
        <div class="float-badge float-bottom-left">
          <div style="font-size:11px;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Valley Altitude</div>
          <div style="font-size:22px;font-family:'Playfair Display',serif;color:var(--gold);">4,400 ft</div>
          <div style="font-size:11px;color:rgba(255,255,255,0.35);margin-top:2px;">Longer carry · faster greens</div>
        </div>
        <div class="float-badge float-top-right">
          <div style="font-size:11px;color:rgba(255,255,255,0.45);margin-bottom:3px;">Whitehawk Ranch</div>
          <div style="font-size:13px;color:#f0f8f2;font-weight:500;">Golf Digest Top 20 CA</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ LODGING ══════ -->
<section style="background:var(--page-bg);padding:clamp(60px,10vw,100px) 0;">
  <div class="container">
    <div class="reveal" style="margin-bottom:clamp(36px,5vw,64px);">
      <p style="font-size:11px;color:var(--gold);letter-spacing:0.16em;text-transform:uppercase;margin:0 0 12px;">Where to Stay</p>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,52px);color:var(--text-primary);margin:0;line-height:1.1;">Stay on the courses.<br/>Wake up ready to play.</h2>
    </div>

    <div class="lodging-four-grid">
      {lodging.map((l, i) => (
        <a href={`/portfolio/${l.slug}`} class={`reveal delay-${i*75} lodging-equal-card`} style="text-decoration:none;display:block;">
          <img src={l.hero} alt={getImgAlt(l.hero, `${l.name} — Graeagle CA lodging for golf groups`)} loading="lazy" class="course-card-img"/>
          <div class="card-gradient"></div>
          <div class="course-card-body">
            <h3 style="font-family:'Playfair Display',serif;font-size:clamp(16px,1.4vw,20px);color:#ffffff;text-shadow:0 1px 8px rgba(0,0,0,0.5);margin:0 0 6px;line-height:1.2;">{l.name}</h3>
            <p style="font-size:12px;color:rgba(255,255,255,0.6);margin:0 0 12px;">{l.subtitle}</p>
            <span class="link-gold-sm">View →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="reveal" style="text-align:center;margin-top:48px;">
      <a href="/lodging" class="btn-ghost">See all lodging options →</a>
    </div>
  </div>
</section>

<!-- ══════ DINING SNAPSHOT ══════ -->
<section class="dark-section" style="background:#1e1a12;padding:clamp(60px,10vw,100px) 0;">
  <div class="container">
    <div class="two-col-section">
      <div class="reveal-left dining-photos">
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/4;grid-row:1/3;">
          <img src="https://nakomaresort.com/wp-content/uploads/fifty44-dining-at-nakoma-lodge-1631x1080.jpg"
            alt="Fifty44 Restaurant at Nakoma — fine dining" loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"/>
        </div>
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/2;">
          <img src="https://nakomaresort.com/wp-content/uploads/outdoor-dining-frank-lloyd-wright-lodge-lawn.jpg"
            alt="Outdoor dining at Nakoma Frank Lloyd Wright lodge" loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"/>
        </div>
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/2;">
          <img src="https://nakomaresort.com/wp-content/uploads/Nakoma-Dining-Patio-01-1620x1080.jpg"
            alt="Nakoma dining patio" loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"/>
        </div>
      </div>

      <div>
        <p class="reveal" style="font-size:11px;color:var(--gold);letter-spacing:0.16em;text-transform:uppercase;margin:0 0 16px;">After Your Round</p>
        <h2 class="reveal delay-100" style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:#f0f8f2;margin:0 0 24px;line-height:1.15;">13 restaurants.<br/>Something for every night.</h2>
        <p class="reveal delay-200" style="font-size:15px;color:rgba(255,255,255,0.55);line-height:1.75;margin:0 0 36px;">From the Frank Lloyd Wright dining room at Nakoma to cold craft beers at Eureka Peak Brewing — the valley has every post-round moment covered.</p>
        <div class="reveal delay-300 dining-grid">
          {[
            ['Fine Dining','Longboards, Sardine Lake, Iron Door, Fifty44'],
            ['Craft Breweries','Eureka Peak, The Brewing Lair, Mohawk Tavern'],
            ['Casual Eats','Grizzly Grill, Roadhouse, Sierra SmokeShow'],
            ['Quick Bites','Little Bite Deli, Graeagle Mountain Frostee'],
          ].map(([cat,places])=>(
            <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:16px;">
              <div style="font-size:11px;font-weight:600;color:rgba(232,168,80,0.85);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;">{cat}</div>
              <div style="font-size:12px;color:rgba(255,255,255,0.45);line-height:1.5;">{places}</div>
            </div>
          ))}
        </div>
        <a href="/dining" class="reveal delay-400 link-gold-sm" style="display:inline-flex;align-items:center;gap:8px;margin-top:36px;">
          See all 13 restaurants →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══════ CTA STRIP ══════ -->
<section style="position:relative;padding:clamp(80px,12vw,120px) clamp(24px,6vw,48px);overflow:hidden;">
  <div style="position:absolute;inset:0;">
    <img src="https://nakomaresort.com/wp-content/uploads/fodge-at-nakoma-exterior-frank-lloyd-wright-1620x1080.jpg"
      alt="Frank Lloyd Wright Nakoma Clubhouse" loading="lazy"
      style="width:100%;height:100%;object-fit:cover;"/>
    <div style="position:absolute;inset:0;background:rgba(13,26,14,0.88);"></div>
  </div>
  <div style="position:relative;z-index:2;max-width:700px;margin:0 auto;text-align:center;">
    <div class="reveal" style="display:inline-flex;align-items:center;gap:8px;background:rgba(232,168,80,0.1);border:1px solid rgba(232,168,80,0.2);border-radius:100px;padding:8px 18px;margin-bottom:28px;">
      <span style="font-size:12px;color:var(--gold);">⛳ 2025 season reservations open</span>
    </div>
    <h2 class="reveal delay-100" style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,60px);color:#f8f4ee;margin:0 0 20px;line-height:1.1;">Ready to plan your round?</h2>
    <p class="reveal delay-200" style="font-size:clamp(14px,1.5vw,16px);color:rgba(248,244,238,0.65);margin:0 0 40px;line-height:1.7;">Tell us your dates, group size, and which courses call to you. We'll handle the rest — tee times, lodging, dining reservations.</p>
    <div class="reveal delay-300 cta-buttons">
      <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=homepage-cta-strip" class="btn-green-glow btn-gold">Request a Free Quote</a>
      <a href="/courses" class="btn-ghost">Browse Courses</a>
    </div>
    <p class="reveal delay-400" style="font-size:12px;color:rgba(248,244,238,0.5);margin:20px 0 0;">No obligation · 72-hour cancellation · Response within 24 hours</p>
  </div>
</section>

<Footer />
</Base>

<style>
  /* ═══ HERO ═══ */
  .hero-section {
    position: relative;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(13,26,14,0.55) 0%,
      transparent 28%,
      transparent 42%,
      rgba(13,26,14,0.88) 72%,
      rgba(13,26,14,0.98) 100%
    );
    z-index: 1;
  }

  /* Film strip */
  .hero-strip {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 3px;
    padding: 3px clamp(20px,4vw,48px);
    padding-top: calc(68px + 3px); /* nav height + gap */
  }
  .strip-item {
    flex: 1;
    height: 58px;
    overflow: hidden;
    border-radius: 6px;
    position: relative;
    text-decoration: none;
    display: block;
    transition: flex 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .strip-item:hover { flex: 2; }
  .strip-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 6s ease;
  }
  .strip-item:hover .strip-thumb { transform: scale(1.08); }
  .strip-dim {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.42);
    transition: background 0.3s;
  }
  .strip-item:hover .strip-dim { background: rgba(0,0,0,0.12); }
  .strip-label {
    position: absolute;
    bottom: 7px;
    left: 9px;
    font-size: 9px;
    color: rgba(255,255,255,0.85);
    font-weight: 600;
    letter-spacing: 0.05em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 90%;
  }

  /* Hero main content — bottom-anchored, two-column */
  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 0 clamp(20px,4vw,52px) clamp(32px,5vh,56px);
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(24px,3vw,48px);
    align-items: end;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }
  .hero-left {}
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .eyebrow-line {
    display: block;
    width: 28px;
    height: 1px;
    background: rgba(232,168,80,0.65);
    flex-shrink: 0;
  }
  .eyebrow-text {
    font-size: 10px;
    color: rgba(232,168,80,0.75);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .hero-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(44px, 6.5vw, 88px);
    font-weight: 500;
    color: #ffffff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
  }
  .hero-h1 em {
    font-style: italic;
    color: #e8a850;
  }
  .hero-sub {
    font-size: clamp(14px, 1.5vw, 17px);
    color: rgba(240,248,242,0.52);
    max-width: 520px;
    line-height: 1.7;
    margin: 0 0 32px;
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Stat card (right side of hero) */
  .hero-right { align-self: end; }
  .stat-card {
    background: rgba(10,20,10,0.82);
    border: 1px solid rgba(232,168,80,0.25);
    border-radius: 16px;
    overflow: hidden;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 13px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    gap: 12px;
  }
  .stat-label {
    font-size: 10px;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    flex-shrink: 0;
