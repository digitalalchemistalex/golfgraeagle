    padding: 3px 9px;
    border-radius: 100px;
    white-space: nowrap;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .course-card-equal:hover .card-pill {
    background: rgba(232,168,80,0.15);
    border-color: rgba(232,168,80,0.55);
    box-shadow: 0 0 8px 2px rgba(232,168,80,0.25);
  }
  .card-gradient-heavy {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(249,246,238,0.96) 0%, rgba(28,18,8,0.04) 60%, transparent 100%);
  }
  .course-card-body {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: clamp(20px, 3vw, 36px) clamp(20px, 3vw, 40px);
  }

  /* ═══ TWO COL ═══ */
  .two-col-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }
  .why-image-wrap { position: relative; }
  .float-badge {
    position: absolute;
    background: rgba(13,26,14,0.97);
    border: 1px solid rgba(232,168,80,0.2);
    border-radius: 16px;
    padding: 18px 22px;
    backdrop-filter: blur(12px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
  }
  .float-bottom-left { bottom: -20px; left: -20px; }
  .float-top-right {
    top: -16px; right: -16px;
    border-color: rgba(232,168,80,0.12);
    border-radius: 12px;
    padding: 14px 18px;
  }

  /* ═══ LODGING ═══ */
  .lodging-four-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }
  .lodging-equal-card {
    position: relative;
    height: 420px;
    overflow: hidden;
    border-radius: 12px;
  }

  /* ═══ DINING ═══ */
  .dining-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .dining-photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* ═══ CTA BUTTONS ═══ */
  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ═══════════════════════════════════
     MOBILE BREAKPOINTS
  ════════════════════════════════════ */
  @media (max-width: 860px) {
    .scroll-hint { display: none; }

    /* Hero → stack vertically */
    .hero-content {
      grid-template-columns: 1fr;
      padding-bottom: clamp(24px,4vh,40px);
    }
    .hero-right { display: none; } /* stat card hidden on mobile — too cramped */

    /* Course grids → 2 col on tablet */
    .courses-five-grid {
      grid-template-columns: 1fr 1fr;
    }
    .course-card-equal { height: 280px; border-radius: 12px; }

    /* Two-col → single col */
    .two-col-section { grid-template-columns: 1fr; }
    /* Image after text on mobile */
    .why-image-wrap { margin-top: 0; }
    .float-badge { display: none; }

    /* Lodging */
    .lodging-four-grid { grid-template-columns: 1fr 1fr; }
    .lodging-equal-card { height: 280px; border-radius: 12px; }

    /* Dining photos hidden on mobile — text content is enough */
    .dining-photos { display: none; }
    .dining-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .courses-five-grid { grid-template-columns: 1fr; }
    .course-card-equal { height: 240px; }
    .lodging-four-grid { grid-template-columns: 1fr; }
    .lodging-equal-card { height: 240px; }
    .hero-ctas { flex-direction: column; align-items: flex-start; }
    .btn-gold { width: 100%; text-align: center; }
    .hero-stats { gap: 16px; }
  }

  @keyframes shimmer {
    0%,100% { opacity:1; }
    50% { opacity:0.7; }
  }
</style>

<script>
  const nav = document.getElementById('sitenav');
  window.addEventListener('scroll', () => {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // Staggered card entrance on scroll
  const cardObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); cardObs.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.courses-five-grid .course-card-equal').forEach(c => cardObs.observe(c));
</script>
