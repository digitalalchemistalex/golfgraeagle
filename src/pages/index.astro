  /* ═══ LAYOUT ═══ */
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .section-header {
    margin-bottom: clamp(36px,5vw,64px);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }

  /* ═══ COURSE CARDS ═══ */
  .courses-feature-row {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2px;
    margin-bottom: 2px;
  }
  .course-card-big {
    position: relative;
    height: 520px;
    overflow: hidden;
    border-radius: 20px 4px 4px 20px;
  }
  .course-card-side {
    position: relative;
    height: 520px;
    overflow: hidden;
    border-radius: 4px 20px 20px 4px;
