    background: #f0f8f2;
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(0.55); }
  }

  /* ═══ BUTTONS ═══ */
  .btn-gold {
    font-size: 15px;
    padding: 16px 36px;
  }
  .btn-gold:hover { }
  .btn-gold-sm {
    display: block;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
    padding: 13px 20px;
  }
  .btn-gold-sm:hover { }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(240,248,242,0.04);
    border: 1px solid rgba(28,18,8,0.08);
    color: rgba(28,18,8,0.55);
    font-size: 14px;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .btn-ghost:hover {
    background: rgba(240,248,242,0.08);
    color:var(--text-primary);
  }
  .btn-ghost-hero {
    color: rgba(28,18,8,0.65);
    font-size: 15px;
