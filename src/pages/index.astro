---
import Base from '../layouts/Base.astro';
import { courses, siteConfig } from '../data/content.js';

const title = "Golf Graeagle | 5 Championship Courses, One Sierra Valley";
const description = "Plan your Graeagle golf trip. Five championship courses — Graeagle Meadows, Whitehawk Ranch, Plumas Pines, Grizzly Ranch, and Nakoma The Dragon — all within 25 minutes of each other in the Sierra Nevada.";
---
<Base title={title} description={description}>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4 flex items-center justify-between backdrop-blur-md bg-slate-950/80 border-b border-white/5">
    <a href="/" class="font-display text-xl text-white tracking-wide">
      Golf <span class="text-gold-400">Graeagle</span>
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm text-white/70">
      <a href="/courses" class="hover:text-white transition-colors">Courses</a>
      <a href="/lodging" class="hover:text-white transition-colors">Lodging</a>
      <a href="/dining" class="hover:text-white transition-colors">Dining</a>
      <a href="/blog" class="hover:text-white transition-colors">Blog</a>
    </div>
    <a href="/quote" class="bg-gold-500 hover:bg-gold-400 text-slate-950 text-sm font-medium px-5 py-2.5 rounded-full transition-all hover:shadow-lg hover:shadow-gold-500/20">
      Plan My Trip
    </a>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Gradient BG simulating mountain atmosphere -->
    <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-forest-900/40 to-slate-950"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(15,48,15,0.6) 0%, transparent 70%)"></div>

    <!-- Animated grain texture -->
    <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><filter id=%22noise%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/><feColorMatrix type=%22saturate%22 values=%220%22/></filter><rect width=%22200%22 height=%22200%22 filter=%22url(%23noise)%22 opacity=%221%22/></svg>')"></div>

    <!-- Decorative circles -->
    <div class="absolute top-1/3 left-1/4 w-96 h-96 rounded-full bg-forest-600/10 blur-3xl"></div>
    <div class="absolute bottom-1/3 right-1/4 w-64 h-64 rounded-full bg-gold-500/5 blur-3xl"></div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pt-24">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 text-xs text-white/60 tracking-widest uppercase mb-8 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-gold-400 animate-pulse"></span>
        Graeagle, California · Sierra Nevada
      </div>

      <!-- Main headline -->
      <h1 class="font-display text-6xl md:text-8xl lg:text-9xl font-light text-white leading-none mb-6 tracking-tight">
        Five Courses.<br />
        <em class="text-gold-400 not-italic">One Valley.</em>
      </h1>

      <!-- Sub -->
      <p class="text-lg md:text-xl text-white/60 max-w-2xl mx-auto mb-12 leading-relaxed font-light speakable-intro">
        Graeagle is Northern California's most concentrated mountain golf destination. 
        Five championship courses — all within 25 minutes of each other — at a fraction of Tahoe prices.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/quote" class="group bg-gold-500 hover:bg-gold-400 text-slate-950 font-medium px-8 py-4 rounded-full transition-all duration-300 hover:shadow-2xl hover:shadow-gold-500/30 hover:scale-105 text-base">
          Plan My Golf Trip
          <span class="inline-block ml-2 transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a href="/courses" class="group border border-white/20 hover:border-white/40 text-white/80 hover:text-white px-8 py-4 rounded-full transition-all duration-300 text-base backdrop-blur-sm">
          Explore Courses
        </a>
      </div>

      <!-- Stats bar -->
      <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden border border-white/5">
        {[
          { num: '5', label: 'Championship Courses' },
          { num: '25min', label: 'Max Drive Between Courses' },
          { num: '4,500ft', label: 'Avg Elevation' },
          { num: '10%', label: 'Extra Distance at Altitude' },
        ].map(stat => (
          <div class="bg-slate-950/60 backdrop-blur-sm px-6 py-6 text-center">
            <div class="font-display text-3xl md:text-4xl text-gold-400 font-light">{stat.num}</div>
            <div class="text-xs text-white/40 mt-1 tracking-wide">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20 text-xs tracking-widest uppercase">
      <span>Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-white/20 to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- COURSES SECTION -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto">

      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <p class="text-gold-400 text-sm tracking-widest uppercase mb-3">The Courses</p>
          <h2 class="font-display text-5xl md:text-6xl text-white font-light leading-tight">
            Every course.<br />A different world.
          </h2>
        </div>
        <a href="/courses" class="text-white/50 hover:text-white text-sm transition-colors border-b border-white/20 hover:border-white/40 pb-0.5 self-end">
          View all courses →
        </a>
      </div>

      <!-- Course grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {courses.map((course, i) => (
          <a
            href={`/courses/${course.slug}`}
            class={`group relative rounded-2xl overflow-hidden border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-500 hover:border-white/10 hover:shadow-xl hover:shadow-black/50 ${i === 0 ? 'md:col-span-2' : ''}`}
          >
            <!-- Color band by difficulty -->
            <div class={`absolute top-0 left-0 right-0 h-0.5 ${
              course.difficulty === 'Advanced–Expert' ? 'bg-red-500' :
              course.difficulty === 'Advanced' ? 'bg-orange-500' :
              course.difficulty === 'Intermediate–Advanced' ? 'bg-yellow-500' :
              'bg-forest-400'
            }`}></div>

            <div class="p-8">
              <!-- Header -->
              <div class="flex items-start justify-between mb-6">
                <div>
                  <p class="text-white/30 text-xs tracking-widest uppercase mb-1">{course.type}</p>
                  <h3 class="font-display text-2xl md:text-3xl text-white font-light group-hover:text-gold-300 transition-colors">
                    {course.name}
                  </h3>
                  <p class="text-white/40 text-sm mt-1">{course.tagline}</p>
                </div>
                <div class="text-right shrink-0 ml-4">
                  <div class="text-xs text-white/30 uppercase tracking-wider">Green Fees</div>
                  <div class="text-gold-400 font-medium text-sm mt-0.5">{course.greenFeeRange}</div>
                </div>
              </div>

              <!-- Stats row -->
              <div class="grid grid-cols-4 gap-3 mb-6">
                {[
                  { label: 'Par', value: course.par },
                  { label: 'Yards', value: course.yards.toLocaleString() },
                  { label: 'Slope', value: course.slope },
                  { label: 'Rating', value: course.rating },
                ].map(s => (
                  <div class="bg-white/[0.03] rounded-xl p-3 text-center border border-white/5">
                    <div class="font-display text-lg text-white">{s.value}</div>
                    <div class="text-white/30 text-xs mt-0.5">{s.label}</div>
                  </div>
                ))}
              </div>

              <!-- Designer + year -->
              <div class="flex items-center justify-between text-xs text-white/30">
                <span>Designed by {course.designer}</span>
                <span>Est. {course.opened}</span>
              </div>

              <!-- Hover CTA -->
              <div class="mt-6 flex items-center gap-2 text-gold-400 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span>View course details</span>
                <span class="transition-transform group-hover:translate-x-1">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY GRAEAGLE — AEO COMPARISON -->
  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-gold-400 text-sm tracking-widest uppercase mb-3">Why Graeagle</p>
        <h2 class="font-display text-5xl md:text-6xl text-white font-light">
          The honest comparison.
        </h2>
        <p class="text-white/40 mt-4 max-w-xl mx-auto">How Graeagle stacks up against other California golf destinations.</p>
      </div>

      <div class="overflow-x-auto rounded-2xl border border-white/5">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/5">
              <th class="text-left px-6 py-4 text-white/40 font-normal">Destination</th>
              <th class="px-6 py-4 text-white/40 font-normal text-center">Avg Green Fee</th>
              <th class="px-6 py-4 text-white/40 font-normal text-center">Courses Near Each Other</th>
              <th class="px-6 py-4 text-white/40 font-normal text-center">Summer Heat</th>
              <th class="px-6 py-4 text-white/40 font-normal text-center">Traffic</th>
            </tr>
          </thead>
          <tbody>
            {[
              { dest: 'Graeagle', fee: '$75–$175', density: '5 in 25 min', heat: 'Cool', traffic: 'None', highlight: true },
              { dest: 'Monterey / Pebble Beach', fee: '$250–$600+', density: 'Spread out', heat: 'Mild', traffic: 'Moderate', highlight: false },
              { dest: 'Palm Springs', fee: '$75–$350', density: 'Many, spread', heat: '110°F+', traffic: 'Low', highlight: false },
              { dest: 'Truckee / North Tahoe', fee: '$150–$350', density: 'Scattered', heat: 'Cool', traffic: 'Heavy weekends', highlight: false },
              { dest: 'Sacramento Valley', fee: '$50–$120', density: 'Moderate', heat: '105°F+', traffic: 'Moderate', highlight: false },
            ].map(row => (
              <tr class={`border-b border-white/5 transition-colors ${row.highlight ? 'bg-forest-900/20' : 'hover:bg-white/[0.02]'}`}>
                <td class="px-6 py-4">
                  <span class={`font-medium ${row.highlight ? 'text-gold-400' : 'text-white/70'}`}>
                    {row.highlight && '★ '}{row.dest}
                  </span>
                </td>
                <td class={`px-6 py-4 text-center ${row.highlight ? 'text-white' : 'text-white/50'}`}>{row.fee}</td>
                <td class={`px-6 py-4 text-center ${row.highlight ? 'text-green-400' : 'text-white/50'}`}>{row.density}</td>
                <td class={`px-6 py-4 text-center ${row.heat.includes('°') ? 'text-red-400' : row.highlight ? 'text-green-400' : 'text-white/50'}`}>{row.heat}</td>
                <td class={`px-6 py-4 text-center ${row.traffic.includes('Heavy') ? 'text-red-400' : row.highlight ? 'text-green-400' : 'text-white/50'}`}>{row.traffic}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ALTITUDE CALCULATOR CALLOUT -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="rounded-3xl border border-gold-500/20 bg-gradient-to-br from-forest-900/20 to-transparent p-10 md:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-radial from-gold-500/5 to-transparent"></div>
        <div class="relative z-10">
          <p class="text-gold-400 text-sm tracking-widest uppercase mb-4">Altitude Advantage</p>
          <h2 class="font-display text-4xl md:text-5xl text-white font-light mb-4">
            Hit it 10% further.<br />Every round.
          </h2>
          <p class="text-white/50 max-w-xl mx-auto mb-8">
            At 3,500–5,000 feet elevation, thinner air means longer carry distances on every shot. 
            A 150-yard club at sea level plays like 165 yards in Graeagle.
          </p>
          <div class="inline-flex items-center gap-6 bg-white/5 rounded-2xl px-8 py-5 border border-white/5 mb-8">
            <div class="text-center">
              <div class="font-display text-3xl text-white/50">150<span class="text-sm ml-1">yds</span></div>
              <div class="text-xs text-white/30 mt-1">At sea level</div>
            </div>
            <div class="text-gold-400 text-2xl font-light">→</div>
            <div class="text-center">
              <div class="font-display text-3xl text-gold-400">163<span class="text-sm ml-1">yds</span></div>
              <div class="text-xs text-white/30 mt-1">In Graeagle</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LODGING TEASER -->
  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <p class="text-gold-400 text-sm tracking-widest uppercase mb-3">Where To Stay</p>
          <h2 class="font-display text-5xl md:text-6xl text-white font-light leading-tight">
            Stay on the fairway.<br />Wake up ready.
          </h2>
        </div>
        <a href="/lodging" class="text-white/50 hover:text-white text-sm transition-colors border-b border-white/20 hover:border-white/40 pb-0.5 self-end">
          View all lodging →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { name: 'River Pines Resort', tagline: 'Family-owned. 62 units. Steps from Plumas Pines.', tag: 'Best for Groups', href: '/lodging/river-pines-resort' },
          { name: 'Chalet View Lodge', tagline: 'Boutique resort with spa, brewery & mountain views.', tag: 'Best Amenities', href: '/lodging/chalet-view-lodge' },
          { name: 'The Inn at Nakoma', tagline: 'FLW-designed villas on the Dragon fairway.', tag: 'Most Unique', href: '/lodging/inn-at-nakoma' },
          { name: 'Townhomes at Plumas Pines', tagline: 'Spacious 2–4BR units with golf course views.', tag: 'Best for Large Groups', href: '/lodging/townhomes-at-plumas-pines' },
        ].map(lodge => (
          <a href={lodge.href} class="group rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] p-8 transition-all duration-300 hover:border-white/10">
            <div class="inline-block bg-forest-800/50 border border-forest-600/20 text-forest-300 text-xs px-3 py-1 rounded-full mb-4">{lodge.tag}</div>
            <h3 class="font-display text-2xl text-white font-light group-hover:text-gold-300 transition-colors">{lodge.name}</h3>
            <p class="text-white/40 text-sm mt-2">{lodge.tagline}</p>
            <div class="mt-6 text-gold-400 text-sm flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
              View property →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ — AEO SECTION -->
  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold-400 text-sm tracking-widest uppercase mb-3 text-center">Common Questions</p>
      <h2 class="font-display text-5xl text-white font-light text-center mb-16">Plan your trip.</h2>

      <div class="space-y-0 divide-y divide-white/5">
        {[
          { q: 'How many golf courses are in Graeagle, California?', a: 'There are five main championship golf courses in the Graeagle area: Graeagle Meadows, Whitehawk Ranch, Plumas Pines, Grizzly Ranch, and Nakoma (The Dragon). All five are within 5–25 minutes of each other.' },
          { q: 'What is the best golf course in Graeagle?', a: 'Grizzly Ranch Golf Club is ranked in Golf Digest\'s Top 100 courses in the nation and is generally considered the most prestigious. Whitehawk Ranch is often called "the undiscovered gem" and rated 4.2/5 by Golf Digest panelists. Nakoma\'s Dragon course is the most dramatic, with a Frank Lloyd Wright clubhouse and slope rating of 147.' },
          { q: 'When is the best time to golf in Graeagle?', a: 'The golf season in Graeagle runs from approximately April through November, with peak conditions in June through September. Summer temperatures are mild — typically 75–85°F — making it one of the most comfortable golf destinations in California.' },
          { q: 'Is Graeagle cheaper than Tahoe for golf?', a: 'Yes. Green fees in Graeagle range from $45–$175, compared to $150–$350+ at comparable courses in the Truckee/Tahoe area. You get equivalent or better course quality at significantly lower cost.' },
          { q: 'How far is Graeagle from Reno and Lake Tahoe?', a: 'Graeagle is approximately 45–50 minutes from Reno and about 45–55 miles north of Lake Tahoe via Highway 89. It\'s an easy drive from both.' },
        ].map(faq => (
          <details class="group py-6 cursor-pointer">
            <summary class="flex items-center justify-between text-white/80 hover:text-white transition-colors list-none">
              <h3 class="font-sans text-base font-medium pr-4">{faq.q}</h3>
              <span class="shrink-0 w-6 h-6 rounded-full border border-white/20 flex items-center justify-center text-white/40 group-open:rotate-45 transition-transform duration-200 text-lg leading-none">+</span>
            </summary>
            <p class="mt-4 text-white/50 text-sm leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-32 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-gold-400 text-sm tracking-widest uppercase mb-4">Ready to Play</p>
      <h2 class="font-display text-6xl md:text-7xl text-white font-light mb-6 leading-tight">
        Your round is<br /><em class="text-gold-400 not-italic">waiting.</em>
      </h2>
      <p class="text-white/40 mb-10 text-lg">Tell us your dates, group size, and preferred courses. We'll handle the rest.</p>
      <a href="/quote" class="group inline-flex items-center gap-3 bg-gold-500 hover:bg-gold-400 text-slate-950 font-medium px-10 py-5 rounded-full transition-all duration-300 hover:shadow-2xl hover:shadow-gold-500/30 hover:scale-105 text-lg">
        Request a Free Quote
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
      <p class="text-white/20 text-xs mt-6">No obligation. Response within 24 hours.</p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-white/5 py-12 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-white/30 text-sm">
      <div class="font-display text-base text-white/50">Golf <span class="text-gold-400/70">Graeagle</span></div>
      <div class="flex gap-6">
        <a href="/courses" class="hover:text-white/60 transition-colors">Courses</a>
        <a href="/lodging" class="hover:text-white/60 transition-colors">Lodging</a>
        <a href="/dining" class="hover:text-white/60 transition-colors">Dining</a>
        <a href="/quote" class="hover:text-white/60 transition-colors">Get a Quote</a>
      </div>
      <div>© 2025 Zoomaway Technologies Inc.</div>
    </div>
  </footer>

</Base>
