    /* Dining photos hidden on mobile — text content is enough */
    .dining-photos { display: none; }
    .dining-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .courses-small-row { grid-template-columns: 1fr; }
