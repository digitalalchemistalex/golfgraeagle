    justify-content: center;
    flex-wrap: wrap;
  }

  /* ═══════════════════════════════════
     MOBILE BREAKPOINTS
  ════════════════════════════════════ */
  @media (max-width: 860px) {
    .scroll-hint { display: none; }

    /* Course grids → single col */
    .courses-feature-row {
      grid-template-columns: 1fr;
