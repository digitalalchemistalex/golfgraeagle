---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { courses, lodging } from '../data/content.js';

const HERO_LCP = 'https://nakomaresort.com/wp-content/uploads/the-dragon-golf-at-nakoma-feather-river-1639x1080.jpg';

const mosaicCourses = [
  { label: 'The Legend',            name: 'Nakoma — The Dragon', accolade: 'Golf World Top 75 · FLW Clubhouse · Slope 147',        img: 'https://nakomaresort.com/wp-content/uploads/the-dragon-golf-at-nakoma-feather-river-1639x1080.jpg',        alt: 'Nakoma Dragon Golf Course aerial', big: true },
  { label: 'The Big Test',          name: 'Grizzly Ranch',           accolade: 'Golf Digest Top 100 · 7,411 yds · Bob Cupp',             img: 'https://grizzlyranchgolfclub.com/wp-content/uploads/2025/06/IMG_0666-2-scaled.jpg',                          alt: 'Grizzly Ranch Golf Club' },
  { label: "Everyone's Favourite",  name: 'Whitehawk Ranch',         accolade: 'Top 20 CA · Dick Bailey design · Slope 132',             img: 'https://whitehawkranch.com/wp-content/uploads/sites/88/2026/02/popup-home.webp',                               alt: 'Whitehawk Ranch Golf Course' },
  { label: 'The Hidden Gem',        name: 'Plumas Pines',            accolade: 'Best Value Sierra NV · Homer Flint · Slope 132',          img: 'https://www.plumaspinesgolf.com/wp-content/uploads/sites/9383/2024/04/Owen-Drone-2.jpg?w=1920&h=700&crop=1', alt: 'Plumas Pines Golf Resort' },
  { label: 'The Valley Classic',    name: 'Graeagle Meadows',        accolade: 'Est. 1968 · Ellis Van Gorder · Feather River',            img: 'https://graeaglemeadows.com/wp-content/uploads/sites/86/2026/03/DJI_0629-2-Edit-scaled.jpg',                   alt: 'Graeagle Meadows Golf Course' },
];
---
<Base
  title="Golf Graeagle — Five Championship Courses in the Sierra Nevada"
  description="Plan your Graeagle golf trip. Five world-class courses within 25 minutes of each other. Stay-and-play packages, tee times, lodging, and dining — all in one valley."
  preloadImage={HERO_LCP}
>
<Nav />

<!-- ══════ HERO MOSAIC ══════ -->
<section class="hero-section">
  <div class="mosaic-grid">
    {mosaicCourses.map((c, i) => (
      <div class={`mosaic-tile${c.big ? ' mosaic-tile-big' : ''}`}>
        <img
          src={c.img}
          alt={c.alt}
          class="mosaic-img"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding={i === 0 ? 'sync' : 'async'}
        />
        <div class="mosaic-name">
          <div class="mosaic-label">{c.label}</div>
          <div class={`mosaic-course${c.big ? ' mosaic-course-big' : ''}`}>{c.name}</div>
          <div class="mosaic-accolade">{c.accolade}</div>
        </div>
      </div>
    ))}
  </div>

  <div class="mosaic-badge">5 courses · 25 minutes apart</div>

  <div class="hero-content">
    <div class="reveal" style="margin-bottom:14px;">
      <span style="font-size:11px;color:rgba(232,168,80,0.75);letter-spacing:0.2em;text-transform:uppercase;">Graeagle, California · Sierra Nevada</span>
    </div>
    <h1 class="reveal delay-100 hero-h1">
      Every course.<br/>
      <em style="color:#e8a850;font-style:italic;">One valley.</em>
    </h1>
    <p class="reveal delay-200 hero-sub">
      The most concentrated mountain golf destination in California — five championship courses, one weekend.
    </p>
    <div class="reveal delay-300 hero-ctas">
      <a href="/request-a-quote" class="btn-gold">Plan My Trip →</a>
      <a href="/courses" class="btn-ghost-hero">Compare all 5 courses</a>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span style="font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#f0f8f2;">Scroll</span>
    <div style="width:1px;height:40px;background:linear-gradient(to bottom,rgba(240,248,242,0.5),transparent);"></div>
  </div>
</section>

<!-- ══════ COURSES GRID ══════ -->
<section style="background:#0d1a0e;padding:clamp(60px,10vw,100px) 0;">
  <div class="container">
    <div class="reveal section-header">
      <div>
        <p style="font-size:11px;color:#e8a850;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 12px;">The Courses</p>
        <h2 style="font-family:'Playfair Display',serif;font-size:clamp(32px,4.5vw,56px);font-weight:500;color:#f0f8f2;margin:0;line-height:1.1;">Five courses.<br/>Zero compromises.</h2>
      </div>
      <a href="/courses" class="link-gold-sm" style="white-space:nowrap;">Compare all →</a>
    </div>

    <div class="courses-feature-row">
      <div class="reveal course-card-big" onclick="window.location='/courses/nakoma-dragon'" style="cursor:pointer;">
        <img src={courses[4].hero} alt="Nakoma Dragon Golf Course — The Dragon fairway" loading="lazy" class="course-card-img"/>
        <div class="card-gradient"></div>
        <div class="course-card-body">
          <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
            <span class="badge">Golf World Top 75</span>
            <span class="badge">FLW Clubhouse</span>
            <span class="badge">Slope 147</span>
          </div>
          <h3 style="font-family:'Playfair Display',serif;font-size:clamp(24px,2.5vw,36px);font-weight:500;color:#f0f8f2;margin:0 0 8px;">Nakoma — The Dragon</h3>
          <p style="font-size:14px;color:rgba(240,248,242,0.55);margin:0 0 20px;">Robin Nelson design · The only FLW golf clubhouse in existence</p>
          <a href="/courses/nakoma-dragon" class="link-gold-sm">View course →</a>
        </div>
      </div>

      <div class="reveal delay-100 course-card-side" onclick="window.location='/courses/grizzly-ranch'" style="cursor:pointer;">
        <img src={courses[3].hero} alt="Grizzly Ranch Golf Club" loading="lazy" class="course-card-img"/>
        <div class="card-gradient"></div>
        <div class="course-card-body">
          <span style="font-size:10px;color:rgba(232,168,80,0.7);letter-spacing:0.1em;text-transform:uppercase;">7,411 yards · Bob Cupp</span>
          <h3 style="font-family:'Playfair Display',serif;font-size:clamp(20px,2vw,26px);color:#f0f8f2;margin:8px 0 4px;">Grizzly Ranch</h3>
          <p style="font-size:12px;color:rgba(240,248,242,0.45);margin:0 0 14px;">The valley's biggest challenge</p>
          <a href="/courses/grizzly-ranch" class="link-gold-sm">View course →</a>
        </div>
      </div>
    </div>

    <div class="courses-small-row">
      {courses.slice(0,3).map((c,i)=>(
        <div class={`reveal delay-${(i+1)*100} course-card-small`} onclick={`window.location='/courses/${c.slug}'`} style="cursor:pointer;">
          <img src={c.hero} alt={`${c.name} Golf Course`} loading="lazy" class="course-card-img"/>
          <div class="card-gradient"></div>
          <div class="course-card-body">
            <span style="font-size:10px;color:rgba(232,168,80,0.65);letter-spacing:0.1em;text-transform:uppercase;">{c.par} par · {c.yards.toLocaleString()} yds · {c.designer}</span>
            <h3 style="font-family:'Playfair Display',serif;font-size:clamp(18px,1.8vw,22px);color:#f0f8f2;margin:6px 0 12px;">{c.name}</h3>
            <a href={`/courses/${c.slug}`} class="link-gold-sm">View course →</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════ WHY GRAEAGLE ══════ -->
<section style="background:rgba(10,18,10,0.98);padding:clamp(60px,10vw,100px) 0;overflow:hidden;">
  <div class="container">
    <div class="two-col-section">
      <div>
        <p class="reveal" style="font-size:11px;color:#e8a850;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 16px;">Why Graeagle</p>
        <h2 class="reveal delay-100" style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,52px);color:#f0f8f2;margin:0 0 32px;line-height:1.15;">Every other California golf region forces a compromise.</h2>
        <div class="reveal delay-200" style="display:flex;flex-direction:column;gap:0;">
          {[
            ['Monterey','Elite — but extremely expensive'],
            ['Palm Springs','Summer heat eliminates half the day'],
            ['Truckee / North Tahoe','Premium-priced, scattered courses'],
            ['San Diego / LA','Traffic, long waits, heat'],
          ].map(([place,issue])=>(
            <div style="display:flex;align-items:flex-start;gap:16px;padding:16px 0;border-bottom:1px solid rgba(240,248,242,0.05);">
              <span style="color:rgba(220,80,80,0.6);font-size:18px;flex-shrink:0;margin-top:1px;">✗</span>
              <div>
                <span style="font-size:14px;font-weight:500;color:rgba(240,248,242,0.5);">{place}: </span>
                <span style="font-size:14px;color:rgba(240,248,242,0.3);">{issue}</span>
              </div>
            </div>
          ))}
          <div style="display:flex;align-items:flex-start;gap:16px;padding:20px 0;background:rgba(232,168,80,0.04);margin:8px -16px 0;padding-left:16px;border-radius:12px;border:1px solid rgba(232,168,80,0.08);">
            <span style="color:#e8a850;font-size:20px;flex-shrink:0;">✓</span>
            <div>
              <span style="font-size:15px;font-weight:600;color:#e8a850;">Graeagle: </span>
              <span style="font-size:15px;color:rgba(240,248,242,0.7);">5 elite courses · predictable drives · no city congestion · lower green fees than Tahoe · altitude advantage</span>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal-right why-image-wrap">
        <div style="border-radius:24px;overflow:hidden;aspect-ratio:4/5;">
          <img src="https://golf-pass.brightspotcdn.com/fb/c0/25fb1031420d23ab00595c5024f0/84464.jpg"
            alt="Whitehawk Ranch Golf Course — Mohawk Valley"
            loading="lazy" style="width:100%;height:100%;object-fit:cover;"/>
        </div>
        <div class="float-badge float-bottom-left">
          <div style="font-size:11px;color:rgba(240,248,242,0.4);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">Valley Altitude</div>
          <div style="font-size:22px;font-family:'Playfair Display',serif;color:#e8a850;">4,400 ft</div>
          <div style="font-size:11px;color:rgba(240,248,242,0.35);margin-top:2px;">Longer carry · faster greens</div>
        </div>
        <div class="float-badge float-top-right">
          <div style="font-size:11px;color:rgba(240,248,242,0.4);margin-bottom:3px;">Whitehawk Ranch</div>
          <div style="font-size:13px;color:#f0f8f2;font-weight:500;">Golf Digest Top 20 CA</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ LODGING ══════ -->
<section style="background:#0d1a0e;padding:clamp(60px,10vw,100px) 0;">
  <div class="container">
    <div class="reveal" style="margin-bottom:clamp(36px,5vw,64px);">
      <p style="font-size:11px;color:#e8a850;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 12px;">Where to Stay</p>
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,52px);color:#f0f8f2;margin:0;line-height:1.1;">Stay on the courses.<br/>Wake up ready to play.</h2>
    </div>

    <div class="lodging-grid">
      <div class="reveal lodging-feature" onclick="window.location='/lodging'" style="cursor:pointer;">
        <img src="https://nakomaresort.com/wp-content/uploads/inn-at-nakoma-lobby-fireplace.jpg"
          alt="The Inn at Nakoma — lobby fireplace" loading="lazy" class="course-card-img"/>
        <div class="card-gradient-heavy"></div>
        <div class="course-card-body">
          <span class="badge" style="display:inline-block;margin-bottom:12px;">Most Unique Stay</span>
          <h3 style="font-family:'Playfair Display',serif;font-size:clamp(22px,2.5vw,30px);color:#f0f8f2;margin:0 0 8px;">The Inn at Nakoma</h3>
          <p style="font-size:13px;color:rgba(240,248,242,0.5);margin:0 0 18px;">Sleep in a Frank Lloyd Wright building. Wake up 50 yards from The Dragon first tee.</p>
          <a href="/lodging" class="link-gold-sm">View lodging →</a>
        </div>
      </div>

      <div class="lodging-side-grid">
        <div class="reveal delay-100 lodging-side-card" onclick="window.location='/lodging'" style="cursor:pointer;">
          <img src="https://nakomaresort.com/wp-content/uploads/2Bedroom-Villa-EXTERIOR.jpg"
            alt="Nakoma 2-Bedroom Villa" loading="lazy" class="course-card-img"/>
          <div class="card-gradient"></div>
          <div class="course-card-body">
            <h3 style="font-family:'Playfair Display',serif;font-size:clamp(18px,1.8vw,22px);color:#f0f8f2;margin:0 0 4px;">Nakoma Villas</h3>
            <p style="font-size:12px;color:rgba(240,248,242,0.45);margin:0;">2-bedroom resort villas on site</p>
          </div>
        </div>
        <div class="reveal delay-200 lodging-side-card" onclick="window.location='/lodging'" style="cursor:pointer;">
          <img src="https://www.plumaspinesgolf.com/wp-content/uploads/sites/9383/2024/04/Clubhouse-from-9th-Tee-25x38-1.jpg"
            alt="Townhomes at Plumas Pines — on the golf course" loading="lazy" class="course-card-img"/>
          <div class="card-gradient"></div>
          <div class="course-card-body">
            <span style="font-size:10px;color:rgba(232,168,80,0.65);text-transform:uppercase;letter-spacing:0.1em;display:block;margin-bottom:6px;">Best for Groups</span>
            <h3 style="font-family:'Playfair Display',serif;font-size:clamp(18px,1.8vw,22px);color:#f0f8f2;margin:0 0 4px;">Townhomes at Plumas Pines</h3>
            <p style="font-size:12px;color:rgba(240,248,242,0.45);margin:0;">Multi-bedroom. On the course. Pool access.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="reveal" style="text-align:center;margin-top:48px;">
      <a href="/lodging" class="btn-ghost">See all lodging options →</a>
    </div>
  </div>
</section>

<!-- ══════ DINING SNAPSHOT ══════ -->
<section style="background:rgba(10,18,10,0.98);padding:clamp(60px,10vw,100px) 0;">
  <div class="container">
    <div class="two-col-section">
      <div class="reveal-left dining-photos">
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/4;grid-row:1/3;">
          <img src="https://nakomaresort.com/wp-content/uploads/fifty44-dining-at-nakoma-lodge-1631x1080.jpg"
            alt="Fifty44 Restaurant at Nakoma — fine dining" loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"/>
        </div>
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/2;">
          <img src="https://nakomaresort.com/wp-content/uploads/outdoor-dining-frank-lloyd-wright-lodge-lawn.jpg"
            alt="Outdoor dining at Nakoma Frank Lloyd Wright lodge" loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"/>
        </div>
        <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/2;">
          <img src="https://nakomaresort.com/wp-content/uploads/Nakoma-Dining-Patio-01-1620x1080.jpg"
            alt="Nakoma dining patio" loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"/>
        </div>
      </div>

      <div>
        <p class="reveal" style="font-size:11px;color:#e8a850;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 16px;">After Your Round</p>
        <h2 class="reveal delay-100" style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:#f0f8f2;margin:0 0 24px;line-height:1.15;">13 restaurants.<br/>Something for every night.</h2>
        <p class="reveal delay-200" style="font-size:15px;color:rgba(240,248,242,0.5);line-height:1.75;margin:0 0 36px;">From the Frank Lloyd Wright dining room at Nakoma to cold craft beers at Eureka Peak Brewing — the valley has every post-round moment covered.</p>
        <div class="reveal delay-300 dining-grid">
          {[
            ['Fine Dining','Longboards, Sardine Lake, Iron Door, Fifty44'],
            ['Craft Breweries','Eureka Peak, The Brewing Lair, Mohawk Tavern'],
            ['Casual Eats','Grizzly Grill, Roadhouse, Sierra SmokeShow'],
            ['Quick Bites','Little Bite Deli, Graeagle Mountain Frostee'],
          ].map(([cat,places])=>(
            <div style="background:rgba(240,248,242,0.02);border:1px solid rgba(240,248,242,0.06);border-radius:12px;padding:16px;">
              <div style="font-size:11px;font-weight:600;color:rgba(232,168,80,0.7);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;">{cat}</div>
              <div style="font-size:12px;color:rgba(240,248,242,0.4);line-height:1.5;">{places}</div>
            </div>
          ))}
        </div>
        <a href="/dining" class="reveal delay-400 link-gold-sm" style="display:inline-flex;align-items:center;gap:8px;margin-top:36px;">
          See all 13 restaurants →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══════ CTA STRIP ══════ -->
<section style="position:relative;padding:clamp(80px,12vw,120px) clamp(24px,6vw,48px);overflow:hidden;">
  <div style="position:absolute;inset:0;">
    <img src="https://nakomaresort.com/wp-content/uploads/fodge-at-nakoma-exterior-frank-lloyd-wright-1620x1080.jpg"
      alt="Frank Lloyd Wright Nakoma Clubhouse" loading="lazy"
      style="width:100%;height:100%;object-fit:cover;"/>
    <div style="position:absolute;inset:0;background:rgba(13,26,14,0.88);"></div>
  </div>
  <div style="position:relative;z-index:2;max-width:700px;margin:0 auto;text-align:center;">
    <div class="reveal" style="display:inline-flex;align-items:center;gap:8px;background:rgba(232,168,80,0.1);border:1px solid rgba(232,168,80,0.2);border-radius:100px;padding:8px 18px;margin-bottom:28px;">
      <span style="font-size:12px;color:#e8a850;">⛳ 2025 season reservations open</span>
    </div>
    <h2 class="reveal delay-100" style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,60px);color:#f0f8f2;margin:0 0 20px;line-height:1.1;">Ready to plan your round?</h2>
    <p class="reveal delay-200" style="font-size:clamp(14px,1.5vw,16px);color:rgba(240,248,242,0.55);margin:0 0 40px;line-height:1.7;">Tell us your dates, group size, and which courses call to you. We'll handle the rest — tee times, lodging, dining reservations.</p>
    <div class="reveal delay-300 cta-buttons">
      <a href="/quote" class="btn-gold">Request a Free Quote</a>
      <a href="/courses" class="btn-ghost">Browse Courses</a>
    </div>
    <p class="reveal delay-400" style="font-size:12px;color:rgba(240,248,242,0.22);margin:20px 0 0;">No obligation · 72-hour cancellation · Response within 24 hours</p>
  </div>
</section>

<Footer />
</Base>

<style>
  /* ═══ HERO MOSAIC ═══ */
  .hero-section {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
  }
  /* 5-tile mosaic: big tile spans 2 rows on left, 4 tiles fill right 2 cols */
  .mosaic-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
  }
  .mosaic-tile {
    position: relative;
    overflow: hidden;
  }
  .mosaic-tile-big {
    grid-row: 1 / 3;
  }
  .mosaic-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.6) saturate(0.85);
    transition: transform 0.65s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.5s ease;
    display: block;
  }
  .mosaic-tile:hover .mosaic-img {
    transform: scale(1.08);
    filter: brightness(0.42) saturate(1.1);
  }
  .mosaic-name {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 14px 16px 12px;
    background: linear-gradient(to top, rgba(10,20,12,0.92) 0%, transparent 100%);
    transform: translateY(4px);
    opacity: 0.55;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .mosaic-tile:hover .mosaic-name {
    opacity: 1;
    transform: translateY(0);
  }
  .mosaic-label {
    font-size: 10px;
    color: rgba(240,248,242,0.45);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 3px;
    transition: color 0.3s;
  }
  .mosaic-tile:hover .mosaic-label {
    color: rgba(232,168,80,0.8);
  }
  .mosaic-course {
    font-size: 13px;
    color: #f0f8f2;
    font-weight: 500;
    line-height: 1.2;
  }
  .mosaic-course-big {
    font-size: 17px;
  }
  .mosaic-accolade {
    font-size: 10px;
    color: rgba(232,168,80,0.7);
    margin-top: 4px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.35s ease 0.05s, transform 0.35s ease 0.05s;
  }
  .mosaic-tile:hover .mosaic-accolade {
    opacity: 1;
    transform: translateY(0);
  }
  .mosaic-badge {
    position: absolute;
    top: 14px; left: 14px;
    z-index: 20;
    background: rgba(232,168,80,0.12);
    border: 1px solid rgba(232,168,80,0.28);
    color: #e8a850;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 100px;
    pointer-events: none;
  }
  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(24px,5vw,48px) clamp(24px,6vw,64px);
    background: linear-gradient(to top, rgba(10,18,10,0.90) 0%, rgba(10,18,10,0.08) 38%, transparent 58%);
    pointer-events: none;
  }
  .hero-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 500;
    color: #f0f8f2;
    line-height: 1.0;
    margin: 0 0 16px;
    max-width: 700px;
  }
  .hero-sub {
    font-size: clamp(14px, 1.4vw, 17px);
    color: rgba(240,248,242,0.55);
    max-width: 480px;
    line-height: 1.7;
    margin: 0 0 28px;
  }
