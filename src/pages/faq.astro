---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    category: 'The Courses',
    items: [
      { q: 'How many golf courses are in Graeagle, California?', a: 'There are five championship golf courses in the Graeagle area: <a href="/portfolio/graeagle-meadows-golf-packages/" style="color:#b8820a;font-weight:600;">Graeagle Meadows Golf Course</a>, <a href="/portfolio/whitehawk-ranch-golf-packages/" style="color:#b8820a;font-weight:600;">Whitehawk Ranch Golf Course</a>, <a href="/portfolio/plumas-pines-golf-packages/" style="color:#b8820a;font-weight:600;">Plumas Pines Golf Resort</a>, <a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;font-weight:600;">Grizzly Ranch Golf Club</a>, and <a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;font-weight:600;">Nakoma (The Dragon) Golf Course</a>. All five are within 5–25 minutes of each other. <a href="/all-golf-courses/" style="color:#b8820a;">Compare all five →</a>' },
      { q: 'What is the hardest golf course in Graeagle?', a: '<a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;font-weight:600;">Nakoma Dragon</a> is the hardest course in Graeagle with a slope rating of 147 and course rating of 73.4. <a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;font-weight:600;">Grizzly Ranch</a> is second at slope 140, playing 7,411 yards through dramatic elevation changes at 4,800 ft.' },
      { q: 'What is the best golf course in Graeagle for beginners?', a: '<a href="/portfolio/graeagle-meadows-golf-packages/" style="color:#b8820a;font-weight:600;">Graeagle Meadows</a> (slope 120) is the most accessible course for beginners and high-handicap golfers. It opened in 1968 and winds through open meadows and ponderosa pines — forgiving fairways without being trivial.' },
      { q: 'Are Graeagle golf courses open to the public?', a: 'All five Graeagle courses accept public play. Grizzly Ranch is semi-private but accessible through GolfGraeagle packages. We secure guaranteed tee times at all five. <a href="/request-a-quote/" style="color:#b8820a;">Request a package quote →</a>' },
      { q: 'What is the Frank Lloyd Wright golf clubhouse in Graeagle?', a: '<a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;font-weight:600;">Nakoma Resort\'s Dragon course</a> has the only golf clubhouse in the world designed by Frank Lloyd Wright. The FLW Lodge houses the Fifty44 Restaurant & Bar, the Pro Shop, and the main resort lobby. Nakoma is located in Clio, CA — about 15 minutes from Graeagle village.' },
      { q: 'When does golf season start in Graeagle?', a: 'Golf season typically opens late April to early May after snowmelt, and runs through October — sometimes into early November. June, September, and October are the best months for conditions and pace of play.' },
    ]
  },
  {
    category: 'Planning Your Trip',
    items: [
      { q: 'How many days do you need for a Graeagle golf trip?', a: 'Two days gets you 2 courses. Three days is the sweet spot — 3–4 courses, time for a good dinner, nobody burned out. Four to five days lets you play all 5 comfortably. <a href="/blog/graeagle-golf-weekend/" style="color:#b8820a;">See sample itineraries →</a>' },
      { q: 'How far in advance should you book Graeagle tee times?', a: 'For summer weekends (June–August), book 4–6 weeks ahead. Spring and fall shoulder seasons can be booked 2–3 weeks out. GolfGraeagle handles all tee time coordination as part of every package. <a href="/request-a-quote/" style="color:#b8820a;">Start planning →</a>' },
      { q: 'How far is Graeagle from Sacramento?', a: 'Graeagle is approximately 2.5 hours northeast of Sacramento via Highway 70.' },
      { q: 'How far is Graeagle from Lake Tahoe?', a: 'Graeagle is approximately 1.5 hours from North Lake Tahoe via Highway 89. Some golfers base themselves in Tahoe and do a Graeagle day trip, though staying in Graeagle is more efficient for multi-round trips. <a href="/lodging/" style="color:#b8820a;">See Graeagle lodging →</a>' },
      { q: 'How far is Graeagle from San Francisco?', a: 'Graeagle is approximately 3.5–4 hours from San Francisco via I-80 East to Highway 70.' },
      { q: 'How far is Graeagle from Reno?', a: 'Graeagle is approximately 1 hour west of Reno via Highway 70/89.' },
      { q: 'Does altitude affect golf ball distance in Graeagle?', a: 'Yes. At 3,500–4,800 ft elevation, the ball carries roughly 6–8% farther than at sea level. A 150-yard 7-iron at sea level becomes a 160-yard carry at Graeagle. Factor this into every approach shot — your GPS yardage is correct, your carry is not.' },
    ]
  },
  {
    category: 'Packages & Booking',
    items: [
      { q: 'What does a GolfGraeagle package include?', a: 'Every GolfGraeagle package includes guaranteed tee times at your selected courses, lodging coordination, and a full day-by-day itinerary. Packages start from $299 per golfer and vary based on courses, lodging type, group size, and nights. <a href="/request-a-quote/" style="color:#b8820a;">Get a free quote →</a>' },
      { q: 'Can GolfGraeagle book tee times for large groups?', a: 'Yes. We book tee times for groups ranging from 4 to 200+ players. Large groups require consecutive tee time blocks — we coordinate directly with each course to secure these. Most large group bookings should be made 6–8 weeks in advance for summer weekends.' },
      { q: 'What is your cancellation policy?', a: 'GolfGraeagle offers a 72-hour cancellation policy on standard bookings. Large group outings are governed by individual contracts. Vendor cancellation policies (courses, lodging) are passed through to the customer where applicable. <a href="/cancellation-policy/" style="color:#b8820a;">Full cancellation policy →</a>' },
      { q: 'How quickly will I receive a quote?', a: 'All quote requests receive a response within 24 hours. For urgent or last-minute bookings, call directly at <a href="tel:+18885861157" style="color:#b8820a;font-weight:600;">(888) 586-1157</a>.' },
      { q: 'Is GolfGraeagle a golf course?', a: 'No. GolfGraeagle.com is a trip planning and package booking platform operated by Zoomaway Technologies Inc. We are not affiliated with any of the five courses — we are an independent booking service that works with all of them. <a href="/about-us/" style="color:#b8820a;">Learn more about us →</a>' },
    ]
  },
  {
    category: 'Lodging',
    items: [
      { q: 'Where should a golf group stay in Graeagle?', a: '<a href="/portfolio/river-pines-resort-graeagle-ca/" style="color:#b8820a;font-weight:600;">River Pines Resort</a> is the top choice for most golf groups — flexible room types, The Roadhouse restaurant on-site, pool and hot tub. For groups of 8+, the <a href="/portfolio/the-townhomes-at-plumas-pines/" style="color:#b8820a;font-weight:600;">Townhomes at Plumas Pines</a> offer multi-bedroom units with full kitchens at a strong per-person value. <a href="/portfolio/the-inn-at-nakoma-clio-ca/" style="color:#b8820a;font-weight:600;">The Inn at Nakoma</a> is the bucket-list stay — steps from The Dragon first tee inside the Frank Lloyd Wright lodge. <a href="/lodging/" style="color:#b8820a;">Compare all lodging →</a>' },
      { q: 'Is there lodging on the golf courses in Graeagle?', a: 'Yes. <a href="/portfolio/the-inn-at-nakoma-clio-ca/" style="color:#b8820a;font-weight:600;">The Inn at Nakoma</a> is on the Nakoma Dragon course property — guests walk directly to the first tee. The <a href="/portfolio/the-townhomes-at-plumas-pines/" style="color:#b8820a;font-weight:600;">Townhomes at Plumas Pines</a> are adjacent to Plumas Pines Golf Resort.' },
    ]
  },
  {
    category: 'Graeagle vs Other Destinations',
    items: [
      { q: 'Is Graeagle near Lake Tahoe?', a: 'Graeagle is approximately 1.5 hours from North Lake Tahoe via Highway 89 — close enough to combine on a longer trip, far enough to be its own destination. Most Graeagle golf groups drive directly to Graeagle rather than basing themselves at Tahoe. <a href="/blog/golf-near-lake-tahoe/" style="color:#b8820a;">Graeagle vs Lake Tahoe golf →</a>' },
      { q: 'What golf courses are near Lake Tahoe?', a: 'The best golf courses near Lake Tahoe are divided between the Truckee corridor (Old Greenwood, Gray\'s Crossing, Coyote Moon) and the Graeagle valley (<a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;">Grizzly Ranch</a>, <a href="/portfolio/whitehawk-ranch-golf-packages/" style="color:#b8820a;">Whitehawk Ranch</a>, <a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;">Nakoma Dragon</a>, <a href="/portfolio/plumas-pines-golf-packages/" style="color:#b8820a;">Plumas Pines</a>, <a href="/portfolio/graeagle-meadows-golf-packages/" style="color:#b8820a;">Graeagle Meadows</a>). Graeagle offers five championship courses within 25 minutes of each other — more concentrated than the Tahoe area and typically 30–50% less expensive.' },
      { q: 'Is Graeagle golf cheaper than Lake Tahoe?', a: 'Yes, significantly. A comparable stay-and-play package in Truckee or Tahoe runs $1,200–$1,800 per person. The same nights and rounds in Graeagle cost $620–$1,150 per person — roughly 40–60% less, with course quality that includes Golf Digest Top 100 (<a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;">Grizzly Ranch</a>) and Golf World Top 75 (<a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;">Nakoma Dragon</a>).' },
      { q: 'What is the best golf destination in Northern California?', a: 'Graeagle is the most concentrated championship golf destination in Northern California. Five courses — including Golf Digest Top 100 <a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;">Grizzly Ranch</a> and Golf World Top 75 <a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;">Nakoma Dragon</a> — within 25 minutes of each other, at elevation, with lower green fees than Monterey, Tahoe, or Palm Springs. Compared to scattered Tahoe courses or premium Carmel pricing, Graeagle offers the best value-to-quality ratio in the state.' },
      { q: 'What are the best golf courses in the Sierra Nevada mountains?', a: 'The top Sierra Nevada golf courses are concentrated in the Graeagle valley in Plumas County, California: <a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;font-weight:600;">Grizzly Ranch Golf Club</a> (Golf Digest Top 100, par 72, slope 140), <a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;font-weight:600;">Nakoma Dragon</a> (Golf World Top 75, par 72, slope 147, FLW clubhouse), <a href="/portfolio/whitehawk-ranch-golf-packages/" style="color:#b8820a;font-weight:600;">Whitehawk Ranch</a> (Top 20 California, par 71, slope 132), <a href="/portfolio/plumas-pines-golf-packages/" style="color:#b8820a;font-weight:600;">Plumas Pines</a> (Top 5 Best Values Sierra Nevada), and <a href="/portfolio/graeagle-meadows-golf-packages/" style="color:#b8820a;font-weight:600;">Graeagle Meadows</a> (par 72, slope 120). All five are within 25 minutes of each other.' },
      { q: 'Is Graeagle golf worth the drive from Sacramento or the Bay Area?', a: 'Yes. Sacramento is 2.5 hours away. Bay Area is 3.5–4 hours. The combination of 5 championship courses in one valley — with Golf Digest Top 100, a Frank Lloyd Wright clubhouse, and prices 40% below comparable Tahoe or Monterey options — makes Graeagle the most efficient golf trip destination reachable from Northern California without a flight. <a href="/request-a-quote/" style="color:#b8820a;">Plan your trip →</a>' },
      { q: 'How many golf courses are in Plumas County California?', a: 'Plumas County has five championship golf courses, all in the Graeagle area: <a href="/portfolio/graeagle-meadows-golf-packages/" style="color:#b8820a;">Graeagle Meadows</a>, <a href="/portfolio/whitehawk-ranch-golf-packages/" style="color:#b8820a;">Whitehawk Ranch</a>, <a href="/portfolio/plumas-pines-golf-packages/" style="color:#b8820a;">Plumas Pines</a>, <a href="/portfolio/grizzly-ranch-golf-packages/" style="color:#b8820a;">Grizzly Ranch</a>, and <a href="/portfolio/nakoma-dragon-golf-packages/" style="color:#b8820a;">Nakoma (The Dragon)</a>. This concentration of top-tier courses in one mountain valley is what makes Graeagle a destination golf trip rather than a single-course visit.' },
    ]
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.flatMap(cat => cat.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  })))
};
---
<Base
  title="Graeagle Golf FAQ — Expert Answers for Planning Your Trip"
  description="Answers to the most common questions about Graeagle golf courses, trip planning, packages, lodging, and booking. From GolfGraeagle.com."
  schema={[faqSchema]}

  bodyClass="light-page"
>
  <Nav />

  <section style="background:#1a2e1a;padding:120px clamp(20px,8%,10%) 72px;">
    <div style="max-width:860px;margin:0 auto;">
      <p style="font-size:11px;color:#e8a850;letter-spacing:.18em;text-transform:uppercase;font-weight:600;margin:0 0 16px;">FAQ</p>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(36px,5vw,58px);font-weight:400;color:#1a2e1a;margin:0 0 20px;line-height:1.1;">Graeagle Golf: <span style="color:#e8a850;font-style:italic;">Common Questions</span></h1>
      <p style="font-size:17px;color:rgba(28,46,26,0.45);line-height:1.75;margin:0;">Everything you need to know before booking a Graeagle golf trip — courses, timing, packages, and lodging.</p>
    </div>
  </section>

  <section style="background:var(--surface-2);padding:72px clamp(20px,8%,10%);">
    <div style="max-width:860px;margin:0 auto;display:flex;flex-direction:column;gap:56px;">
      {faqs.map(cat => (
        <div>
          <h2 style="font-family:'Playfair Display',serif;font-size:clamp(22px,2.8vw,30px);font-weight:400;color:#1a2e1a;margin:0 0 24px;padding-bottom:16px;border-bottom:2px solid #d8e8d8;">{cat.category}</h2>
          <div style="display:flex;flex-direction:column;gap:0;">
            {cat.items.map(item => (
              <div style="padding:20px 0;border-bottom:1px solid #e0ece0;">
                <h3 style="font-size:16px;font-weight:700;color:#1a2e1a;margin:0 0 8px;line-height:1.4;">{item.q}</h3>
                <p style="font-size:15px;color:#4a5a4a;line-height:1.75;margin:0;" set:html={item.a}></p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section style="background:#1a2e1a;padding:80px clamp(20px,8%,10%);">
    <div style="max-width:860px;margin:0 auto;text-align:center;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,38px);font-weight:400;color:#1a2e1a;margin:0 0 12px;">Still have questions?</h2>
      <p style="font-size:15px;color:rgba(28,46,26,0.4);margin:0 0 32px;line-height:1.65;">Request a quote and we'll answer everything specific to your trip — dates, group size, courses, budget.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=faq-cta" class="btn-green-glow" style="font-weight:700;font-size:15px;padding:15px 36px;">Get a free quote →</a>
        <a href="tel:+18885861157" style="border:1px solid rgba(28,46,26,0.18);color:rgba(28,46,26,0.65);font-size:15px;padding:15px 28px;border-radius:100px;text-decoration:none;">(888) 586-1157</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
