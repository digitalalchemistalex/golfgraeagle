---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedTrips from '../components/RelatedTrips.tsx';
import { fetchTripStats } from '../lib/tripStats';
const { minPrice, maxPrice, tripCount } = await fetchTripStats();


const title = "Summer Golf in Graeagle — June, July & August | GolfGraeagle.com";
const description = `Summer golf in Graeagle, California — 5 championship courses, June through August. Book 6–8 weeks ahead for peak season. Conditions, booking windows, and packages from $${minPrice}/golfer.`;

const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "When is the best time to golf in Graeagle in summer?", "acceptedAnswer": { "@type": "Answer", "text": "June and September are the best summer-adjacent months — great conditions, less crowded than July–August peak. July and August have the best weather but require booking 6–8 weeks ahead for weekends, especially at Grizzly Ranch and Nakoma Dragon." } },
    { "@type": "Question", "name": "How far in advance do I need to book summer tee times in Graeagle?", "acceptedAnswer": { "@type": "Answer", "text": "July–August weekends: 6–8 weeks ahead. June and September: 4–6 weeks. Groups of 12+ needing consecutive tee time blocks should add 2 extra weeks to those windows. GolfGraeagle books directly with each pro shop — same booking windows, guaranteed access." } },
    { "@type": "Question", "name": "Are Grizzly Ranch and Nakoma Dragon open in summer?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Both courses are open June through October. Grizzly Ranch and Nakoma Dragon are semi-private — most visitors cannot book them directly. GolfGraeagle guarantees tee time access to both as part of any summer package." } },
    { "@type": "Question", "name": "What is the weather like in Graeagle during summer golf?", "acceptedAnswer": { "@type": "Answer", "text": "Graeagle sits at 4,400–4,800 ft elevation. Summer highs reach 85–90°F with cool mornings in the 55–65°F range. No humidity. Afternoon thunderstorms are possible in July and August — most rounds tee off at 7–9am and finish before any weather arrives." } },
    { "@type": "Question", "name": "How much do summer golf packages in Graeagle cost?", "acceptedAnswer": { "@type": "Answer", "text": `Summer packages start from $${minPrice} per golfer for 2–3 nights and 3–4 rounds. Peak July–August pricing is 10–15% higher than May–June shoulder season. All packages include guaranteed tee times, lodging, and a day-by-day itinerary.` } },
  ]
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://golfgraeagle.com" },
    { "@type": "ListItem", "position": 2, "name": "Golf Packages", "item": "https://golfgraeagle.com/golf-packages/" },
    { "@type": "ListItem", "position": 3, "name": "Summer Golf Graeagle", "item": "https://golfgraeagle.com/summer-golf-graeagle/" }
  ]
};
const orgSchema = {
  "@context": "https://schema.org", "@graph": [
    { "@type": ["TravelAgency","Organization"], "@id": "https://golfgraeagle.com/#organization",
      "name": "GolfGraeagle.com", "url": "https://golfgraeagle.com",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" } },
    { "@type": "WebPage", "url": "https://golfgraeagle.com/summer-golf-graeagle/", "name": title }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org", "@type": "Service",
  "name": "Summer Golf Packages in Graeagle California",
  "description": "Summer golf trip packages in Graeagle — June, July and August. 5 championship courses, guaranteed tee times at semi-private courses, lodging, and full itinerary from ${minPrice}/golfer.",
  "provider": { "@type": "TravelAgency", "@id": "https://golfgraeagle.com/#organization" },
  "areaServed": { "@type": "Place", "name": "Graeagle, California" },
  "serviceType": "Summer Golf Trip Package",
  "offers": { "@type": "AggregateOffer", "lowPrice": `${minPrice}`, "highPrice": "1120", "priceCurrency": "USD" }
};
const howToSchema = {
  "@context": "https://schema.org", "@type": "HowTo",
  "name": "How to Book a Summer Golf Trip to Graeagle",
  "description": "Book summer tee times at Graeagle's 5 championship courses — including semi-private Grizzly Ranch and Nakoma Dragon.",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Pick your dates 6–8 weeks out", "text": "July–August weekends book fastest. Submit dates at least 6–8 weeks ahead. June and September need 4–6 weeks. GolfGraeagle books directly with each pro shop." },
    { "@type": "HowToStep", "position": 2, "name": "Choose your courses — tell us Grizzly Ranch and Nakoma if you want them", "text": "Both semi-private courses are included in any package — just request them. Most visitors cannot book Grizzly Ranch or Nakoma Dragon directly in summer." },
    { "@type": "HowToStep", "position": 3, "name": "Receive tee times + lodging confirmed together", "text": "GolfGraeagle returns a full summer package: tee times, lodging, day-by-day schedule, dining suggestions — all-in price, within 24 hours." },
  ]
};

const months = [
  { name: 'May', temp: '60–75°F', crowds: 'Low', bookAhead: '2–3 weeks', condition: 'Opening season. Some courses still soft. Best pricing.', hot: false, badge: '' },
  { name: 'June', temp: '68–82°F', crowds: 'Moderate', bookAhead: '4–6 weeks', condition: 'Ideal conditions. Firm fairways. Weekday tee times still easy to get.', hot: false, badge: 'Sweet spot' },
  { name: 'July', temp: '75–90°F', crowds: 'Peak', bookAhead: '6–8 weeks', condition: 'Best weather. Grizzly Ranch and Nakoma fill fastest. Book early.', hot: true, badge: 'Peak season' },
  { name: 'August', temp: '72–88°F', crowds: 'Peak', bookAhead: '6–8 weeks', condition: 'Similar to July. Late August starts to ease. Still book early for weekends.', hot: true, badge: 'Peak season' },
  { name: 'September', temp: '62–80°F', crowds: 'Low', bookAhead: '2–4 weeks', condition: 'Best conditions of the year. Firm, fast fairways. Fall color begins. Locals choose this window.', hot: false, badge: 'Best conditions' },
  { name: 'October', temp: '50–68°F', crowds: 'Very low', bookAhead: '1–2 weeks', condition: 'Full fall color. Cool mornings. Last chance before season close. Exceptional value.', hot: false, badge: '' },
];

const courses = [
  { name: 'Graeagle Meadows', slug: 'graeagle-meadows-golf-packages', slope: 120, note: 'Best opener. Open meadows, mountain views. All skill levels.', hero: '/wp-images/graeagle-meadows-hero.webp', access: 'Public', accessColor: '#1a7a40' },
  { name: 'Whitehawk Ranch', slug: 'whitehawk-ranch-golf-packages', slope: 132, note: 'Top 20 California. Sulphur Creek weaves through. Precision over power.', hero: '/wp-images/whitehawk-hero.webp', access: 'Public', accessColor: '#1a7a40' },
  { name: 'Plumas Pines', slug: 'plumas-pines-golf-packages', slope: 132, note: 'On-course lodging option. Best value in the valley.', hero: '/wp-images/plumas-pines-hero.webp', access: 'Public', accessColor: '#1a7a40' },
  { name: 'Grizzly Ranch', slug: 'grizzly-ranch-golf-packages', slope: 140, note: 'Golf Digest Top 100. Most sought-after summer tee times.', hero: '/wp-images/grizzly-ranch-hero.webp', access: 'Semi-private', accessColor: '#b45309' },
  { name: 'Nakoma — Dragon', slug: 'nakoma-dragon-golf-packages', slope: 147, note: 'Golf World Top 75. Frank Lloyd Wright clubhouse. Hardest to book.', hero: '/wp-images/nakoma-dragon-feather-river.webp', access: 'Semi-private', accessColor: '#b45309' },
];

const conditions = [
  ['🌡️', 'Elevation keeps heat manageable', 'Graeagle sits at 4,400–4,800 ft. Summer highs hit 85–90°F but mornings are 55–65°F. No humidity. Most rounds finish by 1pm — before any afternoon heat.'],
  ['⛈️', 'Afternoon thunderstorms are possible', 'July and August can bring afternoon storms. Tee off at 7–9am and the round will finish before any weather arrives. Courses have lightning protocols — rounds are rarely cancelled outright.'],
  ['🌿', 'Fairways firm up through summer', 'June fairways are still soft from snowmelt runoff. By July they are firmer and faster. September gives you the firmest, fastest conditions of the season.'],
  ['🎯', 'Altitude adds 10–15 yards of carry', 'At 4,500 ft, expect 10–15 extra yards on every club. Factor this into course management — especially at Grizzly Ranch (slope 140) and Nakoma Dragon (slope 147).'],
];
---
<Base title={title} description={description} ogType="website"
  schema={[orgSchema, faqSchema, breadcrumbSchema, howToSchema, serviceSchema]}
  canonical="https://golfgraeagle.com/summer-golf-graeagle/"
  ogImage="https://golfgraeagle.com/wp-images/DJI_0949-Edit.webp"
  bodyClass="light-page"
>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="sg-hero">
    <div class="sg-hero-img" style="background-image:url(/wp-images/DJI_0949-Edit.webp)"></div>
    <div class="sg-hero-overlay"></div>
    <div class="sg-hero-inner">
      <p class="sg-eyebrow reveal-up">Summer Golf · Graeagle, California · June · July · August</p>
      <h1 class="sg-h1 reveal-up delay-1">Summer Golf in Graeagle.<br/><em>Book 6 Weeks Out.</em></h1>
      <p class="sg-subhead speakable reveal-up delay-2">5 championship courses open June through October. Peak season tee times — including semi-private Grizzly Ranch and Nakoma Dragon — fill 6–8 weeks ahead. Packages from ${minPrice}/golfer.</p>
      <div class="sg-pills reveal-up delay-3">
        <span class="sg-pill">Open June–October</span>
        <span class="sg-pill">5 courses</span>
        <span class="sg-pill">⭐ 4.8 · 672 reviews</span>
        <span class="sg-pill">From $620/golfer</span>
      </div>
      <div class="sg-hero-ctas reveal-up delay-4">
        <a href="/request-a-quote/" class="btn-green-glow sg-cta-main">Book Summer Tee Times →</a>
        <a href="/tee-times-graeagle/" class="sg-cta-ghost underline-draw">Booking windows ↗</a>
      </div>
    </div>
    <div class="sg-floats reveal-fade delay-5">
      <div class="sg-float"><div class="sg-float-val">6–8</div><div class="sg-float-lbl">Weeks ahead peak</div></div>
      <div class="sg-float"><div class="sg-float-val">4.8★</div><div class="sg-float-lbl">672 reviews</div></div>
      <div class="sg-float"><div class="sg-float-val">5</div><div class="sg-float-lbl">Open courses</div></div>
    </div>
  </section>

  <!-- ═══ MONTH-BY-MONTH — light ═══ -->
  <section class="sg-section">
    <div class="sg-container">
      <div class="sg-header reveal-up">
        <span class="sec-label">When to play — month by month</span>
        <h2 class="sg-h2">Graeagle golf season<br/><em>month by month</em></h2>
        <p class="sg-section-sub">Conditions, crowds, and how far ahead to book — for each month of the season.</p>
      </div>
      <div class="sg-months-grid">
        {months.map((m, i) => (
          <div class={`sg-month glow-card reveal-scale delay-${(i%4)+1}${m.hot?' sg-month-hot':''}`}>
            {m.badge && <div class="sg-month-badge" style={m.hot?'background:#b45309':'background:#1a7a40'}>{m.badge}</div>}
            <div class="sg-month-name">{m.name}</div>
            <div class="sg-month-temp">{m.temp}</div>
            <div class="sg-month-row"><span class="sg-month-lbl">Crowds:</span><span class="sg-month-val" style={m.hot?'color:#e85a20':m.crowds==='Low'||m.crowds==='Very low'?'color:#1a7a40':'color:#b45309'}>{m.crowds}</span></div>
            <div class="sg-month-row"><span class="sg-month-lbl">Book ahead:</span><span class="sg-month-val" style={m.hot?'color:#e85a20':''}>{m.bookAhead}</span></div>
            <p class="sg-month-note">{m.condition}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CONDITIONS — dark ═══ -->
  <section class="sg-section sg-dark">
    <div class="sg-container">
      <div class="sg-header reveal-up">
        <span class="sec-label" style="color:#e8a850">What to expect when you play</span>
        <h2 class="sg-h2" style="color:#f5f0e8">Summer conditions<br/><em>on the course</em></h2>
      </div>
      <div class="sg-cond-grid">
        {conditions.map(([icon, title, body], i) => (
          <div class={`sg-cond glow-card reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="sg-cond-icon">{icon}</div>
            <div class="sg-cond-title">{title}</div>
            <p class="sg-cond-body">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 5 COURSES — light ═══ -->
  <section class="sg-section">
    <div class="sg-container">
      <div class="sg-header reveal-up">
        <span class="sec-label">All 5 courses open in summer — 2 semi-private</span>
        <h2 class="sg-h2">The courses —<br/><em>summer access explained</em></h2>
      </div>
      <div class="sg-courses-grid">
        {courses.map((c, i) => (
          <a href={`/portfolio/${c.slug}/`} class={`sg-course-card glow-card reveal-${i%2===0?'left':'right'} delay-${(i%3)+1}`}>
            <div class="sg-course-img" style={`background-image:url(${c.hero})`}>
              <div class="sg-course-fade"></div>
              <span class="sg-access-badge" style={`background:${c.accessColor}`}>{c.access}</span>
            </div>
            <div class="sg-course-body">
              <h3 class="sg-course-name">{c.name}</h3>
              <div class="sg-course-specs">Slope {c.slope}</div>
              <p class="sg-course-note">{c.note}</p>
              <span class="sg-course-link underline-draw">View packages →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="sg-footer-note reveal-up">
        Grizzly Ranch and Nakoma Dragon are semi-private — most visitors cannot book them directly in summer. GolfGraeagle guarantees tee time access to both as part of any package. See <a href="/tee-times-graeagle/" style="color:var(--sg-green);font-weight:700">how summer tee time booking works →</a>
      </p>
    </div>
  </section>

  <!-- ═══ TRUST STATS ═══ -->
  <section class="sg-trust sg-dark">
    <div class="sg-container sg-trust-row">
      {[
        ['6–8 wks','Advance booking peak'],
        ['4,500 ft','Course elevation'],
        ['4.8★','672 reviews'],
        [`$${minPrice}`,'Starting price/golfer'],
        ['5','Courses in 25 min'],
      ].map(([val, label], i) => (
        <div class={`sg-stat reveal-scale delay-${i+1}`}>
          <div class="sg-stat-val">{val}</div>
          <div class="sg-stat-label">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="sg-section">
    <div class="sg-container" style="max-width:780px">
      <div class="sg-header reveal-up">
        <span class="sec-label">Questions about summer golf in Graeagle</span>
        <h2 class="sg-h2">Summer Golf FAQ</h2>
      </div>
      {faqSchema.mainEntity.map((item: any, i: number) => (
        <details class={`sg-faq reveal-up delay-${(i%4)+1}`}>
          <summary class="sg-faq-q">{item.name}<span class="sg-faq-icon">+</span></summary>
          <p class="sg-faq-a">{item.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ CTA — dark ═══ -->
  <section class="sg-cta-section sg-dark">
    <div class="sg-cta-glow"></div>
    <div class="sg-container" style="text-align:center;max-width:660px;position:relative;z-index:1">
      <h2 class="sg-cta-h2 reveal-up">Summer tee times go fast.<br/><em>Book yours now.</em></h2>
      <p class="sg-cta-sub reveal-up delay-1">Tell us your summer dates, group size, and which courses you want. We confirm tee times — including Grizzly Ranch and Nakoma Dragon — within 24 hours.</p>
      <div class="reveal-scale delay-2">
        <a href="/request-a-quote/" class="btn-green-glow sg-cta-main">Reserve Summer Tee Times →</a>
        <p class="sg-cta-trust">From ${minPrice}/golfer · Semi-private access included · 4.8★ · 24h confirmation</p>
      </div>
    </div>
  </section>

  <RelatedTrips client:load slug="summer-golf-graeagle" type="course" showAll={true} max={3} />
  <Footer />
</Base>

<style>
:root{--sg-gold:#e8a850;--sg-green:#1a7a40;--sg-dark:#0d1a0e;--sg-text:#1c1208;--sg-muted:rgba(28,18,8,0.52);--sg-border:rgba(28,18,8,0.08)}
.sg-container{max-width:1140px;margin:0 auto;padding:0 clamp(20px,6%,80px)}
.sg-section{padding:clamp(72px,9vw,120px) 0;background:var(--page-bg,#f8f5f0)}
.sg-dark{background:var(--sg-dark)!important}
.sg-header{text-align:center;margin-bottom:clamp(40px,5vw,68px)}
.sg-h2{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,52px);font-weight:500;color:var(--sg-text);line-height:1.1;margin:8px 0 0}
.sg-h2 em{font-style:italic;color:var(--sg-green)}
.sg-section-sub{font-size:15px;color:var(--sg-muted);margin:12px auto 0;max-width:520px;line-height:1.65}
.sg-footer-note{text-align:center;font-size:14px;color:var(--sg-muted);max-width:660px;margin:24px auto 0;line-height:1.7}

/* HERO */
.sg-hero{position:relative;min-height:90vh;display:flex;align-items:flex-end;overflow:hidden}
.sg-hero-img{position:absolute;inset:0;background-size:cover;background-position:center 40%;transform:scale(1.06);animation:sgZoom 10s ease forwards}
@keyframes sgZoom{to{transform:scale(1)}}
.sg-hero-overlay{position:absolute;inset:0;background:linear-gradient(158deg,rgba(13,26,14,.15) 0%,rgba(13,26,14,.6) 50%,rgba(13,26,14,.97) 100%)}
.sg-hero-inner{position:relative;z-index:2;padding:0 clamp(24px,8%,120px) clamp(60px,8vw,100px);max-width:820px}
.sg-eyebrow{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(232,168,80,.85);margin:0 0 18px}
.sg-h1{font-family:'Playfair Display',serif;font-size:clamp(42px,7vw,88px);font-weight:500;color:#f5f0e8;line-height:.98;margin:0 0 20px}
.sg-h1 em{font-style:italic;color:var(--sg-gold)}
.sg-subhead{font-size:clamp(16px,2vw,20px);color:rgba(245,240,232,.65);line-height:1.6;margin:0 0 28px}
.sg-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
.sg-pill{font-size:12px;font-weight:600;color:rgba(245,240,232,.85);padding:7px 16px;background:rgba(255,255,255,.1);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.18);border-radius:100px}
.sg-hero-ctas{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.sg-cta-main{display:inline-block;padding:15px 36px;border-radius:100px;font-size:15px;font-weight:700;text-decoration:none}
.sg-cta-ghost{font-size:14px;font-weight:600;color:rgba(232,168,80,.9);text-decoration:none}
.sg-floats{position:absolute;right:clamp(24px,5%,72px);bottom:clamp(56px,8vw,90px);display:flex;flex-direction:column;gap:10px;z-index:3}
.sg-float{background:rgba(255,255,255,.1);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.2);border-radius:16px;padding:14px 22px;text-align:center;min-width:116px}
.sg-float-val{font-family:'Playfair Display',serif;font-size:24px;color:var(--sg-gold);font-weight:400;line-height:1}
.sg-float-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.45);margin-top:5px}

/* MONTHS GRID */
.sg-months-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(180px,44vw),1fr));gap:14px}
.sg-month{border-radius:16px;padding:20px;border:1px solid var(--sg-border);background:#fff;display:flex;flex-direction:column;gap:5px;position:relative;overflow:hidden;transition:all .3s}
.sg-month:hover{transform:translateY(-4px);box-shadow:0 16px 44px rgba(0,0,0,.1)}
.sg-month-hot{border-color:rgba(232,90,32,.2);background:#fffaf7}
.sg-month-badge{position:absolute;top:0;right:0;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#fff;padding:4px 12px;border-radius:0 16px 0 10px}
.sg-month-name{font-family:'Playfair Display',serif;font-size:22px;color:var(--sg-text);font-weight:500}
.sg-month-temp{font-size:13px;color:var(--sg-muted);font-weight:600}
.sg-month-row{display:flex;gap:8px;font-size:11px;align-items:center}
.sg-month-lbl{color:rgba(28,18,8,.35);font-weight:600}
.sg-month-val{font-weight:700}
.sg-month-note{font-size:11px;color:var(--sg-muted);line-height:1.55;margin:4px 0 0;flex:1}

/* CONDITIONS */
.sg-cond-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.sg-cond{border-radius:18px;padding:28px;background:rgba(255,255,255,.06);border:1px solid rgba(245,240,232,.1);display:flex;flex-direction:column;gap:10px}
.sg-cond-icon{font-size:28px}
.sg-cond-title{font-size:15px;font-weight:700;color:#f5f0e8}
.sg-cond-body{font-size:13px;color:rgba(245,240,232,.7);line-height:1.65;margin:0}

/* COURSE CARDS */
.sg-courses-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px}
.sg-course-card{border-radius:18px;overflow:hidden;text-decoration:none;background:rgba(28,18,8,.03);border:1px solid var(--sg-border);transition:all .35s;display:flex;flex-direction:column}
.sg-course-card:hover{transform:translateY(-5px);box-shadow:0 20px 52px rgba(0,0,0,.12);border-color:rgba(232,168,80,.4)}
.sg-course-img{height:160px;background-size:cover;background-position:center;position:relative;flex-shrink:0}
.sg-course-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(9,15,9,.75) 0%,transparent 50%)}
.sg-access-badge{position:absolute;top:10px;right:10px;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#fff;padding:3px 10px;border-radius:100px}
.sg-course-body{padding:16px;flex:1;display:flex;flex-direction:column;gap:5px}
.sg-course-name{font-size:14px;font-weight:700;color:var(--sg-text);margin:0}
.sg-course-specs{font-size:11px;color:var(--sg-muted)}
.sg-course-note{font-size:11px;color:var(--sg-muted);line-height:1.5;flex:1;margin:0}
.sg-course-link{font-size:11px;font-weight:700;color:var(--sg-green)}

/* TRUST */
.sg-trust{padding:clamp(48px,6vw,80px) 0}
.sg-trust-row{display:grid;grid-template-columns:repeat(5,1fr);gap:32px;text-align:center}
.sg-stat-val{font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,40px);color:var(--sg-gold);font-weight:400;line-height:1;margin-bottom:8px}
.sg-stat-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(245,240,232,.55)}

/* FAQ */
.sg-faq{border-bottom:1px solid var(--sg-border)}
.sg-faq[open]{background:rgba(232,168,80,.03);border-radius:12px;border-color:rgba(232,168,80,.22)}
.sg-faq-q{font-size:15px;font-weight:600;color:var(--sg-text);padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px}
.sg-faq-q::-webkit-details-marker{display:none}
.sg-faq[open] .sg-faq-q{color:var(--sg-green)}
.sg-faq-icon{font-size:24px;color:var(--sg-gold);flex-shrink:0;transition:transform .3s}
.sg-faq[open] .sg-faq-icon{transform:rotate(45deg)}
.sg-faq-a{font-size:14px;color:var(--sg-muted);line-height:1.82;padding:0 0 20px;margin:0}

/* CTA */
.sg-cta-section{padding:clamp(80px,10vw,132px) 0;position:relative;overflow:hidden}
.sg-cta-glow{position:absolute;width:720px;height:720px;border-radius:50%;background:radial-gradient(circle,rgba(26,122,64,.18) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.sg-cta-h2{font-family:'Playfair Display',serif;font-size:clamp(28px,5vw,52px);color:#f5f0e8;font-weight:500;line-height:1.15;margin:0 0 20px}
.sg-cta-h2 em{color:var(--sg-gold);font-style:italic}
.sg-cta-sub{font-size:16px;color:rgba(245,240,232,.75);line-height:1.75;margin:0 0 36px}
.sg-cta-trust{font-size:12px;color:rgba(245,240,232,.3);margin-top:14px}

/* Mobile */
@media(max-width:900px){.sg-floats{display:none}.sg-cond-grid{grid-template-columns:1fr}.sg-trust-row{grid-template-columns:repeat(3,1fr);gap:20px}}
@media(max-width:540px){.sg-months-grid{grid-template-columns:1fr 1fr}.sg-courses-grid{grid-template-columns:1fr 1fr}.sg-trust-row{grid-template-columns:1fr 1fr}}
</style>
