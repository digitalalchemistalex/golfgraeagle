---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { courses, siteConfig } from '../../data/content.js';

export function getStaticPaths() {
  return courses.map(c => ({ params: { slug: c.slug }, props: { course: c } }));
}
const { course: c } = Astro.props;
const pageUrl = `${siteConfig.url}/courses/${c.slug}`;

// --- SCHEMA ARRAY ---
const golfCourseSchema = {
  "@type": "GolfCourse",
  "@id": `${pageUrl}#golfcourse`,
  "name": `${c.name} Golf Course`,
  "description": c.description,
  "url": pageUrl,
  "numberOfHoles": 18,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": c.address,
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "designer": { "@type": "Person", "name": c.designer },
  "dateCreated": `${c.year}`,
  "amenityFeature": c.highlights.map(h => ({ "@type": "LocationFeatureSpecification", "name": h, "value": true })),
  "sameAs": c.website,
  "isPartOf": { "@id": `${siteConfig.url}/#organization` }
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "Golf Courses", "item": `${siteConfig.url}/courses` },
    { "@type": "ListItem", "position": 3, "name": c.name, "item": pageUrl }
  ]
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Is ${c.name} open to the public?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${c.name} is open to public play. Tee time availability varies by season. GolfGraeagle can secure guaranteed tee times as part of a stay-and-play package.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the slope rating at ${c.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${c.name} has a slope rating of ${c.slope} and a course rating of ${c.rating}. The course plays to par ${c.par} at ${c.yards.toLocaleString()} yards from the tips.`
      }
    },
    {
      "@type": "Question",
      "name": `Who designed ${c.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${c.name} was designed by ${c.designer} and opened in ${c.year}.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the best time to play ${c.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${c.name} is open approximately May through October, weather permitting. Morning tee times offer cooler temperatures and optimal course conditions.`
      }
    },
    {
      "@type": "Question",
      "name": `How do I book a tee time at ${c.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `GolfGraeagle can book tee times at ${c.name} as part of a custom stay-and-play package. Request a free quote at golfgraeagle.com/quote and receive a response within 24 hours.`
      }
    }
  ]
};
---
<Base
  title={`${c.name} Golf Course — Tee Times & Packages | Graeagle, CA`}
  description={`${c.name}: Par ${c.par}, ${c.yards.toLocaleString()} yards, Slope ${c.slope}. Designed by ${c.designer} (${c.year}). Book stay-and-play packages through GolfGraeagle.`}
  schema={[golfCourseSchema, breadcrumbSchema, faqSchema]}
>
<Nav />

<!-- ═══ HERO — FILM STRIP + MAIN HERO ═══ -->
<section style="background:#090f09;">

  <!-- Film strip: all 5 courses, active one expanded -->
  <div id="course-strip" style="display:flex;gap:3px;padding:3px;padding-top:68px;">
    {courses.map((course, i) => {
      const isActive = course.slug === c.slug;
      return (
        <a
          href={`/courses/${course.slug}`}
          data-slug={course.slug}
          data-active={isActive ? 'true' : 'false'}
          style={`flex:${isActive ? '2.8' : '1'};height:88px;overflow:hidden;border-radius:6px;position:relative;text-decoration:none;display:block;transition:flex 0.4s ease;`}
          aria-label={`View ${course.name}`}
        >
          <img
            src={course.hero}
            alt={course.name}
            style="width:100%;height:100%;object-fit:cover;display:block;"
            loading={isActive ? 'eager' : 'lazy'}
            fetchpriority={isActive ? 'high' : 'auto'}
          />
          <div style={`position:absolute;inset:0;background:${isActive ? 'rgba(0,0,0,0.08)' : 'rgba(0,0,0,0.52)'};transition:background 0.35s;`}></div>
          <div style={`position:absolute;bottom:7px;left:9px;font-size:9px;color:rgba(255,255,255,${isActive ? '0.95' : '0.45'});font-weight:${isActive ? '600' : '400'};letter-spacing:0.04em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:90%;`}>
            {course.name.replace(' — The Dragon', '').replace('Graeagle ', '')}
          </div>
        </a>
      );
    })}
  </div>

  <!-- Main hero -->
  <div style="position:relative;height:clamp(420px,55vh,640px);overflow:hidden;">
    <!-- LCP image — eager, high priority -->
    <img
      src={c.hero}
      alt={`${c.name} Golf Course — Graeagle, California`}
      style="width:100%;height:115%;object-fit:cover;position:absolute;top:0;left:0;object-position:center 40%;"
      loading="eager"
      fetchpriority="high"
      width="1600"
      height="900"
    />
    <!-- Gradient -->
    <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(9,15,9,0.18) 0%,transparent 30%,transparent 40%,rgba(9,15,9,0.92) 80%,rgba(9,15,9,1) 100%);"></div>

    <!-- Bottom content area -->
    <div id="hero-bottom-grid" style="position:absolute;bottom:0;left:0;right:0;padding:clamp(20px,4vw,40px) clamp(20px,5vw,52px);display:grid;grid-template-columns:1fr auto;gap:24px;align-items:flex-end;">

      <!-- Left: identity -->
      <div>
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" style="margin-bottom:14px;">
          <a href="/courses" style="font-size:11px;color:rgba(240,248,242,0.35);text-decoration:none;letter-spacing:0.06em;transition:color 0.2s;"
            onmouseover="this.style.color='rgba(240,248,242,0.65)'" onmouseout="this.style.color='rgba(240,248,242,0.35)'">
            ← All Courses
          </a>
        </nav>

        <!-- Award badges -->
        {(c.awards?.length > 0 || c.tier) && (
          <div style="display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;">
            {c.awards?.map(a => (
              <span style="background:rgba(232,168,80,0.14);border:1px solid rgba(232,168,80,0.28);color:#e8a850;font-size:9px;padding:4px 12px;border-radius:100px;letter-spacing:0.08em;">{a}</span>
            ))}
            <span style="background:rgba(240,248,242,0.07);border:1px solid rgba(240,248,242,0.12);color:rgba(240,248,242,0.5);font-size:9px;padding:4px 12px;border-radius:100px;">{c.tier} Green Fees</span>
          </div>
        )}

        <!-- Course name — H1, LCP text -->
        <h1 class="speakable" style="font-family:'Playfair Display',serif;font-size:clamp(32px,5.5vw,68px);color:#f0f8f2;margin:0 0 10px;line-height:1.0;letter-spacing:-0.01em;">{c.name}</h1>
        <p class="page-intro" style="font-size:clamp(13px,1.6vw,16px);color:rgba(240,248,242,0.45);margin:0 0 22px;max-width:560px;line-height:1.55;">{c.tagline}</p>

        <!-- CTAs -->
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="/request-a-quote"
            style="display:inline-flex;align-items:center;gap:7px;background:#f0f8f2;color:#090f09;font-size:12px;font-weight:700;padding:13px 24px;border-radius:100px;text-decoration:none;letter-spacing:0.01em;transition:all 0.2s;"
            onmouseover="this.style.background='#fff';this.style.transform='translateY(-1px)'"
            onmouseout="this.style.background='#f0f8f2';this.style.transform='translateY(0)'">
            Book a Package →
          </a>
          <a href={c.website || '#'}
            style="display:inline-flex;align-items:center;gap:7px;background:rgba(240,248,242,0.07);border:1px solid rgba(240,248,242,0.14);color:rgba(240,248,242,0.65);font-size:12px;font-weight:500;padding:13px 24px;border-radius:100px;text-decoration:none;transition:all 0.2s;"
            onmouseover="this.style.background='rgba(240,248,242,0.12)'" onmouseout="this.style.background='rgba(240,248,242,0.07)'"
            target="_blank" rel="noopener">
            Course Website ↗
          </a>
        </div>
      </div>

      <!-- Right: stats card -->
      <div id="hero-stats-card" style="background:rgba(9,15,9,0.7);border:1px solid rgba(240,248,242,0.08);border-radius:14px;padding:20px 24px;min-width:170px;flex-shrink:0;backdrop-filter:blur(12px);">
        <div style="font-size:9px;color:rgba(240,248,242,0.25);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px;">Quick Stats</div>
        {[
          ['Par', `${c.par}`],
          ['Yards', c.yards.toLocaleString()],
          ['Slope', `${c.slope}`],
          ['Rating', `${c.rating}`],
        ].map(([k, v]) => (
          <div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(240,248,242,0.05);">
            <span style="font-size:10px;color:rgba(240,248,242,0.28);text-transform:uppercase;letter-spacing:0.1em;">{k}</span>
            <span style="font-size:15px;font-weight:500;color:#f0f8f2;">{v}</span>
          </div>
        ))}
        <div style="margin-top:7px;padding-top:7px;border-top:1px solid rgba(240,248,242,0.05);">
          <div style="font-size:10px;color:rgba(240,248,242,0.28);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:3px;">Designer</div>
          <div style="font-size:13px;font-weight:500;color:rgba(240,248,242,0.8);">{c.designer}</div>
          <div style="font-size:11px;color:rgba(240,248,242,0.3);">Est. {c.year}</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom info bar -->
  <div style="padding:14px clamp(20px,5vw,52px);background:rgba(9,15,9,0.97);border-bottom:1px solid rgba(232,168,80,0.07);display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
    <div style="display:flex;gap:24px;flex-wrap:wrap;">
      {[
        ['Altitude', c.altitude],
        ['Open', 'May – November'],
        ['Location', c.address?.split(',')[1]?.trim() || 'Graeagle, CA'],
      ].map(([k, v]) => (
        <div>
          <span style="font-size:9px;color:rgba(240,248,242,0.25);text-transform:uppercase;letter-spacing:0.1em;margin-right:8px;">{k}</span>
          <span style="font-size:12px;color:rgba(240,248,242,0.55);font-weight:500;">{v}</span>
        </div>
      ))}
    </div>
    <div style="font-size:11px;color:rgba(240,248,242,0.2);">5 courses · All within 25 min of Graeagle</div>
  </div>
</section>

<style>
  .course-body { background: #0d1a0e; padding: clamp(40px, 8vw, 80px) clamp(20px, 10%, 10%); }
  .course-layout { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 380px; gap: 64px; }
  .photo-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
  @media (max-width: 900px) {
    .course-layout { grid-template-columns: 1fr; }
    .course-sidebar { order: -1; }
    .course-sidebar-inner { position: static !important; }
  }
  @media (max-width: 640px) { .photo-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 400px) { .photo-grid { grid-template-columns: 1fr; } }

  /* Hero mobile */
  @media (max-width: 700px) {
    #hero-bottom-grid {
      grid-template-columns: 1fr !important;
    }
    #hero-stats-card {
      display: none !important;
    }
    #course-strip a {
      height: 64px !important;
    }
  }
</style>

<div class="course-body">
  <div class="course-layout">

    <!-- LEFT: Content -->
    <div>
      <!-- Description — speakable intro -->
      <div class="reveal" style="margin-bottom:56px;">
        <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:#f0f8f2;margin:0 0 20px;">About {c.name}</h2>
        <p class="speakable" style="font-size:16px;color:rgba(240,248,242,0.6);line-height:1.85;">{c.description}</p>
      </div>

      <!-- Course Highlights -->
      <div class="reveal" style="margin-bottom:56px;">
        <h2 style="font-family:'Playfair Display',serif;font-size:24px;color:#f0f8f2;margin:0 0 20px;">Course Highlights</h2>
        <div style="display:flex;flex-direction:column;gap:0;">
          {c.highlights.map(h => (
            <div style="display:flex;align-items:flex-start;gap:14px;padding:16px 0;border-bottom:1px solid rgba(240,248,242,0.05);">
              <span style="color:#e8a850;font-size:16px;flex-shrink:0;margin-top:1px;">✓</span>
              <span style="font-size:15px;color:rgba(240,248,242,0.65);line-height:1.5;">{h}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Photo gallery -->
      {c.images.length > 1 && (
        <div class="reveal" style="margin-bottom:56px;">
          <h2 style="font-family:'Playfair Display',serif;font-size:24px;color:#f0f8f2;margin:0 0 20px;">Course Photos</h2>
          <div class="photo-grid">
            {c.images.slice(0,6).map((img,i) => (
              <div style={`border-radius:${i===0?'16px 4px 4px 4px':i===2?'4px 16px 4px 4px':i===3?'4px 4px 4px 16px':i===5?'4px 4px 16px 4px':'4px'};overflow:hidden;aspect-ratio:4/3;`}>
                <img src={img} alt={`${c.name} — hole ${i+1}`} loading="lazy"
                  style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;"
                  onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Best for -->
      <div class="reveal" style="background:rgba(232,168,80,0.05);border:1px solid rgba(232,168,80,0.1);border-radius:16px;padding:28px 32px;margin-bottom:56px;">
        <div style="font-size:11px;color:rgba(232,168,80,0.6);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:10px;">Best For</div>
        <p style="font-size:16px;color:rgba(240,248,242,0.75);margin:0;">{c.bestFor}</p>
      </div>

      <!-- FAQ Section — AEO optimized, answers in DOM (not collapsed) -->
      <div class="reveal" style="margin-bottom:56px;">
        <h2 style="font-family:'Playfair Display',serif;font-size:24px;color:#f0f8f2;margin:0 0 28px;">Frequently Asked Questions</h2>
        <div style="display:flex;flex-direction:column;gap:0;">
          {[
            [`Is ${c.name} open to the public?`, `${c.name} is open to public play. Tee time availability varies by season. GolfGraeagle can secure guaranteed tee times as part of a stay-and-play package.`],
            [`What is the slope rating at ${c.name}?`, `${c.name} has a slope rating of ${c.slope} and a course rating of ${c.rating}. The course plays to par ${c.par} at ${c.yards.toLocaleString()} yards from the tips.`],
            [`Who designed ${c.name}?`, `${c.name} was designed by ${c.designer} and opened in ${c.year}.`],
            [`What is the best time to play ${c.name}?`, `${c.name} is open approximately May through October, weather permitting. Morning tee times offer cooler temperatures and optimal course conditions.`],
            [`How do I book a tee time at ${c.name}?`, `GolfGraeagle can book tee times at ${c.name} as part of a custom stay-and-play package. Request a free quote and receive a response within 24 hours.`],
          ].map(([q, a]) => (
            <details style="border-bottom:1px solid rgba(240,248,242,0.06);padding:0;">
              <summary style="font-size:15px;color:#f0f8f2;font-weight:500;padding:18px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
                {q}
                <span style="color:#e8a850;font-size:18px;flex-shrink:0;margin-left:16px;">+</span>
              </summary>
              <p style="font-size:14px;color:rgba(240,248,242,0.55);line-height:1.75;padding:0 0 18px;margin:0;">{a}</p>
            </details>
          ))}
        </div>
      </div>

    </div>

    <!-- RIGHT: Booking sidebar -->
    <div>
      <div style="position:sticky;top:100px;">
        <div style="background:rgba(240,248,242,0.03);border:1px solid rgba(232,168,80,0.12);border-radius:20px;padding:32px;margin-bottom:20px;">
          <h3 style="font-family:'Playfair Display',serif;font-size:22px;color:#f0f8f2;margin:0 0 8px;">Book {c.name}</h3>
          <p style="font-size:13px;color:rgba(240,248,242,0.4);margin:0 0 28px;">Custom packages — tee times + lodging + dining</p>

          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
            {[['Par',`${c.par}`],['Course Rating',`${c.rating}`],['Slope',`${c.slope}`],['Yardage',`${c.yards.toLocaleString()} yards`]].map(([k,v])=>(
              <div style="display:flex;justify-content:space-between;font-size:14px;padding:10px 0;border-bottom:1px solid rgba(240,248,242,0.05);">
                <span style="color:rgba(240,248,242,0.4);">{k}</span>
                <span style="color:#f0f8f2;font-weight:500;">{v}</span>
              </div>
            ))}
          </div>

          <a href="/request-a-quote" style="display:block;text-align:center;background:#e8a850;color:#0d1a0e;font-size:15px;font-weight:600;padding:16px;border-radius:100px;text-decoration:none;transition:all 0.3s;margin-bottom:12px;"
          onmouseover="this.style.background='#f2c878';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.background='#e8a850';this.style.transform='translateY(0)'">
            Request a Quote
          </a>
          <p style="font-size:11px;color:rgba(240,248,242,0.2);text-align:center;margin:0;">No obligation · 72-hr cancellation · 24hr response</p>
        </div>

        <!-- Add other courses -->
        <div style="background:rgba(240,248,242,0.02);border:1px solid rgba(240,248,242,0.06);border-radius:16px;padding:24px;">
          <p style="font-size:11px;color:rgba(240,248,242,0.35);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 14px;">Add Another Course</p>
          {courses.filter(x=>x.slug!==c.slug).map(x=>(
            <a href={`/courses/${x.slug}`} style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(240,248,242,0.04);text-decoration:none;transition:opacity 0.2s;"
            onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              <div style="width:40px;height:40px;border-radius:8px;overflow:hidden;flex-shrink:0;">
                <img src={x.hero} alt={x.name} style="width:100%;height:100%;object-fit:cover;"/>
              </div>
              <div>
                <div style="font-size:13px;color:#f0f8f2;font-weight:500;">{x.name}</div>
                <div style="font-size:11px;color:rgba(240,248,242,0.3);">Par {x.par} · Slope {x.slope}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</div>

<Footer />
</Base>
