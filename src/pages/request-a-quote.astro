<script define:vars={{ preselected }}>
const form = document.getElementById('qf');
const $id  = id => document.getElementById(id);

// ── URL PARAM PRE-FILL (TripsCaddie + RelatedTrips) ───────────────────────
// Runs before anything else so fields are populated when summary fires
(function prefillFromParams() {
  const p = new URLSearchParams(window.location.search);
  const ref = p.get('ref') || '';
  const tripName = p.get('trip') || '';
  const partySize = p.get('partySize') || '';
  const nights = p.get('nights') || '';
  const rounds = p.get('rounds') || '';
  const lodgingRaw = p.get('lodging') || '';
  const coursesRaw = p.get('courses') || '';
  const vibe = p.get('vibe') || '';
  const budget = p.get('budget') || '';

  const isTripRef = ref === 'trips-caddie' || ref === 'trips-page';
  if (!isTripRef && !tripName && !partySize) return; // nothing to do

  // Group size
  if (partySize) {
    const ps = $id('party-size');
    if (ps) ps.value = partySize;
  }

  // Nights
  if (nights) {
    const nn = $id('num-nights');
    if (nn) nn.value = nights;
  }

  // Rounds — match to radio buttons (1,2,3,4,5 or "other")
  if (rounds) {
    const r = parseInt(rounds);
    const radio = form.querySelector(`[name="totalRounds"][value="${r}"]`);
    if (radio) {
      radio.checked = true;
    } else {
      // value out of range — use "other" and set custom input
      const other = form.querySelector('[name="totalRounds"][value="other"]');
      if (other) {
        other.checked = true;
        const customInput = $id('rounds-other-wrap')?.querySelector('input');
        if (customInput) {
          customInput.value = rounds;
          const wrap = $id('rounds-other-wrap');
          if (wrap) wrap.style.display = 'flex';
        }
      }
    }
  }

  // Courses — TripsCaddie sends full course names, form uses slugs
  // Map common name fragments to form slugs
  if (coursesRaw) {
    const courseNameToSlug = {
      'graeagle meadows': 'graeagle-meadows',
      'whitehawk ranch': 'whitehawk-ranch',
      'plumas pines': 'plumas-pines',
      'grizzly ranch': 'grizzly-ranch',
      'nakoma': 'nakoma-dragon',
      'the dragon': 'nakoma-dragon',
      'dragon': 'nakoma-dragon',
    };
    const courseNames = coursesRaw.split(',').map(s => s.trim().toLowerCase());
    courseNames.forEach(name => {
      let slug = null;
      for (const [key, val] of Object.entries(courseNameToSlug)) {
        if (name.includes(key) || key.includes(name.split(' ')[0])) {
          slug = val; break;
        }
      }
      if (slug) {
        const cb = form.querySelector(`[name="coursesInterested"][value="${slug}"]`);
        if (cb) cb.checked = true;
      }
    });
  }

  // Lodging — map name fragments to slugs
  if (lodgingRaw) {
    const lodgingNameToSlug = {
      'river pines': 'river-pines-resort',
      'chalet view': 'chalet-view-lodge',
      'inn at nakoma': 'inn-at-nakoma',
      'nakoma resort': 'inn-at-nakoma',
      'townhomes': 'townhomes-at-plumas-pines',
      'plumas pines golf resort (': 'townhomes-at-plumas-pines',
    };
    const lname = lodgingRaw.toLowerCase();
    for (const [key, slug] of Object.entries(lodgingNameToSlug)) {
      if (lname.includes(key)) {
        const cb = form.querySelector(`[name="lodgingInterested"][value="${slug}"]`);
        if (cb) cb.checked = true;
        // Uncheck "let us recommend" if a specific property is selected
        const anyChk = $id('lodge-any');
        if (anyChk) anyChk.checked = false;
        break;
      }
    }
  }

  // Budget tier — map vibe to budgetTier radio
  if (vibe) {
    const vibeToTier = {
      'premium': 'premium',
      'value': 'budget',
      'bucket list': 'premium',
      'corporate': 'premium',
      'bachelor party': 'mid',
    };
    const tier = vibeToTier[vibe.toLowerCase()] || 'mid';
    const radio = form.querySelector(`[name="budgetTier"][value="${tier}"]`);
    if (radio) radio.checked = true;
  }

  // Special requests — full trip details for admin + customer clarity
  // Prices are reference only — subject to change
  {
    const sr = form.querySelector('[name="specialRequests"]');
    if (sr) {
      const lines = [];

      if (tripName) lines.push(`Based on trip: "${tripName}"`);

      const details = [];
      if (partySize) details.push(`${partySize} golfers`);
      if (nights)    details.push(`${nights} nights`);
      if (rounds)    details.push(`${rounds} rounds`);
      if (details.length) lines.push(`Trip details: ${details.join(', ')}`);

      if (coursesRaw) {
        const courseList = coursesRaw.split(',').map(c => c.trim()).filter(Boolean).join(', ');
        if (courseList) lines.push(`Courses: ${courseList}`);
      }

      if (lodgingRaw) lines.push(`Lodging: ${lodgingRaw}`);

      if (vibe) lines.push(`Trip style: ${vibe}`);

      const priceRef = p.get('budget') || '';
      if (priceRef) {
        lines.push(`Reference pricing: ~$${Number(priceRef).toLocaleString()}/person (previous trip — subject to change based on current availability and dates)`);
      }

      lines.push('');
      lines.push('Please adjust any details above and add any specific requests below:');

      sr.value = lines.join('\n');
    }
  }

  // Show trip-reference banner at top of sidebar
  if (isTripRef && tripName) {
    const banner = $id('trip-summary');
    const lines = $id('summary-lines');
    if (banner && lines) {
      banner.style.display = 'block';
      lines.innerHTML = `<div style="font-size:13px;color:#1c1208;font-weight:600;margin-bottom:4px;">Based on: ${tripName}</div>` +
        (partySize ? `<div style="font-size:12px;color:rgba(28,18,8,0.55);">👥 ${partySize} golfers${nights ? ` · ${nights} nights` : ''}${rounds ? ` · ${rounds} rounds` : ''}</div>` : '') +
        `<div style="font-size:11px;color:#a06c30;margin-top:6px;">Fields pre-filled from this trip — adjust anything to customise.</div>`;
    }
    // Hide static benefits since trip context is showing
    const benefits = $id('static-benefits');
    if (benefits) benefits.style.display = 'none';
  }
})();
// auto-calc nights
function calcNights() {
  const a = $id('arrival-date')?.value, d = $id('departure-date')?.value;
  if (a && d && d > a) {
    const n = Math.round((new Date(d) - new Date(a)) / 86400000);
    const nn = $id('num-nights');
    if (nn) nn.value = n;
  }
  updateSummary();
}
$id('arrival-date')?.addEventListener('change', calcNights);
$id('departure-date')?.addEventListener('change', calcNights);

// other rounds
document.querySelectorAll('[name="totalRounds"]').forEach(r => {
  r.addEventListener('change', () => {
    $id('rounds-other-wrap').style.display = r.value === 'other' ? 'flex' : 'none';
    updateSummary();
  });
});

// event type conditional
document.querySelectorAll('[name="specialFBEvent"]').forEach(r => {
  r.addEventListener('change', () => {
    $id('event-detail-wrap').style.display =
      ['birthday','bachelor','corporate','anniversary','other'].includes(r.value) ? 'flex' : 'none';
  });
});

// lodge-any dims grid
$id('lodge-any')?.addEventListener('change', function() {
  const grid = $id('lodge-grid');
  grid.style.opacity = this.checked ? '0.35' : '1';
  grid.style.pointerEvents = this.checked ? 'none' : 'auto';
  updateSummary();
});

// live summary
function fv(name) {
  const el = form.querySelector(`[name="${name}"]:checked`);
  return el ? el.value : (form.querySelector(`[name="${name}"]`)?.value || null);
}

function updateSummary() {
  const lines = [];
  const arrive = $id('arrival-date')?.value;
  const depart  = $id('departure-date')?.value;
  const party   = $id('party-size')?.value;
  const rounds  = fv('totalRounds');
  const budget  = fv('budgetTier');
  const skill   = fv('skillLevel');
  const tee     = fv('idealTeeTimes');
  const courses = [...form.querySelectorAll('[name="coursesInterested"]:checked')].map(c => c.value);
  const lodge   = [...form.querySelectorAll('[name="lodgingInterested"]:checked')].map(l => l.value);

  const fmt = d => { if (!d) return ''; const [y,m,day] = d.split('-'); return `${m}/${day}/${y.slice(2)}`; };

  if (arrive && depart && depart > arrive) lines.push({ icon:'📅', text:`${fmt(arrive)} → ${fmt(depart)}` });
  if (party && party > 0)   lines.push({ icon:'👥', text:`${party} golfer${party > 1 ? 's' : ''}` });
  if (rounds && rounds !== 'other') lines.push({ icon:'⛳', text:`${rounds} round${rounds > 1 ? 's' : ''}` });
  if (budget) lines.push({ icon:'💰', text:`${'$'.repeat(budget==='budget'?2:budget==='mid'?3:4)} tier` });
  if (skill)  lines.push({ icon:'🎯', text:`${skill}` });
  if (tee)    lines.push({ icon:'⏰', text:`Tee: ${tee}` });
  if (courses.length) lines.push({ icon:'🏌', text:`${courses.length} course${courses.length > 1 ? 's' : ''} selected` });
  if (lodge.length)   lines.push({ icon:'🏨', text:`${lodge.length} lodging option${lodge.length > 1 ? 's' : ''} selected` });

  const summary = $id('trip-summary');
  const summaryLines = $id('summary-lines');
  const staticBenefits = $id('static-benefits');

  if (lines.length > 0) {
    summaryLines.innerHTML = lines.map(l =>
      `<div class="q-sum-line"><span>${l.icon}</span><span>${l.text}</span></div>`
    ).join('');
    summary.style.display = 'block';
    staticBenefits.style.display = lines.length > 3 ? 'none' : '';
  } else {
    summary.style.display = 'none';
    staticBenefits.style.display = '';
  }
}

form.addEventListener('change', updateSummary);
form.addEventListener('input', updateSummary);

// validate required fields
function validate() {
  let ok = true;
  form.querySelectorAll('[required]').forEach(el => {
    el.classList.remove('invalid');
    if (!el.value.trim()) { el.classList.add('invalid'); ok = false; }
  });
  const a = $id('arrival-date')?.value, d = $id('departure-date')?.value;
  if (a && d && d <= a) {
    $id('departure-date').classList.add('invalid');
    ok = false;
  }
  return ok;
}

// submit
form.addEventListener('submit', async e => {
  e.preventDefault();
  if (!validate()) {
    const err = $id('q-error');
    err.textContent = 'Please fill in all required fields (First Name, Last Name, Email, Phone, Arrival Date, Departure Date, Group Size).';
    err.style.display = 'block';
    // scroll to first invalid
    const first = form.querySelector('.invalid');
    if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
    return;
  }

  const btn = $id('q-submit');
  btn.textContent = 'Sending…';
  btn.disabled = true;
  $id('q-error').style.display = 'none';

  const data = Object.fromEntries(new FormData(form));
  data.coursesInterested = [...form.querySelectorAll('[name="coursesInterested"]:checked')].map(c => c.value);
  data.lodgingInterested = [...form.querySelectorAll('[name="lodgingInterested"]:checked')].map(l => l.value);
  data.destination  = 'graeagle';
  data.source       = 'golfgraeagle.com';
  data.submittedAt  = new Date().toISOString();
  if (data.totalRounds === 'other' && data.totalRoundsCustom) data.totalRounds = data.totalRoundsCustom;

  try {
    const res = await fetch('/api/leads', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
    });
    if (!res.ok) throw new Error(await res.text());
    form.style.display = 'none';
    $id('q-success').style.display = 'block';

    // Basic fields
    $id('s-name').textContent  = data.firstName || 'there';
    $id('s-email').textContent = data.email || '';

    // Party size
    if (data.partySize) {
      $id('s-pax-val').textContent = data.partySize;
      $id('s-stat-pax').style.display = 'block';
    }

    // Nights
    if (data.numNights) {
      $id('s-nights-val').textContent = data.numNights;
      $id('s-stat-nights').style.display = 'block';
    }

    // Rounds
    const roundsVal = data.totalRounds || data.totalRoundsCustom;
    if (roundsVal && roundsVal !== 'other') {
      $id('s-rounds-val').textContent = roundsVal;
      $id('s-stat-rounds').style.display = 'block';
    }

    // Budget tier
    const tierMap = { budget: '$$  Value', mid: '$$$  Mid-range', premium: '$$$$  Premium' };
    if (data.budgetTier && tierMap[data.budgetTier]) {
      $id('s-budget-val').textContent = tierMap[data.budgetTier];
      $id('s-stat-budget').style.display = 'block';
    }

    // Courses
    const selectedCourses = Array.isArray(data.coursesInterested) ? data.coursesInterested : [];
    const courseLabels = {
      'graeagle-meadows': 'Graeagle Meadows',
      'whitehawk-ranch': 'Whitehawk Ranch',
      'plumas-pines': 'Plumas Pines',
      'grizzly-ranch': 'Grizzly Ranch',
      'nakoma-dragon': 'Nakoma Dragon',
    };
    if (selectedCourses.length) {
      const list = $id('s-courses-list');
      selectedCourses.forEach(slug => {
        const span = document.createElement('span');
        span.textContent = courseLabels[slug] || slug;
        span.style.cssText = 'font-size:12px;color:#3a4a3e;background:var(--surface);border:1px solid rgba(28,18,8,0.12);border-radius:6px;padding:3px 10px;font-weight:500;';
        list.appendChild(span);
      });
      $id('s-courses-row').style.display = 'block';
    }

    // Lodging
    const selectedLodging = Array.isArray(data.lodgingInterested) ? data.lodgingInterested : [];
    const lodgingLabels = {
      'river-pines-resort': 'River Pines Resort',
      'chalet-view-lodge': 'Chalet View Lodge',
      'inn-at-nakoma': 'Inn at Nakoma',
      'townhomes-at-plumas-pines': 'Townhomes at Plumas Pines',
    };
    if (selectedLodging.length) {
      $id('s-lodging-val').textContent = selectedLodging.map(s => lodgingLabels[s] || s).join(', ');
      $id('s-lodging-row').style.display = 'block';
    }

    // Dates
    if (data.arrivalDate && data.departureDate) {
      $id('s-dates-val').textContent = `${data.arrivalDate} → ${data.departureDate}`;
      $id('s-dates-row').style.display = 'block';
    }

    // TripsCaddie reference
    const urlP = new URLSearchParams(window.location.search);
    const refTrip = urlP.get('trip');
    const refType = urlP.get('ref');
    if (refTrip && (refType === 'trips-caddie' || refType === 'trips-page')) {
      $id('s-trip-name').textContent = refTrip;
      $id('s-trip-ref').style.display = 'block';
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  } catch {
    const err = $id('q-error');
    err.textContent = 'Something went wrong. Please try again or email mike.eskuchen@golfthehighsierra.com.';
    err.style.display = 'block';
    btn.textContent = 'Send My Quote Request →';
    btn.disabled = false;
  }
});

// reset
$id('q-reset').addEventListener('click', () => {
  form.reset();
  $id('q-success').style.display = 'none';
  form.style.display = 'block';
  $id('q-error').style.display = 'none';
  updateSummary();
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

// pre-check URL param
if (preselected) {
  const cb = form.querySelector(`input[value="${preselected}"]`);
  if (cb) cb.checked = true;
}

updateSummary();
</script>
