<script>
(function(){
  const grid = document.getElementById('about-trips-grid');
  if (!grid) return;
  const vc = { Premium:'#a06c30', Value:'#2d7a3a', Budget:'#1a5a8a' };
  fetch('/api/trips?t=' + Date.now())
    .then(r => r.json())
    .then(data => {
      const gg = data.filter(t => {
        const c = (t.courses||[]).join(' ').toLowerCase();
        return ((t.region||'').toLowerCase().includes('graeagle'))||c.includes('grizzly')||c.includes('nakoma')||c.includes('whitehawk')||c.includes('plumas')||c.includes('graeagle');
      });
      const picks = [...gg.filter(t=>t.vibe==='Premium').slice(0,1), ...gg.filter(t=>t.vibe==='Value').slice(0,2)].slice(0,3);
      if (!picks.length){ grid.style.display='none'; return; }
      grid.innerHTML = picks.map(t => {
        const col = vc[t.vibe]||'#2d7a3a';
        const crs = (t.courses||[]).slice(0,2).join(' + ');
        const img = (t.imageUrl&&!t.imageUrl.startsWith('data:')) ? t.imageUrl : '/wp-images/DJI_0006-Edit.jpg';
        return '<div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:16px;overflow:hidden;">'
          +'<div style="height:145px;overflow:hidden;"><img src="'+img+'" loading="lazy" style="width:100%;height:100%;object-fit:cover;"/></div>'
          +'<div style="padding:16px;">'
          +'<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">'
          +'<span style="font-size:9px;font-weight:700;text-transform:uppercase;color:#fff;background:'+col+';padding:2px 9px;border-radius:100px;">'+(t.vibe||'')+'</span>'
          +'<span style="font-size:13px;font-weight:700;color:#e8a850;">$'+(t.pricePerPerson||0).toLocaleString()+'<span style="font-size:10px;font-weight:400;color:rgba(28,18,8,0.38);">/pp</span></span>'
          +'</div>'
          +'<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:7px;">'
          +'<span style="font-size:10px;color:rgba(28,18,8,0.42);">⛳ '+t.rounds+' rounds</span>'
          +'<span style="font-size:10px;color:rgba(28,18,8,0.42);">🏨 '+t.nights+' nights</span>'
          +'<span style="font-size:10px;color:rgba(28,18,8,0.42);">👥 '+t.groupSize+' golfers</span>'
          +'</div>'
          +'<p style="font-size:11px;color:rgba(28,18,8,0.38);margin:0;">'+crs+'</p>'
          +'</div></div>';
      }).join('');
    })
    .catch(()=>{ if(grid) grid.style.display='none'; });
})();
</script>

