---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="About GolfGraeagle.com — Graeagle Golf Trip Planners | Zoomaway Technologies" description="GolfGraeagle.com is operated by Zoomaway Technologies Inc. We plan and book custom golf packages for Graeagle, California — tee times, lodging, and full itineraries.">
  <Nav />
  <section style="min-height:100vh;padding:140px 10% 100px;max-width:1100px;margin:0 auto;">
    <p style="font-size:11px;color:#e8a850;letter-spacing:0.16em;text-transform:uppercase;font-weight:600;margin:0 0 18px;">About Us</p>
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(36px,5vw,58px);font-weight:500;color:#f0f8f2;margin:0 0 28px;line-height:1.1;">We Plan <span style="color:#e8a850;font-style:italic;">Golf Trips</span><br/>to Graeagle</h1>
    <div style="max-width:700px;">
      <p style="font-size:17px;color:rgba(240,248,242,0.6);line-height:1.85;margin-bottom:24px;">GolfGraeagle.com is operated by Zoomaway Technologies Inc. — a travel technology company specializing in golf trip planning across the High Sierra region.</p>
      <p style="font-size:17px;color:rgba(240,248,242,0.6);line-height:1.85;margin-bottom:24px;">We coordinate tee times, lodging, and full itineraries across all five championship courses in the Graeagle area: Graeagle Meadows, Whitehawk Ranch, Plumas Pines, Grizzly Ranch, and Nakoma — The Dragon.</p>
      <p style="font-size:17px;color:rgba(240,248,242,0.6);line-height:1.85;margin-bottom:48px;">GolfGraeagle.com is a product of <strong style="color:#f0f8f2;">Zoomaway Technologies Inc.</strong>, a subsidiary of Golfthehighsierra.com. We also operate Group Golf Tours, and serve golfers planning trips throughout the Sierra Nevada region.</p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px;">
        {[{n:'5',l:'Championship Courses'},{n:'672+',l:'Verified Reviews'},{n:'24hr',l:'Quote Response'}].map(t=>(
          <div style="text-align:center;padding:24px 16px;border-radius:16px;background:rgba(232,168,80,0.04);border:1px solid rgba(232,168,80,0.1);">
            <div style="font-family:'Playfair Display',serif;font-size:28px;color:#e8a850;">{t.n}</div>
            <div style="font-size:12px;color:rgba(240,248,242,0.35);margin-top:4px;">{t.l}</div>
          </div>
        ))}
      </div>
      <p style="font-size:15px;color:rgba(240,248,242,0.4);margin-bottom:32px;">Contact us: <a href="mailto:sean@zoomaway.com" style="color:#e8a850;text-decoration:none;">sean@zoomaway.com</a> · <a href="tel:+18885861157" style="color:#e8a850;text-decoration:none;">(888) 586-1157</a></p>
      <a href="/request-a-quote/" style="display:inline-block;background:#e8a850;color:#0d1a0e;font-weight:700;font-size:15px;padding:16px 40px;border-radius:100px;text-decoration:none;" onmouseover="this.style.background='#f2c878'" onmouseout="this.style.background='#e8a850'">Plan Your Graeagle Trip →</a>
    </div>
  </section>
  <Footer />
</Base>
