---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { courses } from '../data/content.js';

const aboutSchema = [
  {
    '@type': 'AboutPage',
    '@id': 'https://golfgraeagle.com/about-us#aboutpage',
    name: 'About GolfGraeagle.com',
    description: 'GolfGraeagle.com is operated by Zoomaway Technologies Inc. — a golf trip planning platform for Graeagle, California since 2004.',
    url: 'https://golfgraeagle.com/about-us',
  },
  {
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How long has GolfGraeagle.com been operating?', acceptedAnswer: { '@type': 'Answer', text: 'GolfGraeagle.com is operated by Zoomaway Technologies Inc. and has been booking Graeagle golf trips since 2004 — over 20 years of local expertise.' } },
      { '@type': 'Question', name: 'What services does GolfGraeagle.com provide?', acceptedAnswer: { '@type': 'Answer', text: 'GolfGraeagle.com coordinates tee times at all 5 Graeagle championship courses, matches lodging to group size and budget, and builds full day-by-day itineraries. Packages start from $299 per golfer with free quotes and 24-hour response.' } },
      { '@type': 'Question', name: 'Who runs GolfGraeagle.com?', acceptedAnswer: { '@type': 'Answer', text: 'GolfGraeagle.com is a product of Zoomaway Technologies Inc., based in the Reno-Tahoe corridor. The same team also operates GolfTheHighSierra.com, GroupGolfTours.com, and MesquiteStGeorgeGolfTours.com.' } },
      { '@type': 'Question', name: 'What golf courses does GolfGraeagle work with?', acceptedAnswer: { '@type': 'Answer', text: 'GolfGraeagle.com works with all 5 championship courses in the Graeagle area: Graeagle Meadows, Whitehawk Ranch, Plumas Pines, Grizzly Ranch (Golf Digest Top 100 US), and Nakoma The Dragon (Golf World Top 75, only Frank Lloyd Wright-designed golf clubhouse).' } },
    ],
  },
];
---
<Base
  title="About GolfGraeagle.com — Graeagle Golf Trip Planners | Zoomaway Technologies"
  description="GolfGraeagle.com is operated by Zoomaway Technologies Inc. We plan and book custom golf packages for Graeagle, California — tee times, lodging, and full itineraries for groups of any size."
  canonical="https://golfgraeagle.com/about-us"
  schema={aboutSchema}
>
  <Nav />

  <!-- Hero -->
  <section style="background:#1a2e1a;padding:120px clamp(20px,8%,10%) 80px;">
    <div style="max-width:1100px;margin:0 auto;">
      <p style="font-size:11px;color:#e8a850;letter-spacing:.18em;text-transform:uppercase;font-weight:600;margin:0 0 18px;">About Us</p>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(38px,5.5vw,64px);font-weight:400;color:#f0f8f2;margin:0 0 24px;line-height:1.1;">We plan golf trips<br/><span style="color:#e8a850;font-style:italic;">to Graeagle.</span></h1>
      <p style="font-size:clamp(16px,2vw,19px);color:rgba(240,248,242,0.55);max-width:620px;line-height:1.8;margin:0 0 48px;">GolfGraeagle.com is a golf trip planning and package booking platform for the Graeagle, California region — operated by Zoomaway Technologies Inc. since 2004. We coordinate tee times at all 5 courses, match groups to the right lodging, and handle the full itinerary.</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=about-hero" class="btn-green-glow" style="display:inline-block;font-weight:700;font-size:14px;padding:14px 32px;">Plan your trip →</a>
        <a href="tel:+18885861157" style="display:inline-block;border:1px solid rgba(240,248,242,0.2);color:rgba(240,248,242,0.7);font-size:14px;padding:14px 28px;border-radius:100px;text-decoration:none;">(888) 586-1157</a>
      </div>
    </div>
  </section>

  <!-- Trust stats -->
  <section style="background:#f0f5f0;padding:0;border-bottom:1px solid #e0ece0;">
    <div style="max-width:1100px;margin:0 auto;padding:0 clamp(20px,8%,10%);display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#e0ece0;">
      {[
        { n:'2004', l:'Year founded' },
        { n:'25+', l:'Years booking Graeagle' },
        { n:'6k+', l:'Verified reviews' },
        { n:'4.8/5', l:'Average rating' },
      ].map(s => (
        <div style="background:#f8faf4;padding:32px 24px;text-align:center;">
          <div style="font-family:'Playfair Display',serif;font-size:36px;color:#1a2e1a;font-weight:400;margin-bottom:6px;">{s.n}</div>
          <div style="font-size:12px;color:#6b7c6b;text-transform:uppercase;letter-spacing:.08em;font-weight:600;">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- What we do -->
  <section style="background:#fff;padding:80px clamp(20px,8%,10%);">
    <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;">
      <div>
        <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,3.5vw,40px);font-weight:400;color:#1a2e1a;margin:0 0 20px;">What we actually do</h2>
        <p style="font-size:16px;color:#4a5a4a;line-height:1.8;margin:0 0 18px;">GolfGraeagle is not a golf course. We're the planning layer between you and the courses — a team that knows every tee sheet, every lodge, and every post-round dinner spot in the valley.</p>
        <p style="font-size:16px;color:#4a5a4a;line-height:1.8;margin:0 0 18px;">When you request a quote, a real person builds your itinerary. We book the tee times across however many courses you want, coordinate lodging that fits your group size and budget, and hand you a day-by-day plan.</p>
        <p style="font-size:16px;color:#4a5a4a;line-height:1.8;margin:0 0 32px;">We serve individual golfers, groups of 4–200+, bachelor parties, corporate outings, and families. Packages start from $299 per golfer.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          {[
            'Tee time coordination across all 5 courses',
            'Lodging matched to group size and budget',
            'Full day-by-day itinerary with dining recommendations',
            'Transportation coordination for large groups',
            'Meal functions and group dining reservations',
            '72-hour cancellation policy on standard bookings',
            'Free quotes — 24-hour response',
          ].map(item => (
            <div style="display:flex;align-items:center;gap:12px;font-size:15px;color:#374137;">
              <span style="color:#22a322;font-weight:700;flex-shrink:0;">✓</span>
              {item}
            </div>
          ))}
        </div>
      </div>
      <div>
        <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,3.5vw,40px);font-weight:400;color:#1a2e1a;margin:0 0 20px;">The 5 courses we work with</h2>
        <div style="display:flex;flex-direction:column;gap:10px;">
          {courses.map(c => (
            <a href={`/portfolio/${c.slug === "nakoma-dragon" ? "nakoma-dragon-golf-packages" : c.slug + "-golf-packages"}`} style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;background:#f8faf4;border:1px solid #e0ece0;border-radius:12px;text-decoration:none;transition:all .2s;"
              onmouseover="this.style.borderColor='#e8a850';this.style.background='#fffbf0'"
              onmouseout="this.style.borderColor='#e0ece0';this.style.background='#f8faf4'">
              <div>
                <div style="font-size:14px;font-weight:700;color:#1a2e1a;margin-bottom:2px;">{c.name}</div>
                <div style="font-size:11px;color:#8a9a8a;">Par {c.par} · {c.yards.toLocaleString()} yds · Slope {c.slope}</div>
              </div>
              <span style="font-size:12px;color:#e8a850;font-weight:600;">View →</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Who we are -->
  <section style="background:#f0f5f0;padding:80px clamp(20px,8%,10%);">
    <div style="max-width:1100px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,3.5vw,40px);font-weight:400;color:#1a2e1a;margin:0 0 40px;">The company behind the site</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div style="padding:24px;background:#fff;border:1px solid #e0ece0;border-radius:14px;">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#e8a850;margin-bottom:6px;">Parent Company</div>
          <div style="font-size:16px;font-weight:700;color:#1a2e1a;margin-bottom:8px;">Zoomaway Technologies Inc.</div>
          <div style="font-size:14px;color:#4a5a4a;line-height:1.65;margin-bottom:14px;">GolfGraeagle.com is a product of Zoomaway Technologies Inc. — a travel technology company specializing in golf trip planning across the High Sierra region. Founded in 2004.</div>
          <a href="https://zoomaway.com/?utm_source=golfgraeagle&utm_medium=referral&utm_campaign=parent_company&utm_content=about_page"
             target="_blank" rel="noopener noreferrer"
             style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:#1a2e1a;text-decoration:none;padding:8px 16px;border:1.5px solid #1a2e1a;border-radius:100px;transition:all 0.2s;"
             onmouseover="this.style.background='#1a2e1a';this.style.color='#f0f8f2'"
             onmouseout="this.style.background='transparent';this.style.color='#1a2e1a'">
            Visit zoomaway.com →
          </a>
        </div>
        <div style="padding:24px;background:#fff;border:1px solid #e0ece0;border-radius:14px;">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#e8a850;margin-bottom:6px;">Sibling Platform</div>
          <div style="font-size:16px;font-weight:700;color:#1a2e1a;margin-bottom:8px;">Golf the High Sierra</div>
          <div style="font-size:14px;color:#4a5a4a;line-height:1.65;margin-bottom:14px;">Covers the broader Northern California and Nevada region — Reno, Tahoe, Mesquite, and beyond. Same team, wider geography.</div>
          <a href="https://golfthehighsierra.com/?utm_source=golfgraeagle&utm_medium=referral&utm_campaign=sibling_site&utm_content=about_page"
             target="_blank" rel="noopener noreferrer"
             style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:#1a2e1a;text-decoration:none;padding:8px 16px;border:1.5px solid #1a2e1a;border-radius:100px;transition:all 0.2s;"
             onmouseover="this.style.background='#1a2e1a';this.style.color='#f0f8f2'"
             onmouseout="this.style.background='transparent';this.style.color='#1a2e1a'">
            Visit golfthehighsierra.com →
          </a>
        </div>
        <div style="padding:24px;background:#fff;border:1px solid #e0ece0;border-radius:14px;">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#e8a850;margin-bottom:6px;">Sibling Platform</div>
          <div style="font-size:16px;font-weight:700;color:#1a2e1a;margin-bottom:8px;">Group Golf Tours</div>
          <div style="font-size:14px;color:#4a5a4a;line-height:1.65;margin-bottom:14px;">Specializes in large-group golf outings across multiple destinations. Corporate events, charity tournaments, and group travel.</div>
          <a href="http://groupgolftours.com/?utm_source=golfgraeagle&utm_medium=referral&utm_campaign=sibling_site&utm_content=about_page"
             target="_blank" rel="noopener noreferrer"
             style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:#1a2e1a;text-decoration:none;padding:8px 16px;border:1.5px solid #1a2e1a;border-radius:100px;transition:all 0.2s;"
             onmouseover="this.style.background='#1a2e1a';this.style.color='#f0f8f2'"
             onmouseout="this.style.background='transparent';this.style.color='#1a2e1a'">
            Visit groupgolftours.com →
          </a>
        </div>
        <div style="padding:24px;background:#fff;border:1px solid #e0ece0;border-radius:14px;">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#e8a850;margin-bottom:6px;">Subsidiaries</div>
          <div style="font-size:16px;font-weight:700;color:#1a2e1a;margin-bottom:8px;">Zoomaway Inc. &amp; Tripsee</div>
          <div style="font-size:14px;color:#4a5a4a;line-height:1.65;">Additional technology and booking subsidiaries under the Zoomaway umbrella, focused on travel automation and trip planning tools.</div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section style="background:#f0f5f0;padding:80px clamp(20px,8%,10%);">
    <div style="max-width:780px;margin:0 auto;">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,3.5vw,38px);font-weight:400;color:#1a2e1a;margin:0 0 36px;">Common Questions</h2>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          ['What does GolfGraeagle.com actually do?', 'GolfGraeagle.com is a golf trip planning and package booking platform — not a golf course. We coordinate tee times at all 5 Graeagle championship courses, match lodging to your group size and budget, arrange transportation, coordinate group dining, and hand you a complete day-by-day itinerary. Operated by Zoomaway Technologies Inc. since 2004.'],
          ['How long has GolfGraeagle.com been operating?', 'GolfGraeagle.com is operated by Zoomaway Technologies Inc. and has been booking Graeagle golf trips since 2004 — over 20 years of local knowledge of the valley, the courses, and the lodging properties.'],
          ['Can you plan a trip for a large group?', 'Yes. We book for groups from 4 to 200+ players. Large groups require consecutive tee time blocks across multiple courses — we coordinate directly with each course to secure these. Most large group bookings need 6–8 weeks lead time for summer weekends.'],
          ['What does a package cost?', 'Packages start from $299 per golfer and vary based on courses selected, lodging type, group size, and number of nights. We do not show specific pricing online — request a free quote and receive a custom itinerary with pricing within 24 hours.'],
          ['Do you only book Graeagle golf trips?', 'GolfGraeagle.com focuses on the Graeagle region. Zoomaway Technologies Inc. also operates GolfTheHighSierra.com (Reno, Tahoe, and High Sierra region) and MesquiteStGeorgeGolfTours.com (Southern Nevada and Utah) for trips to adjacent destinations.'],
          ['Is there a cancellation fee?', 'Standard bookings carry a 72-hour cancellation policy. Large group outings are governed by individual contracts. Vendor cancellation policies (golf courses, lodging properties) are passed through to the customer where applicable. Full details are in our Cancellation Policy.'],
        ].map(([q, a]) => (
          <details style="border-bottom:1px solid #d0dcd0;padding:0;">
            <summary style="font-size:16px;color:#1a2e1a;font-weight:500;padding:20px 0;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              {q}
              <span style="color:#e8a850;font-size:20px;flex-shrink:0;margin-left:16px;">+</span>
            </summary>
            <p style="font-size:15px;color:#4a5a4a;line-height:1.8;padding:0 0 20px;margin:0;">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact + CTA -->
  <section style="background:#1a2e1a;padding:80px clamp(20px,8%,10%);">
    <div style="max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:48px;flex-wrap:wrap;">
      <div>
        <h2 style="font-family:'Playfair Display',serif;font-size:clamp(26px,3.5vw,40px);font-weight:400;color:#f0f8f2;margin:0 0 12px;">Get in touch</h2>
        <p style="font-size:15px;color:rgba(240,248,242,0.45);margin:0 0 28px;max-width:420px;line-height:1.65;">For quotes, bookings, or questions about any Graeagle golf trip — reach us directly or request a quote online.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <a href="mailto:mike.eskuchen@golfthehighsierra.com" style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,248,242,0.6);text-decoration:none;">
            <span style="color:#e8a850;">✉</span> mike.eskuchen@golfthehighsierra.com
          </a>
          <a href="tel:+18885861157" style="display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(240,248,242,0.6);text-decoration:none;">
            <span style="color:#e8a850;">📞</span> (888) 586-1157
          </a>
          <div style="font-size:13px;color:rgba(240,248,242,0.3);">
            Zoomaway Technologies Inc. · Operated since 2004
          </div>
        </div>
      </div>
      <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=about-bottom" class="btn-green-glow" style="flex-shrink:0;font-weight:700;font-size:15px;padding:18px 44px;white-space:nowrap;transition:all .2s;"
        onmouseover="this.style.background='#f2c878';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.background='#e8a850';this.style.transform='translateY(0)'">
        Request a free quote →
      </a>
    </div>
  </section>

  <Footer />
</Base>

<style is:global>
@media(max-width:700px){
  section div[style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr!important;}
  section div[style*="grid-template-columns:repeat(4"]{grid-template-columns:repeat(2,1fr)!important;}
}
</style>
