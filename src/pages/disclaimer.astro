---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
export const prerender = true;
<Base title="Disclaimer | Golf Graeagle" description="Disclaimer for GolfGraeagle.com — Zoomaway Technologies Inc.">
  <Nav />
  <div style="min-height:100vh;padding:140px 48px 80px;max-width:860px;margin:0 auto;">
    <div class="reveal">
      <p style="font-size:11px;color:#e8a850;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 16px;">Legal</p>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(36px,5vw,56px);font-weight:500;color:#f0f8f2;margin:0 0 12px;line-height:1.1;">Disclaimer</h1>
      <p style="font-size:13px;color:rgba(240,248,242,0.3);margin:0 0 56px;">GolfGraeagle.com · Operated by Zoomaway Technologies Inc.</p>
    </div>

    <div style="font-size:15px;color:rgba(240,248,242,0.65);line-height:1.8;display:flex;flex-direction:column;gap:32px;">

      <section class="reveal">
        <p>Zoomaway Technologies Inc., and its subsidiaries (Zoomaway Inc. &amp; Tripsee) or operating web products (Golf the High Sierra, Group Golf Tours, Golf Graeagle, ZoomedIN) are not responsible in any way for any offensive content that is posted by users.</p>
        <p style="margin-top:14px;">Our products are a solicitation for business purposes and any other use of our products for personal purposes or illegal activities is strictly prohibited. Zoomaway Inc. staff will report any abuses of this program to the proper authorities.</p>
        <p style="margin-top:14px;">Please feel free to report any offensive material to <a href="mailto:mike.eskuchen@golfthehighsierra.com" style="color:#e8a850;">mike.eskuchen@golfthehighsierra.com</a> and we will do our best to remove the content in question as soon as possible.</p>
      </section>

      <section class="reveal">
        <h2 style="font-family:'Playfair Display',serif;font-size:22px;font-weight:500;color:#f0f8f2;margin:0 0 14px;">Zoomaway Technologies Inc. — Products</h2>
        <p>GolfGraeagle.com is one of several web products operated by Zoomaway Technologies Inc. Other products include:</p>
        <ul style="margin:14px 0;padding-left:24px;display:flex;flex-direction:column;gap:8px;">
          <li><a href="https://golfthehighsierra.com" style="color:#e8a850;">GolftheHighSierra.com</a></li>
          <li><a href="https://groupgolftours.com" style="color:#e8a850;">GroupGolfTours.com</a></li>
          <li>ZoomedIN</li>
        </ul>
      </section>

      <section class="reveal" style="border-top:1px solid rgba(240,248,242,0.06);padding-top:32px;">
        <p style="font-size:13px;color:rgba(240,248,242,0.3);">To report offensive content or for any concerns: <a href="mailto:mike.eskuchen@golfthehighsierra.com" style="color:#e8a850;">mike.eskuchen@golfthehighsierra.com</a></p>
      </section>

    </div>
  </div>
  <Footer />
</Base>
