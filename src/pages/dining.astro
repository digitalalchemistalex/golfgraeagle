---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { dining, siteConfig } from '../data/content.js';
export const prerender = true;

const fineDining  = dining.filter(d => d.category === 'fine-dining');
const casual      = dining.filter(d => ['casual','variety'].includes(d.category));
const breweries   = dining.filter(d => ['brewery','bar'].includes(d.category));
const quickBites  = dining.filter(d => d.category === 'quick');

// Restaurant schema for fine dining + notable casual venues
const cuisineMap = {
  'fine-dining': 'American',
  'casual': 'American',
  'brewery': 'American',
  'bar': 'American',
  'quick': 'American',
};
const priceMap = { 'fine-dining': '$$$', 'casual': '$$', 'brewery': '$$', 'bar': '$', 'quick': '$' };

const aggregateRatingSchema = {
  "@context": "https://schema.org", "@type": "TravelAgency",
  "@id": "https://golfgraeagle.com/#organization",
  "name": "GolfGraeagle.com",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "672", "bestRating": "5" }
};

const restaurantSchemas = dining.map(d => ({
  "@type": "Restaurant",
  "@id": `${siteConfig.url}/dining#${d.slug}`,
  "name": d.name,
  "description": d.tagline,
  "url": `${siteConfig.url}/dining`,
  "servesCuisine": cuisineMap[d.category] || 'American',
  "priceRange": priceMap[d.category] || '$$',
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Graeagle",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "isPartOf": { "@id": `${siteConfig.url}/#organization` }
}));

const diningBreadcrumb = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteConfig.url },
    { "@type": "ListItem", "position": 2, "name": "Dining", "item": `${siteConfig.url}/dining` }
  ]
};

const diningFaq = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the best restaurants in Graeagle CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "The top dining options near Graeagle golf courses include: Sardine Lake Resort for fine Sierra dining, Iron Door Restaurant (open since 1961 in a historic 1906 building), Grizzly Grill at Grizzly Ranch, Roadhouse at River Pines for group dinners, Eureka Peak Brewing Co. for craft beer, and The Brewing Lair for après-golf drinks in a forest setting." }
    },
    {
      "@type": "Question",
      "name": "Are there restaurants near Graeagle golf courses?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Several restaurants are located directly on or adjacent to Graeagle golf courses. Graeagle Meadows Restaurant is inside the Graeagle Meadows clubhouse. Grizzly Grill serves as the 19th hole at Grizzly Ranch. Roadhouse at River Pines is steps from Plumas Pines Golf Resort." }
    },
    {
      "@type": "Question",
      "name": "Where can golf groups eat dinner near Graeagle?",
      "acceptedAnswer": { "@type": "Answer", "text": "The best options for golf group dinners near Graeagle are Roadhouse at River Pines (on-site at River Pines Resort), Iron Door Restaurant in nearby Johnsville, Grizzly Grill at Grizzly Ranch, and Eureka Peak Brewing Co. at Chalet View Lodge. GolfGraeagle can coordinate group dining reservations as part of a stay-and-play package." }
    }
  ]
};
---

<Base
  title="Dining in Graeagle, CA | Best Restaurants Near Golf"
  description="Best restaurants near Graeagle's 5 golf courses — Sardine Lake, Grizzly Grill, Cuccia's #1 Tripadvisor, The Brewing Lair. Group dining reservations coordinated alongside tee times and stay-and-play packages."
  schema={[...restaurantSchemas, diningBreadcrumb, diningFaq, aggregateRatingSchema]}

  bodyClass="light-page"
>
<Nav />

<style>
  /* ── Dining page styles ── */
  .dining-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .dining-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/wp-images/Sardine-Lake-Resort.webp');
    background-size: cover;
    background-position: center;
    transform: scale(1.08);
    transition: transform 12s ease;
  }
  .dining-hero-bg.loaded { transform: scale(1.0); }
  .dining-hero-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, #0d1a0e 0%, rgba(13,26,14,0.55) 50%, rgba(13,26,14,0.1) 100%);
  }
  .dining-hero-content {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px 80px;
    width: 100%;
  }
  /* ── Decision rail ── */
  .decision-rail {
    max-width: 1280px;
    margin: 0 auto;
    padding: 56px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .decision-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px 22px;
    border-radius: 14px;
    background: rgba(28,46,26,0.02);
    border: 1px solid rgba(28,46,26,0.06);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .decision-card:hover {
    background: rgba(232,168,80,0.05);
    border-color: rgba(232,168,80,0.18);
    transform: translateY(-2px);
  }
  /* ── Section header ── */
  .sec-label {
    font-size: 11px;
    color: #e8a850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .sec-h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 400;
    color: #1a2e1a;
    margin: 0;
    line-height: 1.1;
  }
  /* ── Image card ── */
  .img-card {
    border-radius: 18px;
    overflow: hidden;
    background: rgba(28,46,26,0.02);
    border: 1px solid rgba(28,46,26,0.06);
    transition: border-color 0.25s, transform 0.25s;
  }
  .img-card:hover { border-color: rgba(240,248,242,0.12); transform: translateY(-4px); }
  .img-card .thumb {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
    transition: transform 5s ease;
  }
  .img-card:hover .thumb { transform: scale(1.05); }
  .img-card-body { padding: 20px 22px; }
  /* ── On-course cards ── */
  .on-course-card { border-radius: 18px; overflow: hidden; background: rgba(240,248,242,0.025); border: 1px solid rgba(28,46,26,0.06); }
  .on-course-card .thumb { display: block; width: 100%; height: 240px; object-fit: cover; }
  /* ── Brewery row ── */
  .brewery-row {
    display: flex;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(28,46,26,0.02);
    border: 1px solid rgba(28,46,26,0.06);
    transition: border-color 0.2s, background 0.2s;
  }
  .brewery-row:hover { border-color: rgba(232,168,80,0.15); background: rgba(232,168,80,0.03); cursor: pointer; }
  .brewery-row .thumb { display: block; width: 140px; flex-shrink: 0; object-fit: cover; }
  /* ── Matrix table ── */
  .matrix { border-radius: 18px; overflow: hidden; border: 1px solid rgba(28,46,26,0.06); }
  .matrix-col { border-radius: 14px; background: rgba(28,46,26,0.02); border: 1px solid rgba(28,46,26,0.06); overflow: hidden; }
  .matrix-col-head { padding: 16px; border-bottom: 1px solid rgba(28,46,26,0.04); }
  /* ── Badge ── */
  .badge-gold { display: inline-block; font-size: 11px; color: #e8a850; background: rgba(232,168,80,0.08); border: 1px solid rgba(232,168,80,0.15); padding: 5px 12px; border-radius: 100px; }
  /* ── CTA band ── */
  .cta-band { padding: 96px 48px; text-align: center; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: #e8a850; color: #0d1a0e; font-size: 15px; font-weight: 700;
    padding: 16px 42px; border-radius: 100px; text-decoration: none;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
    box-shadow: 0 4px 24px rgba(232,168,80,0.25);
  }
  .btn-primary:hover { background: #f2c878; transform: translateY(-2px); box-shadow: 0 12px 40px rgba(232,168,80,0.4); }
  /* ── Utility ── */
  .page-wrap { max-width: 1280px; margin: 0 auto; padding: 0 48px; }
  .divider { border: none; border-top: 1px solid rgba(28,46,26,0.04); margin: 0; }
  /* grid utility classes — responsive */
  .grid-fine-dining { display: grid; grid-template-columns: 1.3fr 1fr 1fr; gap: 14px; }
  .grid-on-course   { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .grid-casual      { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
  .grid-brewery     { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .grid-quick       { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .grid-matrix      { display: grid; grid-template-columns: repeat(5,1fr); gap: 10px; }

  @media (max-width: 860px) {
    .grid-fine-dining { grid-template-columns: 1fr 1fr; }
    .grid-casual      { grid-template-columns: 1fr 1fr; }
    .grid-matrix      { grid-template-columns: repeat(3,1fr); }
  }
  @media (max-width: 768px) {
    .decision-rail    { grid-template-columns: 1fr; padding: 40px 24px; }
    .page-wrap        { padding: 0 24px; }
    .dining-hero-content { padding: 0 24px 48px; }
    .cta-band         { padding: 72px 24px; }
    .grid-fine-dining { grid-template-columns: 1fr; }
    .grid-on-course   { grid-template-columns: 1fr; }
    .grid-casual      { grid-template-columns: 1fr; }
    .grid-brewery     { grid-template-columns: 1fr; }
    .grid-quick       { grid-template-columns: 1fr; }
    .grid-matrix      { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 600px) {
    /* Hero: taller to contain content, text smaller */
    .dining-hero { min-height: 90vh; align-items: flex-end; }
    .dining-hero-content { padding: 0 20px 40px; }
  }
  @media (max-width: 480px) {
    .grid-matrix      { grid-template-columns: 1fr; }
  }
</style>

<!-- ══════════════════════════════════════════
     HERO — NO reveal class (above fold)
══════════════════════════════════════════ -->
<section class="dining-hero">
  <div class="dining-hero-bg" id="dhbg"></div>
  <div class="dining-hero-grad"></div>
  <div class="dining-hero-content">
    <p class="sec-label" style="margin-bottom:18px;">Food &amp; Drink · Graeagle, California</p>
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(38px,7vw,94px);font-weight:400;color:#1a2e1a;margin:0 0 20px;line-height:1.05;">
      Eat well.<br/><em style="color:#e8a850;font-style:italic;">Drink even better.</em>
    </h1>
    <p class="speakable page-intro" style="font-size:18px;color:rgba(28,46,26,0.5);max-width:540px;line-height:1.75;margin:0 0 36px;">
      Graeagle has no business being this good for food. Remote valley, mountains all around — yet fifteen restaurants and bars, two craft breweries, and one legendary alpine lake restaurant that requires a reservation weeks out.
    </p>
    <!-- Stats row — anchoring -->
    <div style="display:flex;gap:36px;flex-wrap:wrap;">
      {[
        {n:'15+', l:'Restaurants & Bars'},
        {n:'3',   l:'Fine Dining'},
        {n:'2',   l:'Craft Breweries'},
        {n:'2',   l:'On-Course Dining'},
      ].map(s=>(
        <div>
          <div style="font-family:'Playfair Display',serif;font-size:30px;color:#e8a850;line-height:1;">{s.n}</div>
          <div style="font-size:11px;color:rgba(240,248,242,0.32);letter-spacing:0.06em;margin-top:4px;">{s.l}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     DECISION RAIL — human psychology:
     match me to a situation, not a category
══════════════════════════════════════════ -->
<div class="decision-rail reveal">
  {[
    { icon:'🏌️', q:'Just finished 18 holes?',      a:'Grizzly Grill or Roadhouse at River Pines — both are steps from a clubhouse.',    href:'#on-course' },
    { icon:'🥂', q:'Celebrating something?',          a:'Sardine Lake Resort. Remote alpine. Call weeks ahead. Worth it.',                   href:'#fine-dining' },
    { icon:'🍺', q:'Cold beers with the group?',      a:'Eureka Peak Brewing or The Brewing Lair — both craft, both Sierra.',               href:'#breweries' },
    { icon:'🌅', q:'Early tee time, need food first?', a:'Little Bite Deli for pre-round sandwiches. Mountain Frostee after the back nine.', href:'#quick-bites' },
  ].map(c=>(
    <a class="decision-card" href={c.href}>
      <span style="font-size:22px;flex-shrink:0;">{c.icon}</span>
      <div>
        <div style="font-size:13px;font-weight:600;color:#1a2e1a;margin-bottom:4px;">{c.q}</div>
        <div style="font-size:13px;color:rgba(28,18,8,0.55);line-height:1.55;">{c.a}</div>
      </div>
    </a>
  ))}
</div>

<!-- ══════════════════════════════════════════
     FINE DINING
══════════════════════════════════════════ -->
<hr class="divider" />
<section id="fine-dining" style="padding:72px 0;">
  <div class="page-wrap">
    <div class="reveal" style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:36px;">
      <div>
        <p class="sec-label">Fine Dining</p>
        <h2 class="sec-h2">The special occasion spots.</h2>
      </div>
      <p style="font-size:13px;color:rgba(28,18,8,0.45);max-width:300px;text-align:right;line-height:1.6;">Book ahead. These fill up fast in summer. Worth every mile.</p>
    </div>
    <div class="grid-fine-dining reveal">
      {fineDining.map((v, i) => (
        <a href={`/portfolio/${v.slug}/`} class="img-card" style={i === 0 ? 'grid-row: span 1' : ''}>
          <img class="thumb" src={v.hero} alt={v.name} style={`height:${i===0?'260px':'220px'}`} loading={i===0?'eager':'lazy'} />
          <div class="img-card-body">
            <h3 style="font-family:'Playfair Display',serif;font-size:21px;font-weight:400;color:#1a2e1a;margin:0 0 5px;">{v.name}</h3>
            <p style="font-size:13px;color:rgba(28,46,26,0.35);margin:0 0 12px;line-height:1.5;">{v.tagline}</p>
            {v.slug==='sardine-lake'   && <span class="badge-gold">⚠️ Reservations essential · Remote</span>}
            {v.slug==='longboards'     && <span class="badge-gold">🏔️ Lakefront · Gold Lake Lodge</span>}
            {v.slug==='iron-door'      && <span class="badge-gold">🏛️ Historic Johnsville landmark</span>}
            <span style="font-size:12px;color:#e8a850;margin-top:10px;display:inline-block;">View details →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     ON-COURSE DINING — strongest cross-link
══════════════════════════════════════════ -->
<hr class="divider" />
<section id="on-course" style="padding:72px 0;background:rgba(232,168,80,0.025);">
  <div class="page-wrap">
    <div class="reveal" style="margin-bottom:36px;">
      <p class="sec-label">On-Course &amp; On-Property</p>
      <h2 class="sec-h2" style="margin-bottom:10px;">Don't even change your shoes.</h2>
      <p style="font-size:15px;color:rgba(28,18,8,0.55);max-width:500px;line-height:1.7;">Two restaurants are physically on the courses you're already playing. Walk off the 18th and walk straight in.</p>
    </div>
    <div class="grid-on-course reveal">
      {[
        {
          name:'Grizzly Grill', sub:'At Grizzly Ranch Golf Club',
          desc:'The 19th hole bar and grill at the most challenging course in Graeagle. Cold beers, burgers, and a scoreboard full of stories from the back nine.',
          img:'/wp-images/Grizzly-Grill-.jpg',
          badge:'⛳ Walk from the 18th green', courseHref:'/portfolio/grizzly-ranch-golf-packages', course:'Grizzly Ranch'
        },
        {
          name:'Graeagle Meadows Restaurant', sub:"At Graeagle Meadows Golf Course",
          desc:"The valley's original course has its own clubhouse restaurant. Open for breakfast and lunch — the right way to start or end a round at Graeagle's most storied layout.",
          img:'/wp-images/Graeagle-Meadows-Golf-Course-Restaurant.webp',
          badge:'⛳ Graeagle Meadows clubhouse', courseHref:'/portfolio/graeagle-meadows-golf-packages', course:'Graeagle Meadows'
        },
      ].map(v=>(
        <div class="on-course-card">
          <div style="position:relative;overflow:hidden;">
            <img class="thumb" src={v.img} alt={v.name} loading="lazy" />
            <div style="position:absolute;inset:0;background:linear-gradient(0deg,rgba(13,26,14,0.8) 0%,transparent 55%);pointer-events:none;"></div>
            <div style="position:absolute;bottom:14px;left:18px;">
              <span class="badge-gold">{v.badge}</span>
            </div>
          </div>
          <div style="padding:22px 24px;">
            <h3 style="font-family:'Playfair Display',serif;font-size:21px;color:#1a2e1a;margin:0 0 4px;">{v.name}</h3>
            <p style="font-size:12px;color:#b8820a;margin:0 0 10px;">{v.sub}</p>
            <p style="font-size:14px;color:rgba(28,18,8,0.6);line-height:1.65;margin:0 0 16px;">{v.desc}</p>
            <a href={v.courseHref} style="font-size:12px;color:rgba(28,18,8,0.55);text-decoration:none;border:1px solid rgba(28,18,8,0.15);padding:7px 14px;border-radius:100px;display:inline-flex;align-items:center;gap:6px;transition:color 0.2s,border-color 0.2s;"
            onmouseover="this.style.color='#e8a850';this.style.borderColor='rgba(232,168,80,0.25)'"
            onmouseout="this.style.color='rgba(28,18,8,0.55)';this.style.borderColor='rgba(28,18,8,0.15)'">
              View {v.course} →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     CASUAL DINING
══════════════════════════════════════════ -->
<hr class="divider" />
<section style="padding:72px 0;">
  <div class="page-wrap">
    <div class="reveal" style="margin-bottom:36px;">
      <p class="sec-label">Casual Dining</p>
      <h2 class="sec-h2" style="margin-bottom:10px;">The everyday favourites.</h2>
      <p style="font-size:15px;color:rgba(28,18,8,0.55);max-width:500px;line-height:1.7;">Local staples that have been feeding golfers for years. No fuss, no reservation — just good food and a cold drink.</p>
    </div>
    <div class="grid-casual reveal">
      {casual.filter(v=>v.slug!=='meadows-restaurant').map(v=>(
        <a href={`/portfolio/${v.slug}/`} class="img-card">
          <img class="thumb" src={v.hero} alt={v.name} loading="lazy" />
          <div class="img-card-body">
            <h3 style="font-family:'Playfair Display',serif;font-size:19px;font-weight:400;color:#1a2e1a;margin:0 0 5px;">{v.name}</h3>
            <p style="font-size:13px;color:rgba(28,46,26,0.35);line-height:1.5;margin:0;">{v.tagline}</p>
            <span style="font-size:12px;color:#e8a850;margin-top:10px;display:inline-block;">View details →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     BREWERIES & BARS
══════════════════════════════════════════ -->
<hr class="divider" />
<section id="breweries" style="padding:72px 0;">
  <div class="page-wrap">
    <div class="reveal" style="margin-bottom:36px;">
      <p class="sec-label">Breweries &amp; Bars</p>
      <h2 class="sec-h2" style="margin-bottom:10px;">The après-golf scene.</h2>
      <p style="font-size:15px;color:rgba(28,46,26,0.35);max-width:500px;line-height:1.7;">Four options from craft brewery to century-old mountain tavern. All cold, all welcome, all post-round perfect.</p>
    </div>
    <div class="grid-brewery reveal">
      {breweries.map(v=>(
        <a href={`/portfolio/${v.slug}/`} class="brewery-row" style="text-decoration:none;">
          <img class="thumb" src={v.hero} alt={v.name} style="height:100%;min-height:120px;" loading="lazy" />
          <div style="padding:20px 22px;display:flex;flex-direction:column;justify-content:center;">
            <div style="font-size:10px;color:rgba(232,168,80,0.5);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:6px;">
              {v.category==='brewery'?'Craft Brewery':'Mountain Bar'}
            </div>
            <h3 style="font-family:'Playfair Display',serif;font-size:18px;color:#1a2e1a;margin:0 0 5px;">{v.name}</h3>
            <p style="font-size:13px;color:rgba(28,46,26,0.35);line-height:1.5;margin:0;">{v.tagline}</p>
            <span style="font-size:12px;color:#e8a850;margin-top:8px;">View details →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     QUICK BITES
══════════════════════════════════════════ -->
<hr class="divider" />
<section id="quick-bites" style="padding:72px 0;">
  <div class="page-wrap">
    <div class="reveal" style="margin-bottom:32px;">
      <p class="sec-label">Quick Bites</p>
      <h2 class="sec-h2">Fuel for the round.</h2>
    </div>
    <div class="grid-quick reveal">
      {quickBites.map(v=>(
        <a href={`/portfolio/${v.slug}/`} style="display:flex;align-items:center;gap:16px;padding:18px 20px;border-radius:14px;background:rgba(28,46,26,0.02);border:1px solid rgba(28,46,26,0.04);text-decoration:none;transition:border-color 0.2s,background 0.2s;"
          onmouseover="this.style.borderColor='rgba(232,168,80,0.2)';this.style.background='rgba(232,168,80,0.03)'"
          onmouseout="this.style.borderColor='rgba(28,46,26,0.04)';this.style.background='rgba(28,46,26,0.02)'">
          <img src={v.hero} alt={v.name} style="width:68px;height:68px;border-radius:10px;object-fit:cover;flex-shrink:0;" loading="lazy" />
          <div style="flex:1;">
            <h3 style="font-size:15px;font-weight:600;color:#1a2e1a;margin:0 0 3px;">{v.name}</h3>
            <p style="font-size:13px;color:rgba(28,46,26,0.3);margin:0 0 4px;">{v.tagline}</p>
