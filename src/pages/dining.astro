---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { dining } from '../data/content.js';

const title = "Graeagle Dining | Best Restaurants, Bars & Breweries Near the Golf Courses";
const description = "The best restaurants in Graeagle, California. Fine dining at Longboards and Sardine Lake, casual eats at Grizzly Grill, craft beer at Eureka Peak Brewing and The Brewing Lair.";

const fineDining = dining.filter(d => d.category === 'fine-dining');
const variety = dining.filter(d => d.category === 'variety');
const breweries = dining.filter(d => d.category === 'brewery');
---
<Base title={title} description={description}>

  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4 flex items-center justify-between backdrop-blur-md bg-slate-950/80 border-b border-white/5">
    <a href="/" class="font-display text-xl text-white">Golf <span class="text-gold-400">Graeagle</span></a>
    <div class="hidden md:flex items-center gap-8 text-sm text-white/70">
      <a href="/courses" class="hover:text-white transition-colors">Courses</a>
      <a href="/lodging" class="hover:text-white transition-colors">Lodging</a>
      <a href="/dining" class="text-white">Dining</a>
    </div>
    <a href="/quote" class="bg-gold-500 hover:bg-gold-400 text-slate-950 text-sm font-medium px-5 py-2.5 rounded-full transition-all">Plan My Trip</a>
  </nav>

  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold-400 text-sm tracking-widest uppercase mb-4">Food & Drink</p>
      <h1 class="font-display text-6xl md:text-8xl text-white font-light leading-none mb-6">
        Eat well.<br /><em class="text-gold-400 not-italic">Drink better.</em>
      </h1>
      <p class="text-white/50 text-xl max-w-2xl">
        From award-winning dining inside resort lodges to century-old Sierra taverns with cold beer and live music — Graeagle punches well above its size when it comes to food.
      </p>
    </div>
  </section>

  {[
    { label: 'Fine Dining', items: fineDining, desc: 'Elevated mountain cuisine for the post-round celebration.' },
    { label: 'Casual & Variety', items: variety, desc: 'Local favorites for quick bites, big breakfasts, and everything in between.' },
    { label: 'Breweries & Bars', items: breweries, desc: 'Craft beer, mountain taverns, and the best après-golf in the Sierra.' },
  ].map(section => section.items.length > 0 && (
    <section class="py-16 px-6 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="mb-10">
          <h2 class="font-display text-4xl text-white font-light">{section.label}</h2>
          <p class="text-white/40 mt-2">{section.desc}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {section.items.map(venue => (
            <div class="group rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] hover:border-white/10 transition-all duration-300 p-7">
              <div class="w-8 h-8 rounded-full bg-gold-500/10 border border-gold-500/20 flex items-center justify-center text-gold-400 text-xs mb-4">
                {section.label === 'Fine Dining' ? '🍽' : section.label === 'Casual & Variety' ? '🥗' : '🍺'}
              </div>
              <h3 class="font-display text-2xl text-white font-light mb-1 group-hover:text-gold-300 transition-colors">{venue.name}</h3>
              <p class="text-white/40 text-sm mb-3">{venue.tagline}</p>
              <p class="text-white/25 text-xs">📍 {venue.location}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="py-24 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-display text-5xl text-white font-light mb-4">Build the full experience.</h2>
      <p class="text-white/40 mb-8">Golf + lodging + dining recommendations, all packaged together. That's what we do.</p>
      <a href="/quote" class="inline-flex items-center gap-3 bg-gold-500 hover:bg-gold-400 text-slate-950 font-medium px-10 py-5 rounded-full transition-all duration-300 hover:shadow-2xl hover:shadow-gold-500/30 text-lg group">
        Plan My Full Trip
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>

  <footer class="border-t border-white/5 py-12 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-white/30 text-sm">
      <div class="font-display text-base text-white/50">Golf <span class="text-gold-400/70">Graeagle</span></div>
      <div class="flex gap-6">
        <a href="/courses" class="hover:text-white/60 transition-colors">Courses</a>
        <a href="/lodging" class="hover:text-white/60 transition-colors">Lodging</a>
        <a href="/dining" class="hover:text-white/60 transition-colors">Dining</a>
        <a href="/quote" class="hover:text-white/60 transition-colors">Get a Quote</a>
      </div>
      <div>© 2025 Zoomaway Technologies Inc.</div>
    </div>
  </footer>

</Base>
