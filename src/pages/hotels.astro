---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { lodging } from '../data/content.js';
---
<Base title="Hotels in Graeagle, CA – Mountain Lodges & Resorts | GolfGraeagle" description="Stay at Nakoma, Chalet View Lodge, or River Pines with GolfGraeagle stay-and-play packages. Plan with trusted local golf experts.">
  <Nav />
  <section style="padding:140px 10% 40px;max-width:1100px;margin:0 auto;">
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,52px);font-weight:500;color:#f0f8f2;margin:0 0 20px;">Graeagle Hotels, Lodges <span style="color:#e8a850;font-style:italic;">&amp; Resorts</span></h1>
    <p style="font-size:17px;color:rgba(240,248,242,0.5);max-width:600px;line-height:1.75;margin:0 0 60px;">From boutique mountain lodges to on-course resort stays — every option within minutes of all 5 courses.</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      {lodging.map(l => (
        <a href={`/portfolio/${l.slug === 'river-pines-resort' ? 'river-pines-resort-graeagle-ca' : l.slug === 'chalet-view-lodge' ? 'chalet-view-lodge-graeagle-ca' : l.slug === 'inn-at-nakoma' ? 'the-inn-at-nakoma-clio-ca' : 'the-townhomes-at-plumas-pines'}/`}
          style="border-radius:16px;overflow:hidden;text-decoration:none;background:rgba(240,248,242,0.02);border:1px solid rgba(240,248,242,0.07);transition:all 0.2s;"
          onmouseover="this.style.borderColor='rgba(232,168,80,0.2)'" onmouseout="this.style.borderColor='rgba(240,248,242,0.07)'">
          <img src={l.hero} alt={l.name} style="width:100%;height:200px;object-fit:cover;"/>
          <div style="padding:20px 22px;">
            <h2 style="font-family:'Playfair Display',serif;font-size:19px;color:#f0f8f2;margin:0 0 8px;">{l.name}</h2>
            <p style="font-size:13px;color:rgba(240,248,242,0.4);margin:0;">{l.tagline}</p>
          </div>
        </a>
      ))}
    </div>
    <div style="text-align:center;margin-top:60px;">
      <a href="/request-a-quote/" style="display:inline-block;background:#e8a850;color:#0d1a0e;font-weight:700;font-size:15px;padding:16px 44px;border-radius:100px;text-decoration:none;" onmouseover="this.style.background='#f2c878'" onmouseout="this.style.background='#e8a850'">Request a Stay & Play Quote →</a>
    </div>
  </section>
  <Footer />
</Base>
