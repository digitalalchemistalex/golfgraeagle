---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { lodging } from '../data/content.js';
export const prerender = true;

const featuredOrder = ['inn-at-nakoma','river-pines-resort','chalet-view-lodge','townhomes-at-plumas-pines'];
const sorted = featuredOrder.map(s => lodging.find(l => l.slug === s)).filter(Boolean);

const nearestCourse = {
  'river-pines-resort':        { name:'Graeagle Meadows', slug:'graeagle-meadows', dist:'Walking distance' },
  'chalet-view-lodge':         { name:'Graeagle Meadows', slug:'graeagle-meadows', dist:'5 min drive' },
  'inn-at-nakoma':             { name:'Nakoma — The Dragon', slug:'nakoma', dist:'On property' },
  'townhomes-at-plumas-pines': { name:'Plumas Pines', slug:'plumas-pines', dist:'Steps away' },
};

const psychLabel = {
  'river-pines-resort':        { tag:'Best for Groups',     color:'rgba(82,168,98,0.1)',   border:'rgba(82,168,98,0.25)',   text:'rgba(120,196,136,0.9)' },
  'chalet-view-lodge':         { tag:'Best Amenities',      color:'rgba(100,140,232,0.1)', border:'rgba(100,140,232,0.25)', text:'rgba(150,180,245,0.9)' },
  'inn-at-nakoma':             { tag:'Most Unique',         color:'rgba(232,168,80,0.1)',  border:'rgba(232,168,80,0.25)',  text:'#e8a850' },
  'townhomes-at-plumas-pines': { tag:'Best for Large Groups', color:'rgba(210,160,80,0.08)', border:'rgba(210,160,80,0.2)', text:'rgba(210,168,110,0.9)' },
};
---

<Base
  title="Graeagle Golf Lodging | Stay & Play Packages Near Championship Courses"
  description="Where to stay for a Graeagle golf trip. The Inn at Nakoma for on-course luxury, River Pines Resort for groups, Chalet View Lodge for amenities, Townhomes at Plumas Pines for large groups."
>
<Nav />

<style>
  .lodge-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .lodge-hero img.bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .lodge-hero-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, #0d1a0e 0%, rgba(13,26,14,0.5) 55%, rgba(13,26,14,0.08) 100%);
  }
  .lodge-hero-content {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px 80px;
    width: 100%;
  }
  .quick-pick {
    background: rgba(232,168,80,0.04);
    border: 1px solid rgba(232,168,80,0.1);
    border-radius: 20px;
    padding: 26px 30px;
    max-width: 1280px;
    margin: 52px auto 0;
    padding-inline: 48px;
  }
  .pick-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 10px;
    margin-top: 16px;
  }
  .pick-card {
    padding: 16px;
    border-radius: 14px;
    background: rgba(240,248,242,0.02);
    border: 1px solid rgba(240,248,242,0.05);
    text-decoration: none;
    display: block;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .pick-card:hover {
    background: rgba(240,248,242,0.05);
    border-color: rgba(240,248,242,0.12);
    transform: translateY(-2px);
  }
  /* Property section layout */
  .property-section { padding: 80px 0; border-top: 1px solid rgba(240,248,242,0.05); }
  .property-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 52px; align-items: start; }
  .property-grid.flip { direction: rtl; }
  .property-grid.flip > * { direction: ltr; }
  /* Gallery */
  .gallery-main {
    display: block;
    width: 100%;
    height: 340px;
    object-fit: cover;
    border-radius: 18px;
    transition: transform 5s ease;
  }
  .gallery-main:hover { transform: scale(1.02); }
  .gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 8px;
    margin-top: 8px;
  }
  .gallery-thumb {
    display: block;
    width: 100%;
    height: 96px;
    object-fit: cover;
    border-radius: 10px;
    transition: transform 4s ease, opacity 0.2s;
    opacity: 0.8;
  }
  .gallery-thumb:hover { transform: scale(1.06); opacity: 1; }
  /* Highlight list */
  .highlight { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 9px; }
  /* Course link chip */
  .course-chip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 18px;
    border-radius: 14px;
    background: rgba(232,168,80,0.05);
    border: 1px solid rgba(232,168,80,0.12);
    margin-bottom: 22px;
  }
  /* Comparison table */
  .compare-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .compare-table th { text-align: center; padding: 11px 12px; font-size: 10px; color: rgba(240,248,242,0.28); text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 1px solid rgba(240,248,242,0.07); }
  .compare-table th:first-child { text-align: left; }
  .compare-table td { padding: 13px 12px; text-align: center; border-bottom: 1px solid rgba(240,248,242,0.04); }
  .compare-table td:first-child { text-align: left; color: #f0f8f2; font-weight: 500; }
  .compare-table tr:hover td { background: rgba(232,168,80,0.025); }
  /* Utils */
  .page-wrap { max-width: 1280px; margin: 0 auto; padding: 0 48px; }
  .sec-label { font-size: 11px; color: #e8a850; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; margin: 0 0 10px; }
  .sec-h2 { font-family: 'Playfair Display', serif; font-size: clamp(28px,3.5vw,42px); font-weight: 400; color: #f0f8f2; margin: 0; line-height: 1.1; }
  .badge-pill { display: inline-block; font-size: 11px; font-weight: 600; padding: 5px 14px; border-radius: 100px; }
  .btn-primary { display: inline-flex; align-items: center; gap: 10px; background: #e8a850; color: #0d1a0e; font-size: 14px; font-weight: 700; padding: 14px 32px; border-radius: 100px; text-decoration: none; transition: background 0.25s, transform 0.25s, box-shadow 0.25s; box-shadow: 0 4px 24px rgba(232,168,80,0.2); }
  .btn-primary:hover { background: #f2c878; transform: translateY(-1px); box-shadow: 0 10px 36px rgba(232,168,80,0.35); }
  .btn-ghost { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: rgba(240,248,242,0.45); font-size: 14px; font-weight: 500; padding: 14px 28px; border-radius: 100px; text-decoration: none; border: 1px solid rgba(240,248,242,0.1); transition: color 0.2s, border-color 0.2s; }
  .btn-ghost:hover { color: #f0f8f2; border-color: rgba(240,248,242,0.25); }
  @media (max-width: 900px) {
    .property-grid, .property-grid.flip { grid-template-columns: 1fr; direction: ltr; gap: 30px; }
    .pick-grid { grid-template-columns: 1fr 1fr; }
    .page-wrap { padding: 0 24px; }
    .lodge-hero-content { padding: 0 24px 56px; }
    .quick-pick { padding-inline: 24px; }
  }
</style>

<!-- ══════════════════════════════════════════
     HERO — always visible, no reveal class
══════════════════════════════════════════ -->
<section class="lodge-hero">
  <img class="bg" src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=1800&q=85&auto=format" alt="Graeagle lodging" />
  <div class="lodge-hero-grad"></div>
  <div class="lodge-hero-content">
    <p class="sec-label" style="margin-bottom:18px;">Where to Stay · Graeagle, California</p>
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(52px,7vw,94px);font-weight:400;color:#f0f8f2;margin:0 0 20px;line-height:1.0;">
      Wake up.<br/><em style="color:#e8a850;font-style:italic;">Tee off.</em>
    </h1>
    <p style="font-size:18px;color:rgba(240,248,242,0.55);max-width:560px;line-height:1.75;margin:0 0 36px;">
      Every property we recommend puts you within minutes — sometimes steps — of a championship tee. No long drives before your first shot of the day.
    </p>
    <!-- Anchor nav pills -->
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      {[
        {l:'On-course stay', h:'#inn-at-nakoma'},
        {l:'Best for groups', h:'#river-pines'},
        {l:'Best amenities', h:'#chalet-view'},
        {l:'Large groups', h:'#townhomes'},
      ].map(b=>(
        <a href={b.h} style="font-size:12px;color:rgba(240,248,242,0.6);border:1px solid rgba(240,248,242,0.14);padding:8px 18px;border-radius:100px;text-decoration:none;background:rgba(240,248,242,0.03);transition:all 0.2s;"
        onmouseover="this.style.color='#e8a850';this.style.borderColor='rgba(232,168,80,0.3)'"
        onmouseout="this.style.color='rgba(240,248,242,0.6)';this.style.borderColor='rgba(240,248,242,0.14)'">{b.l}</a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     QUICK PICK — psychology decision aid
══════════════════════════════════════════ -->
<div class="quick-pick reveal">
  <p class="sec-label" style="margin:0 0 4px;">Quick Pick — What kind of trip?</p>
  <p style="font-size:13px;color:rgba(240,248,242,0.3);margin:0 0 16px;">Match your situation to the right property in one tap.</p>
  <div class="pick-grid">
    {[
      { icon:'🐉', type:'On-course luxury',    rec:'Inn at Nakoma',           why:'Walk from your room to The Dragon tee', href:'#inn-at-nakoma' },
      { icon:'🏌️', type:'Golf group (4–12)',   rec:'River Pines Resort',       why:'On-site dining, group-friendly rooms', href:'#river-pines' },
      { icon:'🏊', type:'Family or couples',    rec:'Chalet View Lodge',        why:'Pool, hot tub, mountain atmosphere',   href:'#chalet-view' },
      { icon:'🏠', type:'Large group (12+)',    rec:'Townhomes at Plumas Pines', why:'Full kitchens, multiple bedrooms, pool', href:'#townhomes' },
    ].map(c=>(
      <a class="pick-card" href={c.href}>
        <div style="font-size:22px;margin-bottom:8px;">{c.icon}</div>
        <div style="font-size:10px;color:rgba(240,248,242,0.3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">{c.type}</div>
        <div style="font-size:13px;font-weight:600;color:#f0f8f2;margin-bottom:5px;">{c.rec}</div>
        <div style="font-size:11px;color:rgba(240,248,242,0.3);line-height:1.5;">{c.why}</div>
      </a>
    ))}
  </div>
</div>

<!-- ══════════════════════════════════════════
     PROPERTY CARDS — one per property
     Alternating layout, real gallery images
══════════════════════════════════════════ -->
{sorted.map((property, idx) => {
  const course = nearestCourse[property.slug];
  const label  = psychLabel[property.slug];
  const flip   = idx % 2 !== 0;
  const anchorMap = {
    'inn-at-nakoma': 'inn-at-nakoma',
    'river-pines-resort': 'river-pines',
    'chalet-view-lodge': 'chalet-view',
    'townhomes-at-plumas-pines': 'townhomes',
  };
  return (
    <section class="property-section" id={anchorMap[property.slug]}>
      <div class="page-wrap">
        <div class={`property-grid reveal${flip?' flip':''}`}>

          <!-- ── Gallery column ── -->
          <div>
            <div style="position:relative;overflow:hidden;border-radius:18px;">
              <img class="gallery-main" src={property.hero} alt={property.name} loading={idx===0?'eager':'lazy'} />
              <!-- Psychology badge on image -->
              <div style={`position:absolute;top:16px;left:16px;background:${label.color};border:1px solid ${label.border};backdrop-filter:blur(10px);padding:6px 14px;border-radius:100px;`}>
                <span style={`font-size:11px;font-weight:600;color:${label.text};letter-spacing:0.05em;`}>{label.tag}</span>
              </div>
            </div>
            <!-- Thumbnail strip — only if we have more images -->
            {property.images && property.images.length > 1 && (
              <div class="gallery-thumbs">
                {property.images.slice(1, 4).map((img, ti) => (
                  <img class="gallery-thumb" src={img} alt={`${property.name} ${ti+2}`} loading="lazy" />
                ))}
              </div>
            )}
          </div>

          <!-- ── Content column ── -->
          <div style="display:flex;flex-direction:column;justify-content:center;">
            <!-- Pill badge -->
            <span class="badge-pill" style={`background:${label.color};border:1px solid ${label.border};color:${label.text};margin-bottom:18px;`}>
              {label.tag}
            </span>

            <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,3vw,40px);font-weight:400;color:#f0f8f2;margin:0 0 6px;line-height:1.15;">{property.name}</h2>
            <p style="font-size:14px;color:#e8a850;margin:0 0 18px;font-style:italic;">{property.tagline}</p>
            <p style="font-size:15px;color:rgba(240,248,242,0.46);line-height:1.8;margin:0 0 22px;">{property.description}</p>

            <!-- Highlights -->
            <div style="margin-bottom:24px;">
              {(property.highlights||[]).map(h=>(
                <div class="highlight">
                  <span style="color:#e8a850;font-size:12px;margin-top:2px;flex-shrink:0;">✓</span>
                  <span style="font-size:13px;color:rgba(240,248,242,0.52);">{h}</span>
                </div>
              ))}
            </div>

            <!-- Nearest course cross-link -->
            {course && (
              <div class="course-chip">
                <div style="display:flex;align-items:center;gap:12px;">
                  <span style="font-size:20px;">⛳</span>
                  <div>
                    <div style="font-size:10px;color:rgba(240,248,242,0.28);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:2px;">Nearest Course</div>
                    <div style="font-size:13px;font-weight:600;color:#f0f8f2;">{course.name}</div>
                  </div>
                </div>
                <div style="display:flex;align-items:center;gap:10px;">
                  <span style="font-size:11px;color:#e8a850;background:rgba(232,168,80,0.1);padding:4px 10px;border-radius:100px;">{course.dist}</span>
                  <a href={`/courses/${course.slug}`} style="font-size:12px;color:rgba(240,248,242,0.35);text-decoration:none;transition:color 0.2s;"
                  onmouseover="this.style.color='#e8a850'" onmouseout="this.style.color='rgba(240,248,242,0.35)'">View course →</a>
                </div>
              </div>
            )}

            <!-- CTAs -->
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
              <a class="btn-primary" href="/quote">Include in Package →</a>
              {property.website && !property.website.includes('golfgraeagle') && (
                <a class="btn-ghost" href={property.website} target="_blank" rel="noopener">Property Website ↗</a>
              )}
            </div>
          </div>

        </div>
      </div>
    </section>
  )
})}

<!-- ══════════════════════════════════════════
     COMPARISON TABLE — anchoring psychology
     Shows all 4 properties side by side
══════════════════════════════════════════ -->
<section style="padding:80px 0;border-top:1px solid rgba(240,248,242,0.05);background:rgba(240,248,242,0.005);">
  <div class="page-wrap">
    <div class="reveal" style="text-align:center;margin-bottom:44px;">
      <p class="sec-label">Compare All Properties</p>
      <h2 class="sec-h2" style="font-size:clamp(30px,4vw,42px);">Side by side.</h2>
    </div>
    <div class="reveal" style="overflow-x:auto;border-radius:16px;border:1px solid rgba(240,248,242,0.06);">
      <table class="compare-table">
        <thead>
          <tr style="background:rgba(240,248,242,0.02);">
            <th style="text-align:left;padding:13px 18px;">Property</th>
            {['Best For','Type','Nearest Course','Distance','On-Site Dining','Pool / Spa','Full Kitchen','Group Events'].map(h=>(
              <th>{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {[
            { name:'The Inn at Nakoma',         best:'On-Course',  type:'Resort', course:'Nakoma Dragon',  dist:'On-site', dining:'—', pool:'✓', kitchen:'—', events:'✓' },
            { name:'River Pines Resort',         best:'Groups',     type:'Resort', course:'Graeagle Meadows', dist:'Walk', dining:'✓', pool:'—', kitchen:'—', events:'✓' },
            { name:'Chalet View Lodge',          best:'Amenities',  type:'Lodge',  course:'Graeagle Meadows', dist:'5 min', dining:'—', pool:'✓', kitchen:'—', events:'✓' },
            { name:'Townhomes at Plumas Pines',  best:'Large Groups',type:'Rental',course:'Plumas Pines', dist:'Walk', dining:'—', pool:'✓', kitchen:'✓', events:'—' },
          ].map((r,i)=>(
            <tr style={i%2===0?'background:rgba(240,248,242,0.01);':''}>
              <td style="padding:14px 18px;">{r.name}</td>
              <td style="color:#e8a850;font-size:11px;font-weight:500;">{r.best}</td>
              <td style="color:rgba(240,248,242,0.38);">{r.type}</td>
              <td style="color:rgba(240,248,242,0.38);">{r.course}</td>
              <td style="color:rgba(240,248,242,0.38);">{r.dist}</td>
              {[r.dining,r.pool,r.kitchen,r.events].map(v=>(
                <td style={`color:${v==='✓'?'rgba(130,210,140,0.9)':'rgba(240,248,242,0.18)'};font-size:${v==='✓'?'16px':'13px'};`}>{v}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     CTA
══════════════════════════════════════════ -->
<section style="padding:96px 48px;text-align:center;" class="reveal">
  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(34px,4vw,50px);font-weight:400;color:#f0f8f2;margin:0 0 14px;line-height:1.15;">Not sure which fits your group?</h2>
  <p style="font-size:15px;color:rgba(240,248,242,0.36);margin:0 0 36px;max-width:460px;margin-inline:auto;line-height:1.7;">Tell us your group size, dates, and what matters most. We'll match you with the right property and bundle it with tee times.</p>
  <a class="btn-primary" href="/quote" style="font-size:16px;padding:18px 48px;">Build My Package →</a>
  <p style="font-size:12px;color:rgba(240,248,242,0.18);margin:14px 0 0;">Free quote · No obligation · 24-hour response</p>
</section>

<Footer />
</Base>
