---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { lodging, courses, siteConfig } from '../data/content.js';
export const prerender = true;

const hotels = [
  {
    ...lodging.find(l => l.slug === 'river-pines-resort'),
    badge: 'Great for Golf Groups',
    badgeColor: '#22c55e',
    priceRange: '$$',
    capacity: '4–60 guests',
    roomTypes: 'Cabins · Suites · Rooms',
    closestCourse: 'Graeagle Meadows — 5 min',
    perk: 'On-site Roadhouse restaurant. Pool & hot tub. No logistics for group dinners.',
    anchor: 'river-pines',
    portfolioSlug: 'river-pines-resort-graeagle-ca',
  },
  {
    ...lodging.find(l => l.slug === 'chalet-view-lodge'),
    badge: 'Great Amenities',
    badgeColor: '#3b82f6',
    priceRange: '$$$',
    capacity: '2–30 guests',
    roomTypes: 'Lodge rooms · Suites · Cabins',
    closestCourse: 'Graeagle Meadows — 10 min',
    perk: '9-hole exec course + Eureka Peak Brewing on-site. Spa. Full event venue.',
    anchor: 'chalet-view',
    portfolioSlug: 'chalet-view-lodge-graeagle-ca',
  },
  {
    ...lodging.find(l => l.slug === 'inn-at-nakoma'),
    badge: 'The Bucket-List Stay',
    badgeColor: '#a855f7',
    priceRange: '$$$$',
    capacity: 'Up to 42 rooms',
    roomTypes: '42 rooms & suites',
    closestCourse: 'Nakoma Dragon — walk to 1st tee',
    perk: 'Only lodging with walk-on Dragon access. Frank Lloyd Wright building. Fifty44 on-site.',
    anchor: 'inn-at-nakoma',
    portfolioSlug: 'the-inn-at-nakoma-clio-ca',
  },
];

const townhomeData = {
  ...lodging.find(l => l.slug === 'townhomes-at-plumas-pines'),
  badge: 'Great for Large Groups',
  badgeColor: '#e8a850',
  priceRange: '$$',
  capacity: '8–24+ guests',
  portfolioSlug: 'the-townhomes-at-plumas-pines',
};

const lodgingFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Where should a golf group stay in Graeagle?", "acceptedAnswer": { "@type": "Answer", "text": "River Pines Resort works well for most golf groups — multiple room types, on-site dining, pool. For large groups (8+), the Townhomes at Plumas Pines offer multi-bedroom units with full kitchens at a lower per-person cost. For the bucket-list stay, the Inn at Nakoma puts you steps from The Dragon." } },
    { "@type": "Question", "name": "Is there lodging on the golf courses in Graeagle?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The Inn at Nakoma is on the Nakoma Dragon course property. The Townhomes at Plumas Pines are adjacent to Plumas Pines Golf Resort. River Pines Resort is walking distance from Graeagle Meadows." } },
    { "@type": "Question", "name": "What is the difference between a Graeagle hotel and townhome rental?", "acceptedAnswer": { "@type": "Answer", "text": "Hotels and lodges (River Pines, Chalet View, Inn at Nakoma) offer traditional hotel service with amenities, on-site dining, and housekeeping. Townhomes at Plumas Pines are multi-bedroom vacation rentals with full kitchens — better for larger groups who want to self-cater and share common spaces." } },
    { "@type": "Question", "name": "Do Graeagle lodging properties offer stay-and-play golf packages?", "acceptedAnswer": { "@type": "Answer", "text": "GolfGraeagle builds custom stay-and-play packages combining any property with tee times at all 5 courses. Request a free quote with your dates, group size, and preferred courses." } },
  ]
};
---
<Base
  title="Graeagle Lodging for Golf Groups | Trusted Stay and Play Packages from GolfGraeagle"
  description="Choose from Graeagle's best lodging options — townhomes, boutique hotels, and private homes — professionally bundled with tee times, dining, and group logistics by GolfGraeagle's local specialists. Designed for groups of 8 to 200."
  schema={[lodgingFaq]}

  bodyClass="light-page"
>
<Nav />

<!-- HERO -->
<section class="ldg-hero">
  <img src="/wp-images/nakoma-inn-lobby-fireplace.jpg" alt="Graeagle golf lodging — Inn at Nakoma lobby" class="ldg-hero-img" loading="eager"/>
  <div class="ldg-hero-overlay"></div>
  <div class="ldg-hero-content">
    <p class="ldg-eyebrow">Stay & Play · Graeagle, California</p>
    <h1 class="ldg-hero-h1">Sleep on the courses.<br/><span style="color:#e8a850;">Wake up ready to play.</span></h1>
    <p class="ldg-hero-sub">Two lodging types. Four properties. All within 25 minutes of every championship course.</p>
    <div class="ldg-type-pills">
      <a href="#hotels-resorts" class="ldg-pill">🏨 Hotels & Resorts</a>
      <a href="#townhomes" class="ldg-pill">🏘 Townhomes</a>
      <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=lodging-hero" class="btn-green-glow ldg-pill ldg-pill-gold">Request a quote →</a>
    </div>
  </div>
</section>

<!-- QUICK DECISION GUIDE -->
<section class="ldg-decision">
  <div class="ldg-container">
    <h2 class="ldg-section-title">Which type fits your trip?</h2>
    <div class="ldg-decision-grid">
      <div class="ldg-decision-card">
        <div class="ldg-decision-icon">🏨</div>
        <h3 class="ldg-decision-type">Hotels & Resorts</h3>
        <p class="ldg-decision-desc">Traditional hotel service — daily housekeeping, on-site dining, amenities. Three properties from $$ to $$$$.</p>
        <ul class="ldg-decision-list">
          <li>✓ Groups of 2–60 in any room configuration</li>
          <li>✓ On-site restaurants — no coordinating meals</li>
          <li>✓ Spa, pool, hot tub at most properties</li>
          <li>✓ One room per couple/pair</li>
        </ul>
        <a href="#hotels-resorts" class="ldg-decision-link">See the 3 hotels →</a>
      </div>
      <div class="ldg-decision-card">
        <div class="ldg-decision-icon">🏘</div>
        <h3 class="ldg-decision-type">Townhomes</h3>
        <p class="ldg-decision-desc">Multi-bedroom vacation rentals with full kitchens. Best per-person cost for groups of 8+.</p>
        <ul class="ldg-decision-list">
          <li>✓ 2–4 bedrooms per unit — whole group together</li>
          <li>✓ Full kitchens cut meal costs significantly</li>
          <li>✓ On the Plumas Pines Golf Course</li>
          <li>✓ Pool and tennis courts</li>
        </ul>
        <a href="#townhomes" class="ldg-decision-link">See the townhomes →</a>
      </div>
    </div>
  </div>
</section>

<!-- HOTELS & RESORTS -->
<section id="hotels-resorts" class="ldg-section ldg-section-light">
  <div class="ldg-container">
    <div class="ldg-section-header">
      <div>
        <div class="ldg-section-tag">🏨 Hotels & Resorts</div>
        <h2 class="ldg-section-title">Three hotels. Completely different trips.</h2>
        <p class="ldg-section-sub">River Pines for groups, Chalet View for amenities, Nakoma for the bucket-list. Each serves a different kind of golfer.</p>
      </div>
    </div>

    <div class="ldg-hotel-cards">
      {hotels.map((h, i) => (
        <article class="ldg-hotel-card" id={h.anchor}>
          <div class="ldg-hotel-img-wrap">
            <img src={h.hero} alt={`${h.name} — Graeagle golf lodging`} loading={i === 0 ? 'eager' : 'lazy'} class="ldg-hotel-img"/>
            <div class="ldg-hotel-img-fade"></div>
            <span class="ldg-hotel-badge" style={`background:${h.badgeColor}`}>{h.badge}</span>
            <span class="ldg-hotel-price">{h.priceRange}</span>
            {h.images && h.images.length > 1 && (
              <div class="ldg-hotel-thumbs">
                {h.images.slice(1, 4).map((img: string, ti: number) => (
                  <img src={img} alt={`${h.name} ${ti+2}`} loading="lazy" class="ldg-hotel-thumb"/>
                ))}
              </div>
            )}
          </div>
          <div class="ldg-hotel-body">
            <div class="ldg-hotel-meta-row">
              <div>
                <h3 class="ldg-hotel-name">{h.name}</h3>
                <p class="ldg-hotel-tagline">{h.tagline}</p>
              </div>
              <a href={`/portfolio/${h.portfolioSlug}`} class="ldg-hotel-details-link">Details →</a>
            </div>
            <p class="ldg-hotel-desc">{h.description}</p>
            <div class="ldg-hotel-stats">
              <div class="ldg-hstat">
                <div class="ldg-hstat-l">Capacity</div>
                <div class="ldg-hstat-v">{h.capacity}</div>
              </div>
              <div class="ldg-hstat">
                <div class="ldg-hstat-l">Rooms</div>
                <div class="ldg-hstat-v">{h.roomTypes}</div>
              </div>
              <div class="ldg-hstat">
                <div class="ldg-hstat-l">Nearest course</div>
                <div class="ldg-hstat-v">{h.closestCourse}</div>
              </div>
              <div class="ldg-hstat">
                <div class="ldg-hstat-l">Price tier</div>
                <div class="ldg-hstat-v" style={`color:${h.badgeColor}`}>{h.priceRange}</div>
              </div>
            </div>
            <div class="ldg-hotel-perk">
              <span class="ldg-perk-icon">⛳</span>
              <span>{h.perk}</span>
            </div>
            <div class="ldg-hotel-highlights">
              {(h.highlights || []).slice(0, 5).map((hl: string) => (
                <span class="ldg-hl-tag">✓ {hl}</span>
              ))}
            </div>
            <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=lodging-hotel-card" class="btn-green-glow ldg-hotel-cta" style={`background:${h.badgeColor}`}>
              Quote {h.name} →
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- TOWNHOMES -->
<section id="townhomes" class="ldg-section ldg-section-dark">
  <div class="ldg-container">
    <div class="ldg-section-header">
      <div>
        <div class="ldg-section-tag" style="color:#e8a850;background:rgba(232,168,80,0.1);border-color:rgba(232,168,80,0.2);">🏘 Townhomes</div>
        <h2 class="ldg-section-title">Built for groups of 8 or more.</h2>
        <p class="ldg-section-sub">Multi-bedroom vacation rentals on the Plumas Pines Golf Course. Full kitchens, shared living spaces, and the great per-person value in Graeagle.</p>
      </div>
    </div>

    <div class="ldg-townhome-layout">
      <div class="ldg-townhome-img-wrap">
        <img src={townhomeData.hero} alt="Townhomes at Plumas Pines — Graeagle group lodging" loading="lazy" class="ldg-townhome-img"/>
        <span class="ldg-hotel-badge" style="background:#e8a850;top:20px;left:20px;position:absolute;">Great for Large Groups</span>
        <span class="ldg-hotel-price" style="top:20px;right:20px;position:absolute;">$$</span>
      </div>
      <div class="ldg-townhome-body">
        <h3 class="ldg-townhome-name">Townhomes at Plumas Pines</h3>
        <p class="ldg-townhome-tagline">{townhomeData.tagline}</p>
        <p class="ldg-townhome-desc">{townhomeData.description}</p>

        <div class="ldg-townhome-why">
          <div class="ldg-tw-why-title">Why groups choose townhomes over hotels</div>
          {[
            { icon:'💰', point:'Full kitchens', detail:'Breakfast and snacks in-unit. One restaurant dinner vs. three. The savings on a 3-night trip for 12 people are real.' },
            { icon:'🛋', point:'Everyone in one place', detail:'2–4 bedroom units keep the group together. No splitting into separate hotel rooms across a property.' },
            { icon:'⛳', point:'Steps from Plumas Pines', detail:'Wake up and walk to the first tee. No morning car shuffle. Grab your clubs and go.' },
            { icon:'🎯', point:'Best per-person cost', detail:'The more people you split the unit with, the lower your per-night cost. Groups of 12+ get the best value in all of Graeagle.' },
          ].map(w => (
            <div class="ldg-tw-why-item">
              <span class="ldg-tw-why-icon">{w.icon}</span>
              <div>
                <div class="ldg-tw-why-point">{w.point}</div>
                <div class="ldg-tw-why-detail">{w.detail}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="ldg-townhome-features">
          {(townhomeData.highlights || []).map((h: string) => (
            <span class="ldg-tw-feature">✓ {h}</span>
          ))}
        </div>

        <div class="ldg-townhome-ctas">
          <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=lodging-townhomes" class="btn-green-glow ldg-tw-cta-primary">Quote the townhomes →</a>
          <a href="/townhomes" class="ldg-tw-cta-ghost">Full townhome guide →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- COMPARE ALL -->
<section class="ldg-compare-section">
  <div class="ldg-container">
    <h2 class="ldg-section-title">All four properties at a glance</h2>
    <div class="ldg-compare-wrap">
      <table class="ldg-compare-table">
        <thead>
          <tr>
            <th class="ldg-cth ldg-cth-left">Factor</th>
            {[...hotels, {name:'Townhomes at Plumas Pines', priceRange:'$$', badgeColor:'#e8a850', badge:'Townhomes'}].map(p => (
              <th class="ldg-cth">
                <div style="font-family:'Playfair Display',serif;font-size:13px;color:rgba(245,240,232,0.85);">{p.name}</div>
                <div style={`font-size:15px;font-weight:700;color:${p.badgeColor};margin-top:2px;`}>{p.priceRange}</div>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {[
            { label:'Type', vals:['Resort','Lodge','Resort','Vacation rental'] },
            { label:'Good for', vals:['Groups 4–60','Amenity seekers','Bucket-list','Groups 8–24+'] },
            { label:'Room config', vals:['Cabins, suites, rooms','Lodge rooms, cabins','42 hotel rooms','2–4 BR units'] },
            { label:'Nearest course', vals:['Meadows 5 min','Meadows 10 min','Dragon: walk','Plumas Pines: steps'] },
            { label:'On-site dining', vals:['The Roadhouse ✓','Kitchen+Bar + Eureka Peak ✓','Fifty44 + Middle Fork ✓','Full kitchen (self-cater)'] },
            { label:'Pool / hot tub', vals:['Pool + hot tub ✓','Pool + spa ✓','Pool + 2 hot tubs ✓','Community pool ✓'] },
            { label:'Pet friendly', vals:['Check policy','Check policy','✓ 2 dogs, 75 lbs','Check policy'] },
          ].map(row => (
            <tr class="ldg-ctr">
              <td class="ldg-ctd ldg-ctd-label">{row.label}</td>
              {row.vals.map(v => <td class="ldg-ctd">{v}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="ldg-faq-section">
  <div class="ldg-container" style="max-width:860px;">
    <h2 class="ldg-section-title">Lodging FAQ</h2>
    <div class="ldg-faqs">
      {[
        { q:'Where should a golf group stay in Graeagle?', a:'River Pines Resort works well for most golf groups — flexible room types, on-site dining at The Roadhouse, pool and hot tub. For groups of 8+, the Townhomes at Plumas Pines offer multi-bedroom units with full kitchens at a lower per-person cost. The Inn at Nakoma is the luxury bucket-list option.' },
        { q:'What is the difference between a hotel and a townhome in Graeagle?', a:'Hotels and lodges (River Pines, Chalet View, Inn at Nakoma) offer traditional hotel service with on-site dining, housekeeping, and amenities. The Townhomes at Plumas Pines are multi-bedroom vacation rentals with full kitchens — better for larger groups who want to share living space and cut costs by cooking some meals.' },
        { q:'Is there lodging on the golf courses in Graeagle?', a:'Yes. The Inn at Nakoma sits on the Nakoma Dragon course — guests walk directly to the first tee. The Townhomes at Plumas Pines are adjacent to Plumas Pines Golf Resort. River Pines Resort is a short walk from Graeagle Meadows.' },
        { q:'Do Graeagle lodging properties offer stay-and-play packages?', a:'GolfGraeagle builds custom stay-and-play packages combining any property with tee times at all 5 courses. Request a free quote with your dates, group size, and preferred courses — we handle the coordination.' },
      ].map(f => (
        <div class="ldg-faq-item">
          <h3 class="ldg-faq-q">{f.q}</h3>
          <p class="ldg-faq-a">{f.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="ldg-cta-section">
  <div class="ldg-container">
    <div class="ldg-cta-inner">
      <div>
        <h2 class="ldg-cta-title">Not sure which lodging fits?</h2>
        <p class="ldg-cta-sub">Tell us your group size, dates, and budget. We'll match you to the right property and build a full stay-and-play package with tee times at all 5 courses.</p>
      </div>
      <a href="/request-a-quote?utm_source=golfgraeagle&utm_medium=internal&utm_campaign=cta&utm_content=lodging-bottom" class="btn-green-glow ldg-cta-btn">Get a free quote →</a>
    </div>
  </div>
</section>

<Footer />
</Base>

<style is:global>
/* hero */
.ldg-hero{position:relative;height:80vh;min-height:520px;max-height:780px;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;}
.ldg-hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;animation:ldgZoom 16s ease-in-out infinite alternate;}
@keyframes ldgZoom{0%{transform:scale(1.04);}100%{transform:scale(1);}}
.ldg-hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,12,5,0.94) 0%,rgba(5,12,5,0.5) 45%,rgba(5,12,5,0.15) 100%);}
.ldg-hero-content{position:relative;z-index:2;max-width:1200px;margin:0 auto;width:100%;padding:0 clamp(20px,5vw,60px) 56px;}
.ldg-eyebrow{font-size:11px;color:#e8a850;letter-spacing:.2em;text-transform:uppercase;font-weight:600;margin:0 0 16px;}
.ldg-hero-h1{font-family:'Playfair Display',serif;font-size:clamp(40px,6.5vw,82px);font-weight:400;color:#f8faf8;margin:0 0 18px;line-height:1.05;letter-spacing:-.5px;}
.ldg-hero-sub{font-size:clamp(15px,1.8vw,18px);color:rgba(248,250,248,0.55);margin:0 0 32px;line-height:1.7;}
.ldg-type-pills{display:flex;gap:10px;flex-wrap:wrap;}
.ldg-pill{display:inline-block;padding:11px 22px;border:1px solid rgba(248,250,248,0.2);color:rgba(248,250,248,0.75);border-radius:100px;font-size:14px;text-decoration:none;transition:all .2s;}
.ldg-pill:hover{border-color:rgba(248,250,248,0.5);color:#f8faf8;}
.ldg-pill-gold{background:#e8a850;border-color:#e8a850;color:#0d1a0e;font-weight:700;}
.ldg-pill-gold:hover{background:#f2c878;border-color:#f2c878;color:#0d1a0e;}
/* decision guide */
.ldg-decision{padding:72px 0;background:var(--page-bg);}
.ldg-container{max-width:1200px;margin:0 auto;padding:0 clamp(20px,5vw,60px);}
.ldg-section-title{font-family:'Playfair Display',serif;font-size:clamp(24px,3vw,38px);font-weight:400;color:#1a2e1a;margin:0 0 10px;}
.ldg-section-sub{font-size:15px;color:#6b7c6b;margin:0 0 44px;line-height:1.65;max-width:560px;}
.ldg-section-header{margin-bottom:44px;}
.ldg-section-tag{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#1a6020;background:#f0fff0;border:1px solid #a0d0a0;padding:4px 12px;border-radius:100px;margin-bottom:12px;}
.ldg-decision-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
@media(max-width:700px){.ldg-decision-grid{grid-template-columns:1fr;}}
.ldg-decision-card{padding:28px;background:var(--surface-2);border:1px solid #e0ece0;border-radius:18px;}
.ldg-decision-icon{font-size:28px;margin-bottom:12px;}
.ldg-decision-type{font-family:'Playfair Display',serif;font-size:20px;font-weight:400;color:#1a2e1a;margin:0 0 8px;}
.ldg-decision-desc{font-size:14px;color:#4a5a4a;line-height:1.65;margin:0 0 16px;}
.ldg-decision-list{list-style:none;padding:0;margin:0 0 20px;display:flex;flex-direction:column;gap:6px;}
.ldg-decision-list li{font-size:13px;color:#374137;}
.ldg-decision-link{font-size:13px;font-weight:700;color:#e8a850;text-decoration:none;}
.ldg-decision-link:hover{color:#c88840;}
/* sections */
.ldg-section{padding:80px 0;}
.ldg-section-light{background:var(--surface-2);}
.ldg-section-dark{background:#0d1a0e;}
/* ── Text overrides for dark townhomes section ── */
.ldg-section-dark .ldg-section-title{color:#f8faf8;}
.ldg-section-dark .ldg-section-sub{color:rgba(248,250,248,0.6);}
.ldg-section-dark .ldg-townhome-name{color:#f8faf8;}
.ldg-section-dark .ldg-townhome-tagline{color:rgba(248,250,248,0.5);}
.ldg-section-dark .ldg-townhome-desc{color:rgba(248,250,248,0.65);}
.ldg-section-dark .ldg-tw-why-title{color:#e8a850;}
.ldg-section-dark .ldg-tw-why-point{color:#f8faf8;}
.ldg-section-dark .ldg-tw-why-detail{color:rgba(248,250,248,0.55);}
.ldg-section-dark .ldg-tw-feature{color:rgba(248,250,248,0.7);}
.ldg-section-dark .ldg-section-tag{color:#e8a850 !important;background:rgba(232,168,80,0.1) !important;border-color:rgba(232,168,80,0.2) !important;}
/* hotel cards */
.ldg-hotel-cards{display:flex;flex-direction:column;gap:40px;}
.ldg-hotel-card{background:var(--surface);border-radius:22px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06);}
.ldg-hotel-img-wrap{position:relative;height:360px;overflow:hidden;}
@media(max-width:650px){.ldg-hotel-img-wrap{height:240px;}.ldg-hotel-thumbs{display:none;}}
.ldg-hotel-img{width:100%;height:100%;object-fit:cover;transition:transform 8s ease;}
.ldg-hotel-card:hover .ldg-hotel-img{transform:scale(1.04);}
.ldg-hotel-img-fade{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,12,5,0.4) 0%,transparent 55%);}
.ldg-hotel-badge{position:absolute;top:18px;left:18px;font-size:11px;font-weight:700;color:#fff;padding:5px 13px;border-radius:100px;letter-spacing:.03em;}
.ldg-hotel-price{position:absolute;top:18px;right:18px;font-size:14px;font-weight:700;color:#fff;background:rgba(0,0,0,0.45);padding:5px 13px;border-radius:100px;backdrop-filter:blur(4px);}
.ldg-hotel-thumbs{position:absolute;bottom:0;left:0;right:0;display:flex;gap:2px;height:72px;}
.ldg-hotel-thumb{flex:1;object-fit:cover;opacity:.7;transition:opacity .2s;}
.ldg-hotel-thumb:hover{opacity:1;}
.ldg-hotel-body{padding:32px;}
@media(max-width:580px){.ldg-hotel-body{padding:22px 18px;}}
